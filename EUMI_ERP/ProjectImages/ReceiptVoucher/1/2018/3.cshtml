    <script>


        if (localStorage.getItem('defaultdashboard') != null) {

            $('#MainDashboardref').attr("href", '../' + localStorage.getItem('defaultdashboard'));
            $('#MainDashboard').show();
        }


        $('#Comp').text(CompanySettingsArray.CompanyName)
        usermenu1.forEach(myFunction);
        function myFunction(item, index) {
            $('#' + item).show();
        }
        for (var i = 0; i < $('#TotalLi').val() ; i++) {
            $("#liorder_" + i + ">ul>li").each(function () {
                if (this.style.display != 'none') {
                    $('#liorder_' + i).show();
                }
            });
        }


        $("#confirmOk").focus(function (e) {
            $("#confirmOk").removeClass("btn btn-outline-primary");
            $("#confirmOk").addClass("btn btn-primary");
        });

        $("#confirmOk").focusout(function (e) {
            $("#confirmOk").removeClass("btn btn-primary");
            $("#confirmOk").addClass("btn btn-outline-primary");
        });

        $("#confirmOk").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 37) {
                $("#confirmCancel").focus();
            }
        });

        $("#confirmCancel").focus(function (e) {
            $("#confirmCancel").removeClass("btn grey btn-outline-secondary");
            $("#confirmCancel").addClass("btn grey btn-secondary");
        });

        $("#confirmCancel").focusout(function (e) {
            $("#confirmCancel").removeClass("btn grey btn-secondary");
            $("#confirmCancel").addClass("btn grey btn-outline-secondary");
        });

        $("#confirmCancel").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 39) {
                $("#confirmOk").focus();
            }
        });

     


        function GoPage(URL) {
            var win = window.open('../' + URL, '_blank');
            win.focus();
        }
        $(document).keydown(function (e) {

            //$('#Warningpopup').fadeOut();
            if (e.altKey && e.keyCode == 77) {                                   //ACCOUNT STATEMENT
                if (usermenu1.indexOf("M82") != -1) {
                    GoPage('AccountsReport/AccountStatement');
                }

            }
            else if (e.altKey && e.keyCode == 81) {                              //ACCOUNTS QUERY
                if (usermenu1.indexOf("M188") != -1) {
                    GoPage('Report/AccountsQuery');
                }

            }
            else if (e.altKey && e.keyCode == 87) {                             //STOCK QUERY
                if (usermenu1.indexOf("M117") != -1) {
                    GoPage('Report/StockQuery');
                }
                else if (usermenu1.indexOf("M174") != -1) {
                    GoPage('Report/SPStockQuery');
                }
                else if (usermenu1.indexOf("M161") != -1) {
                    GoPage('Report/MobileStockQuery');
                }
                else if (usermenu1.indexOf("M196") != -1) {
                    GoPage('Report/StockQuery_UsedCars');
                }
                else if (usermenu1.indexOf("M232") != -1) {
                    GoPage('StockReport/StockReport');
                }

            }
            else if (e.altKey && e.keyCode == 84) {                          //SALES RETURN
                if (usermenu1.indexOf("M56") != -1) {
                    GoPage('SalesInvoice/SalesReturn');
                }
                else if (usermenu1.indexOf("M169") != -1) {
                    GoPage('SalesInvoice/SalesReturnMobile');
                }
                else if (usermenu1.indexOf("M241") != -1) {
                    GoPage('SalesInvoice/SalesReturnNew');
                }

            }
            else if (e.altKey && e.keyCode == 72) {                      //VOUCHER ENTRY
                if (usermenu1.indexOf("M77") != -1) {
                    GoPage('AccountsErp/VoucherEntry');
                }
            }
            else if (e.altKey && e.keyCode == 73) {                      //SALES INVOICE
                if (usermenu1.indexOf("M54") != -1) {
                    GoPage('inventory/SalesInvoice');
                }
                else if (usermenu1.indexOf("M173") != -1) {
                    GoPage('SalesInvoice/SalesInvoicePress');
                }
                else if (usermenu1.indexOf("M162") != -1) {
                    GoPage('SalesInvoice/SalesInvoiceMobile');
                }
                else if (usermenu1.indexOf("M192") != -1) {
                    GoPage('SalesInvoice/SalesInvoiceUsedCar');
                }
                else if (usermenu1.indexOf("M227") != -1) {
                    GoPage('inventory/SalesInvoiceNew');
                }
            }
            else if (e.altKey && e.keyCode == 82) {                      //PURCHASE INVOICE
                if (usermenu1.indexOf("M31") != -1) {
                    GoPage('inventory/Purchaseinvoice');
                }
                else if (usermenu1.indexOf("M159") != -1) {
                    GoPage('Purchase/MobilePurchaseInvoice');
                }
                else if (usermenu1.indexOf("M233") != -1) {
                    GoPage(' Purchase/PurchaseInvoiceNew');
                }
            }
            else if (e.altKey && e.keyCode == 79) {                      //PURCHASE ORDER
                if (usermenu1.indexOf("M30") != -1) {
                    GoPage('inventory/PurchaseOrder');
                }
                else if (usermenu1.indexOf("M234") != -1) {
                    GoPage('Purchase/PurchaseOrderNew');
                }
            }
            else if (e.altKey && e.keyCode == 76) {                  //PURCHASE ENQUIRY
                if (usermenu1.indexOf("M29") != -1) {
                    GoPage('inventory/PurchaseEnquiry');
                }
                else if (usermenu1.indexOf("M238") != -1) {
                    GoPage('Purchase/PurchaseEnquiryNew');
                }
            }
            else if (e.altKey && e.keyCode == 75) {                  //PURCHASE PERFORMA
                if (usermenu1.indexOf("M221") != -1) {
                    GoPage('Purchase/PurchasePerforma');
                }
            }
            else if (e.altKey && e.keyCode == 90) {                 //DEPARTMENT CHANGE
                ChangeDepartment();

            }
        });


        function ChangeDepartment() {
            var datadep = {};
            datadep.UserId = ERPUserId;
            datadep.DepartmentId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Home/UserDepartmentGets",
                data: datadep,
                success: function (result) {
                    ShowotherDepartments(result.oList);
                }
            });
        }
        function ShowotherDepartments(result) {
            console.log(result)
            $("#newdeptfprlogin").empty();
            for (var i = 0; i < result.length; i++) {
                $("#newdeptfprlogin").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }
            if (result.length > 0) {
                $('#ChangeDepDiv').show();
                $("#newdeptfprlogin").prop("disabled", false);
                $("#newdeptfprlogin").focus();
            }


        }
        function ChangetoNewDeparment() {
            var datadepnew = {};
            datadepnew.UserId = ERPUserId;
            datadepnew.DeptId = $("#newdeptfprlogin").val();
            $.ajax({
                type: "POST",
                url: "../Home/UserLoginOtherDepartment",
                data: datadepnew,
                success: function (result) {
                    NewLoginDepartment(result.oList);
                }
            });
        }

        function NewLoginDepartment(result) {
            var UserDetailsNew = '' + result[0].UserId + ':' + result[0].DeptId + ':' + result[0].LocationID + ':' + result[0].UserName + ':' + result[0].DepartmentName + ':' + result[0].UserMenu + '';

            localStorage.setItem('nanana', UserDetailsNew);
            window.location.reload(true);
        }
    </script>




