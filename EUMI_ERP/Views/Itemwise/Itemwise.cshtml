@{
    ViewBag.Title = "Itemwise";
}

<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>

<div class="myData" data-x="M212" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">


                    <div>
                        <table width="100%" style="table-layout:fixed">
                            <tr>
                                <td><h4 id="header"></h4></td>

                                <td align="right">
                                    <button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#customer').focus()" id="btnback" class="btn btn-outline-primary">Back</button>
                                    <button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('ITEMWISEREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button>

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">
                                <br /><hr style="margin-top:-1%" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <div style="width:166%">
                                        <table id="Tblreport" width="100%" class="table table-striped table-bordered base-style dataTable"></table>
                                    </div><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>




<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" style="background:rgba(0,0,0,0.5); display: block;">
    <div class="modal-dialog modal-lg" role="document" style="">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Itemwise Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <!-- Modal body -->
            <div class="modal-body">

                <div class="row">

                    <div class="col-md-2">
                        <label style="font-weight:bold;">From</label>
                    </div>
                    <div class="col-md-4">
                        <input type="text" id="dateFrom" class="form-control" autocomplete="off">
                    </div>

                    <div class="col-md-2 text-right">
                        <label style="font-weight:bold;">To</label>
                    </div>
                    <div class="col-md-4">
                        <input type="text" id="dateTo" class="form-control" autocomplete="off">
                    </div>

                </div>
                <hr class="mb-1 mt-1" />


                <div class="row mb-1">

                    <label class="col-md-2" style="font-weight:bold;">Customer</label>
                    <div class="col-md-10">
                        <table width="100%">
                            <tr>
                                <td width="30%">
                                    <input type="text" id="customer" class="form-control" onkeyup="$('#custnames').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                    <input type="hidden" id="customerId" class="form-control" />
                                </td>
                                <td>
                                    <input type="text" id="custnames" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                </td>
                            </tr>
                        </table>
                    </div>

                </div>

                <div class="row mb-1">

                    <label class="col-md-2" style="font-weight:bold;">Product</label>
                    <div class="col-md-10">
                        <table width="100%">
                            <tr>
                                <td width="30%">
                                    <input type="text" id="itemname" class="form-control"  style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                    <input type="hidden" id="itemid" class="form-control" />
                                </td>
                                <td>
                                    <input type="text" id="itemm" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                </td>
                            </tr>
                        </table>
                    </div>

                </div>

                <div class="row mb-1">


                    <div class="col-md-2">
                        <label style="font-weight:bold;">Pay Type</label>
                    </div>
                    <div class="col-md-4">
                        <select id="Paytype" class="form-control" name="priority">
                            <option value="0">-All-</option>
                            <option value="1">Cash</option>
                            <option value="2">Credit</option>
                            <option value="3">Card</option>
                        </select>
                    </div>
                    <div class="col-md-2 text-right">
                        <label style="font-weight:bold;">Doctor</label>
                    </div>
                    <div class="col-md-4">
                        <select id="Doctor" name="priority" class="form-control"></select>
                    </div>
                </div>
                <div class="row mb-1">


                    <div class="col-md-2">
                        <label style="font-weight:bold;">Dept.</label>
                    </div>
                    <div class="col-md-4">
                        <select id="Dept" name="priority" class="form-control"></select>
                    </div>

                    <div class="col-md-2 text-right">
                        <label style="font-weight:bold;">Company</label>
                    </div>
                    <div class="col-md-4">
                        <select id="Group" name="priority" class="form-control"></select>
                    </div>
                </div>

                <div class="row mb-1">

                    <div class="col-md-2">
                        <label style="font-weight:bold;">Type</label>
                    </div>
                    <div class="col-md-4">
                        <select id="Category" name="priority" class="form-control"></select>
                    </div>
                    <div class="col-md-2 text-right">
                        <label style="font-weight:bold;">Schedule</label>
                    </div>
                    <div class="col-md-4">
                        <select id="SubCategory" name="priority" class="form-control"></select>
                    </div>

                </div>



                
            </div>

            <!-- Modal footer -->
            <div class="modal-footer">
                <div class="col-md-6">
                    <fieldset class="form-group floating-label-form-group">
                        <div class="row p-2">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="grpbySR">
                                <label class="custom-control-label" for="grpbySR" style="font-weight:bold">Sales Return</label>
                            </div>
                        </div>

                    </fieldset>
                </div>

                <div class="col-md-6">

                    <div class="text-right">
                        <button type="button" id="btnsubmit" class="btn btn-primary" data-dismiss="modal">Apply</button>
                        <input type="hidden" id="Length" class="form-control" />
                        <input type="hidden" id="ResultLength" class="form-control" />


                        
                    </div>
                </div>
                
            </div>







        </div>
    </div>
</div>


<div style="display:none">
    <div class="col-md-2">
        <label style="font-weight:bold;">Area </label>
    </div>
    <div class="col-md-4">
        <select id="Area" name="priority" class="form-control">
            <option value="0">-All-</option>
        </select>
    </div>
    <div class="col-md-2 text-right">
        <label style="font-weight:bold;">Sub Grp.</label>
    </div>
    <div class="col-md-4">
        <select id="SubGroup" name="priority" class="form-control"></select>
    </div>
    <input type="text" class="form-control" id="UserId" style="display:none">
    <div class="col-md-2 text-right">
        <label style="font-weight:bold;">Salesman</label>
    </div>
    <div class="col-md-4">
        <select id="Salesman" name="priority" class="form-control"></select>
    </div>
</div>

<script>




    $("#itemname").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#itemname").val();

            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.ItemCode,
                            label1: item.Description,
                            ItemId: item.ItemId,
                            Product: item.Description,
                            productcode: item.ItemCode,
                            GrpId: item.GrpId,
                            CategoryId: item.CategoryId,
                            headers: ["Code", "Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#itemid').val(ui.item.ItemId)
            $('#itemname').val(ui.item.Description)
            $("#itemname").val(ui.item.Description);
        },
    });








    //Customername Autocomplete

    $("#customer").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#customerId').val(0);
            var data = {};
            data.PatientName = $("#customer").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.OPSerName + '-' + item.OPNumber,
                            label1: item.PatientName,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["RegNo", "Patient"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {

            //dropdownbind
            $('#customerId').val(ui.item.PatientId)
            $('#customer').val(ui.item.PatientName)
            $("#custnames").val(ui.item.PatientName);

        },

    });
    

    $(function () {

        $('#customer').focus();

        GetDepartment(0);
        GetArea(0);
        GetSalesMan(0);
        GroupPageLoad(0);
        CategoryPageLoad(0);
        DoctorLoad();

        $('#Area').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Paytype').focus();
                e.preventDefault();
            }
        });

        $('#Paytype').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Salesman').focus();
                e.preventDefault();
            }
        });

        $('#Salesman').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Dept').focus();
                e.preventDefault();
            }
        });

        $('#Dept').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Group').focus();
                e.preventDefault();
            }
        });
        $('#Group').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#SubGroup').focus();
                e.preventDefault();
            }
        });
        $('#SubGroup').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Category').focus();
                e.preventDefault();
            }
        });
        $('#Category').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#SubCategory').focus();
                e.preventDefault();
            }
        });
        $('#SubCategory').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });

        $('#dateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear()+1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#dateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear()+1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $("#dateFrom,#dateTo").val(CurDate);
    });
    //load Department

    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#Dept").empty();
        $("#Dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    //Load Area
    function GetArea(id) {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGetandGets",
            data: data,
            success: function (result) {
                $.each(result.oList, function (index, ele) {
                    $("#Area").append($("<option>").attr("value", ele.AreaId).text(ele.AreaCode));
                });
            }
        });
    }

    function DoctorLoad() {
        var data = {};                                       //dropdownbind
        data.DoctorId = 0;
        data.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_RevistDoctorGets",
            data: data,
            success: function (result) {
                if (result.oList.length > 0) {
                    $("#Doctor").empty()
                    $("#Doctor").append("<option value='0' Fee='0'>-All-</option>");

                    for (var i = 0; i < result.oList.length; i++) {
                        $("#Doctor").append("<option value='" + result.oList[i].DoctorId + "' Fee='" + result.oList[i].ConsultFees + "'>" + result.oList[i].DoctorName + "</option>");
                    }

                }
            }
        });
    }
    //Load Salesman

    function GetSalesMan(id) {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/SalesmanGetandGets",
            data: data,
            success: function (result) {
                SalesManLoad(result.oList, id);
            }
        });
    }

    function SalesManLoad(result, a) {
        $("#Salesman").empty();
        $("#Salesman").append("<option value='0'>-All-</option>")
        for (var i = 0; i < result.length; i++) {
            $("#Salesman").append("<option value='" + result[i].Id + "'>" + result[i].FirstName + "</option>");
        }
    }

    //Load Group
    function GroupPageLoad(id) {
        var data1 = {};
        data1.GrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/GroupGetandGets",
            data: data1,
            success: function (result) {
                GroupLoad(result.oList, id);
            }
        });
    }

    function GroupLoad(result) {
        $("#Group").empty();
        $("#Group").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {

            $("#Group").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
        }
        SubGroupGets();
    }

    //Load SubGroup

    function SubGroupGets() {
        var data = {};
        data.GroupId = $("#Group").val();


        if (data.GroupId == 0) {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetandGets",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
        else {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetForGroup",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
    }

    function SubGroupLoad(result) {
        $("#SubGroup").empty();
        $("#SubGroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#SubGroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
        }
    }

    //Load Category

    function CategoryPageLoad(id) {
        var data2 = {};
        data2.CategoryId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CategoryGetandGets",
            data: data2,
            success: function (result) {
                CategoryLoad(result.oList, id);
            }
        });
    }


    function CategoryLoad(result) {
        $("#Category").empty();
        $("#Category").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Category").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
        }
        SubCategoryGets();
    }
    //Load SubCategory

    function SubCategoryGets() {

        var data = {};
        data.CategoryId = $("#Category").val();

        if (data.CategoryId == 0) {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetandGets",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);

                }
            });
        }

        else {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetforCategory",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);
                }
            });
        }
    }



    function SubCategoryLoad(result) {
        $("#SubCategory").empty();
        $("#SubCategory").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#SubCategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
        }
    }

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th width=10px>Type</th><th width=100px>Bill#</th><th style='text-align:center' width=10px>Date</th><th style='text-align:center' width=100px>Reg#</th><th width=100px>Patient</th><th width=100px>Doctor</th><th width=400px>Item Name</th><th width=10px>Batch</th><th width=10px>Exp</th><th style='text-align:center' width=10px>Qty.</th><th style='text-align:right' width=10px>Price</th><th width=10px>PayType</th><th style='text-align:right' width=10px>Taxable</th><th style='text-align:right' width=10px>Tax</th><th style='text-align:right' width=10px>Cess</th><th width=10px>Disc.</th><th style='text-align:right' width=10px>Amount</th><th>Company</th><th width=10px>Type</th><th width=10px>Schedule</th><th width=10px>Dept.Code</th></tr></thead><tbody>";

        
        for (var i = 0; i < result.length; i++) {
            var Bach = (result[i].Batch).split("##")
            var slno = parseInt(i + 1);
            if (result[i].InvDate == 'Grand Total') {

                var salesman = (result[i].FirstName);
                salesman = salesman.substring(0, 10);

                responseText += '<tr  style=background-color:#cfd8dc><td style=text-align:center>' + slno + '</td><td id="Col1_' + slno + '">' + result[i].SType + '</td><td></td><td id="Col3_' + slno + '" style=text-align:center><b>' + result[i].InvDate + '</b></td><td id="Col4_' + slno + '">' + result[i].AccCode + '</td><td id="Col5_' + slno + '">' + result[i].CustoName + '</td><td>' + result[i].FirstName + '</td><td id="Col6_' + slno + '">' + result[i].ProductCode + '</td><td></td><td></td><td id="Col8_' + slno + '" style=text-align:center><b>' + ReplaceNumberWithCommas(result[i].ProdQty) + '</b></td><td id="Col10_' + slno + '" style=text-align:right>' + result[i].ProdRate + '</td><td>' + result[i].Payterms + '</td><td style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal)) + '</b></td><td  style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].TaxAmount || 0).toFixed(Decimal)) + '</b></td><td  style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].CessAmount || 0).toFixed(Decimal)) + '</b></td><td style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].ProdDisc || 0).toFixed(Decimal)) + '</b></td><td id="Col9_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].Amount || 0).toFixed(Decimal)) + '</b></td><td>' + result[i].GrpName + ' </td><td>' + result[i].CategoryName + ' </td><td>' + result[i].SubCategoryName + ' </td><td>' + result[i].DepartmentName + ' </td></tr>';
            }

            else {
                var salesman = (result[i].FirstName);
                salesman = salesman.substring(0, 10);
                Bach = (result[i].Batch).split("##")

                responseText += '<tr ondblclick=gotoInvoNo(' + result[i].BillSlNo + "," + result[i].BillSeriesId + ",'" + result[i].SType + "'," + result[i].DeptId + ')><td style=text-align:center>' + slno + '</td><td id="Col1_' + slno + '" style="text-align:center">' + result[i].SType + '</td><td id="Col2x_' + slno + '">' + result[i].BillDescription + '-' + result[i].BillSlNo + '</td><td id="Col3_' + slno + '" style=text-align:center>' + result[i].InvDate + '</td><td id="Col4_' + slno + '">' + result[i].AccCode + '</td><td id="Col5_' + slno + '">' + result[i].CustoName + '</td><td>' + result[i].FirstName + '</td><td id="Col6_' + slno + '">' + result[i].ProductCode + '</td><td>' + Bach[0] + '</td><td>' + Bach[1] + '</td><td id="Col8_' + slno + '" style=text-align:center>' + result[i].ProdQty + '</td><td id="Col10_' + slno + '" style=text-align:right>' + result[i].ProdRate + '</td><td>' + result[i].Payterms + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</td><td  style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</td><td  style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].CessAmount || 0).toFixed(Decimal)) + '</td><td style=text-align:right>' + parseFloat(result[i].ProdDisc || 0).toFixed(Decimal) + '</td><td id="Col9_' + slno + '" style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td>' + result[i].GrpName + ' </td><td>' + result[i].CategoryName + ' </td><td>' + result[i].SubCategoryName + ' </td><td>' + result[i].DepartmentName + ' </td></tr>';
            }

        }
