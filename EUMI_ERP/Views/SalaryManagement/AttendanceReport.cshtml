
@{
    ViewBag.Title = "AttendanceReport";
}



@{
    ViewBag.Title = "SalaryReport";
}
<div class="myData" data-x="M184" />

<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width:"100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="44%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#Employee').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">




                                <br /><hr />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                                <br /><br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">Attendance Report</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
           
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-2">
                            <label style="font-weight:bold">Date</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>

                        <div  class="col-md-2"> 
                        <label style="font-weight:bold">Dept.</label>
                        </div>
                        <div class="col-md-4">
                            <select id="dept" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:3%">
                        <div class="col-md-2">
                            <label style="font-weight:bold">Employee</label>
                        </div>
                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="31%">
                                        <input type="text" id="Employee" class="form-control" onkeyup="$('#EmployeeName').val(''), $('#EmployeeId').val(0)" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="EmployeeId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="EmployeeName" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="text-center">

                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>


<script>
    $("#Employee").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.EmpName = $("#Employee").val();
            data.DeptId = 0;
            data.UserId = 0;
            $.ajax({
                url: '../PayRoll_LeaveApply/EmployeeSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.EmpId,
                            label1: item.EmpName,
                            EmpId: item.EmpId,
                            EmpName: item.EmpName,
                            headers: ["Emp.ID", "Emp. Code"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#EmployeeId').val(ui.item.EmpId);
            $('#Employee').val(ui.item.EmpId);
            $('#EmployeeName').val(ui.item.EmpName);
            $("#btnsubmit").focus();
        },
    });

    var StartingDate = $('#DateFrom').val();
    var EndingDate = $('#DateFrom').val();

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function GetDepartment(id) {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);
            }
        });
    }

    function getDateObject(str) {
        var arr = str.split("/");
        return new Date(arr[2], arr[1], arr[0]);
    }
    function DepartmentLoad(result, a) {
        $("#dept").empty();
        $("#dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    $(function () {
        $("#Employee").focus();
        GetDepartment(0);
       
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        //$('#DateTo').daterangepicker({
        //    minDate: minDate,
        //    maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
        //    singleDatePicker: true,
        //    showDropdowns: true,
        //    locale: {
        //        format: 'DD/MM/YYYY'
        //    }
        //});

        $('#dept').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Employee').focus();
                e.preventDefault();
            }
        });
        $('#Employee').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });



       
        $("#btnsubmit").click(function (e) {
            ReportGets();
        });
   

        if (getQueryString('EmpId') != null) {
            $('#EmployeeName').val(getQueryString('EmpName'))
            $("#Employee").val(getQueryString('EmpId'));
            ReportGets();
            $('#Entry').show();

        }

    });

    function startenddates() {

        var Dt = $('#DateFrom').val();

        someDate = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));

        someMonth = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));

        someDate.setDate(parseInt(someDate.getDate()));

        var a = new Date(someDate.getFullYear(),
                         someDate.getMonth() + 1,
                         0).getDate();
        var month = someMonth.getMonth() + 1;

        StartingDate = "01" + "/" + month + "/" + someMonth.getFullYear();

        EndingDate = a + "/" + month + "/" + someMonth.getFullYear();

    }

    function ReportGets() {

        if ($('#DateFrom').val() == '') {

            $('#DateFrom').focus();

        }
        else {
            if ($('#Employee').val() == '') {
                $('#EmployeeId').val(0);
            }

            $('#Loading').show();
            var data = {};
            startenddates();
            data.FromDate = StartingDate;
            data.ToDate = EndingDate;
            data.DeptId = parseInt($('#dept').val() || 0);
            data.EmpId = parseInt($('#Employee').val() || 0);

            $.ajax({
                type: "POST",
                url: "../SalaryManagement/GetAttendancereport",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);
                }
            });



        }
    }

    function Showreport(result) {
        var TotalDays = 0;
        var date1 = getDateObject(StartingDate);
        var date2 = getDateObject(EndingDate);
        if (date2 - date1 > 0) {
            var TotalDays = (date2 - date1) / 86400000;

        }

        TotalDays += 1;

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr style=background-color:#cfd8dc><th>Sl#</th><th>Emp.Code</th><th>Emp.Name</th><th>Designantion</th><th>Payroll Type</th><th>Full Days</th><th>Half Days</th><th >Leaves</th><th>Holidays</th><th>OT_Hrs</th><th>Working Days</th><th>Total Days</th><th>PH_FullDays</th><th>PH_HalfDays</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var WorkingDays = TotalDays - result[i].Holidays;
            var slno = parseInt(i + 1);


            responseText += '<tr ><td>' + slno + '</td><td>' + result[i].EmpCode + '</td><td>' + result[i].Name + '</td><td>' + result[i].DesignationDescription + '</td><td>' + result[i].PayRollType + '</td><td>' + result[i].FullDays + '</td><td >' + result[i].HalfDays + '</td><td >' + result[i].Leaves + '</td><td >' + result[i].Holidays + '</td><td >' + result[i].OTHrs + '</td><td >' + WorkingDays + '</td><td >' + TotalDays + '</td><td>' + result[i].PH_Fulldays + '</td><td>' + result[i].PH_Halfdays + '</td></tr>';

        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Emp.Code</th><th>Emp.Name</th><th>Designantion</th><th>Payroll Type</th><th>Full Days</th><th style=text-align:right>Half Days</th><th style=text-align:right>Leaves</th><th style=text-align:right>Holidays</th><th style=text-align:right>OT_Hrs</th><th style=text-align:right>Working Days</th><th style=text-align:right>Total Days</th><th>PH_FullDays</th><th>PH_HalfDays</th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Attendance Report - from " + StartingDate + " to " + EndingDate + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }

            if (title == 'Emp.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Emp.Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Dept.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Designation') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Payroll Type') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Full Days') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Half Days') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Leaves') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'OT_Hrs') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Holidays') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Working Days') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Total Days') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'PH_FullDays') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'PH_HalfDays') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }

        });
        var table = null;
        table = $('#' + tablename).DataTable({
            //dom: 'Blfrtip',
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
            //"columnDefs": [

            //     { "width": "17%", "targets": 2 },
            //     { "width": "18%", "targets": 3 },
            //      { "width": "15%", "targets": 4 },
            //        { "width": "15%", "targets": 5 },
            //          { "width": "10%", "targets": 6 },
            //           { "width": "10%", "targets": 7 },

            //]

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

</script>