
@{
    ViewBag.Title = "SalaryReport";
}

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>



<div class="myData" data-x="M183" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="44%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#Employee').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                               
                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">




                                <br /><hr />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                                <br /><br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">Salary Report</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
            
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-2">
                            <label style="font-weight:bold">Date</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <div  class="col-md-2">
                        <label style="font-weight:bold">Dept.</label>
                        </div>
                        <div class="col-md-4">
                            <select id="dept" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:3%">
                        <div class="col-md-2">
                            <label style="font-weight:bold">Employee</label>
                        </div>
                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="31%">
                                        <input type="text" id="Employee" class="form-control" onkeyup="$('#EmployeeName').val(''), $('#EmployeeId').val(0)" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="EmployeeId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="EmployeeName" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="text-center">

                    <button type="button" style="width:100px;" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />
                </div>
            </form>

        </div>
    </div>
</div>


<script>
    $("#Employee").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.EmpName = $("#Employee").val();
            data.DeptId = 0;
            data.UserId = 0;
            $.ajax({
                url: '../PayRoll_LeaveApply/EmployeeSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.EmpId,
                            label1: item.EmpName,
                            EmpId: item.EmpId,
                            EmpName: item.EmpName,
                            headers: ["Emp.ID", "Emp. Code"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#EmployeeId').val(ui.item.EmpId);
            $('#Employee').val(ui.item.EmpId);
            $('#EmployeeName').val(ui.item.EmpName);
            $("#btnsubmit").focus();
        },
    });


    var StartingDate = $('#DateFrom').val();
    var EndingDate = $('#DateFrom').val();
    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function GetDepartment(id) {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }
    function DepartmentLoad(result, a) {
        $("#dept").empty();
        $("#dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    function getDateObject(str) {
        var arr = str.split("/");
        return new Date(arr[2], arr[1], arr[0]);
    }
    function startenddates() {


        var Dt = $('#DateFrom').val();

        someDate = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));

        someMonth = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));

        someDate.setDate(parseInt(someDate.getDate()));

        var a = new Date(someDate.getFullYear(),
                         someDate.getMonth() + 1,
                         0).getDate();
        var month = someMonth.getMonth() + 1;

        StartingDate = "1" + "/" + month + "/" + someMonth.getFullYear();

        EndingDate = a + "/" + month + "/" + someMonth.getFullYear();


    }
    $(function () {
        $('#Employee').focus();
        GetDepartment(0);

    

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    
        $('#dept').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });

          if (getQueryString('EmpId') != null) {
            $('#EmployeeName').val(getQueryString('EmpName'))
            $("#Employee").val(getQueryString('EmpId'));
            ReportGets();
            $('#Entry').show();

        }


        $("#btnsubmit").click(function (e) {
            ReportGets();
        });
    });


    function ReportGets()
    {
        startenddates();

        if ($('#DateFrom').val() == '') {
            alert('Please Select From Date');
            $('#DateFrom').focus();

        }
         
        else {
            $('#Loading').show();
            var data = {};
            data.FromDate = $('#DateFrom').val();
            data.ToDate = $('#DateFrom').val();
            data.DeptId = $('#dept').val();
            data.EmpId = $('#Employee').val()
            $.ajax({
                type: "POST",
                url: "../SalaryManagement/SalaryReportGet",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);
                    console.log(result)
                }
            });
        }
    }
    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th>"+
            "<th>Emp.Code</th>"+
            "<th>Emp.Name</th>"+
            "<th>Dept.Code</th>"+
            "<th>Designation</th>"+
            "<th>DateOfJoin</th>"+
            "<th>PayRoll Type</th>"+
            "<th style=text-align:right;>Basic Salary</th>" +
            "<th style=text-align:right;>DA</th>" +
            "<th style=text-align:right;>TA</th>" +
            "<th style=text-align:right;>HRA</th>" +
            "<th style=text-align:right;>Night Alowance</th>" +
            "<th style=text-align:right;>Other Earnings</th>" +
            "<th style=text-align:right;>Total Earnings</th>" +
            "<th style=text-align:right;>PF</th>" +
            "<th style=text-align:right;>Tax</th>" +
            "<th style=text-align:right;>ESI</th>" +
            "<th style=text-align:right;>Other Deductions</th>" +
            "<th style=text-align:right;>Total Deductions</th>" +
            "<th style=text-align:right;>Net Salary</th>" +
            "<th style=text-align:center;>Working Hours</th>" +
            "<th style=text-align:right;>OT Rate</th>" +
            "</tr></thead><tbody>";
        for (var l = 0; l < result.length; l++) {
            var slno = parseInt(l + 1);
       
                responseText += '<tr><td>' + slno + '</td>' +
                '<td>' + result[l].EmpCode + '</td>' +
                '<td>' + result[l].Name + '</td>' +
                '<td>' + result[l].DepartmentName + '</td>' +
                '<td>' + result[l].DesignationDescription + '</td>' +
                '<td>' + result[l].DateofJoin + '</td>' +
                '<td>' + result[l].PayRollType + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].BS).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].DA).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].TAF).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].HRAF).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].NA).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].EO).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].TE).toFixed(Decimal) + '</td>' +

                '<td style=text-align:right;>' + parseFloat(result[l].PFf).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].Taxf).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].ESIf).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].Od).toFixed(Decimal) + '</td>' +
                '<td style=text-align:right;>' + parseFloat(result[l].TD).toFixed(Decimal) + '</td>' +
               
                '<td style=text-align:right;>' + parseFloat(result[l].NS).toFixed(Decimal) + '</td>' +
                '<td style=text-align:center;>' + parseFloat(result[l].WorkingHours).toFixed(Decimal) + '</td>' +
                '<td style=text-align:center;>' + parseFloat(result[l].OTR).toFixed(Decimal) + '</td>' +
                '</tr>';
                      
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th>'+
            "<th>Emp.Code</th>" +
            "<th>Emp.Name</th>" +
            "<th>Dept.Code</th>" +
            "<th>Designation</th>" +
            "<th>Date Of Join</th>" +
            "<th>PayRoll Type</th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:right;> </th>" +
            "<th style=text-align:center;> </th>" +
            "<th style=text-align:right;> </th>" +
            '</tr></tfoot>');
        var title = "Salary Report - AS ON " + $('#DateFrom').val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#ResultLength').val(result.length);

    }
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }

            if (title == 'Emp.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Emp.Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:200px" />');
            }
            if (title == 'Dept.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Designation') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Date Of Join') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'PayRoll Type') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Basic Salary') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'TA') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Night Alowance') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'HRA') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'EarningOthers') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'PF') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Tax') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'ESI') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Other Deductions') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Total Deductions') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Total Earnings') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Net Salary') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'OT Rate') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Leaves') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Holidays') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Worked Session') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'OT Hrs') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
          
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            //dom: 'Blfrtip',
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
            //"columnDefs": [

            //     { "width": "17%", "targets": 2 },
            //     { "width": "18%", "targets": 3 },
            //      { "width": "15%", "targets": 4 },
            //        { "width": "15%", "targets": 5 },
            //          { "width": "10%", "targets": 6 },
            //           { "width": "10%", "targets": 7 },

            //]

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

</script>