               //    var PH_Earnings=0
               //}







               //







               var TotalEarnings = GrossSalary_Sess + GrossDedUction_Sess + OTEarnings;
               TotalEarnings = TotalEarnings.toFixed(2);
           
               var TotalDeductions = (TotalEarnings - GrossSalary_Sess - OTEarnings);
               if (TotalDeductions >= 0) {
                   TotalDeductions = TotalDeductions.toFixed(2)
               }
               else {
                   TotalDeductions = 0.00
               }
            
               var NetSal = parseFloat(TotalEarnings - TotalDeductions);
               if (NetSal > 0)
               {
                   var NetSalary = parseFloat((TotalEarnings - TotalDeductions) - advancesal);
                   if (advancesal > 0)
                   {
                       advanceFlag=1;
                   }
                       
               }
               else
               {
                   var NetSalary = NetSal;
               }
               NetSalary = NetSalary.toFixed(Decimal)

               var Leave_Deduction = (TotalEarnings / TotalDays) * Leaves;
               //<td><input type=checkbox id=chckHead /></td>
               responseText = responseText + "<tr id=" + 'row' + slno + "><td  id=" + 'td' + slno + " >"
