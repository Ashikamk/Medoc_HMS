    function Calc()
    {
        startenddates();

        var date1 = getDateObject(StartingDate);
        var date2 = getDateObject(EndingDate);
        if (date2 - date1 > 0)
        {
            TotalDays = (date2 - date1) / 86400000;

            $('#DateFrom').val(StartingDate);
            $('#DateTo').val(EndingDate);
            $('#Days').val(TotalDays+1);
            
          
            var data = {};
            data.Startingdate = StartingDate
            data.Enddate = EndingDate
            $('#Loading').show();
            $.ajax({
                type: "POST",
                url: "../SalaryManagement/PayRollCheckInfo",
                data: data,
                success: function (result) {
                    for (var i = 0; i <= result.oList.length; i++) {
                        var status = result.oList[i].Status;
                        if (status != 0) {
                            warningshow('AlreadyGeneratedPayRoll')
                            $('#Loading').hide();``
                            Clear();
                        }
                        else {
                            $.ajax({
                                type: "POST",
                                url: "../SalaryManagement/GetPayRollCalcInfo",
                                data: data,
                                success: function (result) {
                                    if (result.length != 0) {
                                        $('#Loading').hide();
                                        PayRollCalcAndDisplay(result.oList);
                                        $("#btnPayRollSubmit").removeAttr('disabled');
                                    }
                                }
                            });
                        }
                    }

                    }
            });

        }
        else {
            warningshow('Please Select ProperDate')
            $('#DateSelect').focus();
            return false;
        }
