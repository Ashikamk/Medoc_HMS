               var AllowedLeaves = 0;// hardcode.....set in EmployeeTable
               var BasicSalary = result[i].BasicSalary;
               var TA = result[i].TA;
               var NightAlowance = result[i].NightAlowance;
               var HRA = result[i].HRA;
               var EarningOthers = result[i].EarningOthers;
               var PF = result[i].PF;
               var Tax = result[i].Tax;
               var ESI = result[i].ESI;
               var Otherdeductions = result[i].Otherdeductions;
               var OTRate = result[i].OTRate;
               var OTHrs = result[i].OTHrs;
               var Leaves = result[i].Leaves;
               var Holidays = result[i].Holidays;
               var WorkedSession = result[i].WorkedSession;                           
               //Calculation Part....

               var PresntDays_Sess = parseInt(WorkedSession) + parseInt(Holidays * 2) + parseInt(AllowedLeaves * 2)
               var LeaveDays_Sess = parseInt(Leaves * 2);
               if ((BasicSalary + TA + NightAlowance + HRA + EarningOthers) != 0) {
                   var GrossSalary_Sess = PresntDays_Sess * ((BasicSalary + TA + NightAlowance + HRA + EarningOthers) / TotalDays_Sess);
                
               }
               else
               {
                   var GrossSalary_Sess = 0;
               }
               if ((PF + Tax + ESI + Otherdeductions) != 0) {
                   var GrossDedUction_Sess = PresntDays_Sess * ((PF + Tax + ESI + Otherdeductions) / TotalDays_Sess);
                 
               }
               else {
                   var GrossDedUction_Sess = 0;
               }
           
               var OTEarnings = OTRate * OTHrs;







               //




               //var PH_WorkedSession = result[i].PH_WorkedSession;
               //if ((BasicSalary + TA + NightAlowance + HRA + EarningOthers + PF + Tax + ESI + Otherdeductions) != 0)
