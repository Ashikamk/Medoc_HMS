               + NetSalary + "</td><td ><a id=" + 'btnId' + slno + " onclick='handleClick( this )'>" + Editbutton + "</a></td> <td  id=" + 'EmpId' + slno + " style='Display:none' >"
               + result[i].EmpId + "</td><td  id=" + 'DepartmentId' + slno + " style='Display:none' >"
               + result[i].DepartmentId + "</td><td  id=" + 'LocationId' + slno + " style='Display:none' >"
               + result[i].LocationId + "</td><td  id=" + 'DesignationId' + slno + " style='Display:none' >"
               + result[i].DesignationId + "</td><td  id=" + 'DateofJoin' + slno + " style='Display:none' >"
               + result[i].DateofJoin + "</td><td  id=" + 'Gender' + slno + " style='Display:none' >"
               + result[i].Gender + "</td><td  id=" + 'DOB' + slno + " style='Display:none' >"
               + result[i].DOB + "</td><td  id=" + 'BasicSalary' + slno + " style='Display:none' >"
               + result[i].BasicSalary + "</td><td  id=" + 'TA' + slno + " style='Display:none' >"
               + result[i].TA + "</td><td  id=" + 'NightAlowance' + slno + " style='Display:none' >"
               + result[i].NightAlowance + "</td><td  id=" + 'HRA' + slno + " style='Display:none' >"
               + result[i].HRA + "</td><td  id=" + 'EarningOthers' + slno + " style='Display:none' >"
               + result[i].EarningOthers + "</td><td  id=" + 'PF' + slno + " style='Display:none' >"
               + result[i].PF + "</td><td  id=" + 'Tax' + slno + " style='Display:none' >"
               + result[i].Tax + "</td><td  id=" + 'ESI' + slno + " style='Display:none' >"
               + result[i].ESI + "</td><td  id=" + 'Otherdeductions' + slno + " style='Display:none' >"
