       var responseText = "<thead><tr><th>Slno</th><th>EmpCode</th><th>EmpName</th><th>TotalEarnings</th><th width=15px>TotalDeductions</th><th>Advance</th><th>NetSalary</th><th>Edit</th><th Style=Display:none>EmpId</th><th Style=Display:none>DepartmentId </th><th Style=Display:none>LocationId </th><th Style=Display:none>DesignationId</th><th Style=Display:none>DateofJoin</th><th Style=Display:none>Gender </th><th Style=Display:none>DOB </th> <th Style=Display:none>BasicSalary </th><th Style=Display:none>TA</th><th Style=Display:none>NightAlowance </th><th Style=Display:none>HRA </th><th Style=Display:none>EarningOthers</th><th Style=Display:none>PF </th><th Style=Display:none>Tax</th><th Style=Display:none>ESI </th><th Style=Display:none>Otherdeductions  </th><th Style=Display:none>OTRate</th><th Style=Display:none>OTHrs </th><th Style=Display:none>Leaves</th><th Style=Display:none>Holidays</th><th Style=Display:none>WorkedSession </th><th Style=Display:none>PayRollType</th><th style='Display:none'>Flag</th><th Style=Display:none>Designation</th></tr></thead><tbody>";
