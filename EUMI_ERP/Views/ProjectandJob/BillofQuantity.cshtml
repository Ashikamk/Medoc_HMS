    $("#Product_0").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#Product_0").val();

            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '4',
                            label: item.ItemCode,
                            label1: item.Description,
                            label2: item.UnitName,
                            label3: item.SellingPrice.toFixed(Decimal),

                            ProductId: item.ItemId,
                            Unit: item.UnitId,
                            UnitId: item.UnitName,
                            Description: item.Description,
                            Rate: item.AvgCost,
                            AvgCost: item.SellingPrice,
                            headers: ["Item Code", "Description", "Unit Name", "Average Cost"]

                        })
                    }));
                }

            })
        },
        autoFocus: true,
        select: function (event, ui) {
            var ProdFlag = 0;
            var allow = 0;

            for (var p = 1; p <= $('#tblboq tr').length ; p++) {
                if (ui.item.ProductId == $('#ProductId_' + p).val()) {
                    ProdFlag = 1;
                }
            }
            if (ProdFlag == 1) {
                $('#modal_dialog').show();
                $('#btnNo').focus();

                dialog(function () {
                    $('#modal_dialog').hide();
                    $('#Quantity_0').focus();

                    $('#ProductId_0').val(ui.item.ProductId)
                    $('#Unit_0').val(ui.item.Unit);
                    $("#Description_0").val(ui.item.Description);
                    $('#Rate_0').val((ui.item.Rate).toFixed(Decimal));
                    $('#Cost_0').val((ui.item.AvgCost).toFixed(Decimal));
                    $('#textUnit').val(ui.item.UnitId);
                    $('#Quantity_0').val(1);
                    $('#Quantity_0').select();
                    totalamount(0);
                    var data = {};
                    data.ProductId = ui.item.ProductId;
                    data.CustId = 0;
                    data.DeptId = ERPDeptId;
                    $.ajax({
                        type: "POST",
                        url: '../SalesInvoice/CustomerProductDetailsSearch',
                        data: data,
                        success: function (result) {
                            ProductPopuprefresh();
                            CustPrdctLoad(result.oList);
                        }
                    })
                },
             function () {               // Cancel Button
                 $('#modal_dialog').hide();
                 clearrow();
                 return false;
             }
            );
            }
            else if (ProdFlag == 0) {
                $('#ProductId_0').val(ui.item.ProductId)
                $('#Unit_0').val(ui.item.Unit);
                $("#Description_0").val(ui.item.Description);
                $('#Rate_0').val((ui.item.Rate).toFixed(Decimal));
                $('#Cost_0').val((ui.item.AvgCost).toFixed(Decimal));
                $('#textUnit').val(ui.item.UnitId);
                $('#Quantity_0').val(1);
                $('#Quantity_0').focus();
                $('#Quantity_0').select();
                totalamount(0);
                var data = {};
                data.ProductId = ui.item.ProductId;
                data.CustId = 0;
                data.DeptId = ERPDeptId;
                $.ajax({
                    type: "POST",
                    url: '../SalesInvoice/CustomerProductDetailsSearch',
                    data: data,
                    success: function (result) {
                        ProductPopuprefresh();
                        CustPrdctLoad(result.oList);
                    }
                })
            }
        },

    });

    $("#BOQNo").autocomplete({
        source: function (request, response) {
            var data = {};
            data.BOQSlNo = $("#BOQNo").val();
            $.ajax({
                url: '../ProjectandJob/BOQNoSearch',
