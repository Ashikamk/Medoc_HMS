                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {

            var boq = {};
            boq.BOQSlNo = ui.item.BOQNo;

            $.ajax({
                type: "POST",
                url: "../ProjectandJob/BillofQuantityGetandGets",
                data: boq,
                success: function (result) {
                    $('#tblboq tr').remove();
                    BOQNoGets(result.oList);
                    $('#BOQNo').prop("disabled", false);
                    $('#btnsubmit').hide();
                    $('#btnlist').hide();
