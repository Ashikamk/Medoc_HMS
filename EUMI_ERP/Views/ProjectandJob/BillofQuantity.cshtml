                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">

                                                            <input type="text" id="Quantity_0" onkeyup="totalamount(0)" autocomplete="off" onkeypress="isNumberInt(event,this)" class="form-control editds">
                                                        </div>
                                                    </div>


                                                    <div class="col-md-1">
                                                        <div class="form-group">

                                                            <input type="text" id="Rate_0" onkeyup="totalamount(0)" autocomplete="off" onkeypress="isNumber(event,this)" class="form-control editds">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
