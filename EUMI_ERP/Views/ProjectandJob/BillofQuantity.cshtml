                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Rate</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Cost</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Margin%</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Total Amount</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Resource</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 70px;">Remarks</th>
                                                    <th class="jsgrid-header-cell jsgrid-control-field jsgrid-align-center" style="width: 30px;"></th>
                                                </tr>

                                            </tbody>
                                        </table>
                                    </div>


                                    <div id="proddiv" class="jsgrid dataTables_scrollBody" style="position: relative;overflow-x: auto;overflow-y:scroll; height:265px;  width:1800px;">
                                        <table class="jsgrid-table" id="tblboq">
                                            <tbody></tbody>
                                        </table>
                                    </div>

                                </div>
                                @*<br />*@

                                <div class="row" style="margin-left:1375px;display:none">
                                    <div class="text-right">
                                        <label style="font-weight:bold;color:#00B5B8;font-size:large">Grand Total</label>
                                    </div>
                                    <div class="col-md-3">
                                        <input type="text" id="GrandTotal" autocomplete="off" readonly class="form-control" style="width:150px;border-color:white;margin-bottom:5px;margin-top:-7px;font-weight:bold;background-color:white">
                                    </div>
                                </div>

                                <div class="form-actions">
                                    <div class="text-right" style="margin-top:-10px">
                                        <button type="button" style="width:100px" id="btnsubmit" onclick="SaveBOQ()" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:120px" id="btnview" onclick="$('#ViewFromDate,#ViewToDate').val(CurDate), GetList()" class="btn btn-primary btn-min-width mr-1 mb-1">View <i class="ft-eye"></i></button>
                                        <button type="button" style="width:100px" id="btncopy" onclick="GetRows()" class="btn btn-primary btn-min-width mr-1 mb-1">Copy <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px;display:none" id="btnprint" onclick="PrintthisBill()" class="btn btn-primary btn-min-width mr-1 mb-1">Print <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnlist" onclick="gotoreport()" class="btn btn-primary btn-min-width mr-1 mb-1">Report <i class="ft-refresh-cw position-right"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefreshconfirm()" class="btn btn-primary btn-min-width mr-1 mb-1">New <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btnsaveedit" onclick="UpdateBOQ()" class="btn btn-warning white btn-min-width mr-1 mb-1">Update<i class="fa fa-check-square-o"></i></button>
                                        <button style="display:none;width:100px" type="button" id="btnedit" onclick="EditBOQ(0)" class="btn btn-secondary white btn-min-width mr-1 mb-1">Edit<i class="fa ft-edit"></i></button>
                                        <button style="display:none" type="button" id="btndelete" onclick="DeleteBOQ()" class="btn btn-danger btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                    </div>
                                </div>


                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</div>

