                                <div id="customView" class="jsgrid" style="position: relative; height: auto;width: 100%; border:1px solid; margin-top:-10px;border-color:#e9e9e9">
                                    <div class="jsgrid-grid-header jsgrid-header-scrollbar" style="width:1800px;">
                                        <table class="jsgrid-table" id="tblboqheader">
                                            <tbody>
                                                <tr class="jsgrid-header-row">
