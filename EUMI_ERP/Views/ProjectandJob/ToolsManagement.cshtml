            $('#ProductQty').val('');

            var data = {};
            data.Code = $("#Product_0").val();
            $.ajax({
                url: '../Master/ToolsAutocomplete',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
