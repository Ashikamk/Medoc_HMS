                            UnitName:item.UnitName,
                            headers: ["Tool Code", "Description", "Pcs", "Quantity"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            var ProdFlag = 0;
            //$('#ProductId_0').val(ui.item.ToolId);
            //$('#Description_0').val(ui.item.ToolDesc);
            //$('#Pcs_0').val(ui.item.Pcs);
            //$('#Serial_0').select().focus();
            //$('#ProductQty').val(ui.item.ToolQty);
            for (var p = 1; p <= $('#tblToolsDetails tr').length; p++) {
                if (ui.item.ToolId == $('#ProductId_' + p).val()) {
                    ProdFlag = 1;
                }

            }
            if (ProdFlag == 1) {
                $('#modal_dialog').show();
                $('#btnNo').focus();

                dialog(function () {
                    $('#modal_dialog').hide();
                    $('#Serial_0').focus();
                    $('#ProductId_0').val(ui.item.ToolId);
                    $('#Description_0').val(ui.item.ToolDesc);
                    $('#Pcs_0').val(ui.item.Pcs);
                    $('#Serial_0').select().focus();
                    $('#ProductQty').val(ui.item.ToolQty);
                },
             function () {               // Cancel Button
                 $('#modal_dialog').hide();
                 clearrow();
                 return false;
             }
            );
            }
            else if (ProdFlag == 0) {
                $('#Serial_0').focus();
                $('#ProductId_0').val(ui.item.ToolId);
                $('#Description_0').val(ui.item.ToolDesc);
                $('#Pcs_0').val(ui.item.Pcs);
                $('#Serial_0').select().focus();
                $('#ProductQty').val(ui.item.ToolQty);
            }

        },

    });
