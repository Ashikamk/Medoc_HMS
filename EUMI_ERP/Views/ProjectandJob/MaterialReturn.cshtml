            <form id="GoldItemDiv">
                <div class="modal-body">
                  
                    <br />
                    <div class="px-2">
                        <div id="" class="jsgrid" style="position: relative; height: 500px; width: 100%;margin-top:-10px;overflow-x: auto;overflow-y: hidden;margin-bottom:-10px;">
                          <table class="table table-responsive-md-md text-center table-striped table-bordered zero-configuration dataTable" id="TblView" style="font-weight:400"></table>
                        </div>
                    </div>
                   
                </div>

            </form>
        </div>
