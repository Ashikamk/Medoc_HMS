<div class="myData" data-x="M289" />
<div id="Entry" style="">

    <section class="grid-row-label">
        <div class="row">
            <div class="col-md-12">
                <div class="card">

                    <div class="px-3">
                        <div class="row">
                            <div class="col-md-4">
                                <h2 class="card-title mb-0 font-large-1" style="font-weight:bold;text-align:left;padding-top:20px">PROJECT MATERIAL RETURN</h2>
                            </div>                        
                            <div class="col-md-8">
                                <h2 style="font-weight:600;text-align:right;padding-top:20px;">Total Amount &nbsp; <span style="font-weight:600;text-align:right;color:red;padding-top:20px;" id="TotalAmountLbl"></span></h2>
                            </div>

                        </div>
                    </div>

                    <div class="card-content collapse show">
                        <div class="card-body" style="margin-top:-75px">

                            <form action="#">

                                <div class="form-body">
                                    <hr style="margin-top:75px" />


                                    <table class="hedrtbl" style="width:100%;background-color:#F0F6F6;margin-top:-1%">
                                        <tr class="row htdtop">
                                            <td class="col-md-1 htdleft">
                                                <label style="font-weight:bold">PR No</label>
                                            </td>
                                            <td class="col-md-2">
                                                <input type="text" id="ReturnNo" class="form-control EnbTxt AvoidClear" disabled="">
                                                <div id="CopyDiv" class="input-group" style="margin-bottom:0rem;display:none">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text" onclick="GetPrevNextNo(-1)"><b><i class="ft-chevron-left"></i></b></span>
                                                    </div>
                                                    <input type="text" id="ReturnNoCopy" class="form-control EnbTxt AvoidClear atfcs" onfocus="SearchVocNo()">
                                                    <div class="input-group-append">
                                                        <span class="input-group-text" onclick="GetPrevNextNo(1)"><b><i class="ft-chevron-right"></i></b></span>
                                                    </div>
                                                </div>
                                                <div style="display:none">
                                                    <input type="text" id="SavedReturnNo" class="form-control">
                                                    <input type="text" id="CurrentReturnNo" class="form-control AvoidClear">
                                                </div>
                                            </td>
                                            <td class="col-md-1">
                                                <label style="font-weight:bold">Return Date</label>
                                            </td>
                                            <td class="col-md-2">
                                                <input type="text" class="form-control" id="ReturnDate" /> 
                                            </td>

