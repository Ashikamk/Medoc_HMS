                                            <td class="col-md-1 htdleft">
                                                <label style="font-weight:bold">To</label> 
                                            </td>
                                            <td class="col-md-5 input-group">
                                                <input type="text" id="DebitAcc" class="form-control atfcs" onfocus="LoadAccount('DebitAcc')" style="width:37%">
                                                <input type="text" id="DebitAccDesc" class="form-control input-append atfcs" style="width:63%" onkeydown="Focusinput('Product0', event, 'DebitAccDesc')">
                                            </td>
                                        </tr>

                                    </table>

                                    <hr style="margin-top:.3%" />

                                    <div class="px-3" style="margin-top:-1%;overflow:auto">
                                        <table style="" class="Adddets">
                                            <tr>
                                                <td width="10%">
                                                    <label style="font-weight:bold">Product</label>
                                                </td>                                          
                                                <td width="20%">
                                                    <label style="font-weight:bold">Description</label>
                                                </td>
                                                <td width="9%">
                                                    <label style="font-weight:bold">Unit</label>
                                                </td>
                                                <td width="9%">
                                                    <label style="font-weight:bold">Location</label>
                                                </td>
                                                <td width="9%">
                                                    <label style="font-weight:bold">Quantity</label>
                                                </td>
                                                <td width="9%">
                                                    <label style="font-weight:bold">Price</label>
                                                </td>
                                                <td width="9%">
                                                    <label style="font-weight:bold">Total</label>
                                                </td>
                                                <td width="9%">
                                                    <label style="font-weight:bold">CostCode</label>
                                                </td>                                               
                                                <td width="5%" valign="middle">
                                                   
                                                </td>                                           
                                            </tr>
                                            <tr>
                                                <td>
                                                    <input type="text" id="Product0" class="form-control atfcs Addchk" onfocus="LoadProduct('Product0',event)">  
                                                    <input type="text" id="ProductId0" class="form-control Addchk" style="display:none"> 
                                                </td>
                                                <td>
                                                    <input type="text" id="PDescr0" class="form-control Addchk tdes" >
                                                </td>
                                                <td>
                                                    <select type="text" id="PUnit0" class="form-control Addchksl"></select> 
                                                </td>
                                                <td>
                                                    <select type="text" id="PLoc0" class="form-control Addchksl"></select> 
                                                </td>
                                                <td >
                                                    <input type="text" id="PQty0" class="form-control Addchk" onkeypress="isNumberInt(event, this)" onkeyup="RowAmountCalculation(0,0)"> 
                                                </td>
                                                <td>
                                                    <input type="text" id="PPrice0" class="form-control Addchk" onkeypress="isNumber(event,this)" onkeyup="RowAmountCalculation(0,0)">
                                                </td>
                                                <td>
                                                    <input type="text" id="PAmount0" class="form-control Addchk  EnbTxt" disabled="">
                                                </td>
                                                <td>
                                                    @*<select type="text" class="form-control Addchksl" id="PCostCode0"></select>*@    
                                                    <input type="text" class="form-control atfcs Addchk" id="PCostCode0" onfocus="LoadCostCode('PCostCode', 0)" />   
                                                    <input type="text" class="form-control Addchk" id="PCostCodeId0" style="display:none" />                                                 
                                                </td>
                                                <td class="pt-1">
                                                    <button type="button" class="btn btn-outline-primary " id="AddChequ" onclick="Itemaddconfirm(0)"  onkeydown="Focusbtn('AutoChequ',event,'AddChequ')">ADD <i class="fa fa-plus"></i></button>
                                                </td>

                                            </tr>
                                        </table>
                                    </div>
                                  
                                    <div class="px-2">
                                        <div id="customView" class="jsgrid" style="position: relative; height: auto; width: 100%; border:solid 1px;border-color:#e9e9e9;overflow-x: auto;overflow-y: hidden;margin-bottom:-10px;">
                                            <div class="jsgrid-grid-header jsgrid-header-scrollbar" style="width: 100%;">
                                                <table class="jsgrid-table" id="tblsalesinvoiceheader">
                                                    <tr class="jsgrid-header-row">
                                                        <th class="jsgrid-header-cell jsgrid-control-field jsgrid-align-center" style="width:3%"><i class="icon-trash"></i></th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:3%">No</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:12%">Product</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:25%">Description</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:6%">Unit</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:8%">Location</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:6%">Qty.</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:6%">Price</th>
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:8%">Amount</th> 
                                                        <th class="jsgrid-header-cell jsgrid-align-right" style="width:8%">CostCode</th>    
                                                    </tr>
                                                </table>
                                            </div>
                                            <div id="proddiv" class="" style="position: relative; overflow-x: hidden;overflow-y: scroll; height:280px; width: 100%;border-bottom:1px solid;border-bottom-color:#e9e9e9">
                                                <table class="jsgrid-table" id="TblMaterialReturn"></table>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-actions row px-3">
                                        <div class="col-md-3 row">                                          
                                            <div class="col-md-12">
                                                <table class="headertable" id="" style="background-color:white;width:100%;">
                                                    <tr>
                                                        <td class="text-center" width="50%" style="border-left:1px solid #BABFC7;"><b>Total Qty.</b></td>
                                                        <td class="text-center" width="50%" style="border-left:1px solid #BABFC7;"><b>Total Amount</b></td>
                                                    </tr>
                                                    <tr>
                                                        <td style="border-left:1px solid #BABFC7;text-align:center;" class="pt-1">
                                                            <label style="font-weight:bold;"><span id="TotalQty"></span></label>
                                                        </td>                                                       
                                                        <td style="border-left:1px solid #BABFC7;text-align:center;" class="pt-1">
                                                            <label style="font-weight:bold;"><span id="TotalAmt"></span></label>
                                                        </td>

                                                    </tr>

                                                </table>
                                            </div>

                                        </div>
                                        <div class="col-md-9 text-right">
                                            <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                            <button type="button" style="width:100px" id="btncopy" onclick="Clear(1)" class="btn btn-primary btn-min-width mr-1 mb-1">Copy <i class="ft-align-justify"></i></button>
                                            <button type="button" style="width:100px" id="btnnew" onclick="Clear(0)" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                            <button style="display:none;width:100px" type="button" id="btnedit" onclick="$('#otptype').val(1), $('#OTPDiv').show(), $('#txtotp,#otpremarks').prop('disabled', false), $('#txtotp').focus()" class="btn btn-secondary btn-min-width mr-1 mb-1">Edit<i class="fa ft-edit"></i></button>
                                            <button style="display:none;width:100px" type="button" id="btnupdate" class="btn btn-secondary btn-min-width mr-1 mb-1">Update<i class="fa fa-check-square-o"></i></button>
                                            <button style="display:none;width:100px" type="button" id="btndelete" onclick="$('#otptype').val(0), $('#OTPDiv').show(), $('#txtotp,#otpremarks').prop('disabled', false), $('#txtotp').focus()" class="btn btn-danger btn-min-width mr-1 mb-1">Delete<i class="fa fa-times"></i></button>                                         
                                            <button style="display:none;width:120px" type="button" id="btnprint1" onclick="confirmprint()" class="btn btn-primary btn-min-width mr-1 mb-1">Print <i class="ft-printer"></i></button>
                                            <button type="button" class="btn btn-primary btn-min-width mr-1 mb-1"  onclick="Clear(2)">View <i class="ft-eye"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

