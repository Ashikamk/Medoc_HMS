        padding-right: 2%;
    }

    .htdtop {
        padding-top: .5%;
    }

    .htdbot {
        padding-bottom: .5%;
    }

    .overlay1 {
        position: fixed;
        width: 100%;
        height: 100%;
        top: 45%;
        left: 50%;
        right: 0;
        bottom: 0;
        z-index: 2;
        cursor: pointer;
    }

    .modal-xl {
