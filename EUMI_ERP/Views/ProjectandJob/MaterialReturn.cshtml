<div id="itempopup" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="jobheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none">
    <div class="modal-dialog modal-xl" role="document" style="top:5%;">
        <div class="modal-content">
            <div class="modal-header bg-primary white">              
               
                <div class="col-md-2">
                    <input type="text" id="FromDate" class="form-control ITMP1 EnbTxt AvoidClear atfcs" onkeydown="Focusinput('ToDate', event, 'FromDate')"> 
                </div>
                <div style="margin-top:.5%">
                    -
                </div>
               
                <div class="col-md-2">
                    <input type="text" id="ToDate" class="form-control ITMP1 EnbTxt AvoidClear atfcs" onkeydown="Focusinput('Department', event, 'ToDate')">

                </div>
                <div class="col-md-1 white" style="margin-top:.5%">
                   Department
                </div>
                <div class="col-md-2">
                    <select id="Department" class="form-control ITMPS1 EnbTxt atfcs "  onkeydown="Focusinput('btnad', event, 'Department')"></select>
                </div>
