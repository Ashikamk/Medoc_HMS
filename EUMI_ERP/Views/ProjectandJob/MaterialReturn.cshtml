                                                <input type="text" class="form-control" id="CostCodeId" style="display:none" /> 
                                                <input type="text" class="form-control atfcs" id="CostCode" onfocus="LoadCostCode('CostCode', 0)" /> 

                                                @*<select type="text" class="form-control" id="CostCode" onchange="$('#PCostCode0').val($('#CostCode').val())"></select>*@
                                            </td>
                                        </tr>

                                        <tr class="row htdtop" style="">
                                            <td class="col-md-1 htdleft">
                                                <label style="font-weight:bold">From</label>
                                            </td>
                                            <td class="col-md-5 input-group" colspan="3">
                                                <input type="text" id="CreditAcc" class="form-control atfcs" onfocus="LoadAccount('CreditAcc')" style="width:37%;">
                                                <input type="text" id="CreditAccDesc" class="form-control input-append atfcs" style="width:63%" onkeydown="Focusinput('Product0', event, 'CreditAccDesc')">
                                            </td>
                                            <td class="col-md-1" rowspan="2">
                                                <label style="font-weight:bold">Comments</label>
                                            </td>
                                            <td class="col-md-5 htdright" rowspan="2">
                                                <textarea class="form-control" id="Comments" rows="2" style="resize:none;height:140%"></textarea>
                                            </td>                                        
                                        </tr>
