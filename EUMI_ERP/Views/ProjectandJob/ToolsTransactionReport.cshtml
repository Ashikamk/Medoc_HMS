

@{
    ViewBag.Title = "ToolsTransactionReport";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>




<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>

<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }
    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        
        var responseText = "<thead><tr><th>Sl#</th><th width='50px'>TM#</th><th>Date</th><th class='toolhide'>Tool Code</th><th class='toolhide'>Tool Description</th><th>Issued</th><th>Return</th><th class='balancehide'>Balance</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
           
            var slno = parseInt(i + 1);
            if (result[i].VocNo == 0) {
                var nullvalues = "";
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold><td align="center">' + slno + '</td><td>' + nullvalues + '</td><td>' + result[i].Date + '</td><td class="toolhide">' + result[i].ToolCode + '</td><td class="toolhide">' + result[i].ToolDesc + '</td><td align="center">' + nullvalues + '</td><td align="center">' + nullvalues + '</td><td class="balancehide" align="center">' + result[i].Balance + '</td></tr>';
            }
            else if (result[i].JobCodes == 'TTI') {
                var returnqty = 0;
                responseText += '<tr ><td align="center">' + slno + '</td><td>' + result[i].VocNo + '</td><td>' + result[i].Date + '</td><td class="toolhide">' + result[i].ToolCode + '</td><td class="toolhide">' + result[i].ToolDesc + '</td><td align="center">' + result[i].IssuedQty + '</td><td align="center">' + returnqty + '</td><td class="balancehide" align="center">' + result[i].Balance + '</td></tr>';

            }
        
            else if (result[i].JobCodes == 'TTR') {
                var returnqty = 0;
                responseText += '<tr ><td align="center">' + slno + '</td><td>' + result[i].VocNo + '</td><td>' + result[i].Date + '</td><td class="toolhide">' + result[i].ToolCode + '</td><td class="toolhide">' + result[i].ToolDesc + '</td><td align="center">' + returnqty + '</td><td align="center">' + result[i].IssuedQty + '</td><td class="balancehide" align="center">' + result[i].Balance + '</td></tr>';
            }
            else {
                responseText += '<tr ><td align="center">' + slno + '</td><td>' + result[i].VocNo + '</td><td>' + result[i].Date + '</td><td class="toolhide">' + result[i].ToolCode + '</td><td class="toolhide">' + result[i].ToolDesc + '</td><td align="center">' + result[i].IssuedQty + '</td><td align="center">' + result[i].Quantity + '</td><td class="balancehide" align="center">' + result[i].Balance + '</td></tr>';

            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>TM#</th><th>Date</th><th class="toolhide">Tool Code</th><th class="toolhide">Tool Description</th><th>Issued</th><th>Return</th><th class="balancehide">Balance</th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Tools Transaction Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        if (result.length > 0) {
            if (result[0].JobCodes == 'TTI' || result[0].JobCodes == 'TTR') {
                $('.balancehide').show();
                // $('.toolhide').hide();

            }
            else {
                $('.balancehide').hide();
                // $('.toolhide').show();

            }
        }
        
        $('#header').text(title);
    }













    $(function () {


        $('#CustodianCode').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#btnsubmit').focus();
            }
        });

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            if ($('#DateFrom').val() == '')
            {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {
                $('#Loading').show();
                if ($('#detailed').prop("checked")) {
                    var ManagementType = 1;
                }
                else {
                    var ManagementType = 2;
                }
                var data = {};
                data.FromDate = $('#DateFrom').val();
                data.ToDate = $('#DateTo').val();
                data.CustodianId = $('#CustodianId').val();
                data.ManagementType = ManagementType;
                $.ajax({
                    type: "POST",
                    url: "../ProjectandJob/Rpt_ToolsTransactionReport",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();

                    }
                });
            }


        });

    });

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');

         
            if (title == 'TM#' || title == 'Date' || title == 'Issued'|| title == 'Return'|| title == 'Balance')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');

            if (title == 'Tool Code' || title == 'Tool Description')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:500px;" />');
            if (title == 'Job Code' || title == 'Job Description')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:500px;" />');
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) {
                //console.log("download table need title and button container");
            }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

</script>

<div class="myData" data-x="M299" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="35%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">

                                <hr style="margin-top:.1%;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>


                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Tools Transaction Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:10%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>

                        <label style="font-weight:bold;margin-left:-1%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:2.5%;"></div>
                    <div class="row" style="margin-top:3%">
                        <label style="font-weight:bold;margin-left:2%">Custodian</label>
                        <div class="col-md-8">
                            <table width="315px">
                                <tr>
                                    <td width="150px">
                                        <input type="text" id="CustodianCode" class="form-control editds" onkeyup="ClearName()" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left;height:40px;">
                                        <input type="hidden" id="CustodianId" value="0" class="form-control" />
                                    </td>
                                    <td width="250px">
                                        <input type="text" id="CustodianName" class="form-control editds" name="acnt1" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="row" style="margin-top:3%">
                        <div class="custom-control custom-checkbox" style="margin-left:12%">
                            <input type="checkbox" class="custom-control-input" name="customCheck" id="detailed">
                            <label class="custom-control-label" for="detailed">Detailed Report</label>
                        </div>
                    </div>              
                  </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:40%;" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>
<script>
    $("#CustodianCode").autocomplete({

        source: function (request, response) {
            $('#CustodianName').val('');
            $('#CustodianId').val(0);
            var data = {};
            data.EmpCode = $("#CustodianCode").val();
            data.Name = $("#CustodianCode").val();
            $.ajax({
                url: '../Master/EmpAutoComplete',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.EmpCode,
                            label1: item.Name,
                            EmpCode: item.EmpCode,
                            Name: item.Name,
                            EmpId: item.EmpId,
                            headers: ["Code", "Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustodianCode').val(ui.item.EmpCode);
            $('#CustodianName').val(ui.item.Name);
            $('#CustodianId').val(ui.item.EmpId);
            $('#btnsubmit').focus();

        },

    });
    function ClearName() {
        if ($('#CustodianCode').val() == '') {
            $('#CustodianName').val('');
        }
    }
</script>