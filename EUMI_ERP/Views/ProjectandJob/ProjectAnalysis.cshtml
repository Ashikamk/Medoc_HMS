
@{
    ViewBag.Title = "ProjectAnalysis";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>


<style>
    .form-control {
        font-weight: bold;
    }
</style>

<script>

    function popuprefresh() {
        $('#popupdiv').hide();
        ProfitAnalysis(0);
        $('#btnall').prop('checked', true);
    }


    function ProfitAnalysis(flg)
    {
        $('#Loading').show();
        if ($('#Customer').val() == '') {
            $('#CustomerId').val(0);
            $('#CustomerName').val('');
        }
        if ($('#JobCode').val() == '') {
            $('#JobCodeId').val(0);
            $('#JobDescription').val('')
        }
        if ($('#JobGroup').val() == '') {
            $('#JobGroupId').val(0);
            $('#JobGroupDescription').val('')
        }

        
        var data = {};
        data.FromDate = $('#dpDateFrom').val();
        data.ToDate = $('#dpDateTo').val();
        data.JobCodeId = $('#JobCodeId').val();
        data.JobGroup = $('#JobGroup').val();
        data.CustId = $('#CustomerId').val();
        data.Flag = flg;

        $.ajax({
            type: "POST",
            url: "../Projectandjob/ProjectAnalysis",
            data: data,
            success: function (result) {

                disable_datatable('Tblreport', 'buttonPlace');
                var PrevAmout = 0;
                var total = 0;
                var bal = 0;
                var ResponseEntity = "<thead><tr><th>Sl#</th><th>Job Code</th><th>Job Description</th><th>Customer</th><th style=text-align:right>Est.Amount</th><th>LPO#</th><th>Salesman</th><th>Status</th><th>Inv.#</th><th style=text-align:right>Income</th><th style=text-align:right>Cost</th><th style=text-align:right>Profit</th><th style=text-align:right>Profit%</th></tr></thead><tbody>";
                for (var i = 0; i < result.length; i++) {
                    var slno = parseInt(i + 1);

                    if (result[i].JobDescription == 'Total') {
                        ResponseEntity += '<tr style=background-color:#cfd8dc;font-weight:bold><td>' + slno + '</td><td>' + result[i].JobCode + '</td><td>' + result[i].JobDescription + '</td><td>' + result[i].Customer + '</td><td style=text-align:right></td><td>' + result[i].LPO + '</td><td>' + result[i].Salesman + '</td><td>' + result[i].Status + '</td><td>' + result[i].InvNo + '</td><td style=text-align:right>' + parseFloat(result[i].Income || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Cost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Profit || 0).toFixed(Decimal) + '</td><td style=text-align:right></td></tr>';
                    }
                    else {
                        ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].JobCode + '</td><td>' + result[i].JobDescription + '</td><td>' + result[i].Customer + '</td><td style=text-align:right>' + parseFloat(result[i].EstAmount || 0).toFixed(Decimal) + '</td><td>' + result[i].LPO + '</td><td>' + result[i].Salesman + '</td><td>' + result[i].Status + '</td><td>' + result[i].InvNo + '</td><td style=text-align:right>' + parseFloat(result[i].Income || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Cost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Profit || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].ProfitPercentage || 0).toFixed(Decimal) + ' %</td></tr>';
                    }
                }
                $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th> </th><th>Job Code</th><th>Job Description</th><th>Customer</th><th> </th><th>LPO#</th><th>Salesman</th><th>Status</th><th>Inv.#</th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
                $('#Tblreportprint').html(ResponseEntity + '</tbody>');
                var title = "Project Analysis - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
                datatableWithsearch('Tblreport', true, title, 'buttonPlace');
                $('#header').text(title);

                
                $('#Loading').hide();
                $('#divall').show();
                $('#divprofitable').show();
                $('#divUnProfitable').show();
                $('#divInvoiced').show();
                $('#divUnInvoiced').show();
                $('#divreport').show();
                $('#popupdiv').hide();
            }
        });
    }


    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Status') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Inv.#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'LPO') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Salesman') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:150px" />');
            }

        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) {
                //console.log("download table need title and button container");
            }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }



    function checkcustempty() {
        $('#JobCodeId').val(0);
    }
 
    $(document).ready(function () {
        $('#JobCode').focus();
        
       $('#dpDateFrom').val(FinanceStartDate)
        $('#dpDateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $('#dpDateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear()+10, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });
       
    });

</script>


<div class="myData" data-x="M297" />
<div id="Main">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                
                                <td  id="divall" style="display:none">
                                    <div class="d-inline-block custom-control custom-radio ml-1 mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btnall" value="All" checked onchange="ProfitAnalysis(0);">
                                        <label class="custom-control-label" for="btnall">All </label>
                                    </div>
                                </td>
                                <td id="divprofitable"  style="display:none">
                                    <div  class="d-inline-block custom-control custom-radio ml-1 mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btnprofitable" onchange="ProfitAnalysis(1);">
                                        <label class="custom-control-label" for="btnprofitable">Profitable Only </label>
                                    </div>
                                </td>
                                <td id="divUnProfitable"  style="display:none">
                                    <div class="d-inline-block custom-control custom-radio ml-1 mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btnUnProfitable" onchange="ProfitAnalysis(2);">
                                        <label class="custom-control-label" for="btnUnProfitable">UnProfitable Only </label>
                                    </div>
                                </td>
                                <td id="divInvoiced"  style="display:none">
                                    <div class="d-inline-block custom-control custom-radio ml-1 mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btnInvoiced" onchange="ProfitAnalysis(3);">
                                        <label class="custom-control-label" for="btnInvoiced">Invoiced Only </label>
                                    </div>
                                </td>
                                <td id="divUnInvoiced"  style="display:none">
                                    <div class="d-inline-block custom-control custom-radio ml-1 mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btnUnInvoiced" onchange="ProfitAnalysis(4);">
                                        <label class="custom-control-label" for="btnUnInvoiced">UnInvoiced Only </label>
                                    </div>
                                </td>

                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(),$('#JobCode').focus(),$('#btnall').prop('checked',true)" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <hr />
                                <div id="divreport" style="display:none; overflow:auto">
                                    <table id="Tblreport" class="table table-striped table-bordered dataTable" style="margin: 0 auto 0 0;"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                                <br /><br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg " role="document" style="top:5%">
        <div class="modal-content" style="width:680px">
            <div class="modal-header bg-primary white">
                <h2 class="modal-title" id="myheader">Project Analysis</h2>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-3">
                            <label style="font-weight:bold;">Start Date</label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" id="dpDateFrom" class="form-control" autocomplete="off">
                        </div>


                        <div class="col-md-3" style="text-align:center">
                            <label style="font-weight:bold">End Date</label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" id="dpDateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>

                    <div class="row" style="margin-top:2%">
                        <div class="col-md-3">
                            <label style="font-weight:bold">Job Code</label>
                        </div>
                        <div class="col-md-9">
                            <table width="100%">
                                <tr>
                                    <td width="31%">
                                        <input type="text" id="JobCode" onkeyup="$('#JobDescription').val('')" class="form-control"  style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="JobCodeId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="JobDescription" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="row" style="margin-top:2%">
                        <div class="col-md-3">
                            <label style="font-weight:bold">Job Group</label>
                        </div>
                        <div class="col-md-9">
                            <table width="100%">
                                <tr>
                                    <td width="31%">
                                        <input type="text" id="JobGroup" class="form-control" onkeyup="$('#JobGroupDescription').val('')"  style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="JobGroupId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="JobGroupDescription" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="row" style="margin-top:2%">
                        <div class="col-md-3">
                            <label style="font-weight:bold">Customer</label>
                        </div>
                        <div class="col-md-9">
                            <table width="100%">
                                <tr>
                                    <td width="31%">
                                        <input type="text" id="Customer" class="form-control" onkeyup="$('#CustomerName').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="CustomerId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="CustomerName" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    
                </div>
                <hr />
                <div class="text-center">
                    <button type="button" style="width:100px" onclick="ProfitAnalysis(0)" id="btnGo" class="btn btn-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>


<script>
    $("#JobCode").autocomplete({
        source: function (request, response) {
            var data = {};
            data.JobCode = $("#JobCode").val();
            $.ajax({
                url: '../Master/JobCodeSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.JobCode,
                            label1: item.Description,
                            JobCode: item.JobCode,
                            Description: item.Description,
                            JobcodeId: item.ProjectJobId,
                            headers: ["Job Code", "Job Description"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#JobCodeId').val(ui.item.JobcodeId);
            $('#JobCode').val(ui.item.JobCode);
            $('#JobDescription').val(ui.item.Description);
            $('#JobGroup').focus();
        },

    });

    $("#JobGroup").autocomplete({
        source: function (request, response) {
            var data = {};
            data.JobCode = $("#JobGroup").val();
            $.ajax({
                url: '../Master/JobCodeSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.JobCode,
                            label1: item.Description,
                            JobCode: item.JobCode,
                            Description: item.Description,
                            JobcodeId: item.ProjectJobId,
                            headers: ["Job Group", "Description"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#JobGroupId').val(ui.item.JobcodeId);
            $('#JobGroup').val(ui.item.JobCode);
            $('#JobGroupDescription').val(ui.item.Description);
            $('#Customer').focus();
        },

    });
    $("#Customer").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#Customer").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustAccount: item.CustAccount,
                            CustName: item.CustName,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustomerId').val(ui.item.CustId)
            $('#Customer').val(ui.item.CustAccount)
            $('#CustomerName').val(ui.item.CustName)
            $('#btnGo').focus();
        },

    });
</script>

