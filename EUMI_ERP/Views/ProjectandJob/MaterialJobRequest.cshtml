<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <div class="row">
                       
                            <div class="col-md-6">
                                <h4 class="card-title mb-0" style="float:left">Material/Job Request</h4>
                            </div>
                            <div class="col-md-6">
                                <h4 class="mb-0" style="float:right;color:red;font-weight:bold"><span id="TotalAmountLabel">0.00</span></h4>
                            </div>
                       
                    </div>
                    

                </div>
                <div class="card-body">
                    <div class="card-content collapse show">
                        <div class="card-body">
                            <form action="#">
                                <div class="form-body">
                                    <hr class="m-0" />
                                    <div class="row" style="background-color:#E0F3F4;">

                                        <div class="col-md-12">

                                            <div class="form-group px-2">

                                                <div class="row">

                                                    <div class="col-lg-12">
                                                        <div class="row  mt-2">
                                                            <label class="col-md-1">MR#<span class="danger">*</span></label>
                                                            @*============Default Entry No Div====================*@
                                                            <div class="col-md-2 input-group mb-0" id="MRDiv">
                                                                <input type="text" class="form-control" id="MRNo" disabled>
                                                                <div class="input-group-append">
                                                                    <button type="button" id="btnlist" onclick="CopyMR()" class="btn btnde btn-outline-primary"><i class="ft-search"></i></button>
                                                                </div>
                                                            </div>
                                                            @*===================================================*@

                                                            @*============Copy Entry No Div======================*@
                                                            <div id="CopyMRDiv" class="col-md-2 input-group mb-0" style="display:none">
                                                                <div class="input-group-prepend" id="prependdiv">
                                                                    <span class="input-group-btn" title="Previous">
                                                                        <button type="button" id="btnprvs" onclick="GetPrevousornext(-1)" class="btn btn-outline-primary" style="height:100%"><i class="ft-chevron-left"></i></button>
                                                                    </span>
                                                                </div>
                                                                <input type="text" class="form-control" id="CopyMRNo" onkeypress="isNumberInt(event,this)" placeholder="Search Material Request">
                                                                <div class="input-group-append" id="appenddiv">
                                                                    <span class="input-group-btn" title="Next">
                                                                        <button type="button" id="btnnxt" onclick="GetPrevousornext(1)" class="btn btn-outline-primary" style="height:100%"> <i class="ft-chevron-right"></i></button>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            @*===================================================*@

                                                            <label class="col-md-1 text-md-right">MR Date<span class="danger">*</span></label>
                                                            <div class="col-md-2">
                                                                <input type="text" id="MRDate" class="form-control editds">
                                                            </div>

                                                            <label class="col-md-1 text-md-right">Requested By</label>

                                                            <div class="col-md-2">
                                                                <input class="form-control editds" id="RequestedBy" />
                                                                <input type="hidden" id="RequestedById" value="0" />
                                                            </div>
                                                            <label class="col-md-1 text-md-right">Designation</label>
                                                            <div class="col-md-2 input-group mb-0">
                                                                <input type="text" class="form-control editds" id="Designation" />
                                                                <button type="button" class="btn btn-outline-primary butndis input-group-append" onclick="DesgPopup()"><i class="fa fa-plus"></i></button>
                                                                <input type="hidden" id="DesignationId" value="0" />
                                                            </div>

                                                            
                                                        </div>

                                                        <div class="row mt-1">


                                                            <label class="col-md-1 text-md-left">Attn.</label>
                                                            <div class="col-md-2">
                                                                <input type="text" class="form-control editds" id="Attn" />
                                                            </div>
                                                            <label class="col-md-1 text-md-right">Subject</label>
                                                            <div class="col-md-2">
                                                                <input type="text" class="form-control editds" id="Subject" />
                                                            </div>
                                                            
                                                            <label class="col-md-1 text-md-right">Office File#</label>
                                                            <div class="col-md-2">
                                                                <input type="text" class="form-control editds" id="OfficeFileNo" />
                                                            </div>
                                                            <label class="col-md-1 text-md-right">Urgency (if Any)</label>
                                                            <div class="col-md-2">
                                                                <input type="text" class="form-control editds" id="Urgency">
                                                            </div>
                                                        </div>
                                                        <div class="row mt-1">
                                                            <label class="col-md-1">Job Code<span class="danger">*</span></label>

                                                            <div class="col-md-2">
                                                                <input type="text" class="form-control editds" id="JobCode">
                                                                <input type="hidden" id="JobId" value="0">
                                                            </div>

                                                            <div class="col-md-3">
                                                                <input type="text" class="form-control dedisa" id="JobDesc" disabled>
                                                            </div>

                                                            
                                                            <label class="col-md-1 text-md-right">Purpose</label>
                                                            <div class="col-md-5">
                                                                <input type="text" class="form-control editds" id="Purpose">
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                    <hr class="m-0" />
                                    <div class="px-2">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="row mt-1 mb-0">

                                                    <div class="col-md-3">
                                                        <label>Product<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Unit<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>BOQ</label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Issued</label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Balance</label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Quantity<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Price</label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Amount</label>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>BOQRes</label>
                                                    </div>
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-3">
                                                        <div class="input-group mb-0">

                                                            <input type="text" id="product_0" class="form-control editds">
                                                            <button class="btn btn-outline-primary input-group-append butndis" id="addproductbtn" type="button" onclick="window.open('../Master/ItemMaster')">+</button>
                                                        </div>
                                                        <input type="hidden" id="productId_0" class="form-control" />
                                                        <input type="hidden" id="ProductLength" class="form-control" />
                                                        <input type="hidden" id="productdesc_0" class="form-control" />
                                                    </div>


                                                    <div class="col-md-1">
                                                        <select id="unit_0" class="form-control editds"></select>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="boq_0" class="form-control dedisa" disabled/>
                                                        <input type="hidden" id="boqno_0" value="0" />
                                                        <input type="hidden" id="boqsubid_0" value="0" />
                                                        <input type="hidden" id="BOQAmt_0" value="0" />
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="issued_0" class="form-control dedisa" disabled/>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="balance_0" class="form-control dedisa" disabled/>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="quantity_0" class="form-control editds" onkeyup="CalcAmount(0)" onkeypress="isNumberInt(event, this)">
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="price_0" class="form-control editds" onkeyup="CalcAmount(0)" onkeypress="isNumber(event,this)">
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="amount_0" class="form-control dedisa" disabled/>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <input type="text" id="resource_0" class="form-control dedisa" disabled />
                                                        <input type="hidden" id="resourceid_0" value="0" />
                                                    </div>
                                                    <div class="col-md-1">
                                                        <button type="button" id="btnadd" onclick="ProductAdd()" class="btn btn-outline-primary butndis" style="width:100%">&nbsp;&nbsp;+Add&nbsp;&nbsp;</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="px-2">
                                    <div id="customView" class="jsgrid" style="position: relative; height: 300px; width: 100%;overflow-x: auto;overflow-y: hidden; ">
                                        <div class="jsgrid-grid-header jsgrid-header-scrollbar" style="width:100%;">
                                            <table class="jsgrid-table">
                                                <tr class="jsgrid-header-row">
                                                    <th class="jsgrid-header-cell jsgrid-control-field jsgrid-align-center" style="width:4%"><i class="icon-pencil"></i>&nbsp;<i class="icon-trash"></i></th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:4%">No</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:12%">Code</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:18%">Description</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:7%">Unit</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">BOQ</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">Issued</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">Balance</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">Quantity</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">Price</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">Amount</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:8%">BOQRes</th>
                                                </tr>

                                            </table>
                                        </div>
                                        <div id="proddiv" class="" style="position: relative;  overflow-x: auto;overflow-y: scroll; height: 246px;width: 100%;">
                                            <table class="jsgrid-table" id="tbl_materialrequest"></table>
                                        </div>
                                    </div>
                                </div>
                                <div class="p-2">
                                    <table style="width:100%" border="0">
                                        <tr>
                                            <td valign="top" id="Cell1" width="20%">
                                                <div class="text-left">
                                                    <button type="button" id="btnboq" onclick="BOQDetails()" class="btn butndis btn-info btn-min-width mr-1 mb-1">Show BOQ Details <i class="fa fa-list-ul"></i></button>
                                                    <button type="button" id="btnissued" onclick="IssuedDetails(0)" class="btn butndis btn-info btn-min-width mr-1 mb-1">Request Status <i class="fa fa-list-ul"></i></button>
                                                    
                                                    <span id="CopyStatus" class=""></span>
                                                </div>
                                            </td>
                                            <td valign="top" id="Cell2" style="display:none">
                                                <table width="100%" border="1">
                                                    <tr class="text-center">
                                                        
                                                        <td><label style="font-weight:bold">Total Amount</label></td>
                                                        <td><label style="font-weight:bold">Estimated Amount</label></td>
                                                        <td><label style="font-weight:bold">BOQ</label></td>
                                                        <td><label style="font-weight:bold">User Right</label></td>
                                                        <td><label style="font-weight:bold">BOQ Flag</label></td>
                                                        <td><label style="font-weight:bold">EST Flag</label></td>

                                                    </tr>
                                                    <tr class="text-center">
                                                       
                                                        <td><input type="text" class="form-control dedisa text-center" id="TotalAmount" style="font-weight:bold" disabled /></td>
                                                        <td><input type="text" class="form-control dedisa text-center" id="EstAmount" style="font-weight:bold" disabled value="0" /></td>
                                                        <td><input type="text" class="form-control dedisa text-center" id="BOQ" style="font-weight:bold" disabled /></td>
                                                        <td><input type="text" class="form-control dedisa text-center" id="URight" style="font-weight:bold" disabled /></td>
                                                        <td><input type="text" class="form-control dedisa text-center" id="BOQConfirmFlag" style="font-weight:bold" disabled value="NO" /></td>
                                                        <td><input type="text" class="form-control dedisa text-center" id="EstConfirmFlag" style="font-weight:bold" disabled value="NO" /></td>
                                                    </tr>
                                                </table>
                                            </td>
                                            <td valign="top" id="Cell3" width="34%">
                                                <div class="text-right">
                                                    <button type="button" style="width:100px;" id="btnsubmit" onclick="SaveMR()" class="btn btnde btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                                    <button type="button" style="width:100px;" id="btnview" onclick="ViewMRDefault()" class="btn btnde btn-primary btn-min-width mr-1 mb-1">View <i class="ft-eye"></i></button>
                                                    <button type="button" style="width:100px;" id="btnnew"    onclick="NewMR()"  class="btn btnde btn-primary btn-min-width mr-1 mb-1">New <i class="ft-refresh-cw position-right"></i></button>
                                                    <button type="button" style="width:100px;display:none;" id="btnprint"   onclick="PrintMR(1)"  class="btn btnhide btn-primary btn-min-width mr-1 mb-1">Print <i class="ft-printer"></i></button>
                                                    <button type="button" style="width:100px;display:none;" id="btnedit" onclick="EditMR()" class="btn btnhide btn-secondary btn-min-width mr-1 mb-1">Edit <i class="fa ft-edit"></i></button>
                                                    <button type="button" style="width:100px;display:none;" id="btndelete"  onclick="DeleteMR()" class="btn btnhide btn-danger btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                                    <button type="button" style="width:100px;display:none;" id="btnupdate"  onclick="UpdateMR()" class="btn btnhide btn-warning btn-min-width mr-1 mb-1 white">Update <i class="fa fa-check-square-o"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                    </table>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="MRconfirm" class="overlay">
    <div class="modal fade text-left show" id="keyboard" tabindex="-1" role="dialog" aria-labelledby="myModalLabel3" style="display: block; padding-right: 17px; top:20%">
        <div class="modal-dialog" role="document">
            <div class="modal-content">

                <div class="modal-body">
                    <div class="swal-icon swal-icon--warning">
                        <span class="swal-icon--warning__body">
                            <span class="swal-icon--warning__dot"></span>
                        </span>
                    </div>
                    <div id="MRconfirmmessage" class="swal-title"></div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" id="MRConfirmflag" />
                    <input type="hidden" id="MRConfirmRowId" />
                    <button type="button" onclick="MRConfirmboxResult('false', $('#MRConfirmflag').val(), $('#MRConfirmRowId').val())" id="MRconfirmCancel" class="btn grey btn-outline-secondary btn-sizebig" data-dismiss="modal">Cancel</button>
                    <button type="button" onclick="MRConfirmboxResult('true', $('#MRConfirmflag').val(), $('#MRConfirmRowId').val())" id="MRconfirmOk" class="btn btn-primary btn-sizebig" autofocus>Ok</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="alertpopup" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none">
    <div class="modal-dialog" role="document" style="top:20%">
        <div class="modal-content" style="width:600px">
            <form id="alertdiv" style="display:none;">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12" style="overflow:scroll;height:200px;width:100%;overflow:auto;">
                            <table class="table table-responsive-md-md text-center" id="tblAlert"></table>
                        </div>
                    </div>
                    <div class="text-right">
                        <input type="button" class="btn btn-outline-primary" value="Ok" id="btnokalert" onclick="alertpopuprefresh()">
                    </div>

                </div>
            </form>
            <form id="alertdiv1" style="display:none">

                <div class="modal-body">
                    <div class="row">
                        <div class="placeholder"></div>
                        <div class="col-md-12" style="overflow:scroll;height:200px;width:100%;overflow:auto;">
                            <div class="swal2-icon swal2-success animate" style="display: block;"><span class="line tip animate-success-tip"></span> <span class="line long animate-success-long"></span><div class="placeholder"></div> <div class="fix"></div></div>
                            <br />
                            <h2 id="savealert" class="text-center"></h2>
                            <hr />
                        </div>
                    </div>
                    <div class="text-right">

                        <button style="" type="button" id="btnok" class="btn btn-outline-primary btn-min-width mr-1 mb-1 btn-sizebig">Print <i class="ft-printer"></i></button>
                        <button style="" type="button" id="btncnclalrt" class="btn btn-outline-primary btn-min-width mr-1 mb-1">Cancel <i class="ft-x-circle"></i></button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<div style="display:none">
    <input type="text" id="MRMainId" value="0" />
    <input type="text" id="MRSubId" value="0" />
    <input type="text" id="GridLength" value="0" />
    <input type="text" id="RequestFlag" value="0" />
    <input type="text" id="ApprovedBy" value="0" />
    <input type="text" id="ApprovedDate" />
    <input type="text" id="PEFlag" value="0" />
    <input type="text" id="ApprovedByUser" />
    <input type="text" id="MaxMRNo" value="0" />
    
</div>

<div id="OTPDiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="background:rgba(0,0,0,0.5); display: block;margin-top:0%;display: none;">
    <div class="modal-dialog modal-dialog-centered" role="document" style="top:-25%">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" onclick="$('#OTPDiv').hide()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="col-md-12">
                    <div class="row" id="panel" style="margin-top:2%;">

                        <label class="col-md-5" style="text-align:left" id="reason">Enter the OTP:</label>
                        <div class="col-md-7">
                            <input type="text" id="otp" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" id="panel" style="margin-top:2%;">

                        <label class="col-md-5" style="text-align:left" id="reason">Remarks:</label>
                        <div class="col-md-7">
                            <input type="text" id="otpremarks" class="form-control" autocomplete="off">
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" style="width:100px;" id="btndivdelete" onclick="$('#OTPDiv').hide()" class="btn btn-outline-secondary">Cancel</button>
                <button type="button" style="width:100px" id="btncnclsave" onclick="CheckEditInvoce(0)" class="btn btn-outline-warning">Continue</button>
            </div>


        </div>
    </div>
</div>

<div id="productpdiv" style="display:none;border-radius: 25px;">
    <div id="toast-containerinfo" class="toast-container toast-top-half-width" style="position:absolute; top:0; right:0%;opacity:100">
        <div class="toast-primary" style="height:180px;margin-top:70px;font-weight:500;text-align:center;opacity:100;width:100%" id="infomessage">
            <button type="button" class="close" onclick="ProductPopuprefresh()" data-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">×</span>
            </button>
            <section id="productdiv" style="display:none;height:25%;">
                <div class="row">
                    <div class="col-sm-12">
                        <div class="card-body">
                            <input type="hidden" id="LPCost" value="0" />
                            <input type="hidden" id="AvgCost" value="0" />
                            <input type="hidden" id="Sumtotqty" value="0" />
                            <input type="hidden" id="LastSellingPrice" value="0" />
                            <div class="card-block" style="height:115px;width:100%;">
                                <table class="table table-responsive-md-md text-center" id="tblproductdetails"></table>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

    </div>
</div>

<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Designation</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="DesignationDiv">
                <div class="modal-body">

                    <fieldset class="">
                        <label for="sbcatname">Code<span class="danger">*</span></label>
                        <input type="text" id="descode" class="form-control editds" autocomplete="off" onkeyup="changetoupper(this.id)">
                    </fieldset>
                    <br>
                    <fieldset class="">
                        <label for="sbcatdesc">Description<span class="danger">*</span></label>
                        <input type="text" id="desdescription" class="form-control editds" autocomplete="off" onkeyup="changetoupper(this.id)">
                    </fieldset>
                </div>
                <div class="modal-footer">
                    <input type="reset" class="btn btn-outline-secondary" onclick="popuprefresh()" data-dismiss="modal" value="Close">
                    <input type="button" class="btn btn-primary" value="Save" id="btntermssave" onclick="SaveDesignation()">
                </div>
            </form>
        </div>
