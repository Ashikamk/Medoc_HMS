<script>
    $(function () {
        $('#MRDate,#ViewFromDate,#ViewToDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    });
    $("#btnadd").focus(function (e) {
        $("#btnadd").removeClass("btn btn-outline-primary");
        $("#btnadd").addClass("btn btn-primary");
    });

    $("#btnadd").focusout(function (e) {
        $("#btnadd").removeClass("btn btn-outline-primary");
        $("#btnadd").addClass("btn btn-outline-primary");
    });
    $("#btncnclsave").focus(function (e) {
        $("#btncnclsave").removeClass("btn btn-outline-warning");
        $("#btncnclsave").addClass("btn btn-warning white");
    });

    $("#btncnclsave").focusout(function (e) {
        $("#btncnclsave").removeClass("btn btn-warning white");
        $("#btncnclsave").addClass("btn btn-outline-warning");
    });

    $("#JobCode").autocomplete({

        delay: 0,
        minLength: 0,
        source: function (request, response) {

            $('#JobId,#EstAmount').val(0);
            $('#JobDesc,#BOQ').val('');

            var data = {};
            data.JobCode = $("#JobCode").val();

            $.ajax({
                url: '../SalesInvoice/JobSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.JobCode,
                            label1: item.Description,
                            ProjectJobId: item.ProjectJobId,
                            Description: item.Description,
                            BOQ: item.BOQ,
                            EstAmount: item.EstAmount,
                            headers: ["Job Code", "Description"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $('#JobId').val(ui.item.ProjectJobId);
            $('#JobDesc').val(ui.item.Description);
            $('#BOQ').val(ui.item.BOQ);
            $('#EstAmount').val(parseFloat(ui.item.EstAmount||0).toFixed(Decimal));
            $('#product_0').focus();
        },

    });
    $("#Designation").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#DesignationId').val(0);
            var data = {};
            data.DesignationDescription = $("#Designation").val();
            $.ajax({
                url: '../SalarySettings/DesignationNameSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'THREE',
                            label: item.DesignationDescription,
                            label1: item.DesignationCode,
                            label2: item.DesignationId,
                            headers: ["Designation Name", " Code"]
                        })
                    }));
                }

            })
        },
        autoFocus: true,
        select: function (event, ui) {           
            $('#DesignationId').val(ui.item.label2);            
        },

    });

    $("#RequestedBy").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#RequestedById').val(0);
            var data1 = {};
            data1.UserName = $("#RequestedBy").val();

            $.ajax({
                url: '../Master/UserSearchInUserMenuSettings',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {

                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            UserRole: item.UserRole,
                            MenuCode: item.MenuCode,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#RequestedById').val(ui.item.UserId);         
        },
    });

    $("#product_0").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            ClearProductRow(1);
            var data = {};
            data.ItemCode = $("#product_0").val();
            data.DeptId = ERPDeptId;
            data.UserId = ERPUserId;
            data.JobNo = $('#JobId').val();
            if ($('#JobId').val() != 0) {
                $.ajax({
                    url: '../MaterialRequest/MRProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {

                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'GR3',
                                label: item.ItemCode,
                                label1: item.ItemDescription,
                                label2: (item.Cost).toFixed(Decimal),
                                label4: '0',
                                label5: '0',
                                ItemId: item.ItemId,
                                ItemCode: item.ItemCode,
                                Description: item.ItemDescription,
                                Unit: item.UnitId,
                                Cost: (item.Cost).toFixed(Decimal),
                                Rate: (item.Price).toFixed(Decimal),
                                ResourceId: item.ResourceId,
                                ResourceCode: item.ResourceCode,
                                BOQNo: item.BOQNo,
                                BOQSubId: item.BOQSubId,
                                BOQQty: item.BOQQty,
                                IssuedQty: item.IssuedQty,
                                BalanceQty: item.BalanceQty,
                                BOQAmt:item.BOQAmt,

                                headers: ["Item Code", "Description", "Average Cost"]
                            })
                        }));
                    }

                })
            }
            else {
                warningshow('Please Select Job', 'JobCode');
                $("#product_0").val('');
                return false;
            }

        },
        autoFocus: true,
        select: function (event, ui) {
            $("#product_0").val(ui.item.ItemCode);
            $('#productId_0').val(ui.item.ItemId);
            $('#ProductLength').val((ui.item.ItemCode).length);
            $('#productdesc_0').val(ui.item.Description);
            $('#unit_0').val(ui.item.Unit);
            $('#price_0').val(ui.item.Cost);

            $("#boq_0").val(ui.item.BOQQty);
            $("#issued_0").val(ui.item.IssuedQty);
            $("#balance_0").val(ui.item.BalanceQty);

            $("#boqno_0").val(ui.item.BOQNo);
            $("#boqsubid_0").val(ui.item.BOQSubId);

            $("#resource_0").val(ui.item.ResourceCode);
            $("#resourceid_0").val(ui.item.ResourceId);
            $("#BOQAmt_0").val(ui.item.BOQAmt);

            $('#quantity_0').val(1);
            $('#quantity_0').focus();
            $('#quantity_0').select();
            CalcAmount(0);

            var data = {};
            data.ProductId = ui.item.ItemId;
            data.CustId = 0;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: '../SalesInvoice/CustomerProductDetailsSearch',
                data: data,
                success: function (result) {
                    ProductPopuprefresh();
                    CustPrdctLoad(result.oList);
                }
            });

        },
    });

    $("#CopyMRNo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.Variable1 = $("#CopyMRNo").val();
            data.DeptId = ERPDeptId;
            data.UserId = ERPUserId;

            $.ajax({
                url: '../MaterialRequest/MaterialRequestGets',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+3',
                            label: item.MRNo,
                            label1: item.MRDate,
                            label2: item.JobCode,
                            MRNo: item.MRNo,
                            headers: ["MR#", "Date", "JobCode"]

                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            var data = {};
            data.MRNo = ui.item.MRNo;
            data.DeptId = ERPDeptId;
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../MaterialRequest/MaterialRequestGetandGets",
                data: data,
                success: function (result) {
                    formrefresh(1);
                    MRGets(result.oList);                    
                }
            });
        },

    });
</script>