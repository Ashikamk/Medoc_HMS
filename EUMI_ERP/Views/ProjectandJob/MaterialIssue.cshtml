<div class="myData" data-x="M288" />

<div id="Entry" style="margin-top:-15px">

    <section class="grid-row-label">
        <div class="row">
            <div class="col-md-12">
                <div class="card">

                    <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                        <h3 class="card-title mb-0" style="float:left;font-weight:bold">MATERIAL ISSUE</h3>
                        <h2 class="text-right" id="FCGT" style="float:right;font-weight:bold;opacity:0">FCGT </h2>
                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body" style="margin-top:-60px">

                            <form action="#">
                                <div class="form-body">
                                    <hr style="margin-top:50px" />

                                    <div class="row" style="background-color:#F0F6F6;margin-left:3px;width:100%;height:230px;margin-top:-20px;">

                                        <div class="col-md-12" style="margin-top:-5px;">
                                            <br />
                                            <div class="form-group">

                                                <div class="row">
                                                    <div class="col-md-1">
                                                        <label style="margin-top:5px">MI#<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <input type="text" id="MINo" class="form-control" autocomplete="off" disabled>
                                                    </div>

                                                    <div class="col-md-1">
                                                        <label style="margin-top:5px">Issue Date<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <input type="text" id="IssueDate" class="form-control editds" autocomplete="off">
                                                    </div>

                                                    <div class="col-md-1">
                                                        <label>Job Code<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <input type="text" id="JobCode" onkeyup="checkjobcodeempty()" class="form-control ui-autocomplete-input editds" autocomplete="off">
                                                        <input type="hidden" id="JobCodeId" class="form-control" />
                                                        <input type="hidden" id="JobCodeLength" class="form-control" />
                                                    </div>
                                                    <div class="col-md-1"></div>
                                                    <div class="col-md-2">
                                                            <button type="button" style="width:100%" id="btntransfer" class="btn btn-outline-primary butndis" onclick="Transfer()">Material Request Transfer</button>
                                                    </div>
                                                </div>


                                                <div class="row">
                                                    <div class="col-md-1">
                                                        <label>Cr. A/C<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <table width="100%">
                                                            <tr>
                                                                <td width="29%">
                                                                    <input type="hidden" id="CreditAccountId" />
                                                                    <input type="text" id="CreditAccountCode" class="form-control" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px">
                                                                </td>
                                                                <td width="71%">
                                                                    <input type="text" id="CreditAccount" maxlength="4" class="form-control" name="acnt1" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white;" disabled />
                                                                </td>
                                                            </tr>

                                                        </table>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <label>Comments<span class="danger"></span></label>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <textarea id="Comments" class="form-control" style="resize:none;height:200%"></textarea>
                                                    </div>
                                                </div>

                                                <div class="row" style="margin-top:-1%">
                                                    <div class="col-md-1">
                                                        <label>Db. A/C<span class="danger">*</span></label>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <table width="100%">
                                                            <tr>
                                                                <td width="29%">
                                                                    <input type="hidden" id="DebitAccountId" />
                                                                    <input type="text" id="DebitAccountCode" class="form-control" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px">
                                                                </td>
                                                                <td width="71%">
                                                                    <input type="text" id="DebitAccount" maxlength="4" class="form-control" name="acnt2" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white;" disabled />
                                                                </td>
                                                            </tr>

                                                        </table>
                                                    </div>

                                                </div>

                                                <div class="row" style="margin-top:0.5%">
                                                    <div class="col-md-1">
                                                        <label>Remarks</label>
                                                    </div>
                                                    <div class="col-md-5">
                                                        <input type="text" id="Remarks" class="form-control editds" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <hr style="margin-top:5px" />
                                    <div class="px-2">
                                        <div class="row" style="margin-top:-10px">
                                            <div class="col-md-12">
                                                <div class="row  mt-1 mb-0" style="height:26px">

                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Product<span class="danger">*</span></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <div class="form-group">
                                                            <label>Location<span class="danger">*</span></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <label>Unit<span class="danger">*</span></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <label>Quantity<span class="danger">*</span></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <label>Rate</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <label>Stock</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <label>Total Amount</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <label>Cost Code</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="row">
                                                    <div class="col-md-3">
                                                        <div class="input-group mb-0">
                                                            <input type="text" id="Product_0" onkeyup="checkpdcttextempty()" class="form-control editds">
                                                            <button class="btn btn-outline-primary input-group-append" id="btnpdct" type="button" onclick="window.open('../Master/ItemMaster')">+</button>
                                                        </div>
                                                        <input type="hidden" id="ProductId_0" value="0" class="form-control" />
                                                        <input type="hidden" id="Description_0" />
                                                        <input type="hidden" id="ProductLength" class="form-control" />

                                                    </div>
                                                    <div class="col-md-2">
                                                        <div class="row">
                                                            <div class="col-md-11">
                                                                <select type="text" id="Location_0" class="form-control editds" onchange="autoLocationqtycheck(0)" style="position:absolute;width:100%;" name="Remarks" autocomplete="off"></select>
                                                                <input type="text" id="txtlcn" style="display:none">
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <input type="text" id="textUnit" style="display:none" />
                                                            <select id="Unit_0" onchange="getquantity()" class="form-control editds"></select>

                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <input type="text" id="Quantity_0" onkeyup="checkqty(0),totalamount(0)" name="prdaddqty" autocomplete="off" onkeypress="isNumberInt(event, this)" class="form-control editds">
                                                            <input type="text" id="txtstocktotloseqty0" value="0" style="display:none">
                                                        </div>
                                                    </div>


                                                    <div class="col-md-1">
                                                        <div class="form-group">

                                                            <input type="text" id="Rate_0" onkeyup="totalamount(0)" autocomplete="off" onkeypress="isNumber(event,this)" class="form-control editds">
                                                            <input type="hidden" id="Boqno_0" value="0" />
                                                            <input type="hidden" id="Boqsubid_0" value="0" />
                                                            <input type="hidden" id="BOQAmt_0" value="0" />
                                                            <input type="hidden" id="Boq_0" value="0" />
                                                            <input type="hidden" class="form-control dedisa text-center" id="BOQ" style="font-weight:bold" disabled />
                                                            <input type="hidden" class="form-control dedisa text-center" id="BOQConfirmFlag" style="font-weight:bold" disabled value="NO" />
                                                            <input type="hidden" class="form-control dedisa text-center" id="URight" style="font-weight:bold" disabled />
                                                            <input type="hidden" class="form-control dedisa text-center" id="EstAmount" style="font-weight:bold" disabled value="0" />
                                                            <input type="hidden" class="form-control dedisa text-center" id="EstConfirmFlag" style="font-weight:bold" disabled value="NO" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">

                                                            <input type="text" id="Stock_0" onkeyup="totalamount(0)" autocomplete="off" onkeypress="isNumber(event,this)" class="form-control editds" readonly>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <input type="text" id="TotalAmount_0" autocomplete="off" readonly class="form-control">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <input type="text" id="CostCode_0" class="form-control editds" onfocus="LoadCostCode('CostCode_0')" name="Remarks" autocomplete="off" />
                                                            <input type="hidden" id="CostCodeId_0" class="form-control editds" />
                                                        </div>
                                                    </div>

                                                    <div class="col-md-1">
                                                        <div class="form-group">
                                                            <button type="button" id="btnadd" onclick="productadd()" class="btn btn-outline-primary" style="position:absolute;width:70%;">Add</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <div id="customView" class="jsgrid" style="position: relative; height: auto;width: 100%; border:1px solid; margin-top:-10px;border-color:#e9e9e9">
                                    <div class="jsgrid-grid-header jsgrid-header-scrollbar" style="width:1800px;">
                                        <table class="jsgrid-table" id="tblboqheader">
                                            <tbody>
                                                <tr class="jsgrid-header-row">
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 30px;">Sl#</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 75px;">Product/Service</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 75px;">Description</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width: 40px;">Location</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width: 40px;">Unit</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width: 40px;">Quantity</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Rate</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Stock</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Total Amount</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width: 40px;">Cost Code</th>
                                                    <th class="jsgrid-header-cell jsgrid-control-field jsgrid-align-center" style="width: 30px;"></th>
                                                </tr>

                                            </tbody>
                                        </table>
                                    </div>


                                    <div id="proddiv" class="jsgrid dataTables_scrollBody" style="position: relative;overflow-x: auto;overflow-y:scroll; height:265px;  width:1800px;">
                                        <table class="jsgrid-table" id="tblMaterialIssue">
                                            <tbody></tbody>
                                        </table>
                                    </div>

                                </div>
                                @*<br />*@

                                <div class="row" style="margin-left:1375px;display:none">
                                    <div class="text-right">
                                        <label style="font-weight:bold;color:#00B5B8;font-size:large">Grand Total</label>
                                    </div>
                                    <div class="col-md-3">
                                        <input type="text" id="GrandTotal" autocomplete="off" readonly class="form-control" style="width:150px;border-color:white;margin-bottom:5px;margin-top:-7px;font-weight:bold;background-color:white">
                                    </div>
                                </div>

                                <div class="form-actions">
                                    <div class="text-right" style="margin-top:-10px">
                                        <button type="button" style="width:100px" id="btnsubmit" onclick="SaveMI()" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:120px" id="btnview" onclick="$('#ViewFromDate,#ViewToDate').val(CurDate), GetList()" class="btn btn-primary btn-min-width mr-1 mb-1">View <i class="ft-eye"></i></button>
                                        <button type="button" style="width:100px" id="btncopy" onclick="GetRows()" class="btn btn-primary btn-min-width mr-1 mb-1">Copy <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px;display:none" id="btnprint" onclick="PrintthisBill()" class="btn btn-primary btn-min-width mr-1 mb-1">Print <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefreshconfirm()" class="btn btn-primary btn-min-width mr-1 mb-1">New <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btnsaveedit" onclick="UpdateMI()" class="btn btn-warning white btn-min-width mr-1 mb-1">Update<i class="fa fa-check-square-o"></i></button>
                                        <button style="display:none;width:100px" type="button" id="btnedit" onclick="EditMI(0)" class="btn btn-secondary white btn-min-width mr-1 mb-1">Edit<i class="fa ft-edit"></i></button>
                                        <button style="display:none" type="button" id="btndelete" onclick="DeleteMI()" class="btn btn-danger btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                    </div>
                                </div>


                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</div>
<div id="MIconfirm" class="overlay">
    <div class="modal fade text-left show" id="keyboard" tabindex="-1" role="dialog" aria-labelledby="myModalLabel3" style="display: block; padding-right: 17px; top:20%">
        <div class="modal-dialog" role="document">
            <div class="modal-content">

                <div class="modal-body">
                    <div class="swal-icon swal-icon--warning">
                        <span class="swal-icon--warning__body">
                            <span class="swal-icon--warning__dot"></span>
                        </span>
                    </div>
                    <div id="MIconfirmmessage" class="swal-title"></div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" id="MIConfirmflag" />
                    <input type="hidden" id="MIConfirmRowId" />
                    <button type="button" onclick="MIConfirmboxResult('false', $('#MIConfirmflag').val(), $('#MIConfirmRowId').val())" id="MIconfirmCancel" class="btn grey btn-outline-secondary btn-sizebig" data-dismiss="modal">Cancel</button>
                    <button type="button" onclick="MIConfirmboxResult('true', $('#MIConfirmflag').val(), $('#MIConfirmRowId').val())" id="MIconfirmOk" class="btn btn-primary btn-sizebig" autofocus>Ok</button>
                </div>
            </div>
        </div>
    </div>
</div>
