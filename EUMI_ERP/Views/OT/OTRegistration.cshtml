                                                    <h4 class="section-title"><i class="ft-info"></i> OPERATION DETAILS</h4>
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <label class="label-control">OP Date *</label>
                                                            <input type="text" id="OpDate" class="form-control" autocomplete="off">
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="label-control">OP Time *</label>
                                                            <input type="time" id="OpTime" class="form-control">
                                                        </div>
                                                        <div class="col-md-6 mt-2">
                                                            <label class="label-control">Operation Theatre *</label>
