    <!-- =====================================================
         CUSTOM MODAL
    ===================================================== -->
    <!-- Blurred overlay -->
    <div id="OTModalOverlay" onclick="CloseOTList()"></div>

    <!-- Modal: flex column — header+filter fixed, only table scrolls -->
    <div id="OTListModal">

        <!-- HEADER -->
        <div class="ot-modal-header">
            <h4><i class="ft-list"></i> &nbsp;THEATRE REGISTRATIONS</h4>
            <button class="ot-close-btn" onclick="CloseOTList()" title="Close">&times;</button>
        </div>

        <!-- FILTER BAR -->
        <div class="ot-modal-filters">
            <!-- In the modal filter bar -->
            <div class="ot-filter-group">
                <label>Registered From <span style="color:#ff6b6b">*</span></label>
                <input type="text" id="FilterFromInsDate" class="form-control" placeholder="dd/mm/yyyy" autocomplete="off">
            </div>
            <div class="ot-filter-group">
                <label>Registered To</label>
                <input type="text" id="FilterToInsDate" class="form-control" placeholder="dd/mm/yyyy" autocomplete="off">
            </div>
            <div class="ot-filter-group">
                <label>Status</label>
                <select id="FilterStatus" class="form-control">
                    <option value="">All</option>
                    <option value="1">Scheduled</option>
                    <option value="2">In Progress</option>
                    <option value="3">Completed</option>
                    <option value="4">Cancelled</option>
                    <option value="5">Postponed</option>
                </select>
            </div>
            <button class="btn-go" onclick="LoadOTRegistrationList()">GO &rarr;</button>
        </div>

        <!-- TABLE (only this scrolls) -->
        <div class="ot-modal-table-wrap">
            <table id="tblOTList" class="table table-bordered table-striped" style="width:100%">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Op Date</th>
                        <th>Time</th>
                        <th>Patient Name</th>
                        <th>Reg No</th>
                        <th>Doctor</th>
                        <th>OT</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="ot-empty-row">
                        <td colspan="9">Enter a date range and click <strong>GO</strong> to load records</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Loading Indicator -->
    <div id="Loadingsave">
        <div><img src="/app-assets/img/Loading_1.gif"></div>
    </div>

    <!-- Dependencies -->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script type="text/javascript">
        var PRID = 0;   

        $(document).ready(function () {
            document.title = "Operation Theatre";
            SetCurrentDateTime();
            LoadDoctors();
            LoadRegNumber();
            LoadOperationTheatres();
            Defaultfocus();

            // Default status = Scheduled
            $('#Status').val('1');

            $("#OpDate").datepicker({
                dateFormat: "dd/mm/yy",
                changeMonth: true,
                changeYear: true,
                yearRange: "1900:+0",
                showAnim: "fadeIn"
            });

            $("#FilterFromInsDate, #FilterToInsDate").datepicker({
                dateFormat: "dd/mm/yy",
                changeMonth: true,
                changeYear: true
            });

            $(document).on('keydown', function (e) {
                if (e.key === 'Escape') CloseOTList();
            });
        });

        function SetCurrentDateTime() {
            var now = new Date();
            var dd = ('0' + now.getDate()).slice(-2);
            var mm = ('0' + (now.getMonth() + 1)).slice(-2);
            var ds = dd + '/' + mm + '/' + now.getFullYear();
            var ts = ('0' + now.getHours()).slice(-2) + ':' + ('0' + now.getMinutes()).slice(-2);
            $('#OpDate').val(ds);
            $('#OpTime').val(ts);
            $('#CurrentDate').val(ds);
        }

        // ==================== CACHED DROPDOWNS ====================
        function LoadDoctors() {
            var cached = sessionStorage.getItem('otDoctors');
            if (cached) {
                $('#DoctorConsultant').html(cached);
                return;
            }
            $.ajax({
                type: "POST", url: "../OT/HMS_OTDoctorGets",
                data: { DoctorId: 0, DeptId: ERPDeptId },
                success: function (r) {
                    var o = '<option value="">Select Consultant</option>';
                    if (r.oList && r.oList.length)
                        $.each(r.oList, function (i, x) { o += '<option value="' + x.DoctorId + '">' + x.DoctorName + '</option>'; });
                    $('#DoctorConsultant').html(o);
                    sessionStorage.setItem('otDoctors', o);
                }
            });
        }

        function LoadOperationTheatres() {
            var cached = sessionStorage.getItem('otTheatres');
            if (cached && cached.indexOf('<option value="') !== -1) {  // ← validate cache has real options
                $('#OperationTheatre').html(cached);
                return;
            }
            sessionStorage.removeItem('otTheatres');  // ← clear bad cache

            $.ajax({
                type: "POST", url: "../Master/RoomGetandGets", data: { RoomId: 0 },
                success: function (r) {
                    var o = '<option value="">Select OT</option>';
                    if (r && r.length)
                        $.each(r, function (i, x) {
                            o += '<option value="' + x.RoomId + '">' + x.RoomName + '</option>';
                        });
                    $('#OperationTheatre').html(o);
                    // Only cache if we actually got data
                    if (r && r.length) {
                        sessionStorage.setItem('otTheatres', o);
                    }
                }
            });
        }

        function LoadRegNumber() {
            $("#RegNo").autocomplete({
                delay: 100,              
                minLength: 0,              
                source: function (req, resp) {
                    ClearPatientData();
                    $.ajax({
                        url: '../OT/HMS_OTPorPatientSearch', type: "POST",
                        data: { PatientName: $("#RegNo").length ? $("#RegNo").val() : "", DeptId: ERPDeptId },
                        dataType: "json",
                        success: function (data) {
                            resp($.map(data, function (item) {
                                return {
                                    label: item.OPSerName + ' - ' + item.OPNumber,
                                    value: item.OPNumber,
                                    opser: item.OPSerName,
                                    PatientId: item.PatientId,
                                    DOB: item.DOB,
                                    Contact: item.Contact,
                                    OPNumber: item.OPNumber,
                                    PatientName: item.PatientName,
                                    IpNo: item.AadharNo || '',
                                    Address: cleanAddress(item.Add1),
                                    Mobile: item.Mobile || item.Contact || '',
                                    Gender: item.Gender,
                                    Flag: item.Flag
                                };
                            }));
                        }
                    });
                },
                autoFocus: true,
                create: function () {
                    var ac = $(this).data('ui-autocomplete');
                    ac._renderMenu = function (ul, items) {
                        var self = this; ul.empty();
                        ul.append($('<li class="ac-header-row"></li>').append(
                            '<span>Reg No</span><span>Patient</span><span>IP No</span><span>Address</span><span>Mobile</span>'
                        ));
                        $.each(items, function (i, item) { self._renderItemData(ul, item); });
                    };
                    ac._renderItem = function (ul, item) {
                        return $('<li>').append($('<div class="ac-data-row"></div>').append(
                            '<span>' + _esc(item.opser + ' - ' + item.OPNumber) + '</span>' +
                            '<span>' + _esc(item.PatientName) + '</span>' +
                            '<span>' + _esc(item.IpNo) + '</span>' +
                            '<span>' + _esc(item.Address) + '</span>' +
                            '<span>' + _esc(item.Mobile) + '</span>'
                        )).appendTo(ul);
                    };
                },
                select: function (e, ui) {
                    $('#Opseriesname').val(ui.item.opser);
                    $('#PatientName').val(ui.item.PatientName);
                    $('#IpNo').val(ui.item.IpNo);
                    $('#ContactNo').val(ui.item.Contact);
                    $('#AdmissionStatus').val(ui.item.IpNo && ui.item.IpNo.trim() ? "Admitted" : "Not Admitted");
                    PRID = ui.item.PatientId;
                    $('#PatientId').val(ui.item.PatientId);
                    $('#RegNo').data('dob', ui.item.DOB).data('gender', ui.item.Gender).data('flag', ui.item.Flag);
                    GetLastRevisitDetails(ui.item.PatientId);
                }
            });
        }

        function _esc(s) {
            return s == null ? '' : String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function cleanAddress(address) {

            if (!address) return '';
            address = address.replace(/\d{10}/g, '');
            address = address.replace(/#/g, ' ');
            address = address.replace(/,+/g, ' ');
            address = address.replace(/\s+/g, ' ').trim();
            return address;
        }

        function ClearPatientData() {

            $('#PatientId').val('');   

            $('#PatientName,#Age,#Gender,#ContactNo,#OpNo,#IpNo,#RevisitId,#AdmissionStatus').val('');
            $('#DoctorConsultant').val('');
        }

        function GetLastRevisitDetails(pid) {
            $.ajax({
                type: "POST", url: "../OT/HMS_OTLastRevisitGetsop",
                data: { PatientId: pid, DeptId: ERPDeptId },
                success: function (r) {
                    if (r.oList && r.oList.length) FillPatientData(r.oList[0]);
                    else FallbackFillPatientData();
                },
                error: function () { FallbackFillPatientData(); }
            });
        }

        function FallbackFillPatientData() {
            var dob = $('#RegNo').data('dob'), g = $('#RegNo').data('gender'), f = $('#RegNo').data('flag');
            if (dob) $('#Age').val(AgeCalculation(dob));
            if (g) $('#Gender').val(g);
            else if (f) $('#Gender').val(convertGender(f));
        }

        function FillPatientData(d) {
            if (d.DOB) $('#Age').val(AgeCalculation(d.DOB));
            if (d.Flag !== undefined && d.Flag !== null && d.Flag !== '')
                $('#Gender').val($.isNumeric(d.Flag) ? convertGender(d.Flag) : d.Flag);
            else if (d.Gender) $('#Gender').val(d.Gender);
            $('#OpNo').val(d.RevisitId || '');
            if (d.DoctorId) $('#DoctorConsultant').val(d.DoctorId);
            $('#RegSeries').val(d.OPSerId || '');
        }

        function convertGender(f) {
            return f == 1 ? 'Male' : f == 2 ? 'Female' : f == 3 ? 'Others' : '';
        }

        // ==================== OPTIMISED AGE CALCULATION ====================
        function AgeCalculation(dob) {
            if (!dob) return '';
            var birthDate = parseDate(dob);
            if (!birthDate) return dob;

            var today = new Date();
            var years = today.getFullYear() - birthDate.getFullYear();
            var months = today.getMonth() - birthDate.getMonth();
            var days = today.getDate() - birthDate.getDate();

            if (days < 0) {
                months--;
                days += new Date(today.getFullYear(), today.getMonth(), 0).getDate();
            }
            if (months < 0) {
                years--;
                months += 12;
            }

            if (years === 0)
                return months + ' Month' + (months > 1 ? 's' : '');
            return years + ' Year' + (years > 1 ? 's' : '');
        }

        function parseDate(dateStr) {
            // support dd/mm/yyyy and yyyy-mm-dd
            var parts;
            if (dateStr.indexOf('/') > -1) {
                parts = dateStr.split('/');
                return new Date(parts[2], parts[1] - 1, parts[0]);
            } else if (dateStr.indexOf('-') > -1) {
                parts = dateStr.split('-');
                return parts[0].length === 4 ? new Date(parts[0], parts[1] - 1, parts[2]) : new Date(parts[2], parts[1] - 1, parts[0]);
            }
            return new Date(dateStr);
        }

        function GetRows(RoomId) {
            $('#RoomId').val(RoomId);
            $.ajax({ type:"POST", url:"../Master/RoomGetandGets", data:{RoomId:RoomId}, success:function(){} });
        }
        function Defaultfocus() { $('#RegNo').focus().select(); }


        // ==================== MODAL OPEN / CLOSE ====================
        function ShowOTList() {
            var now = new Date();
            var dd = ('0' + now.getDate()).slice(-2);
            var mm = ('0' + (now.getMonth() + 1)).slice(-2);
            var today = dd + '/' + mm + '/' + now.getFullYear();

            $('#FilterFromInsDate').val(today);
            $('#FilterToInsDate').val(today);
            $('#FilterStatus').val('');

            // Destroy any existing DataTable before re-initialising
            if ($.fn.DataTable.isDataTable('#tblOTList')) {
                $('#tblOTList').DataTable().destroy();
            }
            $('#tblOTList tbody').html(
                "<tr class='ot-empty-row'>" +
                "<td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>" +
                "<td>Loading...</td>" +
                "</tr>"
            );

            $('body').addClass('ot-modal-open');
            $('#OTModalOverlay').show();
            $('#OTListModal').css('display', 'flex');

            // Immediately load list (with server-side DataTables)
            LoadOTRegistrationList();
        }

        // ==================== LIST – SERVER‑SIDE DATATABLES ====================
        function getStatusBadge(s) {
            var key = parseInt(s);
            var m = {
                1: ['scheduled', 'Scheduled'],
                2: ['badge-progress', 'In Progress'],
                3: ['completed', 'Completed'],
                4: ['cancelled', 'Cancelled'],
                5: ['postponed', 'Postponed']
            };
            return m[key] ? "<span class='status-badge " + m[key][0] + "'>" + m[key][1] + "</span>"
                : "<span>" + (s || '') + "</span>";
        }

        function LoadOTRegistrationList() {
            if (!$('#FilterFromInsDate').val()) {
                warningshow("Please enter From Registration Date");
                $('#FilterFromInsDate').focus();
                return;
            }

            // Destroy existing DataTable if any
            if ($.fn.DataTable.isDataTable('#tblOTList')) {
                $('#tblOTList').DataTable().destroy();
            }

            // Initialise with server-side processing
            $('#tblOTList').DataTable({
                processing: true,
                serverSide: false,
                ajax: {
                    url: '../OT/HMS_OTRegistrationList',
                    type: 'POST',
                    data: {
                        FromInsDate: $('#FilterFromInsDate').val(),
                        ToInsDate: $('#FilterToInsDate').val(),
                        Status: $('#FilterStatus').val()
                    },
                    dataSrc: ''
                },
                columns: [
                    { data: 'OTRegistrationId' },
                    { data: 'OpDate' },
                    { data: 'OpTime' },
                    { data: 'PatientName' },
                    { data: 'RegNo' },
                    { data: 'DoctorName' },
                    { data: 'RoomName' },
                    {
                        data: 'Status',
                        render: function(data) { return getStatusBadge(data); }
                    },
                    {
                        data: null,
                        render: function (data, type, row) {
                            var safeName = (row.PatientName || '').replace(/'/g, "\\'");
                            return '<button class="btn btn-sm btn-info mr-1" style="height:30px;width:34px;border-radius:50%;padding:0" onclick="EditOTRecord(' + row.OTRegistrationId + ')">' +
                                '<i class="fa fa-pencil"></i></button>' +
                                '<button class="btn btn-sm btn-danger" style="height:30px;width:34px;border-radius:50%;padding:0" onclick="DeleteOTRecord(' + row.OTRegistrationId + ', \'' + safeName + '\')">' +
                                '<i class="fa fa-trash"></i></button>';
                        }
                    }
                ],
                pageLength: 10,
                order: [[2, 'asc']],   // sort by OpDate ascending
                language: {
                    emptyTable: "No records found for the selected filters"
                }
            });
        }

        // ==================== EDIT / DELETE ====================
        function EditOTRecord(id) {
            $.ajax({
                type: "POST",
                url: '@Url.Action("GetOTRegistrationById","OT")',
                data: { OTRegistrationId: id },
                success: function (data) {
                    $('#OTRegistrationId').val(data.OTRegistrationId);
                    $('#PatientId').val(data.PatientId);
                    $('#RegNo').val(data.RegNo);
                    $('#PatientName').val(data.PatientName);
                    $('#Age').val(data.Age);
                    $('#Gender').val(data.Gender);
                    $('#ContactNo').val(data.ContactNo);
                    $('#IpNo').val(data.IpNo);
                    $('#OpNo').val(data.OpNo);
                    $('#RevisitId').val(data.RevisitId);
                    $('#AdmissionStatus').val(data.IpNo && data.IpNo !== "" ? "Admitted" : "Not Admitted");
                    $('#OpDate').val(data.OpDate);
                    $('#OpTime').val(data.OpTime);
                    $('#OperationTheatre').val(data.OperationTheatre);
                    $('#DoctorConsultant').val(data.DoctorConsultant);
                    $('#Status').val(data.Status);
                    $('#Notes').val(data.Notes);

                    CloseOTList();
                }
            });
        }

        function DeleteOTRecord(id, patientName) {
            Swal.fire({
                title: "Do you want to delete this record?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#3085d6",
                confirmButtonText: "Delete"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "../OT/DeleteOTRegistration",
                        data: { OTRegistrationId: id },
                        success: function (res) {
                            if (res.Status == 1) {
                                Swal.fire({ icon: "success", title: "Deleted!", html: "<b>" + patientName + "</b> has been successfully deleted.", confirmButtonColor: "#009DA0", confirmButtonText: "OK" });
                                // Refresh the DataTable (reload current page)
                                $('#tblOTList').DataTable().ajax.reload(null, false);
                            } else {
                                Swal.fire("Error deleting record");
                            }
                        }
                    });
                }
            });
        }

        // ==================== SAVE (combined existence check) ====================
        function SaveOTRegistration() {

            if (!$("#RegNo").val().trim()) {
                warningshow("Please enter Register Number");
                $('#RegNo').focus();
                return;
            }

            if (!$("#PatientId").val()) {
                warningshow("Please select a patient from list");
                $('#RegNo').focus();
                return;
            }
            if (!$("#OpDate").val()) { warningshow("Please select operation date"); $('#OpDate').focus(); return; }
            if (!$("#OpTime").val()) { warningshow("Please select operation time"); $('#OpTime').focus(); return; }
            if (!$("#OperationTheatre").val()) { warningshow("Please select operation theatre"); $('#OperationTheatre').focus(); return; }
            if (!$("#DoctorConsultant").val()) { warningshow("Please select consultant doctor"); $('#DoctorConsultant').focus(); return; }
            if (!$("#Status").val()) { warningshow("Please select status"); $('#Status').focus(); return; }

            var id = $('#OTRegistrationId').val();

            var confirmText = id == 0 ? "Do you want to save this record?" : "Do you want to update this record?";

            Swal.fire({
                title: confirmText,
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Yes",
                cancelButtonText: "Cancel",
                confirmButtonColor: "#009DA0"
            }).then((result) => {

                if (result.isConfirmed) {

                    SaveOTRegistrationConfirm();
                }

            });
        }

        function SaveOTRegistrationConfirm() {

            $("#Loadingsave").show();

            var isNew = ($('#OTRegistrationId').val() == 0 || $('#OTRegistrationId').val() == '');

            $.ajax({
                type: "POST",
                url: "../OT/OTRegistrationInsert",
                data: {
                    OTRegistrationId: $('#OTRegistrationId').val(),
                    PatientId: $('#PatientId').val(),
                    RegNo: $('#RegNo').val(),
                    RegSeries: $('#RegSeries').val(),
                    OpNo: $('#OpNo').val(),
                    RevisitId: $('#RevisitId').val(),
                    IpNo: $('#IpNo').val(),
                    PatientName: $('#PatientName').val(),
                    Age: $('#Age').val(),
                    Gender: $('#Gender').val(),
                    ContactNo: $('#ContactNo').val(),
                    IpYear: 0,
                    OpDate: $('#OpDate').val(),
                    OpTime: $('#OpTime').val(),
                    OperationTheatre: parseInt($('#OperationTheatre').val()),
                    DoctorConsultant: parseInt($('#DoctorConsultant').val()),
                    Status: parseInt($('#Status').val()),
                    Notes: $('#Notes').val(),
                    UserId: ERPUserId,
                    DeptId: ERPDeptId
                },

                success: function (r) {

                    $("#Loadingsave").hide();

                    // ================= SUCCESS =================
                    if (r.Status > 0) {

                        var actionLabel = isNew ? "Registered successfully" : "Updated successfully";
                        var actionMsg = isNew
                            ? "Operation Theatre registration completed successfully for"
                            : "Operation Theatre registration updated successfully for";

                        var patient = $('#PatientName').val();

                        Swal.fire({
                            icon: "success",
                            html:
                                "<div style='font-family:Segoe UI, sans-serif; text-align:center;'>" +
                                "<div style='font-size:22px; font-weight:700; color:#009DA0; margin-bottom:10px;'>" + actionLabel + "</div>" +
                                "<div style='font-size:16px; color:#444;'>" + actionMsg + "</div>" +
                                "<div style='font-size:20px; font-weight:700; color:#2c3e50; margin-top:8px;'>" + patient + "</div>" +
                                "</div>",
                            confirmButtonColor: "#009DA0",
                            confirmButtonText: "OK",
                            allowOutsideClick: false
                        }).then(() => {

                            ClearForm();

                            setTimeout(function () {
                                Defaultfocus();
                            }, 200);

                        });

                    }

                    // ================= OT THEATRE CONFLICT =================
                    else if (r.Status == 0 && r.ConflictType === 'OT_THEATRE_CONFLICT') {
                        var otName = $('#OperationTheatre option:selected').text();
                        Swal.fire({
                            icon: "warning",
                            title: "OT Already Booked",
                            html: "<b>" + otName + "</b> is already booked by <b>" + (r.PatientName || '—') + "</b> on<br><br><b style='color:#e74c3c; font-size:18px;'>" + (r.OpDate || '—') + "</b>",                        confirmButtonColor: "#009DA0",
                            confirmButtonText: "OK"
                        });
                    }

                    else if (r.Status == 0 && r.ConflictType === 'PATIENT_CONFLICT') {
                        Swal.fire({
                            icon: "warning",
                            title: "Already Registered",
                            html: "<b>" + ($('#PatientName').val() || '—') + "</b> already has an OT registration on<br><br><b style='color:#e74c3c; font-size:18px;'>" + ($('#OpDate').val() || '—') + "</b>",
                            confirmButtonColor: "#f39c12"
                        });
                    }

                    // ================= OTHER WARNING =================
                    else {

                        Swal.fire({
                            icon: "warning",
                            title: "Warning",
                            text: r.Message || "Unable to save record"
                        });

                    }

                },

                error: function () {

                    $("#Loadingsave").hide();

                    Swal.fire({
                        icon: "error",
                        title: "Server Error",
                        text: "Unable to process request"
                    });

                }
            });

        }

        function CloseOTList() {
            $('#OTModalOverlay').hide();
            $('#OTListModal').hide();
            $('body').removeClass('ot-modal-open');
            setTimeout(function () {
                Defaultfocus();
            }, 200);
        }

        function warningshow(message, Id) {
            $('#popupmessage').text(message);
            $('#Warningpopup').stop(true, true).show();
            if (Id) { $('#' + Id).focus().select(); }
            clearTimeout(window._warningTimer);
            window._warningTimer = setTimeout(function () {
                $('#Warningpopup').fadeOut();
            }, 3000);
        }

        function ClearForm() {

            $('#OTRegistrationId').val('0');
            $('#RegNo').val('');
            $('#Opseriesname').val('');
            ClearPatientData();
            $('#HiddenRegNo,#RegSeries,#Notes').val('');
            $('#Status').val('1');
            $('#OperationTheatre').val('');
            SetCurrentDateTime();
            setTimeout(function () {
                $('#RegNo').focus().select();
            }, 100);
        }
    </script>