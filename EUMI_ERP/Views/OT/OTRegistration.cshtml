    @{
        ViewBag.Title = "OTRegistration";
        Layout = "~/Views/Shared/_Layout.cshtml";
    }

    <style>
        /* ===== AUTOCOMPLETE DROPDOWN (from OTRegistration) ===== */
        .ui-autocomplete {
            z-index: 9999999 !important;
            max-height: 400px;
            overflow-y: auto;
            overflow-x: hidden;
            background-color: #ffffff !important;
            border: 2px solid #009DA0 !important;
            border-radius: 6px !important;
            box-shadow: 0 6px 12px rgba(0,0,0,0.175) !important;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 13px;
            width: auto !important;
            min-width: 900px !important;
            padding: 0 !important;
        }

        .ui-menu-item {
            padding: 0 !important;
            margin: 0 !important;
            list-style: none;
        }

        .ui-menu-item-wrapper.ui-state-active,
        .ui-menu-item-wrapper.ui-state-focus,
        .ui-state-active,
        .ui-state-focus {
            background: teal !important;
            color: #ffffff !important;
            border: none !important;
        }

            .ui-state-active a,
            .ui-state-focus a {
                background: teal !important;
                color: #ffffff !important;
            }

        .ui-menu-item .ui-state-active {
            background: teal !important;
        }

        .ac-header-row {
            display: grid;
            grid-template-columns: 160px 220px 120px 320px 140px;
            background-color: teal;
            font-weight: bold;
            color: white !important;
            font-size: 18px;
            border-bottom: 1px solid #cccccc;
            position: sticky;
            top: 0;
            z-index: 2;
        }

        .ac-data-row {
            display: grid;
            grid-template-columns: 160px 220px 120px 320px 140px;
            border-bottom: 1px solid #dddddd;
        }

            .ac-data-row:hover {
                background-color: teal !important;
                color: white !important;
                cursor: pointer;
            }

        /* HEADER TEXT */
        .ac-header-row span {
            padding: 4px 8px;
            white-space: nowrap;
            font-weight: 700;
            color: #ffffff !important;
            font-size: 13px;
            border-right: 1px solid #dddddd;
        }

        /* DATA TEXT */
        .ac-data-row span {
            padding: 4px 8px;
            white-space: nowrap;
            font-weight: 600;
            color: #000;
            font-size: 17px;
            overflow: hidden;
            text-overflow: ellipsis;
            border-right: 1px solid #dddddd;
        }

        /* Hover */
        .ac-data-row:hover span {
            color: #ffffff !important;
        }

        .ac-header-row span:last-child,
        .ac-data-row span:last-child {
            border-right: none;
        }

        .ac-data-row:nth-child(even) {
            background-color: #f9f9f9;
        }

        /* ===== FORM INPUTS ===== */
        .form-control,
        .form-control[readonly],
        .form-control:disabled {
            background-color: #ffffff !important;
        }

            .form-control[readonly] {
                opacity: 1;
            }

            .form-control:disabled {
                color: #000;
            }

        /* ===== TWO COLUMN LAYOUT ===== */
        .ot-container {
            display: flex;
            gap: 25px;
            align-items: stretch;
        }

        .ot-left, .ot-right {
            display: flex;
            flex-direction: column;
        }

            .ot-right .ot-card {
                margin-right: 30px;
            }

        /* ===== CARD STYLE ===== */
        .ot-card {
            flex: 1;
            background-color: #CFE7E9;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
            transition: all 0.3s ease;
        }

            .ot-card:hover {
                box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            }

        /* ===== SECTION TITLES ===== */
        .section-title {
            color: #009DA0;
            font-weight: 1000;
            font-size: 22px;
            margin-bottom: 20px;
            border-bottom: 2px solid #009DA0;
            padding-bottom: 8px;
        }

        /* ===== LABELS ===== */
        .label-control {
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 6px;
            display: block;
        }

        /* ===== INPUT SIZE ===== */
        #PatientName, #Age, #Gender, #ContactNo, #OpNo, #RevisitId, #IpNo,
        #AdmissionStatus, #OpDate, #OpTime, #OperationTheatre, #DoctorConsultant,
        #Status, #Notes, #RegNo, #Opseriesname {
            height: 50px;
            font-size: 18px;
            padding: 12px 14px;
            border-radius: 8px;
        }

        textarea#Notes {
            height: 80px;
        }

        /* ===== BUTTON STYLE ===== */
        .btn {
            height: 42px;
            font-size: 15px;
            border-radius: 6px;
            padding-left: 20px;
            padding-right: 20px;
        }

        /* ===== LOADING OVERLAY ===== */
        #Loadingsave {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.7);
            z-index: 99999;
            display: none;
        }

            #Loadingsave > div {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

        /* ===== TOP ALERT ===== */
        .top-alert {
            position: fixed;
            top: 90px;
            left: 50%;
            transform: translateX(-50%);
            background: #ff5c70;
            color: white;
            padding: 14px 35px;
            font-weight: 600;
            font-size: 15px;
            border-radius: 6px;
            box-shadow: 0px 4px 12px rgba(0,0,0,0.2);
            display: none;
            z-index: 999999;
        }

        /* ===== STATUS BADGES ===== */
        .status-badge {
            padding: 4px 10px;
            border-radius: 15px;
            color: white;
            font-size: 12px;
            display: inline-block;
            min-width: 80px;
            text-align: center;
        }

        .scheduled {
            background: #3498db;
        }

        .badge-progress {
            background: #f39c12;
        }

        .completed {
            background: #27ae60;
        }

        .cancelled {
            background: #e74c3c;
        }

        .postponed {
            background: #7f8c8d;
        }

        body.ot-modal-open {
            overflow: hidden !important;
        }

        /* Dark blurred overlay */
        #OTModalOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 9000;
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            background-color: rgba(0, 0, 0, 0.4);
        }

        #OTListModal {
            display: none;
            position: fixed;
            top: 45%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 9100;
            width: 70vw;
            max-width: 1500px; /* allow large screens */

            height: 70vh;
            max-height: 70vh; /* fit viewport */

            flex-direction: column;
            background: #ffffff;
            border-radius: 10px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.45);
            overflow: hidden;
        }

            #OTListModal.ot-visible {
                animation: otModalIn 0.22s ease forwards;
            }

        /* ── Header ─────────────────────────── */
        .ot-modal-header {
            flex-shrink: 0; /* never shrinks */
            background: linear-gradient(135deg, #009DA0 0%, #006f72 100%);
            color: white;
            padding: 13px 22px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 10px 10px 0 0;
        }

            .ot-modal-header h4 {
                margin: 0;
                font-size: 16px;
                font-weight: 700;
                letter-spacing: 0.6px;
                text-transform: uppercase;
            }

        .ot-close-btn {
            background: none;
            border: none;
            color: white;
            font-size: 24px;
            line-height: 1;
            cursor: pointer;
            padding: 0 4px;
            opacity: 0.85;
            transition: opacity 0.15s;
        }

            .ot-close-btn:hover {
                opacity: 1;
            }

        /* ── Filter bar ──────────────────────── */
        .ot-modal-filters {
            flex-shrink: 0; /* never shrinks */
            padding: 12px 22px 10px;
            background: #f3fafa;
            border-bottom: 1px solid #cce8e8;
            display: flex;
            align-items: flex-end;
            gap: 16px;
            flex-wrap: wrap;
        }

        .ot-filter-group {
            display: flex;
            flex-direction: column;
        }

            .ot-filter-group label {
                font-weight: 600;
                font-size: 12px;
                color: #444;
                margin-bottom: 4px;
            }
        /* Override the global tall-input rule inside filter bar */
        .ot-modal-filters .form-control {
            height: 34px !important;
            font-size: 13px !important;
            padding: 4px 10px !important;
            border-radius: 6px !important;
            width: 160px;
        }

        .ot-modal-filters select.form-control {
            width: 160px;
        }

        .btn-go {
            height: 34px;
            padding: 0 24px;
            font-size: 13px;
            font-weight: 700;
            background: #e67e22;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.15s;
            margin-bottom: 0;
            align-self: flex-end;
        }

            .btn-go:hover {
                background: #d06000;
            }

        /* ── Table wrapper (THE ONLY SCROLLABLE PART) ── */
        .ot-modal-table-wrap {
            flex: 1;
            overflow-y: auto;
            overflow-x: auto;
            padding: 0;
            background: #fff;
            min-height: 0;
            /* DataTables controls row */
            .ot-modal-table-wrap .dataTables_wrapper

        {
            padding: 10px 16px 8px;
        }

        .ot-modal-table-wrap .dataTables_filter input,
        .ot-modal-table-wrap .dataTables_length select {
            height: 28px;
            font-size: 12px;
        }

        /* The table itself */
        #tblOTList {
            width: 100% !important;
            border-collapse: collapse;
            font-size: 13px;
        }

            #tblOTList thead th {
                position: sticky;
                top: 0;
                z-index: 3;
                background: #009DA0 !important;
                color: white !important;
                padding: 9px 12px;
                text-align: center;
                border: 1px solid #007c7f;
                white-space: nowrap;
            }

            #tblOTList td {
                padding: 7px 10px;
                text-align: center;
                border: 1px solid #e0e0e0;
                white-space: nowrap;
            }

            #tblOTList tbody tr:nth-child(even) {
                background: #f5fbfb;
            }

            #tblOTList tbody tr:hover {
                background: #d4eeee;
                cursor: pointer;
            }

        /* Empty / placeholder row */
        .ot-empty-row td {
            text-align: center;
            color: #aaa;
            padding: 28px !important;
            font-size: 13px;
        }
    </style>

    <!-- ==================== MAIN FORM ==================== -->
    <div id="Entry" style="margin-top:-20px;">
        <div id="topAlert" class="top-alert"></div>
        <section class="grid-row-label">
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header" style="border-bottom:1px solid #e6e6e6; background-color:#009DA0; height:70px">
                            <div class="row">
                                <table width="100%">
                                    <tr>
                                        <td>
                                            <h2 class="card-title mb-0" style="font-weight:bold; font-size:x-large; color:white;">
                                                OPERATION THEATRE REGISTRATION
                                            </h2>
                                        </td>
                                        <td class="text-right" width="59%">
                                            <i class="ft-calendar" style="font-weight:normal; font-size:x-large; color:white"></i>
                                            <input type="text" id="CurrentDate"
                                                   style="border:none; background-color:#009DA0; color:white; font-weight:normal; font-size:x-large;"
                                                   class="disb" disabled>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="card-content collapse show">
                            <div class="card-body" style="margin-top:-20px">
                                <form action="#">
                                    <div class="form-body">
                                        <hr style="margin-top:1.2%" />

                                        <!-- Hidden fields -->
                                        <input type="hidden" id="OTRegistrationId" value="0" />
                                        <input type="hidden" id="PatientId" />
                                        <input type="hidden" id="HiddenRegNo" />
                                        <input type="hidden" id="RegSeries" />
                                        <input type="hidden" id="RoomId" />
                                        <input type="hidden" id="HiddenRevisitId" />

                                        <div class="ot-container">
                                            <!-- LEFT : PATIENT INFO -->
                                            <div class="ot-left col-md-6">
                                                <div class="ot-card">
                                                    <h4 class="section-title"><i class="ft-user"></i> PATIENT INFORMATION</h4>
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <label class="label-control">Reg No *</label>
                                                            <table width="100%">
                                                                <tr>
                                                                    <td width="30%">
                                                                        <input type="text" id="Opseriesname" class="form-control" readonly placeholder="Series">
                                                                    </td>
                                                                    <td>
                                                                        <input type="text" id="RegNo" class="form-control"
                                                                               placeholder="Type Reg No or Name" autocomplete="off">
                                                                    </td>
                                                                </tr>
                                                            </table>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="label-control">Patient Name</label>
                                                            <input type="text" id="PatientName" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-6 mt-2">
                                                            <label class="label-control">Age</label>
                                                            <input type="text" id="Age" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-6 mt-2">
                                                            <label class="label-control">Gender</label>
                                                            <input type="text" id="Gender" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-6 mt-2">
                                                            <label class="label-control">IP ID</label>
                                                            <input type="text" id="IpNo" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-6 mt-2">
                                                            <label class="label-control">Admission Status</label>
                                                            <input type="text" id="AdmissionStatus" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-4 mt-2">
                                                            <label class="label-control">Contact</label>
                                                            <input type="text" id="ContactNo" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-4 mt-2">
                                                            <label class="label-control">OP ID</label>
                                                            <input type="text" id="OpNo" class="form-control" readonly>
                                                        </div>
                                                        <div class="col-md-4 mt-2">
                                                            <label class="label-control">Revisit ID</label>
                                                            <input type="text" id="RevisitId" class="form-control">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- RIGHT : OPERATION DETAILS -->
                                            <div class="ot-right col-md-6">
