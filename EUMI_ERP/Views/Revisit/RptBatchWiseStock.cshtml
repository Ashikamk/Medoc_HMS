        $('#hd').text('Location-' + $("#Location option:selected").text())
    }

    function LoadReport(result) {
        disable_datatable('tbl_StockReport');
        Text = '<thead><tr>' +
            '<th>SlNo</th>' +
            '<th>Item Code</th>' +
            '<th>Name</th>' +
            '<th>Generic</th>' +
            '<th>Batch</th>' +
            '<th>Expiry</th>' +
            '<th>Supplier</th>' +
            '<th>Type</th>' +            
            '<th>Stock</th>' +

            '<th>Pur Rate</th>' +
            '<th>Sel Rate</th>' +


            '<th>Stock Value</th>' +
            '<th>Sales Value</th>' +
            '</tr><thead><tbody>';

        var space = "                                           ";
        var title = "Batch Wise Stock Report ";

        var Line = "<tr><th></th></tr>";

        Line += "<tr><td>" + $.trim(CompanySettingsArray.CompanyName) + "</td></tr>";
        Line += "<tr><td>" + $.trim(CompanySettingsArray.Address) + "</td></tr>";
        Line += "<tr><td>" + $.trim((CompanySettingsArray.PhoneNo).replace("\n", "")) + "</td></tr>";

        Line += '<tr><td>----------------------------------------------------------------------------------------------------</td></tr>'
        Line += "<tr><td>" +title + "</td></tr>";
        Line += '<tr><td>----------------------------------------------------------------------------------------------------</td></tr>'
        Line += '<tr><td>slno Item                                       Batch       Exp       Qty   Sales Val   Stock Val</td></tr>'
        Line += '<tr><td>----------------------------------------------------------------------------------------------------</td></tr>'

        for (var i = 0; i < result.length; i++) {

            var slno = i + 1;

            var Style = "";
            if (result[i].Flag == '1') { Style = 'background-color:#CFD8DC;font-weight:bold;'; }
            else if (result[i].Flag == '2') { Style = 'font-weight:bold;'; }
            else if (result[i].Flag == '3') { Style = 'background-color:#B0BEC5;font-weight:bold;'; }

            var Stock = Number(result[i].LooseQuantity || 0);

            var Svalue = space + parseFloat(result[i].Cost).toFixed(Decimal);
            Svalue = Svalue.substring(Svalue.length - 10, Svalue.length);


            var PValue = space + parseFloat(result[i].SellAmount).toFixed(Decimal);
            PValue = PValue.substring(PValue.length - 10, PValue.length);

            var QT = space + parseFloat(Stock).toFixed(0);
            QT = QT.substring(QT.length - 5, QT.length);

            var SSSNo = space + slno;
            SSSNo = SSSNo.substring(SSSNo.length - 3, SSSNo.length);
            var oDesc = (result[i].MedType).split("##")

            if (Stock == 0) { Stock = '';}

            var Text = Text + '<tr style="' + Style + '">' +
                '<td align="center">' + slno + '</td>' +
                '<td>' + result[i].ItemCode + '</td>' +
                '<td>' + result[i].ItemDesc + '</td>' +
                '<td></td>' +
                '<td>' + result[i].Batch + '</td>' +
                '<td>' + result[i].Expiry + '</td>' +
                '<td>' + result[i].Company + '</td>' +
                '<td>' + oDesc[0] + '</td>' +                
                '<td align="center">' + Stock + '</td>' +

                '<td>' + parseFloat(result[i].Cost / Stock).toFixed(2) + '</td>' +
                '<td>' + parseFloat(result[i].SellAmount / Stock).toFixed(2) + '</td>' +

                '<td>' + result[i].Cost + '</td>' +
                '<td>' + result[i].SellAmount + '</td>' +
                '</tr>';

            if (result[i].ItemDesc != 'GrandTotal') {
                Line += "<tr><td>" + SSSNo + "  " + (result[i].ItemDesc + space).substring(0, 40) + "  " + (result[i].Batch + space).substring(0, 10) + "   " + (result[i].Expiry + space).substring(0, 7) + "" + QT + "" + PValue + "  " + Svalue + "</td></tr>";
            }
            else {
                var SSSNo = space ;
                SSSNo = SSSNo.substring(SSSNo.length - 3, SSSNo.length);
                Line += '<tr><td>----------------------------------------------------------------------------------------------------</td></tr>'
                Line += "<tr><td>" + SSSNo + "  " + (result[i].ItemDesc + space).substring(0, 40) + "  " + (result[i].Batch + space).substring(0, 10) + "   " + (result[i].Expiry + space).substring(0, 7) + "" + QT + "" + PValue + "  " + Svalue + "</td></tr>";
                Line += '<tr><td>----------------------------------------------------------------------------------------------------</td></tr>'

            }
        }
        Text = Text + '</tbody><tfoot><tr>' +
            '<th></th>' +
            '<th>Item Code</th>' +
            '<th>Name</th>' +
            '<th>Generic</th>' +
            '<th>Batch</th>' +
            '<th>Expiry</th>' +
            '<th>Supplier</th>' +
            '<th>Type</th>' +
            
            '<th></th>' +
             '<th></th>' +
              '<th></th>' +
            '</tr></tfoot>';
        $("#tbl_StockReport").html(Text);

        var title = 'Batch Wise Stock Report';
        datatableWithsearch('tbl_StockReport', true, title, 'itemListButtonPlace');

        $('#DosPrintVEM').html("");
        $('#DosPrintVEM').append(Line);

        $("#LoadingSmall").hide();
        ngOnDestroy();
    }

    function ngOnDestroy() {
        $("#myModal").modal('hide');
    }

    function Filter() {
        if (!($('#myModal').is(':visible'))) {
            $("#myModal").modal("show");
            $("#myModal").appendTo("body");
        }
    }




    function disable_datatable(tablename) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            return;
        }
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != '')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
                //"columnDefs": [
                //                       { "width": "1%", "targets": 0 },
                //                       { "width": "2%", "targets": 1 },
                //                       { "width": "2%", "targets": 2 },
                //                       { "width": "2%", "targets": 3 },
                //                       { "width": "15%", "targets": 4 },
                //                       { "width": "1%", "targets": 5 },
                //                       { "width": "2%", "targets": 6 },
                //                       { "width": "4%", "targets": 7 },
                //                       { "width": "5%", "targets": 8 },
                //                       { "width": "2%", "targets": 9 },
                //],

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        }

        else {
            table = $('#' + tablename).DataTable({


            });
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus().select();
        window.setTimeout(function () {
            $('#Warningpopup').fadeOut();
        }, 3000);
    }

    function GetLocation() {
        var data = {};
        data.LocationId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/LocationGetandGets",
            data: data,
            success: function (result) {
                LocationLoad(result.oList);


            }
        });

    }

    function LocationLoad(result) {
        $("#Location").empty();
        LocationSelect = "<option value='0'>-Select-</option>";
        for (var i = 0; i < result.length; i++) {
            LocationSelect += "<option value='" + result[i].LocationId + "'locname='" + result[i].LocationName + "'>" + result[i].LocationName + "</option>";

        }
        $("#Location").append(LocationSelect);
    }

