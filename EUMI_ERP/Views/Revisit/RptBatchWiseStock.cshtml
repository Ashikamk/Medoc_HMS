    });


    function Search() {
        $("#LoadingSmall").show();
        var data = {};
        data.Param2 = $('#ReportType').val();
        data.Param3 = 1;
        data.Param4 = $('#ItemId').val();
        data.Param5 = 0;
        data.Param6 = $('#Location').val();
        data.Param7 = $('#Company').val();
        data.Param8 = $('#Type').val();
        data.Param9 = $('#Schedule').val();
        data.DeptId = ERPDeptId;
        data.UserId = ERPUserId;

        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_Rpt_StockReport",
            data: data,
            success: function (result) {
                LoadReport(result);
            }
