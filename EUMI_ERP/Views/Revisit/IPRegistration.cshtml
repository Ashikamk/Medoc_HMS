<script>
    $(function () {
        $('#IPDate,#FromDate,#ToDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    });
    $("#RegNumber").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            ClearPatData();
            var data = {};
            data.PatientName = $("#RegNumber").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_IPorPatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.OPSerName + '-' + item.OPNumber,
                            label1: item.PatientName,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["RegNo", "Patient"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $("#RegSeries").val(ui.item.OPSerName);
            $("#RegNumber").val(ui.item.OPNumber);

            var data = {};                                       //dropdownbind
            data.PatientId = ui.item.PatientId;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Revisit/HMS_PatientSearchGet",
                data: data,
                success: function (result) {
                    if (result.oList.length > 0) {
                        GetPatientData(result.oList, 1);
                        $("#RegNumber").val(ui.item.OPNumber);
                    }
                }
            });
            $("#DocName").focus();
        },

    });
    $("#OPVisitId").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            ClearPatData();
            var data = {};
            data.Status = $("#OPVisitId").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_RevisitIdSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.RevisitId,
                            label1: item.PatientName,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            BloodGroup: item.BloodGroup,
                            Gender: item.Gender,
                            RegNo: item.OPSerName + '-' + item.OPNumber,
                            DoctorId: item.DoctorId,
                            headers: ["OPVisitId", "Patient"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $("#OPVisitId").val(ui.item.label);
            $("#PatientId").val(ui.item.PatientId);
            $("#DocName").val(ui.item.DoctorId);
            var data = {};                                       //dropdownbind
            data.PatientId = ui.item.PatientId;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Revisit/HMS_PatientSearchGet",
                data: data,
                success: function (result) {
                    if (result.oList.length > 0) {
                        GetPatientData(result.oList, 1);
                    }
                }
            });
        },

    });
    $("#SearchRegNo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.PatientName = $("#SearchRegNo").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
