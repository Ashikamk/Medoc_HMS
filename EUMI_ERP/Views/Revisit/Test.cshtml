
@{
    ViewBag.Title = "Test";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" type="text/css" href="../../../app-assets/vendors/css/tables/jsgrid/jsgrid-theme.min.css">
<link rel="stylesheet" type="text/css" href="../../../app-assets/vendors/css/tables/jsgrid/jsgrid.min.css">
<link rel="stylesheet" type="text/css" href="../app-assets/vendors/css/hopscotch.css">
<script type="text/javascript" src="~/ProjectScript/TestMst.js"></script>
<style>
    .label-control {
        font-weight: bold;
    }

    #customView {
        border: 1px solid #CCD6E6;
    }

    .GridText {
        height: 30px;
        border:none !important;
        font-weight:bold;

    }
.GridBRow {
    border: 1px solid #9faec3;
           font-weight:bold;
}
</style>

<div class="myData" data-x="M339" />


<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header p-2" style="border-bottom:1px solid #e6e6e6;background-color:#009da0;">
                    <div class="row">
                        <h4 class="card-title mb-0 text-left col-md-12" style="font-weight:bold;color:white;">Test Master</h4>
                    </div>

                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <form action="#">
                                    <div class="form-body">
                                        <div class="col-md-12">

                                            <div class="row mb-1 mt-1">
                                                <label class="col-md-1 label-control">Test Name<span class="danger">*</span></label>
                                                <div class="col-md-5">
                                                    <input type="text" id="TestName" onkeyup="CheckTestType()" class="form-control denull enterflow" autocomplete="off" />
                                                </div>
                                                <label class="col-md-1 label-control">Rate<span class="danger">*</span></label>
                                                <div class="col-md-2">
                                                    <input type="text" id="Rate" class="form-control denull enterflow" autocomplete="off" onkeyup="ratechngeall()" onkeypress="isNumber_Arrow(event, this)" />
                                                </div>
                                                <label class="col-md-1 label-control">Sp. Rate</label>
                                                <div class="col-md-2">
                                                    <input type="text" id="SpRate" class="form-control denull enterflow" autocomplete="off" onkeypress="isNumber_Arrow(event, this)" />
                                                </div>
                                                
                                            </div>
                                            <div class="row mb-1 mt-1">
                                                <label class="col-md-1 label-control">V Sp. Rate</label>
                                                <div class="col-md-2">
                                                    <input type="text" id="VSpRate" class="form-control denull enterflow" autocomplete="off" onkeypress="isNumber_Arrow(event, this)" />
                                                </div>
                                                <label class="col-md-1 label-control">Outside Rate</label>
                                                <div class="col-md-2">
                                                    <input type="text" id="OutsideRate" class="form-control denull enterflow" autocomplete="off" onkeypress="isNumber_Arrow(event, this)"/>
                                                </div>
                                                <label class="col-md-1 label-control">Section<span class="danger">*</span></label>
                                                <div class="col-md-2">
                                                    <select type="text" id="MedDept" class="form-control dezero" onchange="ChangeMedDept()"></select>
                                                </div>
                                                <label class="col-md-1 label-control">Sub Division<span class="danger">*</span></label>
                                                <div class="col-md-2">
                                                    <select type="text" id="SubDivision" class="form-control dezero" onchange="CheckType()">
                                                        <option value="0">--Select--</option>
                                                        <option value="YES">YES</option>
                                                        <option value="NO">NO</option>
                                                    </select>
                                                </div>
                                                <button style="display:none" type="button" class="btn btn-primary" onclick="AddToGrid()"><i class="fa fa-plus"></i></button>
                                            </div>
                                         
                                            <div class="row mb-1 mt-1">
                                                <div class="px-2">
                                                    <div id="customView" class="jsgrid" style="position: relative; height: 300px; width: 100%;overflow-x: auto;overflow-y: hidden; ">
                                                        <div class="jsgrid-grid-header" style="width:100%;">
                                                            <table class="jsgrid-table">
                                                                <tr class="jsgrid-header-row">
                                                                    <th class="jsgrid-header-cell jsgrid-control-field jsgrid-align-center" style="width:4%"><i class="icon-trash"></i></th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:6%">SL#</th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:22%">SubDivision</th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:20%;display:none;">Department</th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:13%;">Std Unit</th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width:26%">Normal Value</th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width:13%">Minimum</th>
                                                                    <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width:13%">Maximum</th>
                                                                </tr>

                                                            </table>
                                                        </div>
                                                        <div id="proddiv" class="" style="position: relative; overflow-x: auto;overflow-y:scroll; height: 246px; width:100%;">
                                                            <table class="jsgrid-table" id="tbl_testsub">
                                                                <tbody>
                                                                    <tr class="jsgrid-row" id="row_1">
                                                                        <td id="edit_1" class="jsgrid-cell p-1 GridBRow  jsgrid-control-field jsgrid-align-center" style="width:4%;">
                                                                            <input class="jsgrid-button jsgrid-delete-button" type="button" title="Delete">
                                                                        </td>
                                                                        <td id="td_1" class="jsgrid-cell p-1 GridBRow" style="width:6%;text-align:center">1
                                                                            <input type="hidden" id="SubTestId_1" value="0" class="dezero">
                                                                        </td>
                                                                        <td class="jsgrid-cell p-1 GridBRow" style="width:22%;">
                                                                            <input type="text" class="form-control GridText" id="SubDiv_1" autocomplete="off" onkeydown="NextGrid('SubDiv_', '1', event)" >
                                                                        </td>
                                                                        <td class="jsgrid-cell p-1 GridBRow" style="width:20%;display:none;">
                                                                            <input type="text" class="form-control demed GridText" id="Department_1" disabled="" style="background-color:white;" >
                                                                        </td>
                                                                        <td class="jsgrid-cell p-1 GridBRow" style="width:13%;">
                                                                            <input type="text" class="form-control GridText" id="StdUnit_1" autocomplete="off" onkeydown="NextGrid('StdUnit_', '1', event)">
                                                                        </td>
                                                                        <td class="jsgrid-cell p-1 GridBRow" style="width:26%;">
                                                                            <input type="text" class="form-control GridText" id="NormalValue_1" ondblclick="ShowModal('1')" autocomplete="off" onkeydown="NextGrid('NormalValue_', '1', event)">
                                                                        </td>
                                                                        <td class="jsgrid-cell p-1 GridBRow" style="width:13%;">
                                                                            <input type="text" class="form-control GridText" id="MinVal_1" autocomplete="off" onkeydown="NextGrid('MinVal_', '1', event)" onkeypress="isNumber_Arrow(event, this)">
                                                                        </td>
                                                                        <td class="jsgrid-cell p-1 GridBRow" style="width:13%;">
                                                                            <input type="text" class="form-control GridText" id="MaxVal_1" autocomplete="off" onkeydown="NextGrid('MaxVal_', '1', event)" onkeypress="isNumber_Arrow(event, this)">
                                                                        </td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                    <br />

                                                </div>
                                            </div>
                                          

                                        </div>
                                        <div class="form-actions">
                                            <div class="col-md-12">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="row">
                                                           
                                                            <div class="col-md-12">
                                                                <textarea id="Notes" placeholder="Notes" class="form-control denull enterflow" style="height:50px;" autocomplete="off"></textarea>
                                                                <br />##-next line Normal Value  <br /> @@@@ Bold Sub Head  <br /> ##-Sub test spacing
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="text-right">
                                                            <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                                            <button type="button" style="width:100px" id="btnlist" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                                            <button type="button" style="width:100px" id="btnnew" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                                            <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="display:none">
    <input type="text" id="TestId" value="0" class="dezero"/>
    <input type="text" id="GridLength" value="1" />
</div>

<div style="display:none;" id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold;">Test Informations</h4></td>

                                <td align="right">
                                    <div class="heading-elements">
                                        <div>

                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>

                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto">
                            <table id="tbl_Test" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<div class="container">
    <!-- Modal -->
    <div class="modal fade" id="myModal" role="dialog" style="">
        <div class="modal-dialog modal-lg">

            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header">
                    <div class="row col-md-12 p-0">
                        <div class="col-md-6">
                            <h4 class="modal-title font-weight-bold">Normal Value</h4>
                        </div>
                        <div class="col-md-5">
                        </div>
                        <div class="col-md-1 p-0">
                            <button type="button" class="close pull-right" onclick="ngOnDestroy(0)">&times;</button>
                        </div>
                    </div>


                </div>
                <div class="modal-body">
                    <textarea id="NormalValue_0" class="form-control" style="min-height:150px;" ></textarea>
                </div>
                <div class="modal-footer">
                    <input type="hidden" id="CrntNormalId" value="0" class="dezero" />
                    <button type="button" class="btn btn-default" onclick="ngOnDestroy(1)">OK</button>
                </div>
            </div>

        </div>
    </div>
</div>

<script>

    function ratechngeall() {
        var amt = $('#Rate').val();
        //if ($('#SpRate').val() == '') { $('#SpRate').val(amt) }
        //if ($('#VSpRate').val() == '') { $('#VSpRate').val(amt) }
        //if ($('#OutsideRate').val() == '') { $('#OutsideRate').val(amt) }
        $('#SpRate').val(amt);
        $('#VSpRate').val(amt);
        $('#OutsideRate').val(amt);


    }




</script>
