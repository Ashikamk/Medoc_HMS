
@{
    ViewBag.Title = "Nurse";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script type="text/javascript" src="~/ProjectScript/Nurse.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<div class="myData" data-x="M376" />


<style>
    .label-control {
        font-weight: bold;
    }

    img {
        max-height: 250px;
        max-width: 250px;
    }

    .modal-xl {
        max-width: 1200px;
    }

    .hoverhead:hover {
        color: #008487 !important;
    }
</style>

<div style="display:none">
    <input type="text" id="NurseId" value="0" class="dezero" />
    <input type="text" id="NuUserId" value="0" class="dezero" />  
</div>

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6;">

                    <h4 class="card-title" style="font-weight:bold;">Nurse</h4>


                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <form action="#">
                                    <div class="form-body">

                                        <div class="row mt-1">
                                            <div class="col-md-5" style="border-right:1px solid #d3dce9;">

                                                <div class="row mb-3">
                                                    <div class="col-md-12">
                                                        <a class="hoverhead" style="font-weight:bold;font-size:large;color:#009DA0"><u>Personal Info</u></a>

                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Name<span class="danger">*</span></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuName" onkeyup="changetoupper('NuName')" class="form-control denull enterflow" autocomplete="off" />
                                                    </div>
                                                </div>

                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Gender<span class="danger">*</span></label>
                                                    <div class="col-md-8">
                                                        <select id="NuGender" class="form-control enterflow" autocomplete="off">
                                                            <option value="2">Female</option>
                                                            <option value="1">Male</option>
                                                            <option value="3">Others</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Mobile<span class="danger">*</span></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuMobile" class="form-control denull enterflow" autocomplete="off" onkeypress="isNumberInt(event,this)" />
                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Phone No.</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuPhone" class="form-control denull enterflow" autocomplete="off" onkeypress="isNumberInt(event,this)" />
                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Email</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuEmail" class="form-control denull enterflow" autocomplete="off" />
                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Languages Known</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuLanguage" class="form-control denull enterflow" autocomplete="off" />
                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control">Address<span class="danger">*</span></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuAddress1" class="form-control denull enterflow" autocomplete="off" />
                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control"></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuAddress2" class="form-control denull enterflow" autocomplete="off" />
                                                    </div>
                                                </div>
                                                <div class="row mb-1">
                                                    <label class="col-md-4 label-control"></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="NuAddress3" class="form-control denull enterflow" autocomplete="off" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-5" style="border-right:1px solid #e6e6e6;">
                                                <ul class="nav nav-tabs">
                                                    <li class="nav-item">
                                                        <a style="font-weight:bold;" class="nav-link active" id="base-tab1" data-toggle="tab" aria-controls="tab1" href="#tab1" aria-expanded="true">Professional Info</a>
                                                    </li>
                                                    <li class="nav-item">
                                                        <a style="font-weight:bold;" class="nav-link" id="base-tab2" data-toggle="tab" aria-controls="tab2" href="#tab2" aria-expanded="false">Qualifications</a>
                                                    </li>
                                                </ul>
                                                <div class="tab-content px-1 pt-1">
                                                    <div role="tabpanel" class="tab-pane active" id="tab1" aria-expanded="true" aria-labelledby="base-tab1">
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">Department<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <select id="NuDept" class="form-control dezero enterflow" autocomplete="off"></select>
                                                            </div>
                                                        </div>
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">Specialization<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <input type="text" id="NuSpecialization" class="form-control denull enterflow" autocomplete="off" />
                                                            </div>
                                                        </div>
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">Experience</label>
                                                            <div class="col-md-8">
                                                                <input type="text" id="NuExperience" class="form-control denull enterflow" autocomplete="off" />
                                                            </div>
                                                        </div>
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">Designation</label>
                                                            <div class="col-md-8">
