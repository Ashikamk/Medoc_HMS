                                                                <input type="text" id="NuTraining" class="form-control denull enterflow" autocomplete="off" />
                                                            </div>
                                                        </div>
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">Certification</label>
                                                            <div class="col-md-8">
                                                                <input type="text" id="NuCertification" class="form-control denull enterflow" autocomplete="off" />
                                                            </div>
                                                        </div>
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">Acheivements</label>
                                                            <div class="col-md-8">
                                                                <textarea type="text" rows="3" style="height:100%" id="NuAcheivement" class="form-control denull enterflow" autocomplete="off"></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="row mb-1">
                                                            <label class="col-md-4 label-control">User</label>
