                                                                <button type="button" class="btn btn-outline-primary m-0 input-group-append" id="QuaAdd">Add</button>
                                                            </div>
                                                        </div>
                                                        <input type="text" id="NuQualification2" style="display:none" class="form-control denull enterflow col-md-10 mb-1" autocomplete="off" />
                                                        <input type="text" id="NuQualification3" style="display:none" class="form-control denull enterflow col-md-10 mb-1" autocomplete="off" />
                                                        <input type="text" id="NuQualification4" style="display:none" class="form-control denull enterflow col-md-10 mb-1" autocomplete="off" />
                                                        <input type="text" id="NuQualification5" style="display:none" class="form-control denull enterflow col-md-10 mb-1" autocomplete="off" />
            
                                                    </div>
                                                </div>

                                            </div>
                                            <div class="col-md-2" style="">

                                                <img id="myImg" src="~/app-assets/img/portrait/medium/avatar-m-100.jpg" alt="" style="width:100%;min-height:250px;max-height:250px" class="img-thumbnail" onerror="this.onerror = null; this.src = '../app-assets/img/portrait/medium/avatar-m-100.jpg';">
                                                <input type="file" style="width:100%" id="selectedImage" accept="image/*" onchange="validate(this.value)" class="btn-lg btn-info font-small-2 p-2" autocomplete="off">


                                            </div>
                                        </div>

                                        <div class="form-actions text-right">

                                            <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-sm mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                            <button type="button" style="width:100px" id="btnlist" class="btn btn-primary btn-sm mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                            <button type="button" style="width:100px" id="btnnew" class="btn btn-primary btn-sm mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                            <button style="width:100px;display:none" type="button" id="btndelete" class="btn btn-danger btn-sm mr-1 mb-1">Delete <i class="fa fa-times"></i></button>


                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div style="display:none;" id="Listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%" style="table-layout:fixed;">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold;">Nurse Info</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <button type="button" onclick="formrefresh(0)" class="btn btn-outline-primary" id="ed" style="margin-left:20px"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto">
                            <table id="tbl_Nurse" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>


<script>
    $("#NuUser").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $("#NuUserId").val(0);
            var data1 = {};
            data1.UserName = $("#NuUser").val();
            $.ajax({
                url: '../Master/UserSearchInUserMenuSettings',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#NuUserId').val(ui.item.UserId);
        },
    });
</script>