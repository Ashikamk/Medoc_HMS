<script>
    $(function () {
        $('#RevisitDate,#FromDate,#ToDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    });
    $("#RegNumber").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            ClearPatData();
            var data = {};
            data.PatientName = $("#RegNumber").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3RR',
                            label: item.OPSerName+'-'+item.OPNumber,
                            label1: item.PatientName ,
                            label2: item.Add1,
                            label3: item.Add2,
                            label4:  item.Contact,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["RegNo", "Patient", "Place", "Address", "Mobile"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {

            var data = {};                                       //dropdownbind
            data.PatientId = ui.item.PatientId;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Revisit/HMS_PatientSearchGet",
                data: data,
                success: function (result) {
                    if (result.oList.length > 0) {
                        GetPatientData(result.oList, 1);
                    }
                }
            });
            $("#DocName").focus();
        },

    });
    $("#PatName").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.PatientName = $("#PatName").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.PatientName,
                            label1: item.OPSerName + '-' + item.OPNumber,

                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["Patient", "RegNo"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {

            var data = {};                                       //dropdownbind
            data.PatientId = ui.item.PatientId;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Revisit/HMS_PatientSearchGet",
                data: data,
                success: function (result) {
                    if (result.oList.length > 0) {
                        GetPatientData(result.oList, 1);
                    }
                }
            });
            $("#DocName").focus();
        },

    });
    $("#SearchRegNo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.PatientName = $("#SearchRegNo").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.OPSerName + '-' + item.OPNumber,
                            label1: item.PatientName,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["RegNo", "Patient"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {

            $("#btnsearch").focus();
        },

    });
    setInterval(function () {
        var date = new Date();

        $('#RevisitTime').text(date.getHours() + ":" + date.getMinutes() + ":" + date.getSeconds())

    }, 500);

    if ("@Request.QueryString["from"]" == "PRegistration") {

        var PatId = sessionStorage.getItem("PatId");

        sessionStorage.removeItem("PatId");

        var data = {};                                       //dropdownbind
        data.PatientId = PatId;
        data.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_PatientSearchGet",
            data: data,
            success: function (result) {
                if (result.oList.length > 0) {
                    GetPatientData(result.oList, 1);
                }
            }
        });
        $("#DocName").focus();

    }
</script>


<script>

    function PaymentPop(flg) {
        $('#revisitpayment').modal('show');
        $('#revisitpayment').appendTo('body');
        //amountfillinpopup();
        //SpceialAmountCalc();
    }

    var DDCONFEE = 0, DDREGFEE = 0;
    function paymethodchange() {
       
        var ptype = $('#PayType').val();
        if (ptype == 0) {
            $('#ConsultationFees').val(0)
            $('#VisitingFees').val(0)
        }
        else {
            $('#ConsultationFees').val(DDCONFEE);
            $('#VisitingFees').val(DDREGFEE)
        }
        amountfillinpopup()
    }


    function amountfillinpopup() {
        var visiting = parseFloat($('#VisitingFees').val() || 0);
        var Consultation = parseFloat($('#ConsultationFees').val() || 0);
        var others = parseFloat($('#OtherFees').val() || 0);
        var tot = parseFloat(visiting + Consultation + others);
        $('#revtotal').val(tot.toFixed(2));

        var Id = $('#PayType').val();
        $('#revcash').val(0.00);
        $('#revupi').val(0.00);
        $('#revcard').val(0.00);

        if (Id == 1) { $('#revcash').val(tot); }
        else if (Id == 3) { $('#revupi').val(tot); }
        else if (Id == 4) { $('#revcard').val(tot); }

        else { $('#revupi').val(0); $('#revupi').val(0); $('#revcard').val(0); }
    }

    function closePop() {
        var Cash = parseFloat($("#revcash").val() || 0);
        var Upi = parseFloat($("#revupi").val() || 0);
        var Card = parseFloat($("#revcard").val() || 0);
        var Result = (Cash + Upi + Card);

        if ($('#PayType').val() == 2) {
            $("#revcash").val(0)
            $("#revupi").val(0)
            $("#revcard").val(0)
            $('#revisitpayment').modal('hide');
        }
        else {

            if (Result != parseFloat($('#revtotal').val()||0)) {
                warningshow('Please Check Payment Amount', 'revcash');
            }
            else {
                $('#revisitpayment').modal('hide');
            }
        }
    }

    SelectPayType()
    function SelectPayType() {
        if (SalesPayType == 'Credit') {
            $('#PayType').val(2);
        }
        else if (SalesPayType == 'UPI Pay') {
            $('#PayType').val(3);
        }
        else if (SalesPayType == 'Card Pay') {
            $('#PayType').val(4);
        }
        else {
            $('#PayType').val(1);
        }
        if (ERPUserId > 3) {
            var x = document.getElementById("PayType").options[4].disabled = true;
        }
    }


    

</script>