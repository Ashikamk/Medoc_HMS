                                        <script>
                                            function TokenPrint() {
                                                var today1 = new Date();
                                                var time = today1.getHours() + ":" + today1.getMinutes() + ":" + today1.getSeconds();
                                                ComapnydivToPrintLab.style.width = "300px";
                                                ComapnydivToPrintLab.style.height = "100px";
                                                var myWindow = window.open("", "", "width=1500,height=1500"); $('#PayType :selected').text()

                                                myWindow.document.write('<style type="text/css">.brdrgh{border-right:1px solid grey;} .blclr{color:#00838F} .brtd2 td{border-right:1px solid grey;} .brtd3 td{border-bottom:1px solid grey;} .txbld{font-weight:bold;font-size:20} .txbld1{font-size:15}  </style> <style type="text/css" media="print"> tfoot{display:table-footer-group;} </style> <style type="text/css" media="screen"> tfoot{ position: relative; display: block;} tr { page-break-inside: avoid }</style>');
                                                myWindow.document.write(PrintBG3);

                                                //  myWindow.document.write('<table height=80px width=100%><tr><td colspan=12></td></tr> </table>');

                                                //  myWindow.document.write('<table width=100%><tr><td colspan=8></td></tr> </table>');
                                                myWindow.document.write('<table width=100% ><tr>');
                                                myWindow.document.write('<td width=100% style="border:none;"><table width=100%><tr align=center><td colspan=6 >');
                                                myWindow.document.write('<table width=100% ><tr ><td  align=center  style=color:#008000;font-weight:bold>' + (ComapnydivToPrintLab.outerHTML) + '</td></tr>');

                                                // myWindow.document.write('<table width=100%; style="text-align:center;"><tr><td style="font-family:tahoma;font-size: 20px;font-weight: bold;"> ' + window.CompanySettingsArray.CompanyName + '</td></tr><tr><td style="font-family:tahoma;font-size: 17px;font-weight: bold;">' + window.CompanySettingsArray.Address + '</td></tr><tr><td style="font-family:tahoma;font-size: 17px;font-weight: bold;">' + window.CompanySettingsArray.Email + '</td></tr> <tr><td style="font-family:tahoma;font-size: 17px;font-weight: bold;">' + window.CompanySettingsArray.PhoneNo + '</td></tr></table>');    
                                                myWindow.document.write('</td></tr></table></td></tr></table>');

                                                myWindow.document.write('<table width=100%><tr><td colspan=8 style="border-top: dotted;font-family:tahoma;"></td></tr> </table>');

                                                var myTag = $('#DocName').find('option:selected').attr('tokenprefix');

                                                myWindow.document.write('<table width=100%>' +
                                                    '<tr><td style="font-family:tahoma;font-size: 13px;font-weight:bold;" width=100%> Date &#160;&#160;&#160; : ' + $('#LabelDate').text() + '   ' + time + '</td></tr>' +

                                                    '<tr><td style="font-family:tahoma;font-size: 13px;font-weight:bold;" width=100%>Patient :' + $('#PatName').val() + ' / ' + ' MR# :  ' + $('#RegNumber').val() + '</td></tr>' +
                                                    '<tr><td style="font-family:tahoma;font-size: 13px;font-weight:bold;" width=100%>Doctor : ' + $('#DocName :selected').text() + '</td></tr></table>');
                                                // myWindow.document.write('<table height=20px><tr><td colspan=12></td></tr> </table>');
                                                myWindow.document.write('<table width=100%><tr height=50px> <td style="font-family:tahoma;font-size: 25px;font-weight:bold;" width=100%> <center>TOKEN NUMBER</center></td></tr> <tr> <td style="font-family:tahoma;font-size: 25px;font-weight:bold;" width=100%> <center>' + myTag + '-' + $('#PatTokenNumber').val() + '</center></td ></tr> </table> ');
                                                // myWindow.document.write('<table height=20px><tr><td colspan=12></td></tr> </table>');
                                                myWindow.document.write('<table width=100%><tr><td colspan=8 style="border-top: dotted;font-family:tahoma;"></td></tr> </table>');
                                                myWindow.document.write('<table width=100%><tr><td style="font-family:tahoma;font-size: 13px;font-weight:bold;text-align:center;">Thank You..Visit Again..</td></tr>   </table>');


                                                myWindow.print();
                                                myWindow.close();


                                            }


                                        </script>

                                        <div class="form-actions">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="text-left">
                                                        @*<button type="button" style="width:160px" class="btn btn-primary btn-min-width mr-1 mb-1" onclick="HealthPop(0)">Health Details <i class="fa fa-heart-o"></i></button>*@
                                                        <button type="button" style="width:160px" id="btnvisiting" class="btn btn-primary btn-min-width mr-1 mb-1">Pre-Visit Details <i class="fa fa-list"></i></button>
