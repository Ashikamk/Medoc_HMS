    function ShowhealthdetailsGet(result) {

        $('#PatWeight').val(result[0].Weight);
        $('#PatHeight').val(result[0].Height);
        $('#PatBP').val(result[0].BP);
        $('#PatTemperature').val(result[0].Temperature);
        $('#PatSugar').val(result[0].Sugar);
        $('#Appti1').val(result[0].BMI);
        $('#Mict1').val(result[0].ChestCircumference);
        $('#Sleep1').val(result[0].HeadCircumference);
        /*$('#PatAbdominal').val(result[0].Abdominal);*/
        $('#TestName').val(result[0].Allergy);
        $('#PatBP').focus();

        var A = (result[0].Abdominal).split("##");

        $('#Patloc').val(A[0]);
        $('#intofpain1').val(A[1]);
        $('#pain1').val(A[2]);
        $('#agg1').val(A[3]);
        $('#PatChest').val(A[4]);
        $('#bowel1').val(A[5]);

    }

