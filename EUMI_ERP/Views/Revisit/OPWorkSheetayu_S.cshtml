    function GetPop(RevisitId, PatientId) {

        var data = {};
        data.RevisitId = RevisitId;
        data.PatientId = PatientId;

        $.ajax({
            type: "POST",
            url: "../Revisit/RevisitPatientHealthDetailsGetandGets",
            data: data,
            success: function (result) {
                if (result.length) {
                    ShowhealthdetailsGet(result);
                }
                else {
                    $('#PatBP').focus();
                }

            }
        });
