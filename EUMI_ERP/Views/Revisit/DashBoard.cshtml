<script>


    if (usermenu1.indexOf("M381") == -1) {
        $('#expdiv').hide()
    }
    else {
        $('#expdiv').show()
        Search();
    }

    function LabIPProcedureGraph(FromDate, ToDate, Grtype) {
        var data = {};
        data.Fromdate = FromDate;
        data.Todate = ToDate;
        data.DeptId = ERPDeptId;
        data.UserId = ERPUserId;
        data.Status = '';
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_DB_BillGraph",
            data: data,
            success: function (result) {               
                LoadLabIPProcedureGraph(result.oList, Grtype);
            }
        });
    }


    function LoadLabIPProcedureGraph(result, GrType) {

        var Date = []; var IPAmount = []; var LBAmount = []; var PBAmount = [];

        for (var i = 0; i < result.length; i++) {
            Date.push(result[i].Title);
            IPAmount.push(Number(result[i].Amount1));
            LBAmount.push(Number(result[i].Amount2));
            PBAmount.push(Number(result[i].Amount3));
        }
        debugger;
        console.log(IPAmount);
        console.log(LBAmount);
        console.log(PBAmount)

        Highcharts.chart('containerlabprocedure', {
        chart: {
            type: GrType
        },
        title: {
            text: 'IP, Lab & Procedure Bill'
        },
        subtitle: {
            text: $("#FromDate").val() + ' to ' + $("#ToDate").val()
        },
        xAxis: {
            categories: Date
        },
        yAxis: {
            title: {
                text: 'Bills (Rs.)'
            }
        },
        plotOptions: {
            line: {
                dataLabels: {
                    enabled: true
                },
                enableMouseTracking: false
            }
        },
        series: [{
            name: 'IP Bill',
            data: IPAmount
        }, {
            name: 'Lab Bill',
            data: LBAmount
        }, {
            name: 'Procedure Bill',
            data: PBAmount
        }]
        });       
    }

    function SalesBillGraph(FromDate, ToDate, Grtype) {
        var data = {};
        data.Fromdate = FromDate;
        data.Todate = ToDate;
        data.DeptId = ERPDeptId;
        data.UserId = ERPUserId;
        data.Status = '';
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_DB_SalesBillGraph",
            data: data,
            success: function (result) {
                LoadSalesBillGraph(result.oList, Grtype);
            }
        });
    }

