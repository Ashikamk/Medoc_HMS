    function getLastWeek(CurDate) {
        var DDate = CurDate.split('/');
        var NewDate = DDate[2] + '-' + DDate[1] + '-' + DDate[0]
        var today = new Date(NewDate);
        var lastWeek = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 10);

        var NewDay = lastWeek.getDate(); if (NewDay < 10) { NewDay = '0' + NewDay; }
        var NewMonth = lastWeek.getMonth()+1; if (NewMonth < 10) { NewMonth = '0' + NewMonth; }
        var NewYear=lastWeek.getFullYear();

        var LastWeekDate = NewDay + '/' + NewMonth + '/' + NewYear
        return LastWeekDate;
    }

