                        '#3e2723',
                        '#e91e63',
                        '#19B6D4',
                        '#FF8558',

            ],
            plotOptions: {
                column: {
                    colorByPoint: true,
                },
                line: {
                    dataLabels: {
                        enabled: true
                    },
                    enableMouseTracking: false
                }
            },
            series: [
            {
                name: 'Revisit',
                data: GrData
            },
            ]
        });


    }

