    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }
    function RevisitGraphMonthly(result, Grtype) {
        //console.log(result)
        var Visit = [];
        var ToDay = [];
        var GrData = [];
        for (var i = 0; i < result.length; i++) {
            Visit.push(parseFloat(result[i].Visit || 0));
            ToDay.push(monthNames[result[i].ToDay]);
            GrData.push({ name: monthNames[result[i].ToDay], y: parseFloat(result[i].Visit || 0) })
        }


        Highcharts.chart('RevisitChart', {
            chart: { type: Grtype },
            title: {
                text: 'Revisit Overview : ' + hhh.getFullYear()
            },
            subtitle: {
                text: 'Source: '
            },
            xAxis: {
                categories: ToDay
            },
            yAxis: {
                title: {
                    text: 'Revisit()'
                }
            },

            colors: [
