        $("#RevisitDate").val($('#RevisitDate_' + slno).text());
        $("#OPSerName").val($('#OPSerName_' + slno).val());
        $("#Gender").val($('#Gender_' + slno).val());

        GetPop($('#OPVisitId_' + slno).val(), $('#PatientId_' + slno).val())

        $("#DetailsModal").modal("show");
        $("#DetailsModal").appendTo("body");



    }

    function Savepopup() {

        var data = {};

        data.RevisitId = $("#GRevisitId").val();
        data.OPNumber = $("#GOPNumber").val();
        data.PatientId = $("#GPatientId").val();
        data.DoctorName = $("#GDoctorName").val();
        data.RevisitDate = $("#RevisitDate").val();
        data.Weight = $("#PatWeight").val();
        data.Height = $("#PatHeight").val();
        data.DelFlag = 1;
        data.BP = $("#PatBP").val();
        data.Temperature = $("#PatTemperature").val();
        data.Sugar = $("#PatSugar").val();
        data.BMI = $("#PatBmi").val();
        data.ChestCircumference = $("#PatChest").val();
        data.HeadCircumference = $("#PatHead").val();
        data.Abdominal = $("#PatAbdominal").val();
        data.Allergy = $("#PatAllergy").val();
        $.ajax({
            type: "POST",
            url: "../Revisit/RevisitPatientHealthDetailsInsertandUpdate",
            data: data,
            success: function (result) {

                var status = result.oList[0].Status;
                var revisitid = result.oList[0].RevisitId;
                Showalerts(status, revisitid);
                formrefresh();
            }
        });
    }



    function CancelPop() {
        formrefresh();
    }


    function formrefresh() {
        $("#GOPNumberdis").val('');
        $("#GPatientName").val('');
        $("#GDoctorName").val('');
        $("#PatWeight").val('');
        $("#PatHeight").val('');
        $("#PatBP").val('');
        $("#PatTemperature").val('');
        $("#PatSugar").val('');
        $("#PatBmi").val('');
        $("#PatChest").val('');
        $("#PatHead").val('');
        $("#PatAbdominal").val('');
        $("#PatAllergy").val('');
    }
    function GetPop(RevisitId, PatientId) {

        var data = {};
        data.RevisitId = RevisitId;
        data.PatientId = PatientId;

        $.ajax({
            type: "POST",
            url: "../Revisit/RevisitPatientHealthDetailsGetandGets",
            data: data,
            success: function (result) {

                    ShowhealthdetailsGet(result);

            }
        });
    }

    function ShowhealthdetailsGet(result) {

            $('#PatWeight').val(result[0].Weight);
            $('#PatHeight').val(result[0].Height);
            $('#PatBP').val(result[0].BP);
            $('#PatTemperature').val(result[0].Temperature);
            $('#PatSugar').val(result[0].Sugar);
            $('#PatBmi').val(result[0].BMI);
            $('#PatChest').val(result[0].ChestCircumference);
            $('#PatHead').val(result[0].HeadCircumference);
            $('#PatAbdominal').val(result[0].Abdominal);
            $('#PatAllergy').val(result[0].Allergy);

    }

    function Showalerts(Status, RevisitId) {
        if (Status == 1) {

            formrefresh();
            swal('Visit ID: ' + RevisitId  +  "   Health Details saved successffully.", "success");

        }

    }


</script>


