
@{
    ViewBag.Title = "OPWorkSheet_S";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .label-control {
        font-weight: bold;
    }

    .bgcolor {
        background-color: #daeff1;
    }

    #divContainerNew {
        border: solid 1px black;
        min-width: 200px;
        min-height: 40px;
        width: auto;
        height: auto;
        background-color: white;
        cursor: pointer !important;
        font-weight:bold;
    }
    
    .divpop {
        position: absolute;
        text-align: left;
        display: none;
        color: black;
        border-radius: 3px;
    }
    .pointer:hover{
   background-color:#acd6f5;
   text-decoration:underline;
}
</style>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<div class="myData" data-x="M361" />


<div class="container">
    <div class="modal fade" id="DetailsModal" role="dialog" style="">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title font-weight-bold">Health Details</h4>
                    <button type="button" class="close pull-right" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="label-control mb-0">
                                BP
                            </label>
                            <input type="text" id="PatBP" class="form-control form-control-sm Patadddet" autocomplete="off" />
                        </div>
                        <div class="col-md-4">
                            <label class="label-control mb-0">
                                Temperature
                            </label>
                            <input type="text" id="PatTemperature" class="form-control form-control-sm Patadddet" autocomplete="off" />
                        </div>
                        <div class="col-md-4">
                            <label class="label-control mb-0">
                                Sugar
                            </label>
                            <input type="text" id="PatSugar" class="form-control form-control-sm Patadddet" autocomplete="off" />
                        </div>

                    </div>
                    <div class="row mt-1">
                        <div class="col-md-4">
                            <label class="label-control mb-0">
                                Height
                            </label>
                            <input type="text" id="PatHeight" class="form-control form-control-sm Patadddet" autocomplete="off" />
                        </div>
                        <div class="col-md-4">
                            <label class="label-control mb-0">
                                Weight
                            </label>
                            <input type="text" id="PatWeight" class="form-control form-control-sm Patadddet" autocomplete="off" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="HealthPop(3)">Save</button>
                    <button type="button" class="btn btn-outline-warning btn-sm" onclick="HealthPop(2)">Clear</button>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%" style="table-layout:fixed;" class="bgcolor">
                            <tr>
                                <td>
                                    <h4 class="card-title pt-2 pb-2" style="font-weight:bold;">OutPatient Worksheet</h4>
                                </td>

                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>


                        </table>
                        <table width="100%" class="bgcolor">
                            <tr>
                                <td>
                                    <label class="label-control">Date :</label>
                                </td>
                                <td width="150px;">
                                    <input type="text" id="FromDate" class="form-control dedate" />
                                </td>
                                <td>
                                    <label class="label-control pl-2 pr-1">-</label>
                                </td>
                                <td width="150px;">
                                    <input type="text" id="ToDate" class="form-control dedate" />
                                </td>
                                <td>
                                    <label class="label-control pl-1">Doctor :</label>
                                </td>
                                <td>
                                    <input type="text" id="Doctor" class="form-control denull" />
                                    <input type="hidden" id="DoctorId" class="form-control dezro" value="0" />
                                </td>
                                <td>
                                    <label class="label-control pl-1">Reg# :</label>
                                </td>
                                <td>
                                    <input type="text" id="RegNo" class="form-control denull" />
                                    <input type="hidden" id="PatientId" class="form-control dezro" value="0" />
                                </td>
                                <td align="left">
                                    <button type="button" id="btnsearch" class="btn btn-outline-primary mt-2 ml-1">
                                        Search <i class="fa fa-search"></i>
                                    </button>
                               
                                    <button id="btnrefresh" type="button" class="btn btn-outline-info mt-2">
                                        <i class="ft-refresh-cw"></i>
                                    </button>
                                </td>
                                <td align="right">
                                    <button type="button" class="btn btn-outline-success mt-2" onclick="GoPage('Revisit/LabBill');">New Lab Bill</button>
                                
                                    <button type="button" class="btn btn-outline-warning mt-2">New Procedure Bill</button>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show" oncontextmenu="return false">
                        <div class="card-body card-dashboard" style="overflow:auto">
                            <table width="100%" id="tbl_WorkSheet" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<div id="divContainerNew" class="row divpop" onmouseleave="$('#divContainerNew').slideUp()"  oncontextmenu="return false">

    <div class="pointer pl-1 pt-1" id="Context_1" onclick="RedirectTo('1')">Lab Bill</div>
    <div class="pointer pl-1 pt-1" id="Context_2" onclick="RedirectTo('2')">Test Result</div>
    <div class="pointer pl-1 pt-1" id="Context_3" onclick="RedirectTo('3')">Procedure Bill</div>
    <div class="pointer pl-1 pt-1" id="Context_4" onclick="RedirectTo('4')">Reg Bill Copy</div>

    <div style="display:none">
        <input type="text" id="CurrentselectedId" class="form-control dezro" value="0" />
    </div>
</div>

<script>
    var colorArray = ['#33ccff', '#ff66cc', '#ff9966', '#FFFF99', '#00B3E6',
		  '#E6B333', '#3366E6', '#999966', '#99FF99', '#B34D4D'];
    $(function () {
        $('#FromDate,#ToDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
        $('.dedate').val(CurDate);

        GetList(CurDate, CurDate, 0, 0);

        $("#btnsearch").click(function (e) {
            GetList($('#FromDate').val(), $('#ToDate').val(), $("#DoctorId").val(), $("#PatientId").val());
        });
        $("#btnrefresh").click(function (e) {
            $('.dedate').val(CurDate);
            $('.denull').val('');
            $('.dezero').val(0);

            GetList(CurDate, CurDate, 0, 0);
        });

        $("#tbl_WorkSheet").on('touchstart mousedown', function (e) {

            if (e.button == 2) {
                var o = {
                    left: e.pageX,
                    top: e.pageY
                };
                $("#divContainerNew").offset(o);
            }
        });
    });

    $("#RegNo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $("#PatientId").val(0);
            var data = {};
            data.PatientName = $("#RegNo").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.OPSerName + '-' + item.OPNumber,
                            label1: item.PatientName,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["RegNo", "Patient"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $("#PatientId").val(ui.item.PatientId);
            $("#btnsearch").focus();
        },

    });
    $("#Doctor").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $("#DoctorId").val(0);
            var data = {};
            data.DoctorName = $("#Doctor").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_WorkSheetDoctorSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.DoctorName,
                            label1: item.Status,
                            DoctorId: item.DoctorId,
                            headers: ["Doctor", "Department"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $("#DoctorId").val(ui.item.DoctorId);
            $("#btnsearch").focus();
        },

    });

    $("#btnsearch").focus(function (e) {
        $("#btnsearch").removeClass("btn btn-outline-primary");
        $("#btnsearch").addClass("btn btn-primary");
    });

    $("#btnsearch").focusout(function (e) {
        $("#btnsearch").removeClass("btn btn-outline-primary");
        $("#btnsearch").addClass("btn btn-outline-primary");
    });

    function GetList(FromDate, ToDate, Doctor, Patient) {
        var data = {};
        data.FromDate = FromDate;
        data.ToDate = ToDate;
        data.DoctorId = Doctor;
        data.PatientId = Patient;
        data.DeptId = ERPDeptId;
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_OPWorkSheetStaff",
            data: data,
            success: function (result) {

                LoadList(result);
            }
        });
    }

    function LoadList(result) {

        disable_datatable('tbl_WorkSheet');
        var responseText = "<thead><tr>" +
            "<th style='align=center'>Sl#</th>" +
            "<th>Reg#</th>" +
            "<th>OP-Visit#</th>" +
            "<th>Date</th>" +
            "<th>Time</th>" +
            "<th>Patient</th>" +
            "<th>Gender</th>" +
           
            "<th>Contact</th>" +
            "<th>Doctor</th>" +
            "<th>Shift</th>" +
            "<th>Token</th>" +
            "<th>Status</th>" +
            "</tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {

            if (result[i].Status == 'New') var Status = '<span class="badge badge-warning white">New-Reg</span>';
            else var Status = '<span class="badge badge-success">Re-Visit</span>';

            if (result[i].IPNumber == 0) var Status = Status;
            else if (result[i].DelFlag == 0) var Status = '<span class="badge badge-danger">Admitted</span>';
            else var Status = '<span class="badge badge-info">Discharged</span>';

            var slno = parseInt(i + 1);
            responseText += '<tr onclick="HealthPop(0)"  onmousedown="WhichButton(event,' + slno + ')" oncontextmenu="return false">' +
                '<td align=center>' + slno +
                '<input type="hidden" id="OPVisitId_' + slno + '" value="' + result[i].RevisitId + '" />' +
                '<input type="hidden" id="OPSerName_' + slno + '" value="' + result[i].OPSerName + '" />' +
                '<input type="hidden" id="OPNumber_' + slno + '" value="' + result[i].OPNumber + '" />' +
                '<input type="hidden" id="PatientId_' + slno + '" value="' + result[i].PatientId + '" />' +
                '<input type="hidden" id="DOB_' + slno + '" value="' + result[i].DOB + '" />' +
                '<input type="hidden" id="BloodGroup_' + slno + '" value="' + result[i].BloodGroup + '" />' +
                '<input type="hidden" id="PatientName_' + slno + '" value="' + result[i].PatientName + '" />' +
                '<input type="hidden" id="Gender_' + slno + '" value="' + result[i].Gender + '" />' +
                '<input type="hidden" id="IPNumber_' + slno + '" value="' + result[i].IPNumber + '" />' +
                '</td>' +
                '<td>' + result[i].OPSerName + '-' + result[i].OPNumber + '</td>' +
                '<td>' + result[i].RevisitId + '</td>' +
                '<td>' + result[i].RevisitDate + '</td>' +
                '<td>' + result[i].DOB + '</td>' +
                '<td>' + result[i].PatientName + '</td>' +
                '<td>' + result[i].Gender + '</td>' +
               
                '<td>' + result[i].Contact + '</td>' +
                '<td>' + result[i].DoctorName + '</td>' +
                '<td style="background-color:' + colorArray[result[i].Flag] + '">' + (result[i].ShiftName).substring(0, 4) + '</td>' +
                '<td align=center style="color:red;font-weight:bold">' + result[i].TokenNumber + '</td>' +
                '<td align=center>' + Status + '</td>' +
                '</tr>';
        }
        $('#tbl_WorkSheet').html(responseText + "</tbody><tfoot><tr>" +
            "<th> </th>" +
            "<th>Reg#</th>" +
            "<th>OP-Visit#</th>" +
            "<th> </th>" +
            "<th> </th>" +
            "<th>Patient</th>" +
            "<th> </th>" +
           
            "<th>Contact</th>" +
            "<th>Doctor</th>" +
            "<th> </th>" +
            "<th> </th>" +
            "<th> </th>" +
            "</tr></tfoot>");
        var title = 'OP WorkSheet From ' + $("#FromDate").val() + ' To ' + $("#ToDate").val();
        datatableWithsearch('tbl_WorkSheet', true, title, 'itemListButtonPlace');
    }



    function HealthPop(flg) {
        if (flg == 0) {
            $("#DetailsModal").modal("show");
            $("#DetailsModal").appendTo("body");
        }
        else if (flg == 2) {
            $("#DetailsModal input").val('');
        }
        else if (flg == 3) {
            $("#DetailsModal").modal('hide');
            $('#btnsubmit').click();
        }
    }



    function WhichButton(e, Id) {
        if (e.button == 2)  //Right Click
        {
            $("#divContainerNew").slideDown(500);
            $("#CurrentselectedId").val(Id);
        }
    }

    function RedirectTo(Flag) {
        if ($("#CurrentselectedId").val() != 0) {
            var Id = $("#CurrentselectedId").val();

           // alert($("#PatientId_" + Id).val())

            if (Flag == 1) //Lab Bill
            {
                sessionStorage.setItem("BSOP_PI", $("#PatientId_" + Id).val());
                sessionStorage.setItem("BSOP_IP", $("#IPNumber_" + Id).val());

                window.open('../Revisit/LabBill?from=SOPWorkSheet', '_blank');
            }
            else if (Flag == 2)    //Lab Result
            {
                sessionStorage.setItem("SOP_OV", $("#OPVisitId_"+Id).val());
                sessionStorage.setItem("SOP_RS", $("#OPSerName_"+Id).val());
                sessionStorage.setItem("SOP_RN", $("#OPNumber_"+Id).val());
                sessionStorage.setItem("SOP_PI", $("#PatientId_"+Id).val());
                sessionStorage.setItem("SOP_DO", $("#DOB_"+Id).val());
                sessionStorage.setItem("SOP_BG", $("#BloodGroup_"+Id).val());
                sessionStorage.setItem("SOP_PN", $("#PatientName_"+Id).val());
                sessionStorage.setItem("SOP_GE", $("#Gender_" + Id).val());
                sessionStorage.setItem("SOP_IP", $("#IPNumber_" + Id).val());
                
                    
                window.open('../Revisit/LabResult?from=SOPWorkSheet', '_blank');
            }
            else if (Flag == 3) {   //Procedure Bill

            }
            else if (Flag == 4) {   //Reg Bill Copy

            }
        }
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
                "columnDefs": [
                                       { "width": "1%", "targets": 0 },
                                       { "width": "2%", "targets": 1 },
                                       { "width": "2%", "targets": 2 },
                                       { "width": "2%", "targets": 3 },
                                       { "width": "2%", "targets": 4 },
                                       { "width": "10%", "targets": 5 },
                                       { "width": "2%", "targets": 6 },
                                       { "width": "4%", "targets": 7 },
                                       { "width": "10%", "targets": 8 },
                                       { "width": "2%", "targets": 9 },
                                       { "width": "2%", "targets": 10 },
                                       { "width": "2%", "targets": 11 },
                ],

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        }
        else {
            table = $('#' + tablename).DataTable({
            });
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }


</script>