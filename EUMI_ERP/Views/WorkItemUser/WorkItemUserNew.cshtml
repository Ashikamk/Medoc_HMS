<style>
    .modal-slg {
        max-width: 700px;
    }
</style>
<script>
    var RemarkFlag = 0;

    $(document).ready(function () {

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        GetDepartment();
        GetDivision();



        $("#btnassign").click(function (e) {
            SaveAndUpdate()
        });
        $("#btncancel").click(function (e) {
            $('#TransferDiv').hide();
            $('#Remarks').prop("disabled", false)
            $('#ReasonDiv').show();
            $('#reason').text('Reason For Cancel:')
            $('#Remarks').focus();
        });
        $("#btntransfer").click(function (e) {
            $('#ReasonDiv').hide();
            $('#rsntransfer').prop("disabled", false);
            $('#transuser').prop("disabled", false);
            $('#TransferDiv').show();
            $('#rsntransfer').focus();

        });
        Defaultfocus();
       
        if ("@Request.QueryString["from"]" == "SalesInvoice") {
            var srlsrs = sessionStorage.getItem("sales_srs");
            var srlno = sessionStorage.getItem("sales_slno");
            var dep = sessionStorage.getItem("sales_deptid");
            var salesbillno = sessionStorage.getItem("sales_bill");
            var salesdesc = sessionStorage.getItem("sales_desc");
            sessionStorage.removeItem("sales_srs");
            sessionStorage.removeItem("sales_slno");
            sessionStorage.removeItem("sales_deptid");
            sessionStorage.removeItem("sales_desc");
            var numId = parseInt(srlsrs);
            var num = parseInt(srlno);
            var deprtid = parseInt(dep)
            if (!isNaN(numId) && !isNaN(num) && !isNaN(deprtid)) {
                GetSalesInvoceWorkItem(numId, num, deprtid,salesbillno, salesdesc);
                $('#popupdiv').show();
                $("#Department").focus();
                GetList(0);
                $("#Type").val(0);
                WorkItemNotifyVar = 0;
            }
            else {
                $('#popupdiv').show();
                $("#Department").focus();
                GetList(0);
                $("#Type").val(0);
                WorkItemNotifyVar = 0;
            }
        }            // FROM SALES INVOICE FOR CREATE NEW WORK ITEM
        
        else if ("@Request.QueryString["from"]" == "Layout") {
            var sorttype = sessionStorage.getItem("sort_type");
            sessionStorage.removeItem("sort_type");
            var worksorttype = parseInt(sorttype);
            if (!isNaN(worksorttype)) {
                $('#popupdiv').hide();
                GetList(worksorttype);
                $("#Type").val(worksorttype);
                WorkItemNotifyVar = 0;
            }
            else {
                $('#popupdiv').show();
                $("#Department").focus();
                GetList(0);
                $("#Type").val(0);
                WorkItemNotifyVar = 0;
            }
        }           // FROM LAYOUT TO CHECK BY TYPE
        else {
            $('#popupdiv').show();
            $("#Department").focus();
            GetList(0);
            $("#Type").val(0);
            WorkItemNotifyVar = 0;
        }

    });
</script>
<div class="myData" data-x="M134" />

