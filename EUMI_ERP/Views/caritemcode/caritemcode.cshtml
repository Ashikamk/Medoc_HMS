    function SaveandUpdate(flag)
    {
        if($('#hiddenitemId').val()==0)
        {
            warningshow('Please Enter Valid Chassis Number', "chassisnoid")
        }
       else if ($("#tblvcc tr").length < 0) {
        warningshow('Please Enter A Chassis Number')
       }
       else if (parseInt($("#AccountvccID").val()||0) == 0) {
           warningshow('Please Select Valid Account',"Accountvcc")
       }
       else if (parseFloat($('#amountid').val() || 0) == 0) {
           warningshow('Please Enter Amount', "amountid");
           $('#amountid').select();
       }
       else {
           rowcount = $('#tblvcc tr').length;
           $('#btnsubmit').prop('disabled', true);
           for (var k = 1; k < 2 ; k++) {
               var data = {};
               data.BillSlNo = $('#txtinvono' + k).val();
               data.ProductDescr = $.trim($('#txtdesc' + k).val());
               data.FromDate = $('#txtdate' + k).val();
               data.Amount = $('#txtamnt' + k).val();
               data.CashAdvnce = $('#txtadv' + k).val();
               data.balanceamt = $('#balamnt' + k).val();
               data.DelFlag = flag;
               data.ProductCode = $('#chassisnoid').val();
               data.acctype = $('#Accounttypeid').val();
               data.BlSlNo = $('#vccnoid').val();
               data.CustName = $('#txtcustomer').val();
               data.CustAddress = $('#addressid').val();
               data.DeptId = ERPDeptId;
               data.VCCDate = $('#date').val();
               data.UserId = ERPUserId;
               data.Location = UserLocationId;
               data.CustId = $('#txtCustId').val();
               data.ProductId = $('#hiddenitemId').val();
               data.CurrencyId = $('#select_crncy').val();
               data.CurrencyRate = $('#txtcrncyrate').val();
               data.VCCBaseAmount = $('#gndtotal').text();
               data.FCAmount = $('#amountid').val();
               data.AccountId = $("#AccountvccID").val();
               data.Account = $("#Accountvcc").val();


               //console.log(data.acctype)
               $.ajax({
                   type: "POST",
                   url: "../caritemcode/VCCInsertandUpdate",
                   data: data,
                   success: function (result) {
                       for (var i = 0; i < result.oList.length; i++) {
                           var status = result.oList[i].Status;
