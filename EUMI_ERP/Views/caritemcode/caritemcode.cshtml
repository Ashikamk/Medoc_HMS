<script>


    $(document).ready(function () {

        $('#chassisnoid').focus();

        $('#amountid').val(parseFloat(0).toFixed(Decimal));

        $('#date').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
        serialnoload();
        GetCurrency(0);

        $('#vccnoid').keyup(function (e) {
            e.preventDefault();           
            var entrkey = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (entrkey == 8) {
                clearbox();                
            }
        });



        $('#Accountvcc').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 8) {
                $("#AccountvccID").val(0);
            }

        });

    });




    function closewarning() {
        $('#alertpopupy').fadeOut();
    }
    function warningpopupshow(message, Id) {
        $('#type-error').text(message);
        $('#alertpopupy').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#alertpopupy').hide();
        }, 3000);
    }
    function warningpopupshown(message, Id) {
        $('#type-show').text(message);
        $('#alertpopupn').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#alertpopupn').hide();
        }, 3000);
    }


    $('#label').css('color', 'blue');
    $('#label').css({ 'font-weight': 'bold' });

    $('#amtid').css('color', 'black');
    $('#amtid').css({ 'font-weight': 'bold' });

    $('#vccid').css('color', 'orange');
    $('#vccid').css({ 'font-weight': 'bold' });

    $('#amountid').css('color', 'black');
    $('#amountid').css({ 'font-weight': 'bold' });
    $('#chassisnoid').css('color', 'black');
    $('#chassisnoid').css({ 'font-weight': 'bold' });



    function Addpopupwindow(Id) {
        $("#popupdiv").css("margin-top", '0px');
        $('#currencydiv').hide(); $('#areadiv').hide();
        $('#locationdiv').hide(); $('#salesmandiv').hide();
        $('#termsdiv').hide();
        $('#popupdiv').show();

        if (Id == 1) {
            $('#myheader').text('Currency');
            $('#currencydiv').show();
            $('#txt_code').focus();
        }
    }





    var BaseCurrency;

    function CurncyLoad(result, a) {
        $("#select_crncy").empty();
        for (var i = 0; i < result.length; i++) {
            if (result[i].BaseCurrencyId != 0) {
                BaseCurrency = result[i].BaseCurrencyId;
            }
        }
        $("#select_crncy").append("<option value='0'>--Select--</option>");

        for (var i = 0; i < result.length; i++) {
            $("#select_crncy").append("<option value='" + result[i].Id + "' name='" + result[i].CurrencyRate + "'>" + result[i].CurrencyName + "</option>");
        }
        if (a == 0) {
            $('#select_crncy').val(BaseCurrency);
            $('#txtcrncyrate').val($('#select_crncy').find("option:selected").attr("name"));

        }
        else {
            $('#select_crncy').val(a);
            $('#txtcrncyrate').val($('#select_crncy').find("option:selected").attr("name"));
        }
    }

    function CurrencyChange(Id) {
        $('#txtcrncyrate').val($('#' + Id).find("option:selected").attr("name"));
    }


    function GetCurrency(id) {

        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CurrencyGetandGets",
            data: data,
            success: function (result) {
                CurncyLoad(result.oList, id);
            }
        });
    }


    $('#txtcrncyrate').keyup(function (e) {

        for (j = 0; j <= i; j++) {
            amountcalculation(j);
        }
        CalcGrandTotal(i);
    });




    function Defaultfocus() {
        $('#chassisnoid').fous();
    }







    $("#txtcustomer").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#txtcustomer").val();
            data.CustType = 'C';
            $.ajax({
