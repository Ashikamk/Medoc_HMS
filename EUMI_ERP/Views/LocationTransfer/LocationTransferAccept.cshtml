    function transferload()
    {
        var data = {};
        data.LocTransId = 0;
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../LocationTransfer/LocationTransferGetandGets",
            data: data,
            success: function (result) {
                disable_datatable('tblLocationTransferTransport');
                ShowLocationTransferlist(result.oList);
              
            }
        });
    }
    var LocationSelect = '';
    function LocationLoad(result) {                     
        for (var m= 0; m < result.length; m++) {
            LocationSelect += "<option value='" + result[m].LocationId + "'>" + result[m].LocationName + "</option>";
        }
        transferload();
    }

