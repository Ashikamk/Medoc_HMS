            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);
                console.log(result[i].FromLoad+'val')
                console.log(slno + 'slno')
                $('#txttype1' + slno).val(result[i].FromLoad);
                $('#txttype2' + slno).val(result[i].ToLoad);
