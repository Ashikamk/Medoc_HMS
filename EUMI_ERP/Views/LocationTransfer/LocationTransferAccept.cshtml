            for (var i = 0; i < result.length; i++) {
               
                var slno = parseInt(i + 1);               
                //responseText += '<tr  id="editrow' + slno + '" style="display:none"><td>' + slno + '</td><td>' + result[i].TransferDate + '</td><td>' + result[i].ChasisNumber + '</td><td>' + result[i].Description + '</td><td><select   id="txttype1' + slno + '" class="form-control" style="width:160px;height:33px;"  disabled>' + LocationSelect + '</select><input type=text id="temptxttype1' + slno + '"  value=' + result[i].FromLoad + ' style="display:none;" /> </td><td> <select   id="txttype2' + slno + '" class="form-control" style="width:160px;height:33px;" disabled >"' + LocationSelect + '" <input type=text id="temptxttype2' + slno + '"  value=' + result[i].ToLoad + ' style="display:none;" /></select></td><td><select id= ' + 'txtkey' + slno + '  class="form-control" style="width:140px;height:33px;" disabled><option value="No">No</option><option value="Yes">Yes</option><input type=text  style="display:none;"  id="temptxtkey' + slno + '"  value=' + result[i].ItemKey + '></text> </td><td>' + result[i].UserName + '</td>' +
                //    '<td   align=center id="txteditrow' + slno + '"  ><a   onclick="EditRows(' + slno + ')">' + tempEditbutton + '</a></td>' +
                //  ' <td  align=left id="txtupdaterow' + slno + '" style="display:none;"> <a  style="float:left" onclick="UpdateRows(' + result[i].ItemId + ',' + slno + ',' + result[i].LocTransId + ')">' + tempUpdatebutton + '</a><a  style="float:right" onclick="CancelRows(' + slno + ')">' + Cancelbutton + '</a></td>' +
                //    '<td align=center><a onclick="GetRows(' + result[i].ItemId + ',' + result[i].FromLoad + ',' + result[i].ToLoad + ',' + result[i].LocTransId + ',' + slno + ')">' + Acceptbutton + '</a></td><td align=center><a onclick="DeleteLocationTrnsfer(' + result[i].LocTransId + ')">' + DeleteButton + '</a></td></tr>';

                responseText += '<tr id="listrow' + slno + '"><td>' + slno + '</td>' +
                    '<td>' + result[i].TransferDate + '</td>' +
