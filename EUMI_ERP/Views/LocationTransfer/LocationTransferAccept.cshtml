                    '<td class="tdedit" style="display:none"><select   id="txttype1' + slno + '" class="form-control" style="width:160px;height:33px;"  disabled>' + LocationSelect + '</select><input type=text id="temptxttype1' + slno + '"  value=' + result[i].FromLoad + ' style="display:none;" /></td>' +
                    '<td class="tdhide">' + result[i].LoadTo + ' </td>' +
                    '<td class="tdedit"  style="display:none"><select   id="txttype2' + slno + '" class="form-control" style="width:160px;height:33px;" disabled >"' + LocationSelect + '" <input type=text id="temptxttype2' + slno + '"  value=' + result[i].ToLoad + ' style="display:none;" /></select></td>' +
