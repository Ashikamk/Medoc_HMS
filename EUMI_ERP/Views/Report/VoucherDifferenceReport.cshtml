
@{
    ViewBag.Title = "VoucherDifferenceReport";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<div class="myData" data-x="M207" />


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                <div>
                    <table style="width:100%" >
                        <tr>
                            <td><h4 id="header">Transaction Difference Report</h4></td>
                            <td width="35%"></td>
                            <td align="right">
                                <div class="btn-group" id="buttonPlace">
                                    <div align="right">
                                        <div class="heading-elements">
                                            <div class="btn-group" id="buttonPlace">
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </td>

                        </tr>
                    </table>
                    <div align="right">
                        <div class="heading-elements">
                            <br /><hr />
                            <div id="divreport" >
                                <table id="tblvoucherrpt" class="table table-striped table-bordered base-style dataTable"></table><br />
                            </div>
                            @*<div>
                                <table id="tblvoucherrpt"></table>
                            </div>*@

                            <br /><br />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(document).ready(function () {      
        $.ajax({
            type: "POST",
            url: "../Report/VoucherDiffReportGetsandGets",
            success: function (result) {             
                    Showlist(result.oList);
             
            }
        });
    });

    function Showlist(result) {
       
        disable_datatable('tblvoucherrpt');
        var responseText = "<thead><tr><th width=15px>Slno</th><th>Department Name</th><th>Voucher Type</th><th>Voucher Number</th><th>Date</th><th>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
        
            var slno = parseInt(i + 1);
            responseText += '<tr><td>' + slno + '</td><td>' + result[i].DepartmentName + '</td><td>' + result[i].TYPE + ' - ' + result[i].Description + '</td><td>' + result[i].VOUCHERNO + '</td><td>' + result[i].Date + '</td><td style="float:right">' + parseFloat(result[i].AMOUNT || 0).toFixed(Decimal) + '</td></tr>';
        }
        $('#tblvoucherrpt').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Department Name</th><th>Voucher Type</th><th>Voucher Number</th><th>Date</th><th>Amount</th></tr></tfoot>');
        //datatableWithsearch('tblvoucherrpt');
        var title = 'Transaction Difference Report';
        datatableWithsearch('tblvoucherrpt', true, title, 'buttonPlace');

    }
</script>


