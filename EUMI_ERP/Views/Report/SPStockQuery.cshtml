<script type="text/javascript">

            $(document).ready(function () {
                var decimal = (window.Decimal || 1);
                    var table = $("#productlist").EumiDataTable({
                        "processing": true,
                        "serverSide": true,
                        "ajax": {
                            "url": "../Report/SPStockQueryJson",
                            "type": "POST",
                        },
                 
                            "columnDefs": [
                            {
                            "targets": 0,
                            "className": "SLNO",
                            "className": "text-center"
                            },
                            {
                            "targets": 4,
                            "className": "text-right",
                            "render": function (data) {
                                return (data || 0).toFixed(decimal);
                            }
                            },
                            {
                            "targets": 5,
                            "className": "text-right",
                            "render": function (data) {
                            return (data || 0).toFixed(decimal);
                            }
                            },
                            {
                                "targets": 10,

                                "className": "text-center",
                            },
                            ],
                            "columns": [
                            { data: "ItemId", data: "OpeningCost", data: "OpenQty", data: "DeptId", data: "slno", title: "Sl#", searchable: false, sortable: false },
                            { data: "ItemCode", title: "Item Code" },
                            { data: "Description", title: "Item Name" },
                            { data: "Stock", title: "Stock" },
                            { data: "Cost", title: "Cost" },
                            { data: "Price", title: "Price" },
                            { data: "GrpName", title: "Group" },
                             { data: "SbgrpName", title: "Sub Group" },
                             { data: "CategoryName", title: "Category" },
                              { data: "SubCategoryName", title: "Sub Category" },
                            { data: "View", data: "GroupId", data: "CategoryId", title: "View", searchable: false, sortable: false }
                                ],
                        "createdRow": function (row, data, index) {
                            row.getElementsByTagName("td")[10].innerHTML = '<a  onclick="GetItem(' + data.ItemId + ',' + data.GroupId + ',' + data.CategoryId + ');">' + Eyebutton + '</a>';
                         //   if (row.getElementsByTagName("td")[3].innerHTML == '0') {
                         //       $(row).css('background-color', '#ffe6e6');
                         //   }
                         //  else if (row.getElementsByTagName("td")[3].innerHTML >= '0') {
                         //      $(row).css('background-color', '#c6ebd8');
                         //  }
                         //  else if (row.getElementsByTagName("td")[3].innerHTML <= '0') {
                         //      $(row).css('background-color', '#d1e0e0');
                         //}

                         
                        },
                        orderCellsTop: true,

                    });


                    var a = '#productlist tr:eq(1) th'

                    $(a).each(function () {
                        var title = $(this).text();
                        if (title != '')
                            if (title == 'Year' || title == 'Color') {
                                $(this).html('<input type="text" class="forsearch"  style="width:80px"  placeholder="' + title + '"/>')
                            }
                            else if (title == 'Group' || title == 'Sub Group' || title == 'Auction') {
                                $(this).html('<input type="text" class="forsearch"  style="width:120px"  placeholder="' + title + '"/>')
                            }
                            else {
                                $(this).html('<input type="text" class="forsearch"   placeholder="' + title + '"/>')
                            }

                    });

                    var table = $('#productlist').DataTable();
                    var allow = 0;

                    table.columns().every(function (index) {

                        $('#productlist thead tr:eq(1) th:eq(' + index + ') input').on('keyup change', function () {

                            if (allow == 1) {
                                table.column($(this).parent().index() + ':visible')
                                                                .search(this.value)
                                                               .draw();
                                allow = 0;
                            }

                        });

                    });

                    $('.forsearch').keydown(function (e) {
                        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;

                        if (key == 13) {
                            allow = 1;
                        }

                        //else if (key == 8 && $('.forsearch').val() == '')
