
@{
    ViewBag.Title = "ProductionEntryReport";
}


<style type="text/css">
    .main-panel {
        height: auto;
        width: auto;
        max-height: none;
        min-height: 100%;
        margin: 0;
        padding-top: 85px;
        float: none;
    }

    .eumi-search-box {
        box-sizing: border-box;
        width: 100%;
    }

    body.eumi-loader::before {
        content: '';
        display: block;
        position: fixed;
        z-index: 31000;
        height: 4px;
        background-color: rgba(0, 157, 160, 0.2);
        top: 0;
        left: 0;
        right: 0;
    }

    body.eumi-loader::after {
        content: '';
        display: block;
        position: fixed;
        z-index: 31001;
        height: 4px;
        background-color: rgba(0, 157, 160, 1);
        top: 0;
        width: 50px;
        animation: eumiloader 4s infinite linear;
    }

    .eumi-search-table, .eumi-shadow {
        border-spacing: 0 0px;
        box-shadow: 0px 0px 0px 2px #fff, 0 0 2px 2px #999;
    }
    /* .eumi-search-table tbody td { border:none; } */
    @@keyframes eumiloader {
        from {
            right: 100%;
        }

        to {
            right: 0;
        }
    }

    
        .form-control {
        font-weight: bold;
    }
     #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnclose:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnchgp:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
         #btnColVisibility:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
      #btnGroupDropDownload:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
       #ClearSearch:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>
<div class="myData" data-x="M118" />
<div class="card">
    <div class="row m-1">
        <div class="col-md-6">
            <h3>Production Entry Report</h3>
        </div>
        <div class="col-md-6 eumi-button-area" id="divReportOptions" data-download-url="@Url.Action("ProductionEntryReportDownload", "Report")">


            <div class="btn-group" role="group">
                <button id="btnColVisibility" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Columns
                </button>
                <div class="dropdown-menu eumi-col-show" aria-labelledby="btnColVisibility">
                </div>
            </div>

            <button type="button" id="btnchgp" class="btn btn-primary" data-toggle="modal" data-target="#paramModal">Change Parameters</button>

            <div class="btn-group excelexport" role="group">
                <button id="btnGroupDropDownload" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Export
                </button>
                <div class="dropdown-menu" aria-labelledby="btnGroupDropDownload">
                    <a class="dropdown-item buttons-excel" data-eumi-download="excel" href="#">Excel</a>
                    <a class="dropdown-item buttons-pdf" data-eumi-download="pdf" href="#">PDF</a>
                    <a class="dropdown-item buttons-csv" data-eumi-download="csv" href="#">CSV</a>
                    <a class="dropdown-item buttons-print" data-eumi-download="print" href="#">Print</a>
                </div>
            </div>
            <button class="btn btn-outline-primary" data-eumi-clear="1" type="button">Clear Search</button>
        </div>       
    </div>


    <div id="popup" style="display:none;">
        <div class="row m-1">
            <div id="paramOfReport" class="row m-1"></div>
        </div>

        <div style="overflow:auto;">
            <table id="ProdEntryReport" class="table table-condensed table-light table-striped table-bordered eumi-search-table" style="width:3000px; margin: 0 auto 0 0;">
                <tfoot>
                    <tr class="eumi-search-row">
                        <th></th>
                        <th>Production#</th>
                        <th>Date</th>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Location</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th>Job Code</th>
                        <th>Department</th>
                    </tr>
                    <tr>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th>Grand Total</th>
                        <th></th>
                        <th id="eumiQuantity" class="text-right">Quantity</th>
                        <th id="eumiCostPerItem" class="text-right">Cost Per Item</th>
                        <th id="eumiTotalProdCost" class="text-right">Total Production Cost</th>
                        <th id="eumiTotalOtherCost" class="text-right">Total Other Cost</th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
<div style="height:100px;clear: both">
    &nbsp;
</div>


<script type="text/javascript">
    $(document).ready(function () {
        $('#UserId').val(ERPUserId);

        $('#btnchgp').click();
        $('#Product').focus();
            var decimal = (window.Decimal || 1);
            window.EumiLastSelectedInProdEntryRpt= null;
            var table = $('#ProdEntryReport').EumiDataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "../Report/ProductionEntryReportJson",
                    "type": "POST",
                    "data": function (data, settings) {
                        var addData = (window.EumiLastSelectedInProdEntryRpt || {});
                        addData.dateFrom = moment(addData.dateFrom || new Date()).format("YYYY-MM-DD");
                        addData.dateTo = moment(addData.dateTo || new Date()).format("YYYY-MM-DD");
                        addData.Product = (addData.Product || 0);
                        addData.Jobcode = (addData.Jobcode || 0);
                        addData.Department = (addData.Department || 0);
                        addData.UserId = (addData.UserId || 0);

                        if (!addData.title) {
                            addData.title = "Parameters - " + "From: " + moment(new Date()).format("DD-MM-YYYY") + " To: " + moment(new Date()).format("DD-MM-YYYY")
                            $("#paramOfReport").text(addData.title);
                        }
                        data.addData = addData;
                        $("#eumiQuantity").text(0);
                        $("#eumiCostPerItem").text(parseFloat(0).toFixed(decimal));
                        $("#eumiTotalProdCost").text(parseFloat(0).toFixed(decimal));
                        $("#eumiTotalOtherCost").text(parseFloat(0).toFixed(decimal));
                    }
                },
                "columnDefs": [
                    {
                        "targets": 0,
                        "className": "text-center",
                    },
                    {
                        "targets": 1,
                         "width":"1%",
                    },
                  
                    {
                        "targets": 3,
                        "width": "25%",
                    },
                      {
                          "targets": 4,
                          "width": "20%",
                      },
                    {
                    "targets": 6,
                    "className": "text-right",
                   
                },
                {
                    "targets": 7,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                {
                    "targets": 8,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                  {
                      "targets": 9,
                      "className": "text-right",
                      "render": function (data) {
                          return (data || 0).toFixed(decimal);
                      }
                  }, ],
                "columns": [
                    { data: "slno", title: "Sl#", searchable: false, sortable: false },
                    { data: "ProEntryNo", title: "Production#", sortable: false },
                    { data: "ProEntryDate", title: "Date", sortable: false },
                    { data: "ItemCode", title: "Item Code", sortable: false },
                     { data: "ItemName", title: "Item Name", sortable: false },
                    { data: "LocationName", title: "Location", sortable: false },
                    { data: "ProductionQuantity", title: "Production Qty.", sortable: false },
                    { data: "CostPerItem", title: "Cost Per Item", sortable: false },
                    { data: "TotalProdCost", title: "Total Production Cost", sortable: false },
                    { data: "TotalOtherCost", title: "Total Other Cost", sortable: false },
                    { data: "JobCode", title: "Job Code", sortable: false },
                    { data: "DepartmentName", title: "Dept.Code", sortable: false },
                ],
                "createdRow": function (row, data, index) {
                    if (index == 0) {
                        $("#eumiQuantity").text(data._ProductionQuantity);
                        $("#eumiCostPerItem").text(data._CostPerItem.toFixed(decimal));
                        $("#eumiTotalProdCost").text(data._TotalProdCost.toFixed(decimal));
                        $("#eumiTotalOtherCost").text(data._TotalOtherCost.toFixed(decimal));
                        console.log(index);
                    }
                },
            });

            $('#ProdEntryReport tbody').on('click', 'tr', function () {

            });
            $('#Product').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#Jobcode').focus();
                    e.preventDefault();
                }
            });

            $('#Jobcode').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#Dept').focus();
                    e.preventDefault();
                }
            });

            $('#Dept').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#btnsubmit').focus();
                    e.preventDefault();
                }
            });
        });
</script>


