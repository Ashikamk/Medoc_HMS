<script type="text/javascript">

            $(document).ready(function () {
                var decimal = (window.Decimal || 1);
                    var table = $("#productlist").EumiDataTable({
                        "processing": true,
                        "serverSide": true,
                        "ajax": {
                            "url": "../Report/MobileStockQueryJson",
                            "type": "POST",
                        },

                        "columnDefs": [
                             {
                                 "targets": 0,                              
                                 "className": "text-center",
                             },
                         {
                         "targets": 10,
                         "className": "text-right",
                          "render": function (data) {
                          return (data || 0).toFixed(decimal);
                         }
                         },
                         {
                         "targets": 11,
                         "className": "text-right",
                          "render": function (data) {
                             return (data || 0).toFixed(decimal);
                            }
                         },
                           {
                               "targets": 12,
                               "className": "text-center",
                           },
                        ],
                        "columns": [
                            { data: "ItemId", data: "OpenQty", data: "DeptId", data: "slno", title: "Sl#", searchable: false, sortable: false },
                            { data: "ItemCode", title: "Item Code" },
                            { data: "Description", title: "Item Name" },
                            { data: "UnitName", title: "Unit" },
                           { data: "Quantity", title: "Quantity" },
                            { data: "GrpName", title: "Group" },
                            { data: "SbgrpName", title: "Sub Group" },
                            { data: "CategoryName", title: "Category" },
                            { data: "SubCategoryName", title: "Subcategory" },
                             { data: "Department", title: "Department" },
                            { data: "SellingPrice", title: "Selling Price" },
                            { data: "AvgCost", title: "Average Cost" },
                           { data: "View", title: "IMEI", searchable: false, sortable: false }
                        ],


                        "createdRow": function (row, data, index) {
                            row.getElementsByTagName("td")[12].innerHTML = '<a  onclick="GetRows(' + data.ItemId + ');">' + IMEI + '</a>';
                        },

                    });

                    $('#productlist tbody').on('click', 'tr', function () {
                        var table = $("#productlist").DataTable();
                        var data = table.row(this).data();
                        
                        $('#ProductId').val(data.ItemId);
                        $('#ItemCode').val(data.ItemCode);
                        $('#ItemDescription').val(data.Description);
                        //ClosePurTransPopup();
                        //salestranspopuprefresh();
                       
                    });

                  
                    $(document).keydown(function (e) {
                        if (e.altKey && e.keyCode == 49) {
                            if ($('#ProductId').val() == 0) {
                                warningshow('Please Select Valid Product', 'ProductId');
                            }
                            else {
                                IMEIPurchasespopup($('#IMEI_Number').val());
                                $('#IMEIPopup').hide();
                            }
                        }
                        else if (e.altKey && e.keyCode == 50) {
                            if ($('#ProductId').val() == 0) {
                                warningshow('Please Select Valid Product', 'ProductId');
                            }
                            else {
                                IMEISalespopup($('#IMEI_Number').val());
                                $('#IMEIPurchasePoup').hide();
                                $('#IMEIPopup').hide();
                            }
                        }

                        else if (e.keyCode == 27) {                  //ESC       :   Popup Close
                            IMEIpopuprefresh();
                        }
                    });
             
                       
                    $("#btnstock").click(function (e) {
                        itempopup($('#ProductId').val());
                        $("#salestransdiv").hide();
                        $("#purchasetrans").hide();
                        $("#transdiv").hide();
                        $("#IMEIdiv").hide();
                        $('#Available').prop("checked", false);
                    });
                    $("#btnpurchase").click(function (e) {
                        Purchasespopup($('#ProductId').val());
                        $("#productdiv").hide();
                        $("#IMEIdiv").hide();
                        $("#salestransdiv").hide();
                        $("#transdiv").hide();
                        $('#Available').prop("checked", false);
                    });
                    $("#btnsales").click(function (e) {
                        Salespopup($('#ProductId').val());
                        $("#productdiv").hide();
                        $("#IMEIdiv").hide();
                        $("#transdiv").hide();
                        $("#purchasetrans").hide();
                        $('#Available').prop("checked", false);
                    });
