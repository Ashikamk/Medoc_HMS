                                <td align="right">
                                    <div class="col-md-6 eumi-button-area" id="divReportOptions" data-download-url="@Url.Action("MobileStockQueryDownload", "Report")">


                                        <div class="btn-group" role="group">
                                            <button class="btn btn-outline-primary" id="btnGo" onclick="window.open('../Master/ItemMaster')" type="button">Add Product</button>
                                        </div>
