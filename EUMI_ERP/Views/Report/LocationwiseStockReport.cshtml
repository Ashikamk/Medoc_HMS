        function GetLocationwiseStock() {
            $('#Loading').show();
            disable_datatable('Locationwisetbl', 'itemListButtonPlace');
            $('#Locationwisetbl thead').remove();
            $('#Locationwisetbl tbody').remove();
            $('#Locationwisetbl tfoot').remove();



            var Condition = "1=1"
            var Condition1 = "1=1"
            var Type = 0;
            
           
            if ($("#Location").val() != 0) {
                Type = 1;
                Condition = Condition + " AND Stock_Location=" + $('#Location').val();

                if ($('#StockType').val() == 'In Stock') {
                    
                    Condition = Condition + " AND isnull(StockQty,0) > 0"
                }
                if ($('#StockType').val() == 'Zero Stock') {
                    
                    Condition = Condition + "  AND isnull(StockQty,0) = 0"
                }
                if ($('#StockType').val() == 'Negative Stock') {
                   
                    Condition = Condition + "  AND isnull(StockQty,0) < 0"
                }
                if ($('#StockType').val() == 'Non-Zero') {
                   
                    Condition = Condition + " AND isnull(StockQty,0) != 0"
                }

                if ($('#Group').val() != 0) {
                    
                    Condition = Condition + " and GroupId=" + $('#Group').val();
                }
                if ($('#SubGroup').val() != 0) {
                    
                    Condition = Condition + " and SubGroupId=" + $('#SubGroup').val();
                }
                if ($('#Category').val() != 0) {
                    
                    Condition = Condition + " and CategoryId=" + $('#Category').val();
                }
                if ($('#SubCategory').val() != 0) {
                    
                    Condition = Condition + " and SubCategoryId=" + $('#SubCategory').val();
                }
            }
            else{
                Type = 0;


                if ($('#StockType').val() == 'In Stock') {

                    Condition1 = Condition1 + " AND isnull(StockQty,0) > 0"
                }
                if ($('#StockType').val() == 'Zero Stock') {

                    Condition1 = Condition1 + " AND isnull(StockQty,0) = 0"
                }
                if ($('#StockType').val() == 'Negative Stock') {

                    Condition1 = Condition1 + " AND isnull(StockQty,0) < 0"
                }
                if ($('#StockType').val() == 'Non-Zero') {

                    Condition1 = Condition1 + " AND isnull(StockQty,0) != 0 "
                }

                if ($('#Group').val() != 0) {

                    Condition1 = Condition1 + " and GroupId=" + $('#Group').val();
                }
                if ($('#SubGroup').val() != 0) {

                    Condition1 = Condition1 + " and SubGroupId=" + $('#SubGroup').val();
                }
                if ($('#Category').val() != 0) {

                    Condition1 = Condition1 + " and CategoryId=" + $('#Category').val();
                }
                if ($('#SubCategory').val() != 0) {

                    Condition1 = Condition1 + " and SubCategoryId=" + $('#SubCategory').val();
                }


            }
            

         

            var data = {};
            data.Condition = Condition;
            data.Condition1 = Condition1;
            data.ToDate = $('#ToDate').val();
            data.Type = Type;
           
            $.ajax({
                type: "POST",
                url: "../Report/DetailedStock",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    if (($('#hidecost').prop("checked")) && ($('#hidestock').prop("checked")) && ($('#detailed').prop("checked"))) {
                        LoadDetailsAllhideDetails(result);
                    }
                    else if (($('#hidecost').prop("checked")) && ($('#detailed').prop("checked"))) {
                        LoadDetailsAllhidecost(result);
                    }
                    else if (($('#hidestock').prop("checked")) && ($('#detailed').prop("checked"))) {
                        LoadDetailsAllhidestock(result);
                    }

                    else if ($('#detailed').prop("checked")) {
                        LoadDetailsAll(result);
                    }

                    else if (($('#hidecost').prop("checked")) && ($('#hidestock').prop("checked"))) {
                        LoadDetailshidedeatils(result);
                    }

                    else if ($('#hidecost').prop("checked")) {
                        LoadDetailshidecost(result);
                    }
                    else if ($('#hidestock').prop("checked")) {
                        LoadDetailshidestockvalue(result);
                    }
                    else {
                        LoadDetails(result);
                    }
                }
            });

        }

        function LoadDetails(result)
        {
            $('#paramOfReport').text('');
            $('#Loc').text('');
            $('#Groupparam').text('');
            $('#SubGroupparam').text('');
            $('#Catparam').text('');
            $('#SubCatparam').text('');
            disable_datatable('Locationwisetbl', 'itemListButtonPlace');

            var responseText = "<thead><tr><th>Sl#</th><th width=500px>Item Code</th><th width=1450px>Item Name</th><th width=10px>Qty.</th><th class='text-right' width=10px>Cost</th><th class='text-right' width=130px>Stock Value</th></tr></thead><tbody>";

            for (var i = 0; i < result.length; i++) {
                if (result[i].ItemDesc != 'Grand Total')
                {

                    responseText += "<tr class='jsgrid-row' >" +
             "<td class='text-left'> " + (i + 1) + " </td>" +
             "<td id='Col1_" + i + "' class='text-left'>" + result[i].ItemCode + "</td>" +
             "<td id='Col2_" + i + "' class='text-left'>" + result[i].ItemDesc + "</td>" +
             "<td id='Col3_" + i + "' class='text-left'>" + parseInt(result[i].StockQty || 0) + "</td>" +
             "<td id='Col4_" + i + "' class='text-right'>" + parseFloat(result[i].AvgCost || 0).toFixed(Decimal) + "</td>" +
             "<td id='Col5_" + i + "' class='text-right'>" + parseFloat(result[i].StockValue || 0).toFixed(Decimal) + "</td>" +
             "</tr>";
                }

                else
                {
                    responseText += "<tr  style=background-color:#cfd8dc  class='jsgrid-row' >" +
                    "<td class='text-left'> " + (i + 1) + " </td>" +
                    "<td id='Col1_" + i + "' class='text-left'>" + result[i].ItemCode + "</td>" +
                    "<td id='Col2_" + i + "' class='text-left'><b>" + result[i].ItemDesc + "</b></td>" +
                    "<td id='Col3_" + i + "' class='text-left'><b>" + parseInt(result[i].StockQty || 0) + "</b></td>" +
                    "<td id='Col4_" + i + "' class='text-right'>" + result[i].AvgCost + "</td>" +
                    "<td id='Col5_" + i + "' class='text-right'><b>" + parseFloat(result[i].StockValue || 0).toFixed(Decimal) + "</b></td>" +
         "</tr>";

                }

            }
            $('#Loading').hide();
            $('#Locationwisetbl').append(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Item Code</th><th>Item Name</th><th> </th><th> </th><th> </th></tr></tfoot>');
            $('#Tblreportprint').html(responseText)
            datatableWithsearch('Locationwisetbl', true, 'Detailed Stock Report', 'itemListButtonPlace');
            $('#popup').show();
            $('#header').text('Stock Report');
            $('#ResultLength').val(result.length);
            $('#paramOfReport').append('As On <b>' + $('#ToDate').val()+'</b>')
            Parameter();

        }


        function LoadDetailsAll(result) {
            $('#paramOfReport').text('');
            $('#Loc').text('');
            $('#Groupparam').text('');
            $('#SubGroupparam').text('');
            $('#Catparam').text('');
