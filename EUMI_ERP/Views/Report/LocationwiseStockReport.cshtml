<script type="text/javascript">
    $(document).ready(function () {
        $('#btnchgp').click();




        $('#Location').focus();
        var decimal = (window.Decimal || 1);

        $('#Location').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#StockType').focus();
                e.preventDefault();
            }
        });

        $('#StockType').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Group').focus();
                e.preventDefault();
            }
        });
        $('#Group').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#SubGroup').focus();
                e.preventDefault();
            }
        });
        $('#SubGroup').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Category').focus();
                e.preventDefault();
            }
        });
        $('#Category').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#SubCategory').focus();
                e.preventDefault();
            }
        });
        $('#SubCategory').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $('#ToDate').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });



    });
</script>

@section popups {
