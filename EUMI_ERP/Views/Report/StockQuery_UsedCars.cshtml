    function userLoad() {
        var data = {};
        data.UserId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/UsersGetandGets",
            data: data,
            success: function (result) {
                if (result.oList.length > 0) {
                    $("#userid").empty();
                    $("#userid").append("<option value='0' Fee='0'>Select</option>");
                    for (var i = 0; i < result.oList.length; i++) {
                        $("#userid").append("<option value='" + result.oList[i].UserId + "'>" + result.oList[i].Name + "</option>");
                    }
                }
            }
        });
    }

    function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');

        });
        var table = null;
        if (download) {

            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                            "<'row'<'col-sm-12'tr>>" +
                            "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
                

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            messageTop: $.trim(CompanySettingsArray.CompanyName) + ',' + CompanySettingsArray.Address + ',' + CompanySettingsArray.PhoneNo,
                            title: title,
                           // exportOptions: { columns: [0, 1, 2,3,4,5] }
                        },
                        {
                            extend: 'pdfHtml5',
                            messageTop: $.trim(CompanySettingsArray.CompanyName) + ',' + CompanySettingsArray.Address + ',' + CompanySettingsArray.PhoneNo,
                            title: title,
                            //exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
                        },
                        {
                            extend: 'print',
                            messageTop: $.trim(CompanySettingsArray.CompanyName) + ',' + CompanySettingsArray.Address + ',' + CompanySettingsArray.PhoneNo,
                            title: title,
                           // exportOptions: { columns: [0, 4, 5,8,9,10] }
                        }
                    ]
                },
                'colvis'
                ],

            });

            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");



        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
    }


