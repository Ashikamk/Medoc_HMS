<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; ">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Collection Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup">
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:11%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:4%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%;display:none">

                        <label style="margin-top:2%;font-weight:bold;margin-left:8%">&#160;&#160;&#160;Type&#160;&#160;&#160;&#160;</label>
                        <div class="col-md-9" style="margin-top:2%">
                            <select type="text" id="Doctor" maxlength="100" class="form-control">
                                <option value="0">Detailed</option>
                                <option value="1">Summary</option>

                            </select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:2%">

                        <label style="margin-top:2%;font-weight:bold;margin-left:8%">&#160;&#160;&#160;User&#160;&#160;&#160;</label>
                        <div class="col-md-9" style="margin-top:2%">
                            <select type="text" id="userid" maxlength="100" class="form-control">
                               
                            </select>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:6%" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="LabBillLength" class="form-control" />
                </div>
            </form>

        </div>
    </div>
</div>

