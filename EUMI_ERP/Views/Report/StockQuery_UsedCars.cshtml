        function Showreportproc(result) {
            disable_datatable('Tblreportproc', 'buttonPlace1');
            var responseText = "<thead><tr><th align= center>Sl#</th><th>Bill No</th><th>Reg No</th><th>Patient</th><th style='text-align:right;'> Amount</th><th style='text-align:right;'> Discount</th><th style='text-align:right;'>Total Amount</th></tr></thead><tbody>";
            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);
                if (result[i].BillNo == '0') {
                    responseText += '<tr style=background-color:#d3d3d3><td align= center id = Col1_' + slno + '>' + slno + '</td><td  id= Col7_' + slno + '>' + " " + '</td><td id= Col2_' + slno + '>' + result[i].BillDate + '</td><td id= Col3_' + slno + '><b>' + result[i].Name + '</b></td><td align= right id= Col10_' + slno + '><b>' + parseFloat(result[i].NetAmt).toFixed(Decimal) + '</b></td><td align=right id= Col9_' + slno + '><b>' + parseFloat(result[i].DiscAmt).toFixed(Decimal) + '</b></td><td align = right  id= Col11_' + slno + '><b>' + parseFloat(result[i].TotalAmt).toFixed(Decimal) + '</b></td></tr>';
                }
                else {
                    responseText += '<tr ><td align= center id = Col1_' + slno + '>' + slno + '</td><td id= Col5_' + slno + '><b>' + result[i].BillNo + '</b></td><td id= Col6_' + slno + '><b>' + result[i].RegNo + '</b></td><td id= Col3_' + slno + '><b>' + result[i].Name + '</b></td><td align= right id= Col10_' + slno + '><b>' + parseFloat(result[i].NetAmt).toFixed(Decimal) + '</b></td><td align=right id= Col9_' + slno + '><b>' + parseFloat(result[i].DiscAmt).toFixed(Decimal) + '</b></td><td align = right  id= Col11_' + slno + '><b>' + parseFloat(result[i].TotalAmt).toFixed(Decimal) + '</b></td></tr>';

                }
