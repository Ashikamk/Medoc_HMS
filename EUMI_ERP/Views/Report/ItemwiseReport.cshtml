@section popups {
    <div class="modal" id="paramModal" style="margin-top:10%">
        <div class="modal-dialog">
            <div class="modal-content" style="height:100%;width:110%">

                <!-- Modal Header -->
                <div class="modal-header bg-primary white">
                    <h4 class="modal-title">Itemwise Report</h4>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Modal body -->
                <div class="modal-body">
              
                    <div class="row">
                        <label style="font-weight:bold;margin-left:11%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="dateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:10.5%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="dateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row"  style="margin-top:2%">
                        <label style="margin-top:2%;font-weight:bold;margin-left:12%">Area </label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="Area" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Location </label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="Location" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>
                    </div>
                  
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:6.5%">Supplier </label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" id="Supplier" class="form-control">
                        </div>

                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Pay Type</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="PayType" class="form-control" name="priority">
                                <option value="0">-All-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>
                    </div>
                 
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:11%">Dept.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="vDept" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>

                        <label style="margin-top:2%;font-weight:bold;margin-left:0.5%">Job Code</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="jobCode" class="form-control">
                        </div>
                    </div>
                    <input type="text" class="form-control" id="UserId" style="display:none">
                  
                </div>
                
                    <!-- Modal footer -->
                    
                <div class="modal-footer">
                    <button type="button" id="btnsubmit" style="margin-right:2%"  class="btn btn-primary" data-dismiss="modal" onclick="redrawTable();">Apply</button>
                    <button type="button" id="btnclose" style="margin-right:30%"  class="btn btn-primary" data-dismiss="modal">Close</button>
                </div>
                
                </div>
        </div>
    </div>
}

@section bottomscripts {
    <script type="text/javascript" src="~/Scripts/EumiDataTable/eumi-datatable.js"></script>
    <script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
    <script type="text/javascript">
            $(document).ready(function () {

                $("#jobCode").autocomplete({
                    source: function (request, response) {
                        var data = {};
                        data.JobCode = request.term;
                        $.ajax({
                            url: '../Master/JobCodeSearch',
                            type: "POST",
                            data: data,
                            dataType: "json",
                            success: function (resultData) {
                                var resultData = $.map(resultData, function (item) {
                                    return {
                                        value: item.JobCode,
                                        label: item.Description,
                                        value2: item.ProjectJobId,
                                    }
                                });
                                response(resultData);
                            }
                        });
                    },
                    autoFocus: true,
                    select: function (event, ui) {
                        $("#jobCode").data("eumi-val", ui.item.value2);
                    },
                }).autocomplete("instance")._renderItem = function (ul, item) {
                    var jqLi = $("<li>")
                    var jqRow = getTableRow(item, ["value", "label"], ["50%", "50%"], ["Code", "Desc"]);
                    return jqLi.append($('<table class="tblautocomplete">').css("width", "300px").append(jqRow)).appendTo(ul);
                };

                $("#Supplier").autocomplete({
                    source: function (request, response) {
                        var data = {};
                        data.CustName = $("#Supplier").val();
                        data.CustType = 'S';

                        $.ajax({
                            url: '../Master/CustomerOrSupplierSearch',
                            type: "POST",
                            data: data,
                            dataType: "json",
                            success: function (data) {

                                response($.map(data, function (item) {
                                    return ({
                                        ColCount: 'TWOEnq',
                                        label: item.CustAccount,
                                        label1: item.CustName,
                                        value2: item.CustId,

                                    })
                                }));
                            }

                        })

                    },
                    autoFocus: true,
                    select: function (event, ui) {
                        $("#Supplier").data("eumi-val", ui.item.value2);

                    },

                }).autocomplete("instance")._renderItem = function (ul, item) {
                    var jqLi = $("<li>")
                    var jqRow = getTableRow(item, ["label", "label1"], ["50%", "50%"], ["Code", "Name"]);
                    return jqLi.append($('<table class="tblautocomplete">').css("width", "300px").append(jqRow)).appendTo(ul);
                };

                $('#dateFrom, #dateTo').daterangepicker({
                    minDate: minDate,
                    maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                    singleDatePicker: true,
                    showDropdowns: true,
                    locale: {
                        format: 'DD/MM/YYYY'
                    }
                });


                GetDepartment(0);
                GetArea(0);
                GetLocation(0);
            });


            function getTableRow(item, keyArray, widthArray, headersArray) {
                var jqRow = $("<tr>")
                for (var x = 0; x < keyArray.length; x++) {
                    $("<td>").css({ "border": "1px solid #d6d9db", "width": widthArray[x] })
                        .html(item[keyArray[x]])
                        .attr("data-em-header", (headersArray[x] || ""))
                        .appendTo(jqRow)
                }
                return jqRow;
            }

            function GetDepartment(id) {
                var data = {};
                data.UserId = ERPUserId;
                $.ajax({
                    type: "POST",
                    url: "../Master/UserDepartmentGetandGets",
                    data: data,
                    success: function (result) {
                        DepartmentLoad(result.oList, id);


                    }
                });
            }

            function DepartmentLoad(result, a) {
                $("#vDept").empty();
                $("#vDept").append("<option value='0'>-All-</option>");
                for (var i = 0; i < result.length; i++) {
                    $("#vDept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
                }
            }

            function GetArea(id) {
                var data = {};
                data.Id = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/AreaGetandGets",
                    data: data,
                    success: function (result) {
                        $.each(result.oList, function (index, ele) {
                            $("#Area").append($("<option>").attr("value", ele.AreaId).text(ele.AreaCode));
                        });
                    }
                });
            }



            function GetLocation(id) {
                var data = {};
                data.LocationId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/LocationGetandGets",
                    data: data,
                    success: function (result) {
                        $.each(result.oList, function (index, ele) {
                            $("#Location").append($("<option>").attr("value", ele.LocationId).text(ele.LocationName));
                        });


                    }
                });

            }
            function redrawTable() {
                $('#popup').show();
                var data = {};
                data.dateFrom = moment($('#dateFrom').val(), "DD-MM-YYYY").toDate();
                data.dateTo = moment($('#dateTo').val(), "DD-MM-YYYY").toDate();
                data.Area = parseInt($('#Area').val() || 0);
                data.LocnId = parseInt($('#Location').val() || 0);
                data.SupplierId = ($('#Supplier').val().match(/^\s*$/) ? 0 : parseInt($('#Supplier').data("eumi-val") || 0));
                data.JobNo = ($('#jobCode').val().match(/^\s*$/) ? 0 : parseInt($('#jobCode').data("eumi-val") || 0));
                data.PayType = parseInt($('#PayType').val() || 0);
                data.DepartmentId = parseInt($('#vDept').val() || 0);
                data.UserId = parseInt($('#UserId').val() || 0);

                data.title = "Parameters - "
                    + "From: " + $('#dateFrom').val()
                    + " To: " + $('#dateTo').val()
                    + " Area: " + $('#Area').find("option:selected").text()
                    + " Location: " + $('#Location').find("option:selected").text()
                    + " Supplier: " + ($('#Supplier').val() || "(All)")
                   + " Job: " + ($('#jobCode').val() || "(All)")
                    + " Pay Type: " + $('#PayType').find("option:selected").text()
                    + " Department: " + $('#vDept').find("option:selected").text();
                if ($.fn.DataTable.isDataTable('#itemreport')) {
                    window.EumiLastSelectedInItemRpt = data;
                    $("#itemreport").DataTable().ajax.reload();
                    $("#paramOfReport").text(data.title);
                }
            }
    </script>
}





