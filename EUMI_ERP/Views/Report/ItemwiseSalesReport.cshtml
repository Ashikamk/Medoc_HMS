        });
        $('#Group').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#SubGroup').focus();
                e.preventDefault();
            }
        });
        $('#SubGroup').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Category').focus();
                e.preventDefault();
            }
        });
        $('#Category').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#SubCategory').focus();
                e.preventDefault();
            }
        });
        $('#SubCategory').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Dept').focus();
                e.preventDefault();
            }
        });
        $('#SubCategory').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        });
</script>


@section popups {
    <div class="modal" id="paramModal">
        <div class="modal-dialog" role="document"  style="top:19%;max-width:35%">
            <div class="modal-content">

                <!-- Modal Header -->
                <div class="modal-header bg-primary white">
                    <h4 class="modal-title">Itemwise Report</h4>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Modal body -->

                <div class="modal-body">

                    <div class="row">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">From</label>
                        <div class="col-md-3">
                            <input type="text" id="dateFrom" class="form-control" autocomplete="off">
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">To</label>
                        <div class="col-md-3">
                            <input type="text" id="dateTo" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-1"></div>
                    </div>

                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>

                    <div class="row" style="margin-top:2%">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Customer</label>
                        <div class="col-md-8" >
                            <table width="100%">
                                <tr>
                                    <td width="30%">
                                        <input type="text" id="customer" class="form-control" onkeyup="$('#custnames').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                    </td>
                                    <td>
                                        <input type="text" id="custnames" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-1"></div>
                    </div>


                    <div class="row"  style="margin-top:2%">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Area </label>
                        <div class="col-md-3" >
                            <select id="Area" name="priority" class="form-control">
                                <option value="0">-All-</option>
                            </select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Pay Type</label>
                        <div class="col-md-3" >
                            <select id="Paytype" class="form-control" name="priority">
                                <option value="0">-All-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>
                        <div class="col-md-1"></div>
                    </div>


                    <div class="row" style="margin-top:2%">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Salesman</label>
                        <div class="col-md-3">
                            <select id="Salesman" name="priority" class="form-control"></select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Dept.</label>
                        <div class="col-md-3" >
                            <select id="Dept" name="priority" class="form-control"></select>
                        </div>
                        <input type="text" class="form-control" id="UserId" style="display:none">
                        @*<label class="col-md-1" style="margin-top:2%;font-weight:bold;">Customer </label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" id="customer" class="form-control">
                        </div>*@
                        <div class="col-md-1"></div>
                    </div>
                    <div class="row" style="margin-top:2%">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Group</label>
                        <div class="col-md-3" >
                            <select id="Group" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Sub Grp.</label>
                        <div class="col-md-3" >
                            <select id="SubGroup" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>
                        <div class="col-md-1"></div>
                    </div>
                    <div class="row" style="margin-top:2%">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Category</label>
                        <div class="col-md-3" >
                            <select id="Category" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Sub Cat.</label>
                        <div class="col-md-3" >
                            <select id="SubCategory" name="priority" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>
                        <div class="col-md-1"></div>
                    </div>



                  
                </div>

                <!-- Modal footer -->
                <div class="modal-footer">
                    <button type="button" id="btnsubmit"   class="btn btn-primary" data-dismiss="modal" onclick="redrawTable();">Apply</button>
                    <button type="button" class="btn btn-primary" style="margin-right:40%"  data-dismiss="modal">Close</button>
                </div>

            </div>
        </div>
    </div>
}

@section bottomscripts {
    <script type="text/javascript" src="~/Scripts/EumiDataTable/eumi-datatable.js"></script>
    <script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
    <script type="text/javascript">
            $(document).ready(function () {



                $("#customer").autocomplete({
                    source: function (request, response) {
                        var data = {};
                        data.CustName = $("#customer").val();
                        data.CustType = 'C';

                        $.ajax({
                            url: '../Master/CustomerOrSupplierSearch',
                            type: "POST",
                            data: data,
                            dataType: "json",
                            success: function (data) {

                                response($.map(data, function (item) {
                                    return ({
                                        ColCount: 'TWOEnq',
                                        label: item.CustAccount,
                                        label1: item.CustName,
                                        value2: item.CustId,
                                        CustName: item.CustName,
                                    })
                                }));
                            }

                        })

                    },
                    autoFocus: true,
                    select: function (event, ui) {
                        $("#customer").data("eumi-val", ui.item.value2);
                        $("#custnames").val(ui.item.CustName);
                        $('#Area').focus();

                    },

                }).autocomplete("instance")._renderItem = function (ul, item) {
                    var jqLi = $("<li>")
                    var jqRow = getTableRow(item, ["label", "label1"], ["50%", "50%"], ["Code", "Name"]);
                    return jqLi.append($('<table class="tblautocomplete">').css("width", "300px").append(jqRow)).appendTo(ul);
                };

                $('#dateFrom, #dateTo').daterangepicker({
                    minDate: minDate,
                    maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                    singleDatePicker: true,
                    showDropdowns: true,
                    locale: {
                        format: 'DD/MM/YYYY'
                    }
                });


                GetDept(0);
                GetArea(0);
                GetSalesMan(0);
                GroupPageLoad(0);
                CategoryPageLoad(0);
            });
          

            function getTableRow(item, keyArray, widthArray, headersArray) {
                var jqRow = $("<tr>")
                for (var x = 0; x < keyArray.length; x++) {
                    $("<td>").css({ "border": "1px solid #d6d9db", "width": widthArray[x] })
                        .html(item[keyArray[x]])
                        .attr("data-em-header", (headersArray[x] || ""))
                        .appendTo(jqRow)
                }
                return jqRow;
            }


            function GetDept(id) {
                    var data = {};
                    data.UserId = ERPUserId;
                    $.ajax({
                        type: "POST",
                        url: "../Master/UserDepartmentGetandGets",
                        data: data,
                        success: function (result) {
                            DepartmentLoad(result.oList, id);


                        }
                    });
                }

                function DepartmentLoad(result, a) {
                    $("#Dept").empty();
                    $("#Dept").append("<option value='0'>-All-</option>");
                    for (var i = 0; i < result.length; i++) {
                        $("#Dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
                    }
                }

            function GetArea(id) {
                var data = {};
                data.Id = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/AreaGetandGets",
                    data: data,
                    success: function (result) {
                        $.each(result.oList, function (index, ele) {
