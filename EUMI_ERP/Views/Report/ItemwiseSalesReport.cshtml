<script type="text/javascript">

    $(document).ready(function () {
        $('#UserId').val(ERPUserId);

        $('#btnchgp').click();
        $('#customer').focus();
            var decimal = (window.Decimal || 1);
            window.EumiLastSelectedInItemRpt = null;
            var table = $('#itemsalesreport').EumiDataTable({
                "processing": true,
                "serverSide": true,
                
                "ajax": {
                    "url": "../Report/ItemwiseSalesReportJson",
                    "type": "POST",
                    "data": function (data, settings) {
                        var addData = (window.EumiLastSelectedInItemRpt || {});
                        addData.dateFrom = moment(addData.dateFrom || new Date()).format("YYYY-MM-DD");
                        addData.dateTo = moment(addData.dateTo || new Date()).format("YYYY-MM-DD");
                        addData.Area = (addData.Area || 0);
                        addData.Paytype = (addData.Paytype || 0);
                        addData.SalesamanId = (addData.SalesamanId || 0);
                        addData.CustId = (addData.CustId || 0);
                        addData.GroupId = (addData.GroupId || 0);
                        addData.SubGroupId = (addData.SubGroupId || 0);
                        addData.CategoryId = (addData.CategoryId || 0);
                        addData.SubCategoryId = (addData.SubCategoryId || 0);
                        addData.DepartmentId = (addData.DepartmentId || 0);
                        addData.UserId = (addData.UserId || 0);
                        if (!addData.title) {
                            addData.title = "Parameters - " + "From: " + moment(new Date()).format("DD-MM-YYYY") + " To: " + moment(new Date()).format("DD-MM-YYYY")
                            $("#paramOfReport").text(addData.title);
                        }
                        data.addData = addData;
                        $("#eumiQuantity").text(0);
                        $("#eumiUnitPrice").text(parseFloat(0).toFixed(decimal));
                        $("#eumiTaxableAmount").text(parseFloat(0).toFixed(decimal));
                        $("#eumiDiscount").text(parseFloat(0).toFixed(decimal));
                        $("#eumiTaxAmount").text(parseFloat(0).toFixed(decimal));
                        $("#eumiAmount").text(parseFloat(0).toFixed(decimal));
                        $("#eumiFCAmount").text(parseFloat(0).toFixed(decimal));
                    }
                },
                "columnDefs": [
                    {
                        "targets": 0,
                        "className": "text-center",
                    },
                    {
                        "targets": 2,
                        "className": "text-center",
                    },
                    {
                        "targets": 3,
                        "className": "text-center",
                    },
                     
                     {
                        "targets": 9,
                         "className": "text-center",
                     },
                      {
                          "targets": 10,
                          "className": "text-right",
                          "render": function (data) {
                              return (data || 0).toFixed(decimal);
                          }
                      },
                     {
                         "targets": 21,
                         "className": "text-center",
                     },
                      {
                          "targets": 22,
                          "className": "text-right",
                          "render": function (data) {
                              return (data || 0).toFixed(decimal);
                          }
                      },
                       
                    {
                        "targets": 5,
                        "className": "text-left",
                        "render": function (data) {
                            if (data !== null) {
                                return (data.substring(0, 10));
                            }
                            else {
                                return (null);
                            }

                        }
                    },
                   
                    {
                    "targets": 17,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                {
                    "targets": 18,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                {
                    "targets": 19,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                 {
                     "targets": 20,
                     "className": "text-right",
                     "render": function (data) {
                         return (data || 0).toFixed(decimal);
                     }
                 },
                {
                    "targets": 23,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
               ],
                "columns": [

                    { data: "BillSlNo", data: "BillSeriesId", data: "DeptId", data: "slno", title: "Sl#", searchable: false, sortable: false },

                    { data: "BillSeries", title: "Bill#", sortable: false },
                  
                    { data: "InvDate", title: "Date", sortable: false },
                    { data: "AccCode", title: "Account#", sortable: false },
                    { data: "Customer", title: "Customer", sortable: false },
                      { data: "Salesman", title: "Salesman", sortable: false },
                    { data: "ProductCode", title: "Item Code", sortable: false },
                    { data: "ProductDescription", title: "Item Name", sortable: false },
                     { data: "UnitName", title: "Unit", sortable: false },
                    { data: "Quantity", title: "Qty.", sortable: false },
                     { data: "ProdRate", title: "Unit Price", sortable: false },
                     { data: "Area", title: "Area", sortable: false },
                    { data: "LocationName", title: "Location", sortable: false },
                    { data: "TermDescription", title: "Terms", sortable: false },
                    { data: "Payterms", title: "Pay Type", sortable: false },
                      { data: "JobCode", title: "Job Code", sortable: false },
                      { data: "LPO", title: "TRN#", sortable: false },
                    { data: "TaxableAmount", title: "Taxable Amount", sortable: false },
                    { data: "TaxAmount", title: "Tax Amount", sortable: false },
                    { data: "ProdDisc", title: "Disc.", sortable: false },
                    { data: "Amount", title: "Amount", sortable: false },
                    { data: "CurrencyName", title: "Fx.", sortable: false },
                    { data: "CurrencyRate", title: "Rate", sortable: false },
                    { data: "FCAmount", title: "FC Amount", sortable: false },
                    { data: "GrpName", title: "Group", sortable: false },
                    { data: "SbgrpName", title: "Sub Group", sortable: false },
                    { data: "CategoryName", title: "Category", sortable: false },
                     { data: "SubCategoryName", title: "Sub Category", sortable: false },
                      { data: "DepartmentName", title: "Dept.Code", sortable: false },
                ],
                fixedColumns: true,
                "createdRow": function (row, data, index) {
                    if (index == 0) {
                        $("#eumiQuantity").text(ReplaceNumberWithCommas(data._quantity));
                        $("#eumiUnitPrice").text(ReplaceNumberWithCommas(data._ProdRate.toFixed(decimal)));
                        $("#eumiTaxableAmount").text(ReplaceNumberWithCommas(data._taxableamount.toFixed(decimal)));
                        $("#eumiDiscount").text(ReplaceNumberWithCommas(data._discount.toFixed(decimal)));
                        $("#eumiTaxAmount").text(ReplaceNumberWithCommas(data._taxamount.toFixed(decimal)));
                        $("#eumiAmount").text(ReplaceNumberWithCommas(data._amount.toFixed(decimal)));
                        $("#eumiFCAmount").text(ReplaceNumberWithCommas(data._fcamount.toFixed(decimal)));
                        console.log(index);
                    }
                },
            });

            $('#itemsalesreport tbody').on('dblclick', 'tr', function () {
                var table = $("#itemsalesreport").DataTable();
                var data = table.row(this).data();
                GetRows(data.BillSlNo, data.BillSeriesId, data.DeptId);
            });

          

            function GetRows(BillSlNo, BillSeriesId, DeptId) {
                if ((usermenu1.indexOf("M54") != -1)) {
                    window.open('../inventory/SalesInvoice?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                }
                else if ((usermenu1.indexOf("M227") != -1)) {
                    window.open('../inventory/SalesInvoiceNew?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                }
                else {
                    warningshow('Invalid User Rights');
                    return false;
                }
            }

            function warningshow(message, Id) {
                $('#popupmessage').text(message);
                $('#Warningpopup').show();
                $('#' + Id).focus();
                window.setTimeout(function () {
                    $('#Warningpopup').hide();
                }, 3000);
            }


        $('#Area').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Paytype').focus();
                e.preventDefault();
            }
        });

        $('#Paytype').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Salesman').focus();
                e.preventDefault();
            }
        });

        $('#Salesman').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Dept').focus();
