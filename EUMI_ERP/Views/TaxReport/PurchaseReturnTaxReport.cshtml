<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }



    function Showautocomplete(Id) {
        $("#"+ Id).autocomplete({
            source: function (request, response) {
                var data = {};
                data.AccCode = $("#" + Id).val();

                $.ajax({
                    url: '../Inventory/ExpenseAccountCodeSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'THREE',
                                label: item.DebitAccount,
                                label1: item.AccountDescription,
                                DebitAccount: item.DebitAccount,
                                AccountDescription: item.AccountDescription,
                                AccountId: item.AccountId
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#AccCode').val(ui.item.DebitAccount)
            },

        });
    }

    $("#accountGrp").autocomplete({
        source: function (request, response) {

            var data = {};
            data.AccGrp = $("#accountGrp").val();
            $.ajax({
                url: '../Inventory/ExpenseAccountGroupSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            AccountId: item.AccountId,
                            DebitAccount: item.DebitAccount,
                            headers: ["Code", "Decription"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#AccGrp').val(ui.item.DebitAccount);
            $('#accountGrp').val(ui.item.AccountId);

        },

    });



    function Showreport(result) {
       disable_datatable('Tblreport', 'buttonPlace');

       var responseText = "<thead><tr><th>Sl#</th><th>Type</th><th>Place of Supply</th><th>Rate</th><th>Applicable %-Of Tax Rate</th><th>Taxable-Value</th><th style=text-align:right>Tax-Value</th><th>Cess</th><th>Ecommerce-GSTIN</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            responseText += '<tr><td style=text-align:center>' + slno + '</td><td>OE</td><td>Kerala</td><td>' + result[i].TaxPercent + '</td><td></td><td>' + result[i].TaxableAmount + '</td><td>' + result[i].TaxAmount + '</td> <td style=text-align:right></td><td style=text-align:right></td></tr>';

        }
        $('#Tblreport').html(responseText + '</tbody>');
       // $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "B2CS Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearchs('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    $(function () {
        $('#accountGrp').focus();
        $("#account").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            $('#AccCode').val(0);
            if (key == 13) {
                e.preventDefault();
                $('#btnsubmit').focus();
            }

        });

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {


                $('#Loading').show();

                if ($('#account').val() == '') {
                    $('#AccCode').val(0);
                }
                if ($('#accountGrp').val() == '') {
                    $('#AccGrp').val(0);
                }
                var data = {};
                data.FromDate = $('#DateFrom').val();
                data.ToDate = $('#DateTo').val();
                data.Account = parseInt($('#AccCode').val() || 0);
                data.AccountGrp = parseInt($('#AccGrp').val() || 0);
                data.Userid = ERPUserId;
                data.Dept = ERPDeptId;
                $.ajax({
                    type: "POST",
                    url: "../TaxReport/B2cs",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }


        });

    });
    function GroupClear() {
        $("#accountGrp").val('');
        $("#AccGrp").val(0);
    }
    function CodeClear() {
        $("#account").val('');
        $("#AccCode").val(0);
    }


    function datatableWithsearchs(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Voucher No') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:70px" />');
            }
            if (title == 'Voucher Prefix') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:70px" />');
            }
            if (title == 'Account#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:60px" />');
            }
            if (title == 'DeptCode') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:60px" />');
            }
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                "<'row'<'col-sm-12'tr>>" +
                "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
                "columnDefs": [
                      { "width": "5%", "text-align": "center", "targets": 0 },
                     

                ]

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,

                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,

                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,

                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }






</script>










