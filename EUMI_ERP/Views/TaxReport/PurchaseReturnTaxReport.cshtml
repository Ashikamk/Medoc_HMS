                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:13.5%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:6%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%;display:none">
                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Account Grp.</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="accountGrp" onkeyup="CodeClear()" class="form-control">
                            <input type="hidden" id="AccGrp" class="form-control" />
