                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Code</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="account" onkeyup="GroupClear()" onkeypress="Showautocomplete('account')" class="form-control">
