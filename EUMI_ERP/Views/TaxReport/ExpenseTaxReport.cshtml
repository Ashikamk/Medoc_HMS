        var title = "HSN Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + '( ' + DPt1 + ")";
        datatableWithsearchs('Tblreport', true, title, 'buttonPlace');


        $('#tblprint').html('')
        $('#tblprint').append(Line)

        $('#header').text(title);
    }


    $(function () {
        $('#accountGrp').focus();
        $("#account").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            $('#AccCode').val(0);
            if (key == 13) {
                e.preventDefault();
                $('#btnsubmit').focus();
            }

        });

        $('#DateFrom').daterangepicker({
