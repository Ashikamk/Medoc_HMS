<script>
    var DPt = ""

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    GetDepartment(0)
    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);
            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#department").empty();
        $("#department").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            DPt = DPt + ',' + result[i].DepartmentName
        }
    }

    function Showautocomplete(Id) {
        $("#" + Id).autocomplete({
            source: function (request, response) {
                var data = {};
                data.AccCode = $("#" + Id).val();

                $.ajax({
                    url: '../Inventory/ExpenseAccountCodeSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'THREE',
                                label: item.DebitAccount,
                                label1: item.AccountDescription,
                                DebitAccount: item.DebitAccount,
                                AccountDescription: item.AccountDescription,
                                AccountId: item.AccountId
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#AccCode').val(ui.item.DebitAccount)
            },

        });
    }




    function Showreport(result) {

        var printline = ""; var pref = '                                                                                       ';
        disable_datatable('Tblreport', 'buttonPlace');
        var title = " GST SALES REGISTER- from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        var Line = "<tr><th></th></tr>";
        Line += "<tr><td>" + $.trim(CompanySettingsArray.CompanyName) + "</td></tr>";
        Line += "<tr><td>" + $.trim(CompanySettingsArray.Address) + "</td></tr>";
        Line += "<tr><td>" + $.trim((CompanySettingsArray.PhoneNo).replace("\n", "")) + "</td></tr>";

        Line += '<tr><td>---------------------------------------------------------------------------------</td></tr>'   //bold on

        Line += "<tr><td>" + title + "</td></tr>";

        //debugger;

        var Amount = 0; var Amount = 0;
        Line += '<tr><td>---------------------------------------------------------------------------------</td></tr>'   //bold on
        Line += '<tr><td>Gst%           Taxable Amount        CGST	SGST               Total</td></tr>'   //bold on
        Line += '<tr><td>----------------------------------------------------------------------------------</td></tr>'   //bold on


        var responseText = "<thead><tr><th>Sl#</th><th>HSN Name</th><th>Description</th><th>UQC</th><th>Qty</th><th>Total Amount</th><th style=text-align:right>Taxable</th><th>Tax</th><th>IGST</th><th>CGST</th><th>SGST</th><th>Gst%</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);


            D6 = (pref + result[i].Dept).substring((pref + result[i].Dept).length - 6, (pref + result[i].Dept).length)
            D2 = (pref + result[i].VDescription).substring((pref + result[i].VDescription).length - 15, (pref + result[i].VDescription).length)
            D3 = (pref + result[i].TotalAmount).substring((pref + result[i].TotalAmount).length - 15, (pref + result[i].TotalAmount).length)
            D1 = (pref + result[i].Dept).substring((pref + result[i].Dept).length - 15, (pref + result[i].Dept).length)
            D4 = (pref + (result[i].TotalAmount / 2).toFixed(3)).substring((pref + (result[i].TotalAmount / 2).toFixed(3)).length - 15, (pref + (result[i].TotalAmount / 2).toFixed(3)).length)
            D5 = (pref + result[i].AccountDesc).substring((pref + result[i].AccountDesc).length - 15, (pref + result[i].AccountDesc).length)



            if (result[i].InvoNo == 'SALES VALUE' || result[i].InvoNo == 'HSN SALES RETURN' || result[i].InvoNo == 'SALES RETURN VALUE') {
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold;><td style=text-align:center>' + slno + '</td><td>' + result[i].Prefix + '</td><td>' + result[i].InvoNo + '</td><td>Nos</td><td>' + result[i].AccountCode + '</td><td>' + result[i].AccountDesc + '</td><td>' + result[i].VDescription + '</td> <td style=text-align:right>' + result[i].TotalAmount + '</td><td style=text-align:right>0.00</td><td style=text-align:right>' + (result[i].TotalAmount / 2).toFixed(3) + '</td><td style=text-align:right>' + (result[i].TotalAmount / 2).toFixed(3) + '</td><td  style=text-align:right>' + result[i].Dept + '</td></tr>';
                prodname = D6 + D2  + D4 + D4 + D5
                Line += '<tr><td>----------------------------------------------------------------------------------</td></tr>'   //bold on
                Line += '<tr><td>' + prodname + '</td></tr>';
                Line += '<tr><td>----------------------------------------------------------------------------------</td></tr>'   //bold on

            }
            else
