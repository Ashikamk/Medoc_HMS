                responseText += '<tr><td style=text-align:center>' + slno + '</td><td>' + result[i].Prefix + '</td><td>' + result[i].InvoNo + '</td><td>Nos</td><td>' + result[i].AccountCode + '</td><td>' + result[i].AccountDesc + '</td><td>' + result[i].VDescription + '</td> <td style=text-align:right>' + result[i].TotalAmount + '</td><td style=text-align:right>0.00</td><td style=text-align:right>' + (result[i].TotalAmount / 2).toFixed(3) + '</td><td style=text-align:right>' + (result[i].TotalAmount / 2).toFixed(3) + '</td><td  style=text-align:right>' + result[i].Dept + '</td></tr>';
                prodname = D6 + D2  + D4 + D4 + D5
                //D3 Taxable

               
                if (result[i].Dept.length) {
                    Line += '<tr><td>' + prodname + '</td></tr>';
                }
                else {
                    Line += '<tr><td>----------------------------------------------------------------------------------</td></tr>'   //bold on
                    Line += '<tr><td>' + prodname + '</td></tr>';
                    Line += '<tr><td>----------------------------------------------------------------------------------</td></tr>'   //bold on

                }
              

            }


        }
        $('#Tblreport').html(responseText + '</tbody>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var DPt1
