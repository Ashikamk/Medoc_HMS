<script>
    var DefaultTaxPercentageId = 2;
    function popuprefresh() {
        $('#popupdiv').hide();
        $('#taxgrp').hide();
        $("#Tax").val(DefaultTaxPercentageId);
    }



    function GetAreaGroupselect(id) {
        var data = {};
        data.AreaGrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGroupGetandGets",
            data: data,
            success: function (result) {
                AreaGroupLoad(result.oList, id);
            }
        });

    }

    function AreaGroupLoad(result) {
        $("#area").empty();
        $("#area").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#area").append("<option value='" + result[i].AreaGrpId + "'>" + result[i].AreaName + "</option>");
        }
    }
    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#dept").empty();
        $("#dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }
    function TaxCall(id) {
        var data1 = {};
        data1.TaxId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/TaxGetandGets",
            data: data1,
            success: function (result) {
                TaxLoad(result.oList,id);
            }
        });
    }

    function TaxLoad(result) {
        $("#Tax").empty();
         $("#Tax").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Tax").append("<option value='" + result[i].TaxId + "' name='" + result[i].TaxRate + "'>" + result[i].TaxName + "</option>");
        }
        $("#Tax").val(DefaultTaxPercentageId);
    }


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style=text-align:center>Sl#</th><th>Inv.#</th><th>Sup.Inv.#</th><th style=text-align:center>Date</th><th>Supplier Name</th><th  style=text-align:right>Supplier VAT#</th><th style=text-align:right>Disc.</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Percentage</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);


            if (result[i].InvoDate == "Grand Total") {
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold><td style=text-align:center;width:1px>' + slno + '</td><td>' + result[i].SlNo + '</td><td>' + result[i].InvoNo + '</td><td style=text-align:center>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td  style=text-align:right>' + result[i].CustomerVATNo + '</td><td style=text-align:right>' + result[i].Discount + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + result[i].TaxPercent + '</td><td style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right;width:100px>' + parseFloat(result[i].TotalAmount || 0).toFixed(Decimal) + '</td></tr>';
            }

            else if (result[i].SlNo == '') {

                responseText += '<tr style=background-color:#cfd8dc><td style=text-align:center;width:1px>' + slno + '</td><td>' + result[i].SlNo + '</td><td>' + result[i].InvoNo + '</td><td style=text-align:center><b>' + result[i].InvoDate + '</b></td><td>' + result[i].Customer + '</td><td  style=text-align:right>' + result[i].CustomerVATNo + '</td><td style=text-align:right>' + result[i].Discount + '</td><td style=text-align:right>' + result[i].TaxableAmount + '</td><td style=text-align:right>' + result[i].TaxPercent + '</td><td style=text-align:right>' + result[i].TaxAmount + '</td><td style=text-align:right;width:100px>' + result[i].TotalAmount + '</td></tr>';
            }
            else {
                responseText += '<tr ondblclick=gotoInvoNo(' + result[i].SlNo + "," + result[i].Dept + ')><td style=text-align:center;width:5px>' + slno + '</td><td>' + result[i].SlNo + '</td><td>' + result[i].InvoNo + '</td><td style=text-align:center>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td  style=text-align:right>' + result[i].CustomerVATNo + '</td><td style=text-align:right>' + parseFloat(result[i].Discount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxPercent || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right;width:100px>' + parseFloat(result[i].TotalAmount || 0).toFixed(Decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th style=width:1px> </th><th>Inv.#</th><th>Sup.Inv.#</th><th>Date</th><th>Supplier Name</th><th  style=text-align:right>Supplier VAT#</th><th> </th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Purchase Tax Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearchs('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearchs(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Inv.#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Sup.Inv.#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Supplier VAT#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }

            if (title == 'Supplier Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:400px" />');
            }
            if (title == 'Disc.') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }

        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }



    function gotoInvoNo(SlNo, Dept) {
        if ((usermenu1.indexOf("M31") != -1)) {
            window.open('../inventory/PurchaseInvoice?slno=' + SlNo + '&dept=' + Dept);
        }
        else if ((usermenu1.indexOf("M233") != -1)) {
            window.open('../Purchase/PurchaseInvoiceNew?slno=' + SlNo + '&dept=' + Dept);

        }
        else {
            warningshow('Invalid User Rights');
            return false;
        }
    }

    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

    $(function () {
        GetAreaGroupselect(0);
        GetDepartment(0);
        TaxCall(0);
        $('#area').focus();

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
        $('#area').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#dept').focus();
                e.preventDefault();
            }
        });
        $('#dept').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });


        $("#btnsubmit").click(function (e) {

            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {


                $('#Loading').show();

                if ($("#grpbyarea").prop("checked"))
                {

                    var data = {};
                    data.FromDate = $('#DateFrom').val();
                    data.ToDate = $('#DateTo').val();
                    data.Dept = parseInt($('#dept').val() || 0);
                    data.Area = parseInt($('#area').val() || 0);
                    data.TaxPercent = parseInt($('#Tax').val() || 0);
                    data.UserId = ERPUserId;
                    $.ajax({
                        type: "POST",
                        url: "../TaxReport/PurchaseTaxReportGet",
                        data: data,
                        success: function (result) {
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            $('#taxgrp').hide();
                            $('#taxgrp').hide();
                            //$("#Tax").val(DefaultTaxPercentageId);
                            Showreport(result);
                        }
                    });
                }

                else
                {
                    var data = {};
                    data.FromDate = $('#DateFrom').val();
                    data.ToDate = $('#DateTo').val();
                    data.Dept = parseInt($('#dept').val() || 0);
                    data.Area = parseInt($('#area').val() || 0);
                    data.TaxPercent = parseInt($('#Tax').val() || 0);
                    data.UserId = ERPUserId;
                    $.ajax({
                        type: "POST",
                        url: "../TaxReport/PurchaseAreaGrpTaxReportGet",
                        data: data,
                        success: function (result) {
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            $('#taxgrp').hide();
                           // $("#Tax").val(DefaultTaxPercentageId);
                            Showreport(result);
                        }
                    });
                }
            }


        });

    });

    $(document).keydown(function (e) {

        if (e.altKey && e.keyCode == 86) {              //ALT+V
            $('#taxgrp').show();
        }
    });

    

</script>







