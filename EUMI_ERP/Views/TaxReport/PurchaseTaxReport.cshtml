                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:12%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:6%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">
                        <label style="margin-top:2%;font-weight:bold;margin-left:13%">Area</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="area" name="priority" class="form-control"></select>
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Dept.</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="dept" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:2%;display:none1">
                        <label style="margin-top:2%;font-weight:bold;margin-left:4.5%">Tax Group</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="Tax" name="priority" class="form-control"></select>
                        </div>

                    </div>

                </div>
               
                <div class="modal-footer">
                    <fieldset class="form-group floating-label-form-group" style="margin-right:10%">
                        <div class="row">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="grpbyarea">
                                <label class="custom-control-label" for="grpbyarea" style="font-weight:bold">Group by Area</label>
                            </div>

                        </div>
                    </fieldset>
                    <button type="button" style="width:100px;margin-right:40%" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
