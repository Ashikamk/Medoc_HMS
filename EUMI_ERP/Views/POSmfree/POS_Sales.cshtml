    <script>


        $("#txtcustomer").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.CustName = $("#txtcustomer").val();
                data.CustType = 'C';
                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        //console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2ph',
                                label: item.CustName,
                                label1: item.CustAccount,
                                label2: item.PhoneNumber,
                                CustName: item.CustName,
                                Address: item.CustStreet1 + '\n' + item.CustCity1 + '\n' + item.CustState1,
                                Street: item.CustStreet1,
                                City: item.CustCity1,
                                State: item.CustState1,
                                TRNNumber: item.TRNNumber,
                                CustId: item.CustId,
                                SalesmanId: item.SalesmanId,
                                CurncyId: item.CurrencyId,
                                CustTermsId: item.CustTermsId,
                                AreaId: item.AreaId,
                                PriceGroupId: item.PriceGroupId,
                                PhoneNumber: item.PhoneNumber,
                                headers: ["Customer Name", "Account Code", "Phone No"]
                            })
                        }));
                    }
                })

            },
            autoFocus: true,
            select: function (event, ui) {

            },

        });



        $("#itembarcode").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#itembarcode").val();
                data.LocId = 1;
                data.DeptId = 1;
                data.CustId = 0;
                data.UserId = 1;
                data.ProductMultiPriceId = 0;
                $.ajax({
                    url: '../SalesInvoice/ProductSearchSales',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {

                        response($.map(data, function (item) {
                            return ({
                                ColCount: '4',
                                label: item.ItemCode,
                                label1: item.Description,
                                label3: item.SellingPrice.toFixed(2),
                                label2: item.stocktotloseqty,
                                label4: item.SellingPrice.toFixed(2),
                                label5: item.GrpName.substring(0, 15),
                                label6: item.SbgrpName.substring(0, 15),
                                label7: item.CategoryName.substring(0, 15),
                                label8: item.SubCategoryName.substring(0, 15),

                                stocktotloseqty: item.stocktotloseqty,
                                Unit: item.UnitId,
                                Tax: item.VatId,
                                Taxpercent: item.VatPer,
                                Rates: item.SellingPrice,
                                UnitName: item.UnitName,
                                ProductId: item.ItemId,
                                Product: item.ItemCode,
                                ProductDesc: item.Description,
                                LPCost: item.LPCost,
                                AvgCost: item.AvgCost,
                                Otherdescription: item.Otherdescription,
                                MRP: item.MRP,
                                headers: ["Code", "Description", "Quantity"]
                            })
                        }));
                    }
                })

            },
            autoFocus: true,
            select: function (event, ui) {
                var data = "<div class='col-xs-12'><div class='panel panel-default product-details'><div class='panel-body' style=''><div class='col-xs-5 nopadding'><div class='col-xs-2 nopadding'><a href='javascript:void(0)' onclick='delete_posale('2324')'><span class='fa-stack fa-sm productD'><i class='fa fa-circle fa-stack-2x delete-product'></i><i class='fa fa-times fa-stack-1x fa-fw fa-inverse'></i></span></a></div><div class='col-xs-10 nopadding'><span class='textPD'>" + ui.item.label1 + "</span></div></div><div class='col-xs-2'><span class='textPD'>" + ui.item.Rates + "</span></div><div class='col-xs-3 nopadding productNum'><a href='javascript:void(0)'><span class='fa-stack fa-sm decbutton'><i class='fa fa-square fa-stack-2x light-grey'></i><i class='fa fa-minus fa-stack-1x fa-inverse white'></i></span></a><input type='text' id='qt-2324' onchange='edit_posale(2324)' class='form-control' value='1' placeholder='0' maxlength='2'><a href='javascript:void(0)'><span class='fa-stack fa-sm incbutton'><i class='fa fa-square fa-stack-2x light-grey'></i><i class='fa fa-plus fa-stack-1x fa-inverse white'></i></span></a></div><div class='col-xs-2 nopadding '><span class='subtotal textPD'>" + ui.item.Rates + "</span></div></div></div></div>";
                $('#productList').append(data);
                document.getElementById('itembarcode').value = 'dhinesh';

            },

        });















