<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }


    function ShowReport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Pay Type</th><th>Taxable Amount</th><th>Tax Amount</th><th>Amount</th><th>FC Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].InvDate == '') {
                ResponseEntity += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].BillSlNo + '</td><td>' + result[i].InvDate + '</td><td><b>' + result[i].PayType + '</b></td><td style=text-align:right>' + result[i].TaxableAmount + '</td><td style=text-align:right>' + result[i].TaxAmount + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCTaxAmount + '</td></tr>';
            }
            else if (result[i].InvDate == 'Grand Total')
            {
                ResponseEntity += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].BillSlNo + '</td><td><b>' + result[i].InvDate + '</b></td><td>' + result[i].PayType + '</td><td style=text-align:right><b>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].FCTaxAmount || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else
            {
                ResponseEntity += '<tr onclick=gotoInvoNo(' + result[i].BillSlNo + "," + result[i].BillSeriesID + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].BillSlNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].PayType + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].FCTaxAmount || 0).toFixed(Decimal) + '</td><td style=display:none><input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '/></td><td style=display:none><input type="hidden" id="BillSeries_' + i + '" value=' + result[i].BillSeriesID + '/></td></tr>';
            }
            }

        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Pay Type</th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');

        var title = "Customerwise Sales Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Bill#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Bill Series') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Pay Type') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Customer') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:1000px" />');
            }

        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function gotoInvoNo(InvoNo, BillSeriesId, DeptId) {
        if ((usermenu1.indexOf("M54") != -1)) {
            window.open('../inventory/SalesInvoice?slno=' + InvoNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

        }
        else if ((usermenu1.indexOf("M227") != -1)) {
            window.open('../inventory/SalesInvoiceNew?slno=' + InvoNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

        }
        else {
            warningshow('Invalid User Rights');
            return false;
        }
    }
    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

    $(function () {
        $('#UserId').val(ERPUserId);
        $("#cmbCustomerName").focus();

        $('#dpDateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $('#dpDateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });

        //$('#cmbCustomerName').keydown(function (e) {
        //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        //    $('#CustomerID').val(0);
        //    if (key == 13) {
        //        $('#cmbPayType').focus();
        //        e.preventDefault();
        //    }
        //});

        $('#cmbPayType').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnGo').focus();
                e.preventDefault();
            }
        });

        $("#btnGo").click(function (e) {
            $('#Loading').show();

            if ($('#cmbCustomerName').val() == '') {
                $('#CustomerID').val(0);
            }

            var data = {};
            data.InvDate = $('#dpDateFrom').val();
            data.DueDate = $('#dpDateTo').val();
            data.CustID = $('#CustomerID').val();
            data.PayType = $('#cmbPayType').val();
            data.UserId = $('#UserId').val();
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/CustomerwiseSalesGet",
                data: data,
                success: function (result) {
                    ShowReport(result);
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                }
            });
        });
    });

</script>
