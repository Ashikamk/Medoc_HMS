
@{
    ViewBag.Title = "EmployeeAttendanceReport";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

</style>

<script>


    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function ShowReport(result)
    {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th   width=2px>Sl#</th><th width=100px>Emp. Code</th><th width=300px>Emp. Name</th><th  width=80px>Salary</th><th width=80px>Deduction</th><th width=80px>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);         
            ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].EmpCode + '</td><td>' + result[i].EmpName + '</td><td class="text-center">' + result[i].InTime + '</td><td class="text-center">' + result[i].OutTime + '</td><td class="text-center">' + result[i].Workinghrs + '</td></tr>';
        }
        $('#Tblreport').html(ResponseEntity + '</tbody>');
        var title = "Attendance Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    function ShowReportemp(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th   width=2px>Sl#</th><th width=100px>Emp. Code</th><th width=300px>Emp. Name</th><th  width=80px>Salary</th><th width=80px>Deduction</th><th width=80px>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (i == 0) {
                ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].EmpCode + '</td><td>' + result[i].EmpName + '</td><td class="text-center">' + result[i].InTime + '</td><td class="text-center">' + result[i].OutTime + '</td><td class="text-center"></td></tr>';
            }
            ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].EmpCode + '</td><td>' + result[i].EmpName + '</td><td class="text-center"></td><td class="text-center">' + result[i].OutTime + '</td><td class="text-center"></td></tr>';

        }
        $('#Tblreport').html(ResponseEntity + '</tbody>');
        var title = "Attendance Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }



    function ShowReportSummary(result) {


        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th>Sl#</th><th  width=50px>Attendance Date</th><th width=150px>Emp. Code</th><th  width=1000px>Emp. Name</th><th  width=100px>In Time</th><th width=100px>Out Time</th><th width=150px>Working Hours</th><th width=100px>User</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].AttendanceDate + '</td><td>' + result[i].EmpCode + '</td><td>' + result[i].EmpName + '</td><td>' + result[i].InTime + '</td><td>' + result[i].OutTime + '</td><td>' + result[i].Workinghrs + '</td><td>' + result[i].User + '</td></tr>';
        }
        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th>Sl#</th><th>Attendance Date</th><th>Emp. Code</th><th>Emp. Name</th><th>In Time</th><th>Out Time</th><th>Working Hours</th><th>User</th></tr> </tfoot>');

        var title = "Attendance Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    $(function () {
        $("#User").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.EmpCode = $("#User").val();
                data.Name = $("#User").val();
                data.UserName = $("#User").val();
                $.ajax({
                    //url: '../Master/UserSearch',
                    url: '../Master/EmployeeSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {

                        response($.map(data, function (item) {
                            console.log(data)
                            return ({
                                ColCount: '2',
                                label: item.EmpCode,
                                label1: item.Name,
                                label2: item.EmpId,
                                EmpCode: item.EmpCode,
                                Name: item.Name,
                                EmpId: item.EmpId,
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#UserId').val(ui.item.EmpId);
                $('#btnGo').focus();
            },
        });
        $('#dpDateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $('#dpDateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnGo").click(function (e) {
            $('#Loading').show();

            if ($('#User').val() == '') {
                $('#UserId').val(0);
            }
            Detail();
        });
    });


    function Detail() {
        var data = {};
        data.FromDate = $('#dpDateFrom').val();
        data.ToDate = $('#dpDateTo').val();
        data.User = parseInt($('#UserId').val()||0);
        $.ajax({
            type: "POST",
            url: "../Purchaseandsalesreports/EmployeeAttendanceReport",
            data: data,
            success: function (result) {
                if (parseInt($('#UserId').val() || 0) == 0) {
                    ShowReport(result);
                }
                else {
                    ShowReportemp(result);
                }
               
                $('#Loading').hide();
                $('#divreport').show();
                $('#tdsummarypopup').show();
                $('#tddetailpopup').show();
                $('#popupdiv').hide();

            }
        });
    }
    function summary() {

        var data = {};
        data.FromDate = $('#dpDateFrom').val();
        data.ToDate = $('#dpDateTo').val();

        $.ajax({
            type: "POST",
            url: "../Purchaseandsalesreports/EmployeeAttendanceSummaryReport",
            data: data,
            success: function (result) {
                ShowReportSummary(result);
                $('#Loading').hide();
                $('#divreport').show();
                $('#tdsummarypopup').show();
                $('#tddetailpopup').show();
                $('#popupdiv').hide();
            }
        });
    }
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            if (title == 'Emp. Code')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            if (title == 'Emp. Name')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            if (title == 'In Time')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            if (title == 'Out Time')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            if (title == 'Working Hours')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            if (title == 'User')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");
           
        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }
</script>
