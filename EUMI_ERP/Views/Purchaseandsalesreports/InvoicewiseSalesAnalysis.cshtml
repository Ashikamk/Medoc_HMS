                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.JobCode,
                            label1: item.Description,
                            ProjectJobId: item.ProjectJobId,
                            headers: ["Job Code", "Job Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#JobID').val(ui.item.ProjectJobId)
