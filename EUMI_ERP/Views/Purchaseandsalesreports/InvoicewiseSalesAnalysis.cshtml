    $("#txtCustomer").autocomplete({
        source: function (request, response) {

            var data = {};
            data.CustName = $("#txtCustomer").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustomerID').val(ui.item.CustId)
            $("#custnames").val(ui.item.CustName);
            $('#cmbSalesMan').focus();
        },

    });

    $("#txtJob").autocomplete({
        source: function (request, response) {

            var data = {};
            data.JobCode = $("#txtJob").val();
            data.CustType = 'C';

            $.ajax({
