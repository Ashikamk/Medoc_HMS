        //        $('#btnGo').focus();
        //        e.preventDefault();
        //    }
        //});
    });
        $("#btnGo").click(function (e) {


            var Condition = '';
            var FromDate = $('#dpDateFrom').val();
            var ToDate = $('#dpDateTo').val();
            var Salesman = parseInt($('#cmbSalesMan').val() || 0);
            var Customer = parseInt($('#CustomerID').val() || 0);
            var Job = parseInt($('#JobID').val() || 0);
            //var Userid = ERPUserId;



            $('#Loading').show();
            if (Salesman == 0 && Customer == 0 && Job == 0) {
                Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }
            else if (Salesman != 0 && Customer == 0 && Job == 0) {
                Condition = 'SalesManId=' + Salesman + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }
            else if (Salesman == 0 && Customer != 0 && Job == 0) {
                Condition = 'CustId=' + Customer + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }
            else if (Salesman == 0 && Customer == 0 && Job != 0) {
                Condition = 'JobNumber=' + Job + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }


            else if (Salesman != 0 && Customer != 0 && Job == 0) {
                Condition = 'SalesManId=' + Salesman + ' and CustId=' + Customer + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }
            else if (Salesman != 0 && Customer == 0 && Job != 0) {
                Condition = 'SalesManId=' + Salesman + ' and JobNumber=' + Job + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }
            else if (Salesman == 0 && Customer != 0 && Job != 0) {
                Condition = 'CustId=' + Customer + ' and JobNumber=' + Job + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }

            else{
                Condition = 'SalesManId=' + Salesman + ' and CustId=' + Customer + ' and JobNumber=' + Job + ' and  CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
            }
            var data = {};
            data.Condition = Condition;
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/InvoicewiseSalesAnalysisGet",
                data: data,
                success: function (result) {

                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);

                }
            });
        });
    




