
@{
    ViewBag.Title = "AreaGroupwiseSales";
}

<script src="~/Scripts/Chart/highcharts.js"></script>
<script src="~/Scripts/Chart/export-data.js"></script>
<script src="~/Scripts/Chart/exporting.js"></script>



<style type="text/css">
   
    .form-control {
        font-weight: bold;
    }
</style>

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<div class="myData" data-x="M61" />
<div id="Entry">
   
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="30%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#AreaGroup').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <div id="divreport" style="display:none; overflow:auto">
                                    <hr style="margin-top:-1px;" />
                                    <table id="Tblreport" class="table table-striped table-bordered dataTable" style="margin: 0 auto 0 0;"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</div>


<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">AreaGroupwise Sales Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
 
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:14%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:4.5%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>

                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">
                        <label style="margin-top:2%;font-weight:bold;margin-left:4%">Area Group</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="AreaGroup" onchange="SubAreaGets()" name="priority" class="form-control"></select>
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Area</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="placeofsupply" name="priority" class="form-control"></select>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <fieldset class="form-group floating-label-form-group" style="margin-right:37%" >
                        <div class="row">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="graphreport">
                                <label class="custom-control-label" for="graphreport" style="font-weight:bold">Graphical Report</label>
                            </div>

                        </div>
                    </fieldset>
                    <button type="button" style="width:100px;" id="btnsubmit" onclick="AreaGroupwiseGraphReport('column')" class="btn btn-primary">Go</button>
                </div>

            </form>

        </div>
    </div>
</div>

<div class="row" id="graph" style="display:none">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <div>
                    <h3>AreaGroupwise Sales Report </h3>
                </div>
                <div class="text-right">
                    <button type="button" style="width:100px" onclick="$('#popupdiv').show(),$('#AreaGroup').focus()" id="btnback" class="btn btn-outline-primary">Back</button>
                </div>
            </div>
            <div class="card-body">
                <div class="card-block">
                    <div id="line-area" class="height-350 lineArea">
                        <div id="Sales" style="min-width: 310px; height: 350px; margin: 0 auto"></div>

                        <div class="input-group" style="margin-top:-20px;">
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline1" checked="" name="customRadioInline1" class="custom-control-input" onclick="AreaGroupwiseGraphReport('column')">
                                <label class="custom-control-label" for="customRadioInline1">Column chart</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline2" name="customRadioInline1" class="custom-control-input" onclick="AreaGroupwiseGraphReport('line')">
                                <label class="custom-control-label" for="customRadioInline2">Line chart</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                    <input type="radio" id="customRadioInline3" name="customRadioInline1" class="custom-control-input" onclick="('container')">
                                    <label class="custom-control-label" for="customRadioInline3">Pi chart</label>
                                </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline4" name="customRadioInline1" class="custom-control-input" onclick="('container2')">
                                <label class="custom-control-label" for="customRadioInline4">Half-Pi chart</label>
                            </div>
                        </div>

                    </div>
                    <hr />
                    <div class="card-body" id="pi" style="display:none">
                        <div id="container" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto;"></div>
                    </div>
                    <div class="card-body" id="halfpi" style="display:none">
                        <div id="container2" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto"></div>
                    </div>

                    <table id="salesrept"></table>
                </div>
            </div>
        </div>
    </div>
</div>



<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }


    function ShowReport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th>Taxable Amount</th><th>Tax Amount</th><th>Amount</th><th>FC Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var x = result[i].HFlag;
            var slno = parseInt(i + 1);
            if (x == "AG") {
                responseText += '<tr style=background-color:#b0bec5><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].InvoNo + '</td><td><b>' + result[i].InvoDate + '</b></td><td>' + result[i].Customer + '</td><td>' + result[i].CustAddress + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td></tr>';
            }
            
            else if (x == "A") {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].InvoNo + '</td><td><b>' + result[i].InvoDate + '</b></td><td>' + result[i].Customer + '</td><td>' + result[i].CustAddress + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td></tr>';
            }
            else if (result[i].InvoDate == "Grand Total") {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].InvoNo + '</td><td><b>' + result[i].InvoDate + '</b></td><td>' + result[i].Customer + '</td><td>' + result[i].CustAddress + '</td><td style=text-align:right><b>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].FCAmount || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else {
                responseText += '<tr ondblclick=gotoInvoNo(' + result[i].InvoNo + "," + result[i].BillSeriesId + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].CustAddress + '</td><td style=text-align:right>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].FCAmount || 0).toFixed(Decimal) + '</td><td style=display:none><input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '/></td><td style=display:none><input type="hidden" id="BillSeries_' + i + '" value=' + result[i].BillSeriesId + '/></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "AreaGroupwise Sales Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Bill#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Bill Series') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Dept.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Customer') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
            if (title == 'Customer Details') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:500px" />');
            }
          
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function gotoInvoNo(InvoNo, BillSeriesId, DeptId) {
        if ((usermenu1.indexOf("M54") != -1)) {
            window.open('../inventory/SalesInvoice?slno=' + InvoNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

        }
        else if ((usermenu1.indexOf("M227") != -1)) {
            window.open('../inventory/SalesInvoiceNew?slno=' + InvoNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

        }
        else {
            warningshow('Invalid User Rights');
            return false;
        }
    }
    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

    function ShowReportShort(result, GrType) {
        $('#salesrept').html('');
        var Amount = [];
        var AreaGroup = [];
        var GrData = [];

        $("#salesrept").append('<thead><th>Area Group</th><th>Amount</th></thead>');
        for (var i = 0; i < result.length; i++) {
            Amount.push(parseFloat(result[i].Amount || 0));
            AreaGroup.push(result[i].AreaGroup);
            GrData.push({ name: result[i].AreaGroup, y: parseFloat(result[i].Amount || 0) })
            $("#salesrept").append('<tr><td>' + result[i].AreaGroup + '</td><td>' + result[i].Amount + '</td></tr>');
        }



        Highcharts.chart('Sales', {
            chart: { type: GrType },
            title: {
                text: 'AreaGroupwise Sales'
            },
            subtitle: {
                text: 'Source: eumierp.com'
            },
            xAxis: {
                categories: AreaGroup
            },
            yAxis: {
                title: {
                    text: 'Sales()'
                }
            },
            colors: [
                           '#FF4758',
                           '#08B46B',
                           '#19B6D4',
                            '#FF8558',
                           '#ec407a',
                           '#9c27b0',
                            '#1a237e',
                            '#3e2723'
            ],
            plotOptions: {
                column: {
                    colorByPoint: true,
                },

            },
            series: [
            {
                name: 'Amount',
                data: Amount
            },
            ]
        });



        //For PI Chart
        Highcharts.chart('container', {
            chart: {
                plotBackgroundColor: null,
                plotBorderWidth: null,
                plotShadow: false,
                type: 'pie'
            },
            title: {
                text: 'AreaGroupwise Sales-PI Chart'
            },
            tooltip: {
                pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>'
            },
            colors: [
                   '#FF4758',
                   '#08B46B',
                   '#19B6D4',
                    '#FF8558',
                   '#ec407a',
                   '#9c27b0',
                    '#1a237e',
                    '#3e2723'
            ],
            plotOptions: {
                pie: {
                    allowPointSelect: true,
                    cursor: 'pointer',
                    dataLabels: {
                        enabled: false
                    },
                    showInLegend: true
                }
            },
            series: [{
                name: 'Sales',
                colorByPoint: true,
                data: GrData
            }]
        });

        Highcharts.chart('container2', {
            chart: {
                plotBackgroundColor: null,
                plotBorderWidth: 0,
                plotShadow: false,
                type: 'pie',
            },
            title: {
                text: 'AreaGroupwise Sales-Half PI Chart'
            },
            tooltip: {
                pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>'
            },
            colors: [
                   '#FF4758',
                   '#08B46B',
                   '#19B6D4',
                    '#FF8558',
                   '#ec407a',
                   '#9c27b0',
                    '#1a237e',
                    '#3e2723'
            ],
            plotOptions: {
                pie: {
                    dataLabels: {
                        enabled: true,
                        distance: -50,
                        style: {
                            fontWeight: 'bold',
                            color: 'white'
                        }
                    },
                    startAngle: -90,
                    endAngle: 90,
                    center: ['50%', '75%']
                }
            },
            series: [{
                name: 'Sales',
                innerSize: '50%',
                colorByPoint: true,
                data: GrData

            }]
        });



    }






    function GetAreaGroupselect(id) {
        var data = {};
        data.AreaGrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGroupGetandGets",
            data: data,
            success: function (result) {
                AreaGroupLoad(result.oList, id);
            }
        });

    }

    function AreaGroupLoad(result) {
        $("#AreaGroup").empty();
        $("#AreaGroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#AreaGroup").append("<option value='" + result[i].AreaGrpId + "'>" + result[i].AreaName + "</option>");
        }
        SubAreaGets();
    }



    function SubAreaGets() {

        var data = {};
        data.AreaGrpId = $("#AreaGroup").val();

        if (data.AreaGrpId == 0)
        {
            data.Id = 0;
            $.ajax({
                type: "POST",
                url: "../Master/AreaGetandGets",
                data: data,
                success: function (result) {
                    SubAreaLoad(result.oList);
                }
            });
        }

        else {
            data.Id = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubAreaGetforArea",
                data: data,
                success: function (result) {
                    SubAreaLoad(result.oList);
                }
            });

        }

    }


    function SubAreaLoad(result) {
        $("#placeofsupply").empty();
        $("#placeofsupply").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#placeofsupply").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaName + "</option>");
        }
    }




    $(function () {
        $("#AreaGroup").focus();
        GetAreaGroupselect(0);
        $("#customRadioInline1").click(function (e) {
            $('#pi').hide();
            $('#halfpi').hide();
            $('#Sales').show();
            $('#Loading').hide();
        });
        $("#customRadioInline2").click(function (e) {
            $('#pi').hide();
            $('#halfpi').hide();
            $('#Sales').show();
            $('#Loading').hide();
        });
        $("#customRadioInline3").click(function (e) {
            $('#pi').show();
            $('#halfpi').hide();
            $('#Sales').show();
            $('#Loading').hide();
        });
        $("#customRadioInline4").click(function (e) {
            $('#halfpi').show();
            $('#pi').hide();
            $('#Sales').show();
            $('#Loading').hide();
        });


        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#AreaGroup').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#placeofsupply').focus();
                e.preventDefault();
            }
        });
        $('#placeofsupply').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
    });



    function AreaGroupwiseGraphReport(Grtype) {
        $('#Loading').show();

        if ($("#graphreport").prop("checked")) {
            var data = {};
            data.Fromdate = $('#DateFrom').val();
            data.Todate = $('#DateTo').val();
            data.AreaId = parseInt($('#placeofsupply').val() || 0);
            data.AreaGroupId = parseInt($('#AreaGroup').val() || 0);
            data.Userid = ERPUserId;

            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/AreaGroupwiseGraphReport",
                data: data,
                success: function (result) {
                    ShowReportShort(result, Grtype);
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    $('#Entry').hide();
                    $('#graph').show();

                }
            });
        }
        else {

            var data = {};
            data.DateFrom = $('#DateFrom').val();
            data.DateTo = $('#DateTo').val();
            data.PlaceOfSupply = parseInt($('#placeofsupply').val() || 0);
            data.AreaGroup = parseInt($('#AreaGroup').val() || 0);
            data.Userid = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/AreaGroupSalesReportGet",
                data: data,
                success: function (result) {
                    ShowReport(result);
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    $('#Entry').show();
                    $('#graph').hide();
                }
            });
        }

        //});
    }

</script>







