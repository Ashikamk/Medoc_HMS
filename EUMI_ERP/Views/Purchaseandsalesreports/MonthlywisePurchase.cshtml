<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }
   


    function Showreport(result) {


     

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Purchase SlNo</th><th>Inv No</th><th>Inv Date</th><th>Supplier</th><th>Taxable Amount</th><th>Tax Amount</th><th>Amount</th><th>FC Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].PurchaseSlNo == '') {
                responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Purchase SlNo</th><th>Inv No</th><th>Inv Date</th><th>Supplier</th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Monthwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');

        $('#header').text(title);

        
    }


    $(function () {

    

        $("#supplierId").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#supplierId').val(0);
            }

        });

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnsubmit").click(function (e) {

            var Condition = '';
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
        



            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
           
            else {
                $('#Loading').show();
                Condition = 'CONVERT(datetime,InvoDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvoDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
                var data = {};
                data.Condition = Condition;
                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/PurchaseReportGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        var title = "Monthwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                       
                        
                    }
                });
            }
   

        });

    });





</script>


