                <div>
                    <h3>Top Customerwise Sales Report </h3>
                </div>
                <div class="text-right">
                    <button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button>
                </div>
            </div>
            <div class="card-body">
                <div class="card-block">
                    <div id="line-area" class="height-350 lineArea">
                        <div id="Sales" style="min-width: 310px; height: 350px; margin: 0 auto"></div>



                        <div class="input-group" style="margin-top:-20px;">
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline1" checked="" name="customRadioInline1" class="custom-control-input" onclick="TopCustomerGraphReport('column')">
