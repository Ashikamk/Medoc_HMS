<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }

    $("#customername").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#customername").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#customerId').val(ui.item.CustId)
            $('#customername').val(ui.item.CustName)
            $('#custnames').val(ui.item.CustName)

            
            $('#Values').focus();
        },

    });


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Customer Code</th><th>Customer Name</th><th>Quantity</th><th style=text-align:right>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].Customer == 'Grand Total') {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].CustId + '</td><td><b>' + result[i].Customer + '</b></td><td><b>' + result[i].Qty + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].CustId + '</td><td>' + result[i].Customer + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';
            }
           
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Customer Code</th><th>Customer Name</th><th>Quantity</th><th style=text-align:right> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Top Customer Analysis Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }

            if (title == 'Quantity') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Supplier Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:110px" />');
            }

            if (title == 'Supplier Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:230px" />');
            }




        });
        var table = null;
        table = $('#' + tablename).DataTable({
            //dom: 'Blfrtip',
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
            //"columnDefs": [

            //     { "width": "17%", "targets": 2 },
            //     { "width": "18%", "targets": 3 },
            //      { "width": "15%", "targets": 4 },
            //        { "width": "15%", "targets": 5 },
            //          { "width": "10%", "targets": 6 },
            //           { "width": "10%", "targets": 7 },

            //]

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }
    function ShowReportShort(result, GrType) {

        console.log(result);
        console.log(GrType);


        $('#salesrept').html('');
        var Amount = [];
        var Customer = [];
        var GrData = [];

        $("#salesrept").append('<thead><th>Customer</th><th>Amount</th></thead>');
        for (var i = 0; i < result.length; i++) {
            Amount.push(parseFloat(result[i].Amount || 0));
            Customer.push('Customer:' + result[i].Customer);
            GrData.push({ name: result[i].Customer, y: parseFloat(result[i].Amount || 0) })
            $("#salesrept").append('<tr><td>' + result[i].Customer + '</td><td>' + result[i].Amount + '</td></tr>');
        }



        //For Column chart and Line Chart
        Highcharts.chart('Sales', {
            chart: { type: GrType },
            title: {
                text: 'Top Customerwise Sales'
            },
            subtitle: {
                text: 'Source: eumierp.com'
            },
            xAxis: {
                categories: Customer
            },
            yAxis: {
                title: {
                    text: 'Sales()'
                }
            },
            colors: [
            '#FF4758',
            '#08B46B',
            '#19B6D4',
             '#FF8558',
            '#ec407a',
            '#9c27b0',
             '#1a237e',
             '#3e2723'
           ],
            plotOptions: {
                column: {
                    colorByPoint: true,
                },

            },
            series: [
            {
                name: 'Amount',
                data: Amount
            },
            ]
        });

        //For PI Chart
        Highcharts.chart('container', {
            chart: {
                plotBackgroundColor: null,
                plotBorderWidth: null,
                plotShadow: false,
                type: 'pie'
            },
            title: {
                text: 'Top Customerwise Sales-PI Chart'
            },
            tooltip: {
                pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>'
            },
            colors: [
            '#FF4758',
            '#08B46B',
            '#19B6D4',
            '#FF8558',
            '#ec407a',
            '#9c27b0',
            '#1a237e',
            '#3e2723'
            ],
            plotOptions: {
                pie: {
                    allowPointSelect: true,
                    cursor: 'pointer',
                    dataLabels: {
                        enabled: false
                    },
                    showInLegend: true
                }
            },
            series: [{
                name: 'Sales',
                colorByPoint: true,
                data: GrData
            }]
        });

        Highcharts.chart('container2', {
            chart: {
                plotBackgroundColor: null,
                plotBorderWidth: 0,
                plotShadow: false,
                type: 'pie',
            },
            title: {
                text: 'Top Customerwise Sales-Half PI Chart'
            },
            tooltip: {
                pointFormat: '{series.name}: <b>{point.percentage:.1f}%</b>'
            },
            colors: [
                     '#FF4758',
                     '#08B46B',
                     '#19B6D4',
                      '#FF8558',
                     '#ec407a',
                     '#9c27b0',
                      '#1a237e',
                      '#3e2723'
            ],
            plotOptions: {
                pie: {
                    dataLabels: {
                        enabled: true,
                        distance: -50,
                        style: {
                            fontWeight: 'bold',
                            color: 'white'
                        }
                    },
                    startAngle: -90,
                    endAngle: 90,
                    center: ['50%', '75%']
                }
            },
            series: [{
                name: 'Sales',
                innerSize: '50%',
                colorByPoint: true,
                data: GrData

            }]
        });

    }

    $(function () {
        $("#customername").focus();
        $("#customRadioInline1").click(function (e) {
            $('#pi').hide();
            $('#halfpi').hide();
            $('#Sales').show();
            $('#Loading').hide();
        });
        $("#customRadioInline2").click(function (e) {
            $('#pi').hide();
            $('#halfpi').hide();
            $('#Sales').show();
            $('#Loading').hide();
        });
        $("#customRadioInline3").click(function (e) {
            $('#pi').show();
            $('#halfpi').hide();
            $('#Sales').hide();
            $('#Loading').hide();
        });
        $("#customRadioInline4").click(function (e) {
            $('#halfpi').show();
            $('#pi').hide();
            $('#Sales').hide();
            $('#Loading').hide();
        });

        $('#Values').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });

        //$("#customername").keydown(function (e) {
        //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        //    $('#customerId').val(0);
        //    if (key == 13) {
        //        e.preventDefault();
        //        $('#btnsubmit').focus();
        //    }

        //});
       
      

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

    });

        function TopCustomerGraphReport(Grtype) {




         
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {


                $('#Loading').show();

                if ($("#graphreport").prop("checked")) {
                    var data = {};
                    data.DateFrom = $('#DateFrom').val();
                    data.DateTo = $('#DateTo').val();
                    data.number = parseInt($('#Values').val() || 0);
                    data.CustId = parseInt($('#customerId').val() || 0);
                    data.UserId = ERPUserId;

                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/TopCustomerAnalysisGraph",
                        data: data,
                        success: function (result) {
                            ShowReportShort(result, Grtype);
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            $('#Entry').hide();
                            $('#graph').show();
                            console.log(result)
                        }
                    });
                }
                else {

                    var data = {};
                    data.DateFrom = $('#DateFrom').val();
                    data.DateTo = $('#DateTo').val();
                    data.number = parseInt($('#Values').val() || 0);
                    data.CustId = parseInt($('#customerId').val() || 0);
                    data.UserId = ERPUserId;

                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/TopCustomerReportGet",
                        data: data,
                        success: function (result) {
                            Showreport(result);
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            $('#Entry').show();
                            $('#graph').hide();
                        }
                    });
                }
            }


        }

   
        function change()
        {
            if ($('#customername').val() == '') {
                $('#customerId').val(0);
            }

        }

</script>







