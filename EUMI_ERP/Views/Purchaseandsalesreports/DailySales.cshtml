
@{
    ViewBag.Title = "DailySales";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>




<div id="Main">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                  
                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="41%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">

                                <br /><hr />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                                <br /><br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Itemwise Sales Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:37px">From Date </label>
                        <div class="col-md-4">
                            <input type="text" id="dpDateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="margin-top:5px;margin-left:60px">To Date </label>
                        <div class="col-md-4">
                            <input type="text" id="dpDateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">

                        <label style="margin-top:5px;margin-left:78px">Area </label>
                        <div class="col-md-4">
                            <select id="cmbArea" name="priority" class="form-control"></select>
                        </div>


                        <label style="margin-top:5px;margin-left:50px">Pay Type </label>
                        <div class="col-md-4">
                            <select id="cmbPayType" class="form-control" name="priority">
                                <option value="0">-Select-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:40px">Salesman </label>
                        <div class="col-md-4">
                            <select id="cmbSalesMan" class="form-control" name="priority"></select>
                        </div>


                        <label style="margin-top:5px;margin-left:45px">Customer</label>
                        <div class="col-md-4">
                            <input type="text" id="cmbCustomerName" onkeyup="checkcustempty()" class="form-control">
                            <input type="hidden" id="CustomerID" value="0" class="form-control" />
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:67px">Group </label>
                        <div class="col-md-4">
                            <select id="cmbGroup" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-Select-</option>
                            </select>
                        </div>

                        <label style="margin-top:5px;margin-left:40px">Sub Group </label>
                        <div class="col-md-4">
                            <select id="cmbSubgroup" class="form-control" name="priority">
                                <option value='0'>-Select-</option>
                            </select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:45px">Category </label>
                        <div class="col-md-4">
                            <select id="cmbCategory" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-Select-</option>
                            </select>
                        </div>

                        <label style="margin-top:5px;margin-left:18px">Sub Category</label>
                        <div class="col-md-4">
                            <select id="cmbSubcategory" class="form-control" name="priority">
                                <option value='0'>-Select-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:25px">Department</label>
                        <div class="col-md-4">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>
                    </div>

                    </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px" id="btnGo" class="btn btn-outline-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>

    $("#cmbCustomerName").autocomplete({
        source: function (request, response) {

            var data = {};
            data.CustName = $("#cmbCustomerName").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustomerID').val(ui.item.CustId)

        },

    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }


    function ShowReport(result)
    {

        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th>Slno</th><th>Bill Series</th><th>Bill SlNo</th><th>Bill Date</th><th>Customer</th><th>SalesMan</th><th>Area</th><th>LPO Number</th><th>Product Code</th><th>Product Description</th><th>Unit</th><th>Quantity</th><th>Discount</th><th>Taxable Amount</th><th>Tax</th><th>Tax Amount</th><th>Amount</th><th>Currency</th><th>Rate</th><th>FC Amount</th><th>Location</th><th>Job Number</th><th>Pay Type</th><th>Terms</th><th>Department</th><th>Group</th><th>Subgroup</th><th>Category</th><th>Subcategory</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].BillSlNo == '') {
                ResponseEntity += '<tr style=background-color:#00CED1><td>' + slno + '</td><td>' + result[i].BillSeriesID + '</td><td>' + result[i].BillSlNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].CustName + '</td><td>' + result[i].SalesManName + '</td><td>' + result[i].AreaName + '</td><td>' + result[i].LPONumber + '</td><td>' + result[i].ProductCode + '</td><td>' + result[i].ProductDescription + '</td><td>' + result[i].Unit + '</td><td>' + result[i].Quantity + '</td><td style=text-align:right>' + parseFloat(result[i].Discount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Tax || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td>' + result[i].CurrencyID + '</td><td style=text-align:right>' + result[i].CurrencyRate  + '</td><td style=text-align:right>' + parseFloat(result[i].FCTaxAmount || 0).toFixed(Decimal) + '</td><td>' + result[i].LockID + '</td><td>' + result[i].JobNumber + '</td><td>' + result[i].PayType + '</td><td>' + result[i].InvTerms + '</td><td>' + result[i].Department + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubgroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td></tr>';
            }
            else {
                ResponseEntity += '<tr onclick=gotoInvoNo(' + result[i].BillSlNo + "," + result[i].BillSeriesID + "," + result[i].DeptId+')><td>' + slno + '</td><td>' + result[i].BillSeriesID + '</td><td>' + result[i].BillSlNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].CustName + '</td><td>' + result[i].SalesManName + '</td><td>' + result[i].AreaName + '</td><td>' + result[i].LPONumber + '</td><td>' + result[i].ProductCode + '</td><td>' + result[i].ProductDescription + '</td><td>' + result[i].Unit + '</td><td>' + result[i].Quantity + '</td><td style=text-align:right>' + parseFloat(result[i].Discount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Tax || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td>' + result[i].CurrencyID + '</td><td style=text-align:right>' + result[i].CurrencyRate + '</td><td style=text-align:right>' + parseFloat(result[i].FCTaxAmount || 0).toFixed(Decimal) + '</td><td>' + result[i].LockID + '</td><td>' + result[i].JobNumber + '</td><td>' + result[i].PayType + '</td><td>' + result[i].InvTerms + '</td><td>' + result[i].Department + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubgroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td></tr>';
            }
        }
        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th>Slno</th><th>Bill Series</th><th>Bill SlNo</th><th>Bill Date</th><th>Customer</th><th>SalesMan</th><th>Area</th><th>LPO Number</th><th>Product Code</th><th>Product Description</th><th>Unit</th><th>Quantity</th><th>Discount</th><th>Taxable Amount</th><th>Tax</th><th>Tax Amount</th><th>Amount</th><th>Currency</th><th>Rate</th><th>FC Amount</th><th>Location</th><th>Job Number</th><th>Pay Type</th><th>Terms</th><th>Department</th><th>Group</th><th>Subgroup</th><th>Category</th><th>Subcategory</th></tr> </tfoot>');
        var title = "Itemwise Sales Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function gotoInvoNo(BillSlNo,BillSeriesID, DeptId) {
        sessionStorage.setItem("sales_slno", BillSlNo);
        sessionStorage.setItem("sales_srs", BillSeriesID);
        sessionStorage.setItem("sales_deptid", DeptId);
        window.location = "@Url.Action("SalesInvoice", "inventory", new { from = "SalesReport" })";
    }



    function GetDepartment(id) {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#department").empty();
        $("#department").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
        if (a == 0) {
            $('#department').val(0);
        }
        else {
            $('#department').val(a);
        }
    }


    $(function ()
    {
        GetArea(0);
        GetSalesMan(0);
        GroupPageLoad(0);
        CategoryPageLoad(0);
        GetDepartment(0);

        $('#dpDateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $('#dpDateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnGo").click(function (e)
        {
            $('#Loading').show();

                var data = {};
                data.InvDate = $('#dpDateFrom').val();
                data.DueDate = $('#dpDateTo').val();
                data.AreaId = $('#cmbArea').val();
                data.SalesManId = $('#cmbSalesMan').val();
                data.CustID = $('#CustomerID').val();
                data.GroupID = $('#cmbGroup').val();
                data.SubgroupID = $('#cmbSubgroup').val();
                data.CategoryID = $('#cmbCategory').val();
                data.SubCategoryID = $('#cmbSubcategory').val();
                data.Department = $('#department').val();
                data.PayType = $('#cmbPayType').val();

                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/DailySalesGet",
                    data: data,
                    success: function (result) {
                        ShowReport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
        });
    });


    function GetArea(id)
    {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGetandGets",
            data: data,
            success: function (result)
            {
                AreaLoad(result.oList, id);
            }
        });
    }

    function AreaLoad(result, a)
    {
        $("#cmbArea").empty();
        $("#cmbArea").append("<option value='0'>-Select-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbArea").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaCode + "</option>");
        }
        if (a == 0)
        {
            $('#cmbArea').val(0);
        }
        else {
            $('#cmbArea').val(a);
        }
    }


    function GetSalesMan(id)
    {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/SalesmanGetandGets",
            data: data,
            success: function (result)
            {
                SalesManLoad(result.oList, id);
            }
        });
    }

    function SalesManLoad(result,a)
    {
        $("#cmbSalesMan").empty();
        $("#cmbSalesMan").append("<option value='0'>-Select-</option>")
        for (var i = 0; i < result.length; i++) {
            $("#cmbSalesMan").append("<option value='" + result[i].Id + "'>" + result[i].FirstName + "</option>");
        }
        if (a == 0)
        {
            $('#cmbSalesMan').val(0);
        }
        else
        {
            $('#cmbSalesMan').val(a);
        }
    }


    function checkcustempty()
    {
        $('#CustomerID').val(0);
    }

    function GroupPageLoad(id) {
        var data1 = {};
        data1.GrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/GroupGetandGets",
            data: data1,
            success: function (result) {
                GroupLoad(result.oList,id);
            }
        });
    }

    function GroupLoad(result) {
        $("#cmbGroup").empty();
        $("#cmbGroup").append("<option value='0'>-Select-</option>");
        for (var i = 0; i < result.length; i++) {

            $("#cmbGroup").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
        }
        SubGroupGets();
    }

    function SubGroupGets() {
        var data = {};
        data.GroupId = $("#cmbGroup").val();


        if (data.GroupId == 0) {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetandGets",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
        else {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetForGroup",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
    }

    function SubGroupLoad(result) {
        $("#cmbSubgroup").empty();
        $("#cmbSubgroup").append("<option value='0'>-Select-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbSubgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
        }
    }



    function CategoryPageLoad(id) {
        var data2 = {};
        data2.CategoryId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CategoryGetandGets",
            data: data2,
            success: function (result) {
                CategoryLoad(result.oList,id);
            }
        });
    }


    function CategoryLoad(result) {
        $("#cmbCategory").empty();
        $("#cmbCategory").append("<option value='0'>-Select-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbCategory").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
        }
        SubCategoryGets();
    }

    function SubCategoryGets() {

        var data = {};
        data.CategoryId = $("#cmbCategory").val();

        if (data.CategoryId == 0) {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetandGets",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);

                }
            });
        }

        else {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetforCategory",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);
                }
            });
        }
    }



    function SubCategoryLoad(result) {
        $("#cmbSubcategory").empty();
        $("#cmbSubcategory").append("<option value='0'>-Select-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbSubcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
        }
    }

</script>