    function gotoInvoNo(PurchaseSlNo, DeptId) {
        if ((usermenu1.indexOf("M426") != -1)) {
            window.open('../inventory/PurchaseInvoice?slno=' + PurchaseSlNo + '&dept=' + DeptId);
        }
        else if ((usermenu1.indexOf("M233") != -1)) {
            window.open('../Purchase/PurchaseInvoiceNew?slno=' + PurchaseSlNo + '&dept=' + DeptId);

