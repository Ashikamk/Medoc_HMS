                    '<td id="Col11_' + slno + '" style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].SalesAmount || 0).toFixed(Decimal)) + '</td>' +
                    '<td id="Col12_' + slno + '" style=text-align:center>' + result[i].CurrencyName + '</td>' +
                    '<td id="Col13_' + slno + '" style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].CurrencyRate || 0).toFixed(Decimal)) + '</td>' +
