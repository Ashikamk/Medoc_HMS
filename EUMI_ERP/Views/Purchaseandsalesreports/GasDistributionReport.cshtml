        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Dept.</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th>Salesman</th><th>Area</th><th>Pay Type</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th><th>Fx.</th><th style=text-align:right>Rate</th><th style=text-align:right>FC Amount</th></tr></thead><tbody>";


