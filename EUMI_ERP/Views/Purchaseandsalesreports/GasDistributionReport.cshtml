
@{
    ViewBag.Title = "GasDistributionReport";
}


<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>





<table style="display:none" id="Tblreportprint"></table>

<div class="myData" data-x="M303" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="35%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#customername').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                @*<td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('SALESREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>*@
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        </table>
                        <div align="center">
                            <br /><hr style="margin-top:-1%" />
                            <div class="heading-elements">

                                <div id="divreport" style="overflow:auto;display:none;">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:100%;">
    <div class="modal-dialog " role="document" style="top:5%;max-width:35%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Gas Distribution Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">

                    <div class="row">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">From</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-2">
                            <label style="font-weight:bold;">To</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>

                    </div>

                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>

                    <div class="row" style="margin-top:2%;">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">Customer</label>
                        </div>

                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="30%">
                                        <input type="text" id="customername" class="form-control" onkeyup="$('#custnames').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="customerId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="custnames" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>


                    <div class="row" style="margin-top:2%;">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">Area </label>
                        </div>

                        <div class="col-md-4">
                            <select id="placeofsupply" name="priority" class="form-control"></select>
                        </div>
                        <label class="col-md-2" style="font-weight:bold;">Pay Type</label>
                        <div class="col-md-4">
                            <select id="PayType" class="form-control" name="priority">
                                <option value="0">-All-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>

                    </div>

                    <div class="row" style="margin-top:2%">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">Salesman</label>
                        </div>

                        <div class="col-md-4">
                            <select id="salesman" name="priority" class="form-control"></select>
                        </div>
                        <div class="col-md-2">
                            <label style="font-weight:bold;">Dept.</label>
                        </div>

                        <div class="col-md-4">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <fieldset class="form-group floating-label-form-group" style="margin-right:65%">
                        <div class="row">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="grpbyFC">
                                <label class="custom-control-label" for="grpbyFC" style="font-weight:bold">FC Amount</label>
                            </div>
                        </div>
                    </fieldset>

                    <button type="button" style="width:80px" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />

                </div>

            </form>
        </div>
    </div>
</div>

<script>
    var SummaryFlag = 0;
    //Customername Autocomplete

    $("#customername").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#customername").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#customerId').val(ui.item.CustId)
            $('#customername').val(ui.item.CustName)
            $("#custnames").val(ui.item.CustName);
            $('#placeofsupply').focus();
        },

    });
    //User Autocomplete

    $("#User").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.UserName = $("#User").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        console.log(data)
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            value2: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#UserId').val(ui.item.value2)
            $('#User').val(ui.item.UserName)
        },

    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }





    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

    //Area Load

    function GetArea(id) {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGetandGets",
            data: data,
            success: function (result) {
                AreaLoad(result.oList, id);


            }
        });
    }

    function AreaLoad(result, a) {
        $("#placeofsupply").empty();
        $("#placeofsupply").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#placeofsupply").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaCode + "</option>");
        }
        if (a == 0) {
            $('#placeofsupply').val(0);
        }
        else {
            $('#placeofsupply').val(a);
        }
    }


    //Department Load

    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#department").empty();
        $("#department").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    // Selesman Load
    function GetSalesMan(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserSalesmanGetandGets",
            data: data,
            success: function (result) {
                SalesManLoad(result.oList, id);
            }
        });
    }

    function SalesManLoad(result, a) {
        console.log(result)
        $("#salesman").empty();
        //$("#salesman").append("<option value='0'>-All-</option>")
        for (var i = 0; i < result.length; i++) {
            $("#salesman").append("<option value='" + result[i].SalesmanId + "'>" + result[i].FirstName + "</option>");
        }
    }





    $(function () {
        $('#customername').focus();
        $('#btndetail').prop("checked", true);

        GetArea(0);
        GetDepartment(0);
        GetSalesMan(0);



        $('#placeofsupply').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#PayType').focus();
                e.preventDefault();
            }
        });

        $('#PayType').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#salesman').focus();
                e.preventDefault();
            }
        });
        $('#salesman').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#User').focus();
                e.preventDefault();
            }
        });
        $('#User').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#department').focus();
                e.preventDefault();
            }
        });

        $('#department').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            $('#Loading').show();
            $('#btndetail').prop("checked", true);

            if ($('#customername').val() == '') {
                $('#customerId').val('');
            }

            var data = {};
            data.FromDate = $('#DateFrom').val();
            data.ToDate = $('#DateTo').val();
            data.CustId = $('#customerId').val();
            data.SalesmanId = $('#salesman').val();
            data.AreaId = $('#placeofsupply').val();
            data.PayTerms = $('#PayType').val();
            data.DeptId = $('#department').val();
            $.ajax({
                type: "POST",
                url: "../SalesReport/GasDistributionGets",
                data: data,
                success: function (result) {

                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    if ($("#grpbyFC").prop("checked")) {
                        ShowreportFC(result);
                    }
                    else
                    {
                        Showreport(result);
                    }
                }
            });

        });
    });
    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Dept.</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th>Salesman</th><th>Area</th><th>Pay Type</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th></tr></thead><tbody>";


        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            console.log(slno)

            if (result[i].CustoName == 'Total') {
                responseText += '<tr  style=background-color:#cfd8dc><td style=text-align:center>' + slno + '</td>' +
                    '<td id="Col1_' + slno + '">' + result[i].DepartmentCode + '</td>' +
                    '<td id="Col2_' + slno + '" style=text-align:center ></td>' +
                    '<td  id="Col3_' + slno + '" style=text-align:center >' + result[i].InvDate + '</td>' +
                    '<td id="Col4_' + slno + '"><b>' + result[i].CustoName + '</b></td>' +
                    '<td id="Col5_' + slno + '">' + result[i].CustAddress + '</td>' +
                    '<td id="Col6_' + slno + '">' + result[i].FirstName + '</td>' +
                    '<td id="Col7_' + slno + '">' + result[i].Code + '</td>' +
                    '<td id="Col8_' + slno + '">' + result[i].PayTerms + '</td>' +
                    '<td id="Col9_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal)) + '</b></td>' +
                    '<td id="Col10_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].TotalTax || 0).toFixed(Decimal)) + '</b></td>' +
                    '<td id="Col11_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].SalesAmount || 0).toFixed(Decimal)) + '</b></td>' +
                    '</tr>';
            }

            else {
                responseText += '<tr><td style=text-align:center>' + slno + '</td>' +
                    '<td id="Col1_' + slno + '">' + result[i].DepartmentCode + '</td>' +
                    '<td id="Col2_' + slno + '" style=text-align:center >' + result[i].Billdescription + '-' + result[i].BillSlNo + '</td>' +
                    '<td  id="Col3_' + slno + '" style=text-align:center >' + result[i].InvDate + '</td>' +
                    '<td id="Col4_' + slno + '">' + result[i].CustoName + '</td>' +
                    '<td id="Col5_' + slno + '">' + result[i].CustAddress + '</td>'+
                    '<td id="Col6_' + slno + '">' + result[i].FirstName + '</td>' +
                    '<td id="Col7_' + slno + '">' + result[i].Code + '</td>' +
                    '<td id="Col8_' + slno + '">' + result[i].PayTerms + '</td>' +
                    '<td id="Col9_' + slno + '" style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal)) + '</td>' +
                    '<td id="Col10_' + slno + '" style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].TotalTax || 0).toFixed(Decimal)) + '</td>' +
                    '<td id="Col11_' + slno + '" style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].SalesAmount || 0).toFixed(Decimal)) + '</td>' +
                    '</tr>';
                }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th> </th><th>Dept.</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th>Salesman</th><th>Area</th><th>Pay Type</th><th> </th><th> </th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText)
        var title = "Gas Distribution Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#ResultLength').val(result.length);

    }

