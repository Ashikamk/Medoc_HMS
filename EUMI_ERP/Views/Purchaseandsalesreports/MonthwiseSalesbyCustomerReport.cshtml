
@{
    ViewBag.Title = "MonthwiseSalesbyCustomerReport";
}





<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

</style>

<div class="myData" data-x="M70" />

<div id="Entry">
  
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="25%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(),$('#customername').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">
                                <hr style="margin-top:-1px;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%;max-width:35%;margin-left:33%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">Monthwise Sales Report by Customer</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
              
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-1"></div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">From</label>
                        <div class="col-md-3">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">To</label>
                        <div class="col-md-3">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-1"></div>

                    </div>
                    <div class="row" style="margin-top:2%;">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Customer</label>
                        <div class="col-md-8">
                            <table width="100%">
                                <tr>
                                    <td width="30%">
                                        <input type="text" id="customername" class="form-control" onkeyup="$('#custnames').val(''), change()" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="customerId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="custnames" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-1"></div>
                    </div>

                    @*<div class="row" style="margin-top:2%">

                        <label style="font-weight:bold;">Customer</label>
                        <div class="col-md-4">
                            <input type="text" id="customername" class="form-control" onkeyup="change()">
                            <input type="hidden" id="customerId" class="form-control" />
                        </div>
                    </div>*@
                </div>
               
                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:45%" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>


<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    $("#customername").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#customername").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#customerId').val(ui.item.CustId)
            $('#customername').val(ui.item.CustName)
            $('#custnames').val(ui.item.CustName)
            $("#btnsubmit").focus();
        },

    });


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Customer Code</th><th>Customer Name</th><th>January</th><th>February</th><th>March</th><th>April</th><th>May</th><th>June</th><th>July</th><th>August</th><th>September</th><th>October</th><th>November</th><th>December</th><th>Total</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].Customer == 'TOTAL') {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].CustId + '</td><td><b>' + result[i].Customer + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column1 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column2 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column3 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column4 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column5 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column6 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column7 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column8 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column9 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column10 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column11 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column12 || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Column13 || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].CustId + '</td><td>' + result[i].Customer + '</td><td style=text-align:right>' + parseFloat(result[i].Column1 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column2 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column3 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column4 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column5 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column6 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column7 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column8 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column9 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column10 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column11 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column12 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Column13 || 0).toFixed(Decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Customer Code</th><th>Customer Name</th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Monthwise Sales Report by Customer - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }
            if (title == 'Customer Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:110px" />');
            }
            if (title == 'January') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'February') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'March') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'April') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'May') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'June') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'July') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'August') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'September') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'October') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'November') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'December') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Total') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                "<'row'<'col-sm-12'tr>>" +
                "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    $(function () {


        $("#customername").focus();

        //$("#customername").keydown(function (e) {
        //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        //    $('#customerId').val(0);
        //    if (key == 13) {
        //        e.preventDefault();
        //        $("#btnsubmit").focus();
        //    }

        //});

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {
            var Condition = '';
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var Customer = parseInt($('#customerId').val() || 0);

          
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {


                $('#Loading').show();



                if (Customer == 0) {
                    Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
                }
                else {

                    Condition = 'Inv_SalesMain.CustId=' + Customer + ' and CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
                }



                var data = {};
                data.Condition = Condition;
                data.UserId = ERPUserId;
                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/MonthwiseSalesReportbyCustomerGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }


        });

    });


    function change()
    {
        if ($('#customername').val() == '') {
            $('#customerId').val(0);
        }

    }


</script>







