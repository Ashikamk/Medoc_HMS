        font-weight: bold;
    }
</style>

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<div class="myData" data-x="M97" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>


                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="37%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <hr style="margin-top:-1px;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                               
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


    <div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1">
        <div class="modal-dialog" role="document" style="top:10%">
            <div class="modal-content">
                <div class="modal-header bg-primary white">
                    <h3 class="modal-title" id="myheader">GST Purchase Report</h3>
                    <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>
                <form id="monthpopup" style="display:none1">
                    <div class="modal-body">
                        <div class="row">
                            <label style="font-weight:bold;margin-left:10%">From</label>
                            <div class="col-md-4">
                                <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                            </div>


                            <label style="font-weight:bold;margin-left:-1%">To</label>
                            <div class="col-md-4">
                                <input type="text" id="DateTo" class="form-control" autocomplete="off">
                            </div>
                        </div>

                        <input type="text" class="form-control" id="UserId" style="display:none">
                    </div>
                   
                    <div class="modal-footer">
                        <button type="button" style="width:100px;margin-right:40%;" id="btnsubmit" class="btn btn-primary">Go</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }

        function Showreport(result) {
            disable_datatable('Tblreport', 'buttonPlace');

            // Updated header with CGST/SGST columns
            var responseText = `
    <thead>
        <tr>
            <th>Sl#</th><th>Inv.#</th><th>Sup.Inv.#</th><th>Date</th><th>Supplier</th><th>Gst No</th>
            <th>Amount0</th>
            <th>Amount5</th><th>CGST2.5</th><th>SGST2.5</th>
            <th>Amount12</th><th>CGST6</th><th>SGST6</th>
            <th>Amount18</th><th>CGST9</th><th>SGST9</th>
            <th>Amount28</th><th>CGST14</th><th>SGST14</th>
            <th>Taxable</th><th>Tax</th><th>Amount</th>
        </tr>
    </thead>
    <tbody>`;

            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);

                // Split GST into 2 parts
                var cgst5 = (parseFloat(result[i].GST5 || 0) / 2).toFixed(Decimal);
                var sgst5 = (parseFloat(result[i].GST5 || 0) / 2).toFixed(Decimal);

                var cgst12 = (parseFloat(result[i].GST12 || 0) / 2).toFixed(Decimal);
                var sgst12 = (parseFloat(result[i].GST12 || 0) / 2).toFixed(Decimal);

                var cgst18 = (parseFloat(result[i].GST18 || 0) / 2).toFixed(Decimal);
                var sgst18 = (parseFloat(result[i].GST18 || 0) / 2).toFixed(Decimal);

                var cgst28 = (parseFloat(result[i].GST28 || 0) / 2).toFixed(Decimal);
                var sgst28 = (parseFloat(result[i].GST28 || 0) / 2).toFixed(Decimal);

                // Common row data
                var rowData = '<td>' + slno + '</td>'
                    + '<td>' + result[i].BillNo + '</td>'
                    + '<td>' + result[i].BillSeries + '</td>'
                    + '<td>' + result[i].BillDate + '</td>'
                    + '<td>' + (result[i].Customer).split("##")[0] + '</td>'
                    + '<td>' + (result[i].Customer).split("##")[1] + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Amount0 || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Amount5 || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + cgst5 + '</td>'
                    + '<td style="text-align:right">' + sgst5 + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Amount12 || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + cgst12 + '</td>'
                    + '<td style="text-align:right">' + sgst12 + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Amount18 || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + cgst18 + '</td>'
                    + '<td style="text-align:right">' + sgst18 + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Amount28 || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + cgst28 + '</td>'
                    + '<td style="text-align:right">' + sgst28 + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Taxable || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Tax || 0).toFixed(Decimal) + '</td>'
                    + '<td style="text-align:right">' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td>';

                if (result[i].BillNo == '') {
                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold;">' + rowData + '</tr>';
                } else {
                    responseText += '<tr onclick="gotoInvoNo(' + result[i].BillNo + ',' + result[i].DeptId + ')">' + rowData + '</tr>';
                }
            }

            responseText += '</tbody><tfoot><tr><th colspan="22"></th></tr></tfoot>';

            $('#Tblreport').html(responseText);

            var title = "GST Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val();
            datatableWithsearch('Tblreport', true, title, 'buttonPlace');
            $('#header').text(title);
        }


    function Showreport111(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Inv.#</th><th>Sup.Inv.#</th><th>Date</th><th>Supplier</th><th>Gst No</th><th>Amount0</th><th>Amount5</th><th>GST5</th><th>Amount12</th><th>GST12</th><th>Amount18</th><th>GST18</th><th>Amount28</th><th>GST28</th><th>Taxable</th><th>Tax</th><th>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].BillNo == '') {
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold;><td>' + slno + '</td><td>' + result[i].BillNo + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].BillDate + '</td><td>' + (result[i].Customer).split("##")[0] + '</td><td>' + (result[i].Customer).split("##")[1] + '</td><td style=text-align:right>' + parseFloat(result[i].Amount0 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount5 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST5 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount12 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST12 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount18 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST18 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount28 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST28 || 0).toFixed(Decimal) + '</td>   <td style=text-align:right>' + parseFloat(result[i].Taxable || 0).toFixed(Decimal) + '</td> <td style=text-align:right>' + parseFloat(result[i].Tax || 0).toFixed(Decimal) + '</td> <td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td> </tr>';
            }
            else {
                responseText += '<tr onclick=gotoInvoNo(' + result[i].BillNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].BillNo + '</td><td>' + result[i].BillSeries + '</td><td>' + result[i].BillDate + '</td><td>' + (result[i].Customer).split("##")[0] + '</td><td>' + (result[i].Customer).split("##")[1] + '</td><td style=text-align:right>' + parseFloat(result[i].Amount0 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount5 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST5 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount12 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST12 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount18 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST18 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount28 || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].GST28 || 0).toFixed(Decimal) + '</td>   <td style=text-align:right>' + parseFloat(result[i].Taxable || 0).toFixed(Decimal) + '</td> <td style=text-align:right>' + parseFloat(result[i].Tax || 0).toFixed(Decimal) + '</td> <td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th></th><th></th><th></th><th></th><th></th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
        //$('#Tblreportprint').html(responseText + '</tbody>');
        var title = "GST Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
               // $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
               // $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Inv.#') {
               // $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Sup.Inv.#') {
                //$(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
          
            if (title == 'Supplier') {
               // $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
           

        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }


    function gotoInvoNo(BillNo, DeptId) {
        sessionStorage.setItem("purchase_slno", BillNo);
        sessionStorage.setItem("pur_deptid", DeptId);
        window.location = "@Url.Action("PurchaseInvoice", "inventory", new { from = "PurchaseReport" })";
    }

    $(function () {

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnsubmit").click(function (e) {

            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {
                $('#Loading').show();

                var data = {};
                data.FromDate = $('#DateFrom').val();
                data.ToDate = $('#DateTo').val();
                data.Userid = ERPUserId;

                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/GSTPurchase",
                    data: data,
                    success: function (result) {
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                        Showreport(result);


                    }
                });
            }
        });

    });
    </script>




