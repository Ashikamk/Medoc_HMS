<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%;width:580px;">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Quotation Entry Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
              
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:12.5%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off" style="font-weight:bold">
                        </div>
                        <label style="font-weight:bold;margin-left:7.5%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off" style="font-weight:bold">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:5%">Quotaion#</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" class="form-control" id="enquiryno" style="font-weight:bold" />
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:-1%">Account</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" class="form-control" id="suppliername" onkeyup="change()"/>
                            <input type="hidden" class="form-control" id="supplierId" />
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:12%">Dept.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="vDept" class="form-control">
                                <option value="0">- All -</option>
                            </select>
                        </div>

                    </div>
                </div>
               
                <div class="modal-footer">
                    <button type="button" id="btnsubmit" style="margin-right:40%" class="btn btn-primary" data-dismiss="modal">Apply</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    $("#enquiryno").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.QuotationNo = $("#enquiryno").val();
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../SalesInvoice/QuotationNoSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3',
                            label: item.QuotationNo,
                            label1: item.CustName,
                            label2: item.InvDate,
                            QuotationNo: item.QuotationNo,
                            QuotationEntryMainId: item.QuotationEntryMainId,
                            headers: ["Quotation No", "Customer Name", "Inv Date"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#enquiryno').val(ui.item.QuotationNo);
        }
    });



    $("#suppliername").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.CustName,
                            label1: item.CustAccount,
                            CustId: item.CustId,
                            headers: ["Customer Name", "Account Code"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId);
            $('#suppliername').val(ui.item.CustName)
            $('#vDept').focus();
        },
    });

    $("#btnsubmit").click(function (e) {
        $('#Loading').show();
        var Condition = '', Customer = '', vDept = '', EnquiryNO = ''
        var data = {};
        var FromDate = $('#DateFrom').val();
        var ToDate = $('#DateTo').val();
        var Customer = $('#supplierId').val();
        var Dept = $('#vDept').val();
        var EnquiryNO = $('#enquiryno').val();
        var Userid = ERPUserId;

            Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'



            if (Customer != 0) { Condition += ' and CustId = ' + Customer; }

            if (Dept !=0) { Condition += ' and DeptId = ' + Dept; }

            if (EnquiryNO != '') { Condition += ' and QuotationNo=' + EnquiryNO; }

            if (Userid != 0) { Condition += 'and Inv_QuotationEntryMain.DeptId in (select DeptId from Mst_UserDeptDivision where UserId= ' + Userid + ')'; }


            var data = {};
            data.Condition = Condition;
            console.log(data.Condition)

            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/QuotationEntryMain",
                data: data,
                success: function (result) {
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    $('#Loading').hide();
                    // Showreport(result.oList);

                    disable_datatable('Tblreport', 'buttonPlace');
                    var responseText = "<thead><tr><th>Sl#</th><th>Quotation#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th>Phone#</th><th>Salesman</th><th>Taxable Amount</th><th>Tax Amount</th><th>Amount</th><th>Dept.Code</th></thead><tbody>";
                    for (var i = 0; i < result.length; i++) {
                        var slno = parseInt(i + 1);
                        if (result[i].InvoiceNo == '') {
                            responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td><b>' + result[i].InvDate + '</b></td><td>' + result[i].Customer + '</td><td>' + result[i].CustAddress + '</td><td>' + result[i].PhoneNumber + '</td><td>' + result[i].Salesman + '</td><td style=text-align:right><b>' + parseFloat(result[i].TaxableAmount || 0).toFixed(decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].TaxAmount || 0).toFixed(decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</b></td><td>' + result[i].Department + '</td></tr>';
                        }
                        else {
                            responseText += '<tr><td>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].CustAddress + '</td><td>' + result[i].PhoneNumber + '</td><td>' + result[i].Salesman + '</td><td style=text-align:right>' + parseFloat(result[i].TaxableAmount || 0).toFixed(decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TaxAmount || 0).toFixed(decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</td><td>' + result[i].Department + '</td></tr>';

                        }
                    }
                    $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Quotation#</th><th>Date</th><th>Customer</th><th>Customer Details</th><th>Phone#</th><th>Salesman</th><th> </th><th> </th><th> </th><th>Dept.Code</th></tr></tfoot>');

                    var title = "Quotation Entry Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
                    datatableWithsearch('Tblreport', true, title, 'buttonPlace');
                    $('#header').text(title);
                }
            });

    });

    function change() {
        if ($('#suppliername').val() == '') {
            $('#supplierId').val(0);
        }
    }
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Quotation#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
           
            if (title == 'Dept.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Customer') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
            if (title == 'Customer Details') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
            if (title == 'Salesman') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
           
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
            

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'EUMI ERP',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }
</script>




