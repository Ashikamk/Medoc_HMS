<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }
    function GroupPageLoad(id) {
        var data1 = {};
        data1.GrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/GroupGetandGets",
            data: data1,
            success: function (result) {
                GroupLoad(result.oList, id);
            }
        });
    }

    function GroupLoad(result) {
        $("#Group").empty();
        $("#Group").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {

            $("#Group").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
        }
        SubGroupGets();
    }

    function SubGroupGets() {
        var data = {};
        data.GroupId = $("#Group").val();


        if (data.GroupId == 0) {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetandGets",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
        else {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetForGroup",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
    }

    function SubGroupLoad(result) {
        $("#Subgroup").empty();
        $("#Subgroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Subgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
        }
    }



    function CategoryPageLoad(id) {
        var data2 = {};
        data2.CategoryId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CategoryGetandGets",
            data: data2,
            success: function (result) {
                CategoryLoad(result.oList, id);
            }
        });
    }


    function CategoryLoad(result) {
        $("#Category").empty();
        $("#Category").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Category").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
        }
        SubCategoryGets();
    }

    function SubCategoryGets() {

        var data = {};
        data.CategoryId = $("#Category").val();

        if (data.CategoryId == 0) {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetandGets",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);

                }
            });
        }

        else {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetforCategory",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);
                }
            });
        }
    }



    function SubCategoryLoad(result) {
        $("#Subcategory").empty();
        $("#Subcategory").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Subcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
        }
    }
   
    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#dept").empty();
        $("#dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    function Showreport(result) {
   
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Item Code</th><th>Item Name</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th><th>Qty.</th><th style=text-align:right>Avg.Cost</th><th style=text-align:right>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);


            if (result[i].ItemCode == '') {
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold><td>' + slno + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDesc + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubGroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + result[i].AvgCost + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDesc + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubGroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + parseFloat(result[i].AvgCost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Item Code</th><th>Item Name</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th><th> </th><th style=text-align:right> </th><th style=text-align:right> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Fast Moving Items Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    $(function () {
        $('#Group').focus();
        $('#Group').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Subgroup').focus();
                e.preventDefault();
            }
        });
        $('#Subgroup').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Category').focus();
                e.preventDefault();
            }
        });
        $('#Category').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Subcategory').focus();
                e.preventDefault();
            }
        });
        $('#Subcategory').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#dept').focus();
                e.preventDefault();
            }
        });
        $('#dept').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Qty').focus();
                e.preventDefault();
            }
        });
        $('#Qty').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Values').focus();
                e.preventDefault();
            }
        });
        $('#Values').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        GroupPageLoad(0);
        CategoryPageLoad(0);
        GetDepartment(0);

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {


            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var grp = '', subgrp = '', cat = '', subcat = '', Qty = '', dept = '', Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
          
            var GrpId = parseInt($('#Group').val() || 0);
            var SubGrpId = parseInt($('#Subgroup').val() || 0);
            var CatId = parseInt($('#Category').val() || 0);
            var SubCatID = parseInt($('#Subcategory').val() || 0);
            var Department = parseInt($('#dept').val() || 0);
            var Quantity = ($('#Qty').val());
            var Userid = ERPUserId;

           

            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            if ($('#Qty').val() == '0') {
                warningshow('Quantity cannot be zero', 'Qty');
                $('#Qty').select();
            }
            else {

                $('#Loading').show();

                if (GrpId != 0) { Condition += ' and GrpId=' + GrpId ; }
                if (SubGrpId != 0) { Condition += ' and SbgrpId=' + SubGrpId; }
                if (CatId != 0) { Condition += ' and I.CategoryId=' + CatId; }
                if (SubCatID != 0) { Condition += ' and I.SubCategoryId=' + SubCatID; }
                if (Department != 0) { Condition += ' and Inv_SalesSub.DeptId=' + Department; }
                if (Userid != 0) { Condition += 'and Inv_SalesSub.DeptId  in (select DeptId from Mst_UserDeptDivision where UserId= ' + Userid + ')'; }



                Condition += 'group by ProductCode,ProductDescr,GrpCode,SbgrpName,CategoryCode,SubCategoryName,Inv_SalesSub.DeptId,avgcost '

                if (Quantity != '') { Condition += ' having SUM(ProdQty)>=' + Quantity; }

                Condition += 'order by Quantity desc'

                
                var data = {};
                data.Number = parseInt($('#Values').val() || 0);
                data.Condition = Condition;
                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/FastMovingItemsGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }


        });

    });
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Qty.') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Avg.Cost') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Amount') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Group') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Sub Group') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Category') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Sub Category') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Item Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:150px" />');
            }
            if (title == 'Item Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:400px" />');
            }
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
           
            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }


</script>






