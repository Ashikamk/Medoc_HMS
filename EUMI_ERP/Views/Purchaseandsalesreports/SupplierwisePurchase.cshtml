<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Supplierwise Purchase Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:13%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:-1%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:4%;"></div>
                    <div class="row" style="margin-top:2%">

                        <label style="margin-top:2%;font-weight:bold;margin-left:8%">Supplier</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="suppliername" class="form-control">
                            <input type="hidden" id="supplierId" class="form-control" />
                        </div>
                    </div>

                </div>

            

                <div class="modal-footer">
                    <fieldset class="form-group floating-label-form-group" style="margin-right:20%">
                        <div class="row">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="fcamt">
                                <label class="custom-control-label" for="fcamt" style="font-weight:bold">FC Amount</label>
                            </div>

                        </div>
                    </fieldset>

                    <button type="button" style="margin-right:40%" id="btnsubmit" class="btn btn-primary">Apply</button>
                </div>
            </form>

        </div>
    </div>
</div>
<div style="display:none;">
    <input type="text" id="ResultLength" value="0" />
</div>


<script>


    function popuprefresh() {
        $('#popupdiv').hide();
    }


    $("#suppliername").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Supplier Code", "Supplier Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId)
            $('#suppliername').val(ui.item.CustName);

        },

    });


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th width=10px>Inv.#</th><th width=10px>Sup.Inv.#</th><th width=1000px>Date</th><th width=10px>Purchase Type</th><th style=text-align:right width=10px>Other Cost</th><th style=text-align:right width=10px>Taxable Amount</th><th style=text-align:right width=10px>Tax Amount</th><th style=text-align:right width=10px>Amount</th></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            //alert(result[i].InvoDate)
            if (result[i].PurchaseSlNo == '') {
                //var suplier = (result[i].InvoNo);
                //suplier = suplier.substring(0, 10);
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td id="Col1_' + slno + '">' + result[i].PurchaseSlNo + '</td><td id="Col2_' + slno + '">' + result[i].InvoNo + '</td><td id="Col3_' + slno + '"><b>' + result[i].InvoDate + '</b></td><td id="Col4_' + slno + '">' + result[i].PurchaseType + '</td><td  id="Col5_' + slno + '" ; style=text-align:right><b>' + result[i].OtherCost + '</b></td><td id="Col6_' + slno + '"; style=text-align:right><b>' + result[i].TotalTaxable + '</b></td><td  id="Col7_' + slno + '" ; style=text-align:right><b>' + result[i].TotalTax + '<b></td><td id="Col8_' + slno + '"  style=text-align:right><b>' + result[i].Amount + '</b></td></tr>';
            }

            else  {
                responseText += '<tr ondblclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td id="Col1_' + slno + '">' + result[i].PurchaseSlNo + ' </td><td id="Col2_' + slno + '"> ' + result[i].InvoNo + '</td><td id="Col3_' + slno + '">' + result[i].InvoDate + '</td><td id="Col4_' + slno + '">' + result[i].PurchaseType + '</td><td id="Col5_' + slno + '"; style=text-align:right>' + parseFloat(result[i].OtherCost || 0).toFixed(Decimal) + '</td><td id="Col6_' + slno + '"; style=text-align:right>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td><td id="Col7_' + slno + '" ; style=text-align:right>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td><td  id="Col8_' + slno + '"; style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Inv.#</th><th>Sup.Inv.#</th><th>Date</th><thPurchase Type</th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Supplierwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch1('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }





    function Showreport1(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th width=10px>Inv.#</th><th width=10px>Sup.Inv.#</th><th width=2000px>Date</th><th width=10px>Purchase Type</th><th style=text-align:right width=10px>Other Cost</th><th style=text-align:right width=10px>Taxable Amount</th><th style=text-align:right width=10px>Tax Amount</th><th style=text-align:right width=10px>Amount</th><th style=text-align:right width=10px>FC Amount</th><th style=text-align:right width=10px>Fx.</th><th style=text-align:right width=10px>Rate</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].PurchaseSlNo == '') {
                var suplier = (result[i].InvoNo);
                suplier = suplier.substring(0, 10);
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td><b>' + result[i].InvoDate + '</b></td><td>' + result[i].PurchaseType + '</td><td style=text-align:right><b>' + result[i].OtherCost + '</b></td><td style=text-align:right><b>' + result[i].TotalTaxable + '<b></td><td style=text-align:right><b>' + result[i].TotalTax + '</b></td><td style=text-align:right><b>' + result[i].Amount + '</b></td><td style=text-align:right><b>' + result[i].FCAmount + '<b></td><td style=text-align:right><b>' + result[i].CurrencyName + '</b></td><td style=text-align:right><b>' + result[i].CurrencyRate + '</b></td></tr>';
            }
            else {
                responseText += '<tr ondblclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + ' </td><td> ' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].PurchaseType + '</td><td style=text-align:right>' + parseFloat(result[i].OtherCost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].FCAmount || 0).toFixed(Decimal) + '<td style=text-align:right>' + result[i].CurrencyName + '</td><td style=text-align:right>' + result[i].CurrencyRate + '</td> <input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Inv.#</th><th>Sup.Inv.#</th><th>Date</th><th>Purchase Type</th><th> </th><th> </th><th> </th><th> </th><th> </th><th>Fx.</th><th>Rate</th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Supplierwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch1('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#ResultLength').val(result.length);
    
    }



    function gotoInvoNo(PurchaseSlNo, DeptId) {
        if ((usermenu1.indexOf("M31") != -1)) {
            window.open('../inventory/PurchaseInvoice?slno=' + PurchaseSlNo + '&dept=' + DeptId);
        }
        else if ((usermenu1.indexOf("M233") != -1)) {
            window.open('../Purchase/PurchaseInvoiceNew?slno=' + PurchaseSlNo + '&dept=' + DeptId);

        }
        else {
            warningshow('Invalid User Rights');
            return false;
        }
    }

    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

    $(function () {

        $('#suppliername').focus();


        $("#suppliername").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);
            if (key == 13) {
                $("#btnsubmit").focus();
                e.preventDefault();
            }
        });
        $("#suppliername").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);

        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            


            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {


                $('#Loading').show();

                if ($('#suppliername').val() == '') {
                    $('#supplierId').val(0);
                }



                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.SupplierId = parseInt($('#supplierId').val() || 0);
                data.Userid = ERPUserId;
                $.ajax({
                
                    type: "POST",
                    url: "../Purchaseandsalesreports/SupplierReportGet",
                    data: data,
                    success: function (result) {
                        if ($("#fcamt").prop("checked")) {
                            Showreport1(result);
                        } else {
                            Showreport(result);
                        }
                      
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }


        });

    });



    function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }
            if (title == 'Sup.Inv.#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }

            if (title == 'Inv.#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }

         
            if (title == 'Purchase Type') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Fx.') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Rate') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            //dom: 'Blfrtip',
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
         
        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }
    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }
</script>




