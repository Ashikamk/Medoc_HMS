
@{
    ViewBag.Title = "ProfitAnalysisSalesReturn";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

</style>

<div class="myData" data-x="M101" />
<div id="Entry">
  
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="26%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#Customer').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">
                                <hr style="margin-top:2px;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:110%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%;">
        <div class="modal-content" style="width:68%">
            <div class="modal-header bg-primary white">
                <h6 class="modal-title" id="myheader">Profit Analysis Invoicewise Report</h6>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
               
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:11%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:10%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom: 1px solid #cfd8dc; margin-top: 4%; display: none"></div>


                    <div class="row" style="margin-top:1%;display:none">
                        <label style="margin-top:2%;font-weight:bold;margin-left:4%">Customer</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="Customer" class="form-control">
                            <input type="hidden" id="CustomerId" class="form-control">
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:-1%">Salesman</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="Salesman" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:1%;display:none">
                        <label style="margin-top:2%;font-weight:bold;margin-left:6.5%">Account</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="Account" name="priority" class="form-control"></select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:6%">Area</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="Area" name="priority" class="form-control"></select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row" style="margin-right:10%">
                        <div class="custom-control custom-checkbox">
                            <input type="checkbox" class="custom-control-input" name="customCheck" id="grpbysalesreturn">
                            <label class="custom-control-label" style="margin-left:10px;font-weight:bold" for="grpbysalesreturn">Item Wise</label>
                        </div>
                    </div>
                    <button type="button" style="width:100px;margin-right:40%" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>


<script>

    $("#Customer").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#Customer").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            headers: ["Customer Code", "Customer Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustomerId').val(ui.item.CustId)

        },

    });


    function popuprefresh() {
        $('#popupdiv').hide();
    }


    function GetAreaselect(id) {
        var data = {};
        data.AreaGrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGetandGets",
            data: data,
            success: function (result) {
                AreaLoad(result.oList, id);
            }
        });

    }

    function AreaLoad(result) {
        $("#Area").empty();
        $("#Area").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Area").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaName + "</option>");
        }
    }


    function GetSalesMan(id) {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/SalesmanGetandGets",
            data: data,
            success: function (result) {
                SalesManLoad(result.oList, id);
            }
        });
    }

    function SalesManLoad(result, a) {
        $("#Salesman").empty();
        $("#Salesman").append("<option value='0'>-All-</option>")
        for (var i = 0; i < result.length; i++) {
            $("#Salesman").append("<option value='" + result[i].Id + "'>" + result[i].FirstName + "</option>");
        }
    }

    function AccountLoad(result) {
        $("#Account").empty();
        $("#Account").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Account").append("<option value='" + result[i].AcntId + "' name='" + result[i].AcntSlno + "'>" + result[i].AcntDescription + ' - ' + result[i].AcntCode + "</option>");
        }
    }
    function accounttypeload() {
        var data4 = {};
        data4.AcntId = 0;
        data4.UserType = 'C'
        data4.DeptId = ERPDeptId
        $.ajax({
            type: "POST",
            url: "../Master/AcntGetandGets",
            data: data4,
            success: function (result) {
                AccountLoad(result.oList);
            }
        });

    }

    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Salesman</th><th style=text-align:right>Sales Value</th><th style=text-align:right>VAT Value</th><th style=text-align:right>Net Sales Value</th><th style=text-align:right>Cost</th><th style=text-align:right>Profit</th><th style=text-align:right>Profit%</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);


            if (result[i].InvoNo == '') {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td></td><td>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].Salesman + '</td><td style=text-align:right>' + parseFloat(result[i].SalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].VATValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].NetSalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Cost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Profit || 0).toFixed(Decimal) + '</td><td style=text-align:right></td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].BillSeries + '-' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].Salesman + '</td><td style=text-align:right>' + parseFloat(result[i].SalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].VATValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].NetSalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Cost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Profit || 0).toFixed(Decimal) + '</td><td style=text-align:right></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Salesman</th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Profit Analysis Invoicewise - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function gotoInvoNo(InvoNo, BillSeriesId, DeptId) {
        window.open('../inventory/SalesInvoice?slno=' + InvoNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);
    }
    function ShowreportSalesReturn(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Type</th><th>Bill#</th><th>Date</th><th>Product</th><th>Batch</th><th style=text-align:right>Sales Value</th><th style=text-align:right>VAT Value</th><th style=text-align:right>Net Sales Value</th><th style=text-align:right>Cost</th><th style=text-align:right>Profit</th><th style=text-align:right>Profit%</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);


            if (result[i].InvoNo == '') {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].SType + '</td><td></td><td>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].Salesman + '</td><td style=text-align:right>' + parseFloat(result[i].SalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].VATValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].NetSalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Cost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Profit || 0).toFixed(Decimal) + '</td><td style=text-align:right></td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].SType + '</td><td>' + result[i].BillSeries + '-' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].Salesman + '</td><td style=text-align:right>' + parseFloat(result[i].SalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].VATValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].NetSalesValue || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Cost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Profit || 0).toFixed(Decimal) + '</td><td style=text-align:right></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Type</th><th>Bill#</th><th>Date</th><th>Product</th><th>Batch</th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Profit Analysis Invoicewise- from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    $(function () {
        GetAreaselect(0);
        GetSalesMan(0);
        accounttypeload();
        $('#Customer').focus();

        $("#Customer").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            $('#CustomerId').val(0);
            if (key == 13) {
                e.preventDefault();
                $('#Salesman').focus();
            }

        });

        $("#Salesman").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#Account').focus();
            }

        });
        $("#Account").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#Area').focus();
            }

        });
        $("#Area").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#btnsubmit').focus();
            }

        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var Salesman = '', Customer = '', Account = '', Area = '', Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

            var Salesman = parseInt($('#Salesman').val() || 0);
            var Customer = parseInt($('#CustomerId').val() || 0);
            var Account = parseInt($('#Account').val() || 0);
            var Area = parseInt($('#Area').val() || 0);


            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {

                $('#Loading').show();

                if ($('#Customer').val() == '') {
                    $('#CustomerId').val(0);
                }

                if ($("#grpbysalesreturn").prop("checked")) {

                    if (Salesman != 0) { Condition += ' and Mst_Salesman.Id=' + Salesman; }
                    if (Customer != 0) { Condition += ' and Mst_CustomerMain.CustId=' + Customer; }
                    if (Account != 0) { Condition += ' and Mst_CustomerMain.AccountType=' + Account; }
                    if (Area != 0) { Condition += ' and Mst_Area.AreaId=' + Area; }


                    var data = {};

                    data.Condition = Condition;
                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/ProfitAnalysisSalesReturn",
                        data: data,
                        success: function (result) {
                            ShowreportSalesReturn(result);
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                        }
                    });
                }
                else
                {


                    if (Salesman != 0) { Condition += ' and S.SalesManId=' + Salesman; }
                    if (Customer != 0) { Condition += ' and S.CustId=' + Customer; }
                    if (Account != 0) { Condition += ' and C.AccountType=' + Account; }
                    if (Area != 0) { Condition += ' and S.AreaId=' + Area; }

                    var data = {};

                    data.Condition = Condition;
                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/ProfitAnalysis",
                        data: data,
                        success: function (result) {

                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            Showreport(result);
                        }
                    });
                }
            }



        });

    });


    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
          
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Bill#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
           
            if (title == 'Customer') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
            if (title == 'Salesman') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
            if (title == 'Type') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
        });

        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],

            });



            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }





    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }


</script>




