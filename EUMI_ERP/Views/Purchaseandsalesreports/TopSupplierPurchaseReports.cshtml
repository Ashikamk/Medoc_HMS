
@{
    ViewBag.Title = "TopSupplierPurchaseReports";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>





<div id="Entry">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0">Purchase Analysis-Top Suppliers Report</h4>

                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>


                                <div class="row">

                                    <label style="margin-top:5px">From Date </label>
                                    <div class="col-md-2">
                                        <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                                    </div>


                                    <label style="margin-top:5px">To Date </label>
                                    <div class="col-md-2">
                                        <input type="text" id="DateTo" class="form-control" autocomplete="off">
                                    </div>

                                    <label style="margin-top:5px">Supplier </label>
                                    <div class="col-md-2">
                                        <input type="text" id="suppliername" class="form-control">
                                        <input type="hidden" id="supplierId" class="form-control" />
                                    </div>

                                    <label style="margin-top:5px">Top 'N' Values</label>
                                    <div class="col-md-2">
                                        <input type="text" id="Values" class="form-control" autocomplete="off">
                                    </div>


                                    <div class="col-md-2">
                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1">Go</button>
                                    </div>

                                    <div align="right">
                                        <div class="heading-elements">
                                            <div class="btn-group">

                                                <button type="button" class="btn btn-outline-primary"><i class="ft-edit"></i> Export</button>
                                                <button type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <span class="sr-only">Toggle Dropdown</span>
                                                </button>
                                                <div class="dropdown-menu">
                                                    <a class="dropdown-item" href="#">Excel</a>
                                                    <a class="dropdown-item" href="#">PDF</a>
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item" href="#">Print</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                                <br />
                                <div id="divreport" style="display:none; overflow:auto">
                                    <hr />
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                    <input type="button" onclick="tableToExcel('Tblreportprint', 'W3C Example Table')" value="Export to Excel" class="btn btn-primary btn-min-width mr-1 mb-1" />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

