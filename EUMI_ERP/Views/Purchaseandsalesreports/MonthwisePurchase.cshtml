
@{
    ViewBag.Title = "MonthwisePurchase";
}



<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>





<div id="Entry">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%"><tr><td><h4 id="header"></h4></td><td width="36%"></td><td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                            
                            
                            <td align="right">

                                <div class="btn-group" id="buttonPlace">




                                    <div align="right">
                                        <div class="heading-elements">
                                            <div class="btn-group" id="buttonPlace">

                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </td>
                            
                            </tr></table>


                        <div align="right">
                           
                            <div class="heading-elements">
                               

                             

                                <div id="divreport" style="display:none; overflow:auto">
                              <hr />

                                <table id="Tblreport" class="table table-striped table-bordered dataTable" style="margin: 0 auto 0 0;"></table><br />
                            </div>
                            <div style="display:none">
                                <table id="Tblreportprint"></table>
                            </div>
                        </div>
                    </div>
                </div>

          </div>
      </div>
    </div>
</div>
</div>



           
<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Monthwise Purchase Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <fieldset class="form-group floating-label-form-group">
                        <label for="DateFrom">From Date</label>
                        <input type="text" id="DateFrom" class="form-control">
                    </fieldset>
                    <br>
                    <fieldset class="form-group floating-label-form-group">
                        <label for="DateTo">To Date</label>
                        <input type="text" id="DateTo" maxlength="100" class="form-control">
                    </fieldset>
                    <br />

                </div>
                <div class="modal-footer">

                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-outline-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }
   


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Purchase SlNo</th><th>Inv No</th><th>Inv Date</th><th>Supplier</th><th>Taxable Amount</th><th>Tax Amount</th><th>Amount</th><th>FC Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].PurchaseSlNo == '') {
                responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td></tr>';
            }
            else {
                responseText += '<tr onclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Purchase SlNo</th><th>Inv No</th><th>Inv Date</th><th>Supplier</th><th> </th><th> </th><th> </th><th> </th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Monthwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');

        $('#header').text(title);

        
    }
    function gotoInvoNo(PurchaseSlNo, DeptId) {
        sessionStorage.setItem("purchase_slno", PurchaseSlNo);
        sessionStorage.setItem("pur_deptid", DeptId);
        window.location = "@Url.Action("PurchaseInvoice", "inventory", new { from = "PurchaseReport" })";
    }


    $(function () {

    

        $("#supplierId").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#supplierId').val(0);
            }

        });

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnsubmit").click(function (e) {

            var Condition = '';
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
        



            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
           
            else {
                $('#Loading').show();
                Condition = 'CONVERT(datetime,InvoDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvoDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
                var data = {};
                data.Condition = Condition;
                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/PurchaseReportGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        var title = "Monthwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                       
                        
                    }
                });
            }
   

        });

    });





</script>


