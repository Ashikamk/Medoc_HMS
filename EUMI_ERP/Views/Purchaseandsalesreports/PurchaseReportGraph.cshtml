
@{
    ViewBag.Title = "PurchaseReportGraph";
}


<script src="~/Scripts/Chart/highcharts.js"></script>
<script src="~/Scripts/Chart/export-data.js"></script>
<script src="~/Scripts/Chart/exporting.js"></script>

<script type="text/javascript" src="../Projectscript/Common.js"></script>

<div id="Entry">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="42%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">

                                <br /><hr />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                                <br /><br />
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Purchase Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:37px">From Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control">
                        </div>


                        <label style="margin-top:5px;margin-left:60px">To Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control">
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:67px">Group </label>
                        <div class="col-md-4">
                            <select id="Group" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <label style="margin-top:5px;margin-left:40px">Sub Group </label>
                        <div class="col-md-4">
                            <select id="Subgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:45px">Category </label>
                        <div class="col-md-4">
                            <select id="Category" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <label style="margin-top:5px;margin-left:18px">Sub Category</label>
                        <div class="col-md-4">
                            <select id="Subcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-33px">
                        <label style="margin-top:5px;margin-left:45px">Department </label>
                        <div class="col-md-4">
                            <select id="dept" class="form-control" name="priority" style="width:97%">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <div class="custom-control custom-checkbox" style="margin-left:130px">
                            <input type="checkbox" class="custom-control-input" name="customCheck" id="graphreport">
                            <label class="custom-control-label" style="margin-left:5px" for="graphreport">Graphical Report</label>
                        </div>
                    </div>
                 
                </div>
                <div class="modal-footer">
                    <div class="input-group">
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" id="All" checked="" name="customRadioInline1" class="custom-control-input">
                            <label class="custom-control-label" for="All">All</label>
                        </div>
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" id="rbGroup" name="customRadioInline1" class="custom-control-input">
                            <label class="custom-control-label" for="rbGroup">Group</label>
                        </div>
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" id="rbSubGroup" name="customRadioInline1" class="custom-control-input">
                            <label class="custom-control-label" for="rbSubGroup">Sub Group</label>
                        </div>
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" id="rbCategory" name="customRadioInline1" class="custom-control-input">
                            <label class="custom-control-label" for="rbCategory">Category</label>
                        </div>
                        <div class="custom-control custom-radio custom-control-inline">
                            <input type="radio" id="rbSubCategory" name="customRadioInline1" class="custom-control-input">
                            <label class="custom-control-label" for="rbSubCategory">Sub Category</label>
                        </div>
                    </div>
                    <button type="button" style="width:100px"  onclick="PurchaseReportGraph('column')" class="btn btn-outline-primary">Go</button>

                </div>
            </form>

        </div>
    </div>
</div>

<div class="row" id="graph" style="display:none">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <div>
                    <h3>Purchase Report </h3>
                </div>
                <div class="text-right">
                    <button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button>
                </div>
            </div>
            <div class="card-body">
                <div class="card-block">
                    <div id="line-area" class="height-350 lineArea">
                        <div id="PurchaseReport" style="min-width: 310px; height: 350px; margin: 0 auto"></div>



                        <div class="input-group" style="margin-top:-20px;">
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline1" checked="" name="customRadioInline1" class="custom-control-input" onclick="PurchaseReportGraph('column')">
                                <label class="custom-control-label" for="customRadioInline1">Column chart</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline2" name="customRadioInline1" class="custom-control-input" onclick="PurchaseReportGraph('line')">
                                <label class="custom-control-label" for="customRadioInline2">Line chart</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline3" name="customRadioInline1" class="custom-control-input" onclick="('PurchaseReport2')">
                                <label class="custom-control-label" for="customRadioInline3">Pi chart</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input type="radio" id="customRadioInline4" name="customRadioInline1" class="custom-control-input" onclick="('PurchaseReport3')">
                                <label class="custom-control-label" for="customRadioInline4">Half-Pi chart</label>
                            </div>
                        </div>



                    </div>
                    <hr />


                    <div class="card-body" id="pi" style="display:none">
                        <div id="PurchaseReport2" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto;"></div>
                    </div>

                    <div class="card-body" id="halfpi" style="display:none">
                        <div id="PurchaseReport3" style="min-width: 310px; height: 400px; max-width: 600px; margin: 0 auto"></div>
                    </div>


                    <table id="purchasereport"></table>


                </div>



            </div>
        </div>
    </div>
</div>


<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }
    function GroupPageLoad(id) {
        var data1 = {};
        data1.GrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/GroupGetandGets",
            data: data1,
            success: function (result) {
                GroupLoad(result.oList, id);
            }
        });
    }

    function GroupLoad(result) {
        $("#Group").empty();
        $("#Group").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {

            $("#Group").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
        }
        SubGroupGets();
    }

    function SubGroupGets() {
        var data = {};
        data.GroupId = $("#Group").val();


        if (data.GroupId == 0) {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetandGets",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
        else {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetForGroup",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
    }

    function SubGroupLoad(result) {
        $("#Subgroup").empty();
        $("#Subgroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Subgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
        }
    }



    function CategoryPageLoad(id) {
        var data2 = {};
        data2.CategoryId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CategoryGetandGets",
            data: data2,
            success: function (result) {
                CategoryLoad(result.oList, id);
            }
        });
    }


    function CategoryLoad(result) {
        $("#Category").empty();
        $("#Category").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Category").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
        }
        SubCategoryGets();
    }

    function SubCategoryGets() {

        var data = {};
        data.CategoryId = $("#Category").val();

        if (data.CategoryId == 0) {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetandGets",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);

                }
            });
        }

        else {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetforCategory",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);
                }
            });
        }
    }



    function SubCategoryLoad(result) {
        $("#Subcategory").empty();
        $("#Subcategory").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Subcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
        }
    }

    function GetDepartment(id) {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#dept").empty();
        $("#dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Product Code</th><th>Product Name</th><th>Terms</th><th>Area</th><th>Location</th><th>Purchase Type</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th><th style=text-align:right>FC Amount</th><th>Department</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].PurchaseSlNo == '') {
                responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Product + '</td><td>' + result[i].ProductDesc + '</td><td>' + result[i].Terms + '</td><td>' + result[i].SupplyTo + '</td><td>' + result[i].Location + '</td><td>' + result[i].PurchaseType + '</td><td>' + result[i].Group + '</td><td>' + result[i].SubGroup + '</td><td>' + result[i].Category + '</td><td>' + result[i].SubCategory + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + '</td></tr>';
            }
            else {
                responseText += '<tr onclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Product + '</td><td>' + result[i].ProductDesc + '</td><td>' + result[i].Terms + '</td><td>' + result[i].SupplyTo + '</td><td>' + result[i].Location + '</td><td>' + result[i].PurchaseType + '</td><td>' + result[i].Group + '</td><td>' + result[i].SubGroup + '</td><td>' + result[i].Category + '</td><td>' + result[i].SubCategory + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + ' <input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Product Code</th><th>Product Name</th><th>Terms</th><th>Area</th><th>Location</th><th>Purchase Type</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th><th style=text-align:right> </th><th style=text-align:right> </th><th style=text-align:right> </th><th style=text-align:right> </th><th>Department</th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    function ShowreportGroup(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Supplier</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th><th style=text-align:right>FC Amount</th><th>Department</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var x = result[i].HFlag;
            var slno = parseInt(i + 1);

       if (x == "G") {
           responseText += '<tr style=background-color:#60ecb9><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + '</td></tr>';
            }
           else if (x == "SG") {
                responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + '</td></tr>';
            }
            else {
                responseText += '<tr onclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + ' <input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Supplier</th><th style=text-align:right> </th><th style=text-align:right> </th><th style=text-align:right> </th><th style=text-align:right> </th><th>Department</th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function ShowreportSubGroup(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Supplier</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th><th style=text-align:right>FC Amount</th><th>Department</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
