    function ShowreportSubCategory(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Supplier</th><th style=text-align:right>Taxable Amount</th><th style=text-align:right>Tax Amount</th><th style=text-align:right>Amount</th><th style=text-align:right>FC Amount</th><th>Department</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var x = result[i].HFlag;
            var slno = parseInt(i + 1);

            if (x == "SC") {
                responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + '</td></tr>';
            }
            else if (x == "O") {
                responseText += '<tr onclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].Dept + ' <input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '></td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Purchase SlNo</th><th>Invo No</th><th>Invo Date</th><th>Supplier</th><th style=text-align:right> </th><th style=text-align:right> </th><th style=text-align:right> </th><th style=text-align:right> </th><th>Department</th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

