        function PurchaseReportGraph(Grtype) {


            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var grp = '', subgrp = '', cat = '', subcat = '', dept = '', Condition = 'CONVERT(datetime,InvoDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvoDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

            var GroupId = parseInt($('#Group').val() || 0);
            var SubGroupId = parseInt($('#Subgroup').val() || 0);
            var CatId = parseInt($('#Category').val() || 0);
            var SubCatID = parseInt($('#Subcategory').val() || 0);
            var Department = parseInt($('#dept').val() || 0);


            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {

                $('#Loading').show();

                if ($("#All").prop("checked")) {
                    if (GroupId != 0) { Condition += ' and mst_item.GroupId=' + GroupId; }
                    if (SubGroupId != 0) { Condition += ' and SubGroupId=' + SubGroupId; }
                    if (CatId != 0) { Condition += ' and mst_item.CategoryId=' + CatId; }
                    if (SubCatID != 0) { Condition += ' and mst_item.SubCategoryId=' + SubCatID; }
                    if (Department != 0) { Condition += ' and Inv_PurchaseMain.DepartmentId=' + Department; }


                    var data = {};
                    data.Condition = Condition;
                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/PurchaseReportGraph",
                        data: data,
                        success: function (result) {
                            Showreport(result);
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                        }
                    });
                }

               else if ($("#rbGroup").prop("checked")) {
                    var data = {};
                    data.DateFrom = $('#DateFrom').val();
                    data.DateTo = $('#DateTo').val();
                    data.SubGroup = parseInt($('#Subgroup').val() || 0);
                    data.Group = parseInt($('#Group').val() || 0);
                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/PurchaseReportGroupwise",
                        data: data,
                        success: function (result) {
                            ShowreportGroup(result);
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                        }
                    });
                }

                else if ($("#rbSubGroup").prop("checked")) {
                    var data = {};
