<script>
    $("#enquiryno").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.DONo = $("#enquiryno").val();
            data.LocnId = UserLocationId;
            data.DepartmentId = ERPDeptId;
            $.ajax({
                url: '../MRVPurchase/MRVSerialNoSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3',
                            label: item.MRVNo,
                            //  label1: item.DONo,
                            label1: item.MRVDate,
                            label2: item.SupplierName,
                            MRVNo: item.MRVNo,
                            headers: ["Invoice No", "Date", "Supplier"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#enquiryno').val(ui.item.MRVNo);
        }
    });


    $("#txtproduct").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#txtproduct").val();
            data.LocId = UserLocationId;
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../SalesInvoice/ProductSearchSales',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.ItemCode,
                            label1: item.Description,
                            Description: item.Description,
                            ProductId: item.ItemId,
                            Product: item.ItemCode,
                            headers: ["Material Code", "Material Description"]
                        })
                    }));
                }
            })
        },

        autoFocus: true,
        select: function (event, ui) {
            $('#txtproduct').val(ui.item.Product);
            $('#txtproductId').val(ui.item.ProductId);
            $("#suppliername").focus();
        },
    });

    function change() {
        if ($('#txtproduct').val() == '') {
            $('#txtproductId').val(0);
        }
    }
    $("#suppliername").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.CustName,
                            label1: item.CustAccount,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Supplier Name", "Account Code"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId);
            $('#suppliername').val(ui.item.CustName);
            $("#cmbGroup").focus();
        },
    });
    function changes() {
        if ($('#suppliername').val() == '') {
            $('#supplierId').val(0);
        }
    }
    $("#btnsubmit").click(function (e) {

