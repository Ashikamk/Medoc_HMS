    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>


                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="10%"></td>

                                <td align="right" ;width="20%"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#User').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('LABITEMREPORT', $('#LabLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>

                                <td align="right">






