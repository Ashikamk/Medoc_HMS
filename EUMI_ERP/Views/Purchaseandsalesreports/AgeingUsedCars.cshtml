<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Procedure Wise  Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:11%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control frsdwn" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:4%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control frsdwn" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">

                        <label style="margin-top:2%;font-weight:bold;margin-left:2.5%"> Proc Name</label>
                        <div class="col-md-9" style="margin-top:2%">
                            <input type="text" id="TestName0" maxlength="100" onfocus="LoadTest(0)" class="form-control frsdwn">
                        </div>
                    </div>


                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%;display:none1">

                        <label style="margin-top:2%;font-weight:bold;margin-left:2.5%"> Doctor&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;</label>
                        <div class="col-md-9" style="margin-top:2%">
                            <select id="Department0"  class="form-control"></select>
                        </div>
                    </div>


                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:6%" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="LabLength" class="form-control" />
                </div>
            </form>

        </div>
    </div>
</div>

<script>


    $(document).ready(function () {
        $('.frsdwn').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                var inputs = $(this).closest('form').find('.frsdwn:enabled');
                inputs.eq(inputs.index(this) + 1).focus().select();
            }
        });
        $(function () {

            $('#User').focus();
            $('#Dept').keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#btnsubmit').focus();
                    e.preventDefault();
                }
            });
            $('#DateFrom').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#DateTo').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });
            $('#DateFrom,#DateTo').val(CurDate);

            $("#btnsubmit").click(function (e) {


                if ($('#DateFrom').val() == '') {
                    alert('Please Select From Date');
                    $('#DateFrom').focus();

                }
                else if ($('#DateTo').val() == '') {
                    alert('Please Select To Date');
                    $('#DateTo').focus();

                }

                else {
                    $('#Loading').show();

                    var data = {};
                    data.FromDate = $('#DateFrom').val() + '##' + $('#Department0').val();
                    data.ToDate = $('#DateTo').val() + '##PR' ;
                    data.TestId = parseInt($('#TestId').val() || 0);

                    $.ajax({
                        type: "POST",
                        url: "../Master/LabTestWiseReport",
                        data: data,
                        success: function (result) {
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            Showreport(result);


                        }
                    });
                }
            });

        });
    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }


    var data = {};
    data.DepId = 0;
    $.ajax({
        type: "POST",
        url: "../Master/MedDeptGetandGets",
        data: data,
        success: function (result) {
            DeptLoad = '';
            if (result.oList.length > 0) {
                DeptLoad += "<option value='0' Fee='0'>All</option>";
                for (var i = 0; i < result.oList.length; i++) {
                    DeptLoad += "<option value='" + result.oList[i].DepId + "'>" + result.oList[i].Department + "</option>";
                }
                $("#Department0").empty();
                $("#Department0").append(DeptLoad);
            }
        }
    });



    function ClearData(flg, Id) {
        if (flg == 0) {
            $('.patdet').val('');
            $('#Doctor,#Gender').val(0);
        }
        else if (flg == 1) {
            RateArray = [];
            $('#TestId' + Id).val('');
            $('#Department' + Id).val($('#Department' + Id).find('option:first').val());
            if (Id == 0) {
                $('#TestAmount' + Id).val('');
            }
            else {
                $('#TestAmount' + Id).val('0.00');
            }

        }
    }
    function LoadTest(Id) {

        $('#TestName0').autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                ClearData(1, Id);
                $("#TestId").val(0);
                var data = {};
                data.ProcedureName = $('#TestName0').val();
                data.ProcedureId = ERPDeptId;
                $.ajax({
                    url: '../Revisit/HMS_ProcedureSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWOEnq',
                                label: item.ProcedureCode,
                                label1: item.ProcedureName,
                                ProcedureId: item.ProcedureId,
                                Rate: item.Procedurecharge,
                                ProcedureName: item.ProcedureName,
                                headers: ["Procedure Code", "Procedure Name"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#TestId').val(ui.item.ProcedureId);

            },
        });
    }
    function LOadRate(Id) {
        if (RateArray.Rate != undefined) {
            var Rate = 0; var Type = $('#RateType0').val();
            if (Type == 0) { Rate = RateArray.Rate }
            else if (Type == 1) { Rate = RateArray.SpRate }
            else if (Type == 2) { Rate = RateArray.VSpRate }
            else { Rate = RateArray.OutsideRate }

            $('#TestAmount' + Id).val(parseFloat(Rate).toFixed(Decimal));
        }
    }

    function Showreport(result) {

        $('#LabLength').val(result.length);
        console.log(result.length);
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th align= center>Sl#</th><th>Bill No</th><th> Date</th><th>Name</th><th>Doctor</th><th>Test</th><th>Department</th><th style='text-align:right;'> Rate</th><th style='text-align:right;'> Dis%</th><th style='text-align:right;'>Outside Rate</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {

            var AA = result[i].TestName.split("##");
            var slno = parseInt(i + 1);

            if (AA[0] != 'TOTAL') {
                responseText += '<tr><td align= center id = Col1_' + slno + ' >' + slno + '</td><td id = Col2_' + slno + '>' + result[i].BillNo + '</td><td  id= Col3_' + slno + '>' + result[i].BillDate + '</td><td id=Col4_' + slno + '>' + AA[0] + '</td><td id=Col4_' + slno + '>' + AA[4] + '</td><td id=Col4_' + slno + '>' + AA[2] + '</td><td id=Col4_' + slno + '>' + AA[1] + '</td><td align=right  id=Col5_' + slno + '>' + parseFloat(result[i].PRate).toFixed(Decimal) + '</td> <td align=right  id=Col5_' + slno + '>' + parseFloat(AA[3]).toFixed(Decimal) + '</td>       <td align = right id=Col6_' + slno + '>' + parseFloat(result[i].TestAmount).toFixed(Decimal) + '</td></tr>';

            }
            else {
                responseText += '<tr style="font-weight: bold;"><td align= center id = Col1_' + slno + ' >' + slno + '</td><td id = Col2_' + slno + '></td><td  id= Col3_' + slno + '></td><td id=Col4_' + slno + '>TOTAL</td><td id=Col4_' + slno + '></td><td id=Col4_' + slno + '></td><td id=Col4_' + slno + '></td><td align=right  id=Col5_' + slno + '>' + parseFloat(result[i].PRate).toFixed(Decimal) + '</td> <td align=right  id=Col5_' + slno + '>' + parseFloat(AA[3]).toFixed(Decimal) + '</td>       <td align = right id=Col6_' + slno + '>' + parseFloat(result[i].TestAmount).toFixed(Decimal) + '</td></tr>';

            }


        }
        $('#Tblreport').html(responseText + '</tbody>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Procedure Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');

        $('#header').text(title);


        if ($('#Summary').prop('checked') == true) {
            Detailed(1);
        }
        else if ($('#Detailed').prop('checked') == true) {
            Detailed(0);
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }

    function Detailed(flag) {
        if (flag == 0) { $('.Hidden').show(); }
        else { $('.Hidden').hide(); }
    }

    //function gotoInvoNo(BillSlNo) {
    //    if (SType == 'SI') {
    //        if ((usermenu1.indexOf("M54") != -1)) {
    //            window.open('../inventory/SalesInvoice?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

    //        }

    //        else {
    //            warningshow('Invalid User Rights');
    //            return false;
    //        }

    //    }
    //}
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');

        });
        var table = null;
        if (download) {

            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
                "columnDefs": [
                    { "width": "0%", "targets": 0 },
                    { "width": "10%", "targets": 1 },
                    { "width": "10%", "targets": 2 },
                    { "width": "25%", "targets": 3 },
                    { "width": "15%", "targets": 4 },
                    { "width": "15%", "targets": 5 },






                ],

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                    {
                        extend: 'collection',
                        text: 'Export',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                title: title,
                                messageTop: 'MEDOO HMS',
                                // exportOptions: { columns: [0, 1, 2,3,4,5] }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: title,
                                messageTop: 'MEDOO HMS',
                                // exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
                            },
                            {
                                extend: 'print',
                                title: title,
                                messageTop: 'MEDOO HMS',
                                // exportOptions: { columns: [0, 1, 2, 3, 4, 5] }
                            }
                        ]
                    },
                    'colvis'
                ],

            });

            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");



        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
    }

</script>


