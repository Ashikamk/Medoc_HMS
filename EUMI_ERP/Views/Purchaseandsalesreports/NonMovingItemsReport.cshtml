
@{
    ViewBag.Title = "NonMovingItemsReport";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>

<div class="myData" data-x="M116" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="35%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#Group').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <div align="right">
                            <div class="heading-elements">
                                <hr style="margin-top:.1%;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:110%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content" style="width:85%">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Non-Moving Items Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                   
                    
                    <div class="row" style="margin-left:2%"><h6>Exclude Purchase Date</h6></div>
                    <div class="row" style="margin-top:1%">
                        <div class="col-md-2">
                            <label style="font-weight:bold">From</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <div class="col-md-2">
                            <label style="font-weight:bold">To</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:3%">
                        <div class="col-md-2">
                            <label style="font-weight:bold">Group</label>
                        </div>
                        <div class="col-md-4">
                            <select id="Group" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>


                        <div class="col-md-2">
                            <label style="font-weight:bold">SubGroup</label>
                        </div>
                        <div class="col-md-4">
                            <select id="Subgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:3%">
                        <div class="col-md-2">
                            <label style="font-weight:bold">Category</label>
                        </div>
                        <div class="col-md-4">
                            <select id="Category" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>


                        <div class="col-md-2">
                            <label style="font-weight:bold">SubCat.</label>
                        </div>
                        <div class="col-md-4">
                            <select id="Subcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:3%">
                        @*<label style="margin-top:2%;font-weight:bold;margin-left:10%">Dept.</label>
                            <div class="col-md-4" style="margin-top:2%;">
                                <select id="dept" class="form-control" name="priority">
                                    <option value='0'>-All-</option>
                                </select>
                            </div>*@
                        <div class="col-md-2">
                            <label style="font-weight:bold">Qty.</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="Qty" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-2">
                            <label style="font-weight:bold;">TopValues</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="Values" class="form-control" autocomplete="off">
                        </div>

                    </div>
                    <div class="row">

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:37%;" id="btnsubmit" onclick="GetNonMovingItems()" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>




<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }
    function GroupPageLoad(id) {
        var data1 = {};
        data1.GrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/GroupGetandGets",
            data: data1,
            success: function (result) {
                GroupLoad(result.oList, id);
            }
        });
    }

    function GroupLoad(result) {
        $("#Group").empty();
        $("#Group").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {

            $("#Group").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
        }
        SubGroupGets();
    }

    function SubGroupGets() {
        var data = {};
        data.GroupId = $("#Group").val();


        if (data.GroupId == 0) {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetandGets",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
        else {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetForGroup",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
    }

    function SubGroupLoad(result) {
        $("#Subgroup").empty();
        $("#Subgroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Subgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
        }
    }



    function CategoryPageLoad(id) {
        var data2 = {};
        data2.CategoryId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CategoryGetandGets",
            data: data2,
            success: function (result) {
                CategoryLoad(result.oList, id);
            }
        });
    }


    function CategoryLoad(result) {
        $("#Category").empty();
        $("#Category").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Category").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
        }
        SubCategoryGets();
    }

    function SubCategoryGets() {

        var data = {};
        data.CategoryId = $("#Category").val();

        if (data.CategoryId == 0) {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetandGets",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);

                }
            });
        }

        else {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetforCategory",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);
                }
            });
        }
    }



    function SubCategoryLoad(result) {
        $("#Subcategory").empty();
        $("#Subcategory").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Subcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
        }
    }

    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#dept").empty();
        $("#dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }



    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Code</th><th>Description</th><th>Qty.</th><th style=text-align:right>Avg.Cost</th><th>Stock</th><th>Import Pur.Date</th><th>Local Pur.Date</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            //if (result[i].ItemCode == '') {
            //    responseText += '<tr style=background-color:#cfd8dc;font-weight:bold><td>' + slno + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDesc + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubGroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + result[i].AvgCost + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';
            //}
            //else {
            responseText += '<tr><td>' + slno + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDesc + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + parseFloat(result[i].AvgCost || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseInt(result[i].Stock || 0) + '</td><td>' + result[i].ImportDate + '</td><td>' + result[i].LocalDate + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubGroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td></tr>';
           // }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Code</th><th>Description</th><th> </th><th style=text-align:right> </th><th style=text-align:right> </th><th>Import Pur.Date</th><th>Local Pur.Date</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Non-Moving Items Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    $(function () {
        //GetNonMovingItems(1, 10);
        $('#Group').focus();
        $('#Group').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Subgroup').focus();
                e.preventDefault();
            }
        });
        $('#Subgroup').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Category').focus();
                e.preventDefault();
            }
        });
        $('#Category').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Subcategory').focus();
                e.preventDefault();
            }
        });
        $('#Subcategory').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#dept').focus();
                e.preventDefault();
            }
        });
        $('#dept').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Qty').focus();
                e.preventDefault();
            }
        });
        $('#Qty').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Values').focus();
                e.preventDefault();
            }
        });
        $('#Values').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        GroupPageLoad(0);
        CategoryPageLoad(0);
        GetDepartment(0);

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });


    });

    function GetNonMovingItems() {

            //if ($('#Qty').val() == '0') {
            //    warningshow('Quantity cannot be zero', 'Qty');
            //    $('#Qty').select();
            //}
      

            $('#Loading').show();


            var data1 = {};
            data1.Qty = parseInt($('#Qty').val() || 0);
            data1.DateFrom = $('#DateFrom').val();
            data1.DateTo = $('#DateTo').val();
            data1.Type = parseInt($('#Values').val()||0);
            data1.GroupId = parseInt($('#Group').val() || 0);
            data1.SubGroupId = parseInt($('#Subgroup').val() || 0);
            data1.CategoryId = parseInt($('#Category').val() || 0);
            data1.SubCategoryId = parseInt($('#Subcategory').val() || 0);
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/NonMovingItemsDashboard",
                data: data1,
                success: function (result) {
                    Showreport(result);
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                }
            });
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Qty.') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Avg.Cost') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Amount') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Group') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Sub Group') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Category') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Sub Category') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Item Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:150px" />');
            }
            if (title == 'Item Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:400px" />');
            }
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }


</script>












