
@{
    ViewBag.Title = "ItemwisePurchase";
}



<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>





<div id="Entry">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">


                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="38%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">


                                <br /><hr />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                                <br /><br />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Itemwise Purchase Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:30px">From Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="margin-top:5px;margin-left:45px">To Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">

                        <label style="margin-top:5px;margin-left:70px">Area </label>
                        <div class="col-md-4">
                            <select id="placeofsupply" name="priority" class="form-control"></select>
                        </div>


                        <label style="margin-top:5px;margin-left:40px">Location </label>
                        <div class="col-md-4">
                            <select id="location" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:43px">Supplier </label>
                        <div class="col-md-4">
                            <input type="text" id="suppliername" class="form-control">
                            <input type="hidden" id="supplierId" class="form-control" />
                        </div>


                        <label style="margin-top:5px">Purchase Type</label>
                        <div class="col-md-4">
                            <select id="purchasetype" name="priority" class="form-control">
                                <option value="0">-All-</option>
                                <option value="Local">Local</option>
                                <option value="Import">Import</option>

                            </select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:15px">Department </label>
                        <div class="col-md-4">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>
                        <label style="margin-top:5px;margin-left:53px">Job No</label>
                        <div class="col-md-4">
                            <input type="text" id="jobno" class="form-control">
                            <input type="hidden" id="jobId" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-outline-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
        //Suppliername Autocomplete

        $("#suppliername").autocomplete({
            source: function (request, response) {
                var data = {};
                data.CustName = $("#suppliername").val();
                data.CustType = 'S';

                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWOEnq',
                                label: item.CustAccount,
                                label1: item.CustName,
                                CustId: item.CustId,
                                headers: ["Supplier Code", "Supplier Name"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#supplierId').val(ui.item.CustId)
            },

        });

        $("#jobno").autocomplete({
            source: function (request, response) {

                var data = {};
                data.JobCode = $("#jobno").val();

                $.ajax({
                    url: '../SalesInvoice/JobSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWOEnq',
                                label: item.JobCode,
                                label1: item.Description,
                                ProjectJobId: item.ProjectJobId,
                                headers: ["Job Code", "Job Name"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#jobId').val(ui.item.ProjectJobId)
            },

        });

        function popuprefresh() {
            $('#popupdiv').hide();
        }


        function Showreport(result) {
            disable_datatable('Tblreport', 'buttonPlace');
            var responseText = "<thead><tr><th>Slno</th><th>Invoice Number</th><th>Supplier Invoice Number</th><th>Date</th><th>Supplier</th><th>Item Code</th><th>Item Name</th><th>Job Code</th><th>Terms</th><th>Area</th><th>Location</th><th>Purchase Type</th><th>Taxable Amount</th><th>Tax Amount</th><th>Amount</th><th>Currency</th><th>Rate</th><th>FC Amount</th><th>Due Date</th><th>Ship Date</th><th>Department</th></tr></thead><tbody>";
            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);

                if (result[i].PurchaseSlNo == '') {
                    responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td>' + result[i].Product + '</td><td>' + result[i].ProductDesc + '</td><td>' + result[i].JobNo + '</td><td>' + result[i].Terms + '</td><td>' + result[i].SupplyTo + '</td><td>' + result[i].Location + '</td><td>' + result[i].PurchaseType + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td>' + result[i].FC + '</td><td style=text-align:right>' + result[i].CurrencyRate + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].DueDate + '</td><td>' + result[i].ShipDate + '</td><td>' + result[i].Dept + '</td></tr>';
                }
                else {
                    responseText += '<tr ondblclick=gotoInvoNo(' + result[i].PurchaseSlNo + "," + result[i].DeptId + ')><td>' + slno + '</td><td>' + result[i].PurchaseSlNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].InvoDate + '</td><td>' + result[i].Supplier + '</td><td>' + result[i].Product + '</td><td>' + result[i].ProductDesc + '</td><td>' + result[i].JobNo + '</td><td>' + result[i].Terms + '</td><td>' + result[i].SupplyTo + '</td><td>' + result[i].Location + '</td><td>' + result[i].PurchaseType + '</td><td style=text-align:right>' + result[i].TotalTaxable + '</td><td style=text-align:right>' + result[i].TotalTax + '</td><td style=text-align:right>' + result[i].Amount + '</td><td>' + result[i].FC + '</td><td style=text-align:right>' + result[i].CurrencyRate + '</td><td style=text-align:right>' + result[i].FCAmount + '</td><td>' + result[i].DueDate + '</td><td>' + result[i].ShipDate + '</td><td>' + result[i].Dept + ' <input type="hidden" id="Dept_' + i + '" value=' + result[i].DeptId + '></td></tr>';
                }
            }
            $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Invoice Number</th><th>Supplier Invoice Number</th><th>Date</th><th>Supplier</th><th>Item Code</th><th>Item Name</th><th>Job Code</th><th>Terms</th><th>Area</th><th>Location</th><th>Purchase Type</th>><th> </th><th> </th><th> </th><th>Currency</th><th> </th><th> </th><th>Due Date</th><th>Ship Date</th><th>Department</th></tr></tfoot>');

            var title = "Itemwise Purchase Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
            datatableWithsearch('Tblreport', true, title, 'buttonPlace');
            $('#header').text(title);
        }



        function gotoInvoNo(PurchaseSlNo, DeptId) {
            sessionStorage.setItem("purchase_slno", PurchaseSlNo);
            sessionStorage.setItem("pur_deptid", DeptId);
            window.location = "@Url.Action("PurchaseInvoice", "inventory", new { from = "PurchaseReport" })";
        }


        function GetLocation(id) {
            var data = {};
            data.LocationId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/LocationGetandGets",
                data: data,
                success: function (result) {
                    LocationLoad(result.oList, id);


                }
            });

        }

        function LocationLoad(result, a) {
            $("#location,#locn_0,#locn_job").empty();
            LocationSelect = "<option value='0'>-All-</option>";
            for (var i = 0; i < result.length; i++) {
                LocationSelect += "<option value='" + result[i].LocationId + "'locname='" + result[i].LocationName + "'>" + result[i].LocationName + "</option>";

            }
            $("#location,#locn_0,#locn_job").append(LocationSelect);
            if (a == 0) {
                $('#location').val(0);
            }
            else {
                $('#location').val(a);
            }
        }



        function GetArea(id) {
            var data = {};
            data.Id = 0;
            $.ajax({
                type: "POST",
                url: "../Master/AreaGetandGets",
                data: data,
                success: function (result) {
                    AreaLoad(result.oList, id);


                }
            });
        }

        function AreaLoad(result, a) {
            $("#placeofsupply").empty();
            $("#placeofsupply").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#placeofsupply").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaCode + "</option>");
            }
            if (a == 0) {
                $('#placeofsupply').val(0);
            }
            else {
                $('#placeofsupply').val(a);
            }
        }




        function GetDepartment(id) {
            var data = {};
            data.DeptId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/DepartmentGetandGets",
                data: data,
                success: function (result) {
                    DepartmentLoad(result.oList, id);


                }
            });
        }

        function DepartmentLoad(result, a) {
            $("#department").empty();
            $("#department").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }
            if (a == 0) {
                $('#department').val(0);
            }
            else {
                $('#department').val(a);
            }
        }


