                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">

                        <label style="margin-top:2%;font-weight:bold;margin-left:0.5%">Top 'N' Values</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="Values" class="form-control" autocomplete="off">
                        </div>

                        <label style="margin-top:2%;font-weight:bold;margin-left:-2%">Sup.</label>
