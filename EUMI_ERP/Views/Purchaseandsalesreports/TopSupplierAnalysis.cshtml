    function TopSupplierGraphReport(Grtype) {




        if ($('#suppliername').val() == '') {
            $('#supplierId').val(0);
        }

        if ($('#DateFrom').val() == '') {
            alert('Please Select From Date');
            $('#DateFrom').focus();

        }
        else if ($('#DateTo').val() == '') {
            alert('Please Select To Date');
            $('#DateTo').focus();

        }

        else {

            $('#Loading').show();

            if ($("#graphreport").prop("checked")) {
                var data = {};
                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.number = parseInt($('#Values').val() || 0);
                data.SupplierId = parseInt($('#supplierId').val() || 0);
                data.Userid = ERPUserId;
                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/TopSupplierGraphReportGet",
                    data: data,
                    success: function (result) {
                      
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                        $('#Entry').hide();
                        $('#graph').show();
                        ShowReportShort(result, Grtype);
                        console.log(result)
                    }
                });
            }
            else {

                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.number = parseInt($('#Values').val() || 0);
                data.SupplierId = parseInt($('#supplierId').val() || 0);
                data.Userid = ERPUserId;


                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/TopSupplierReportGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                        $('#Entry').show();
                        $('#graph').hide();
                    }
                });
            } datatableWithsearch1
        }


    }


    function datatableWithsearch2(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }
            
            if (title == 'Quantity') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
            }
            if (title == 'Supplier Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:110px" />');
            }

            if (title == 'Supplier Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:230px" />');
            }
           

          
            
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            //dom: 'Blfrtip',
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
            //"columnDefs": [

            //     { "width": "17%", "targets": 2 },
            //     { "width": "18%", "targets": 3 },
            //      { "width": "15%", "targets": 4 },
            //        { "width": "15%", "targets": 5 },
            //          { "width": "10%", "targets": 6 },
            //           { "width": "10%", "targets": 7 },

            //]

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }




</script>





