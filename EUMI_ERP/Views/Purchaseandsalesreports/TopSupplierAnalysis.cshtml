    $("#suppliername").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Supplier Code", "Supplier Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId)
            $('#suppliername').val(ui.item.CustName);

        },

    });


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th Style=width:10px>Sl#</th><th Style=width:10px>Supplier Code</th><th Style=width:620px>Supplier Name</th><th Style=width:150px;text-align:center>Quantity</th><th style=text-align:right;width:190px>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].SupplierId == '') {
                responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].SupplierId + '</td><td><b>' + result[i].Supplier + '</b></td><td style=text-align:center><b>' + result[i].Qty + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].SupplierId + '</td><td>' + result[i].Supplier + '</td><td style=text-align:center>' + result[i].Qty + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Supplier Code</th><th>Supplier Name</th><th> </th><th style=text-align:right> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Top Supplier Analysis Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch2('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
