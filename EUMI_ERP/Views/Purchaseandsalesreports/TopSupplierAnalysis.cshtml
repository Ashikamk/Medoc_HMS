                            <input type="hidden" id="supplierId" class="form-control" />
                        </div>
                    </div>

                </div>
             

                <div class="modal-footer">
                    <fieldset class="form-group floating-label-form-group" style="margin-right:10%">
                        <div class="row">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="graphreport">
                                <label class="custom-control-label" for="graphreport" style="font-weight:bold">Graphical Report</label>
                            </div>

                        </div>
                    </fieldset>

                    <button type="button" id="btnsubmit" style="width:100px;margin-right:35%" onclick="TopSupplierGraphReport('column')" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>


