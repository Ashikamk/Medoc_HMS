
@{
    ViewBag.Title = "MetricTonReport";
}


<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>


<table style="display:none" id="Tblreportprint"></table>

<div class="myData" data-x="M317" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="35%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#Supplier').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                @*<td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('SALESREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>*@
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        </table>
                        <div align="center">
                            <br /><hr style="margin-top:-1%" />
                            <div class="heading-elements">
                                <div id="divreport" style="overflow:auto;display:none;">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:100%;">
    <div class="modal-dialog " role="document" style="top:5%;max-width:30%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Purchase - Item wise Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">From</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-2 text-center">
                            <label style="font-weight:bold;">To</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="margin-top:3%">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">Supplier</label>
                        </div>
                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="30%">
                                        <input type="text" id="Supplier" class="form-control" onkeyup="$('#SupplierName').val(''), $('#supplierId').val(0)" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="SupplierId" class="form-control" />

                                    </td>
                                    <td>
                                        <input type="text" id="SupplierName" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" style="width:80px" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />

                </div>

            </form>
        </div>
    </div>
</div>

<script>
    $("#Supplier").autocomplete({
        source: function (request, response) {
            var data = {};
            data.CustName = $("#Supplier").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            CustAccount: item.CustAccount,
                            headers: ["Supplier Code", "Supplier Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#SupplierId').val(ui.item.CustId)
            $('#SupplierName').val(ui.item.CustName)
            $('#Supplier').val(ui.item.CustAccount)
            $('#btnsubmit').focus();
        },

    });
    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }


    $(function () {
       
        $('#Supplier').focus();
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear()+50, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear()+50, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $("#DateFrom").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#DateTo').focus();
            }

        });

        $("#DateTo").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#location').focus();
            }

        });

        $("#location").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#btnsubmit').focus();
            }

        });

        $("#btnsubmit").click(function (e) {

            $('#Loading').show();
            if ($('#Supplier').val() == '') {
                $('#SupplierId').val(0);
            }
            var data = {};
            data.FromDate = $('#DateFrom').val();
            data.ToDate = $('#DateTo').val();
            data.Supplier = parseInt($('#SupplierId').val()||0);

            $.ajax({
                type: "POST",
                url: "../purchaseandsalesreports/MetricTonReportGet",
                data: data,
                success: function (result) {

                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);
                }
            });

        });
    });
    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Item Code</th><th>Item Desctiption</th>" +
                "<th style=text-align:right>Quantity</th>" +
            "</tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].ItemCode == 'Total') {
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold><td style=text-align:center;>' + slno + '</td>' +
                    '<td id="Col1_' + slno + '">' + result[i].ItemCode + '</td>' +
                    '<td id="Col2_' + slno + '">' + result[i].ItemDescription + '</td>' +
                    '<td id="Col2_' + slno + '" style=text-align:right>' + parseFloat(result[i].Quantity).toFixed(Decimal) + '</td>' +
                    '</tr>';
            }
            else {
                responseText += '<tr><td style=text-align:center>' + slno + '</td>' +
                    '<td id="Col1_' + slno + '">' + result[i].ItemCode + '</td>' +
                    '<td id="Col2_' + slno + '">' + result[i].ItemDescription + '</td>' +
                    '<td id="Col3_' + slno + '" style=text-align:right>' + parseFloat(result[i].Quantity).toFixed(Decimal) + '</td>' +
                    '</tr>';
            }
        }

        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th style=text-align:center>Sl#</th><th>Item Code</th><th>Item Desctiption</th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText)
        var title = "Purchase - Item wise Report - From " + $("#DateFrom").val() + " to  " + $("#DateTo").val();
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#ResultLength').val(result.length);

    }


    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Item Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }
            if (title == 'Item Desctiption') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:500px" />');
            }
           

        });

        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],

            });



            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }

</script>







