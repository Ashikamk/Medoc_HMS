<script>
    $("#Entryno").autocomplete({
        source: function (request, response) {
            var data = {};
            data.DeptId = ERPDeptId;
            data.ProEntryNo = $("#Entryno").val();
            $.ajax({
                url: '../ProductionEntry/CopyProdEntry',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3',
                            label: item.ProEntryNo,
                            label1: item.ProEntryDate,
                            label2: item.ItemCode,
                            ProEntryNo: item.ProEntryNo,
                            headers: ["Entry Number", "Date", "Item Code"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#Entryno').val(ui.item.ProEntryNo);
        },
    });


    $("#JobCode").autocomplete({
        source: function (request, response) {

            var data = {};
            data.JobCode = $("#JobCode").val();
            $.ajax({
                url: '../SalesInvoice/JobSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.JobCode,
                            label1: item.Description,
                            ProjectJobId: item.ProjectJobId,
                            headers: ["Job Code", "Job Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#JobCodeId').val(ui.item.ProjectJobId)
        },

    });

    $("#Product").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#Product").val();
            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.ItemCode,
                            label1: item.Description,
                            ItemId: item.ItemId,
                            headers: ["Item Code", "Description"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $("#ProductId").val(ui.item.ItemId);
        },
    });

    $("#btnsubmit").click(function (e) {
        var Condition = '', Product = '', Dept = '', Entryno = '', JobCode = ''
        var data = {};
        var FromDate = $('#DateFrom').val();
        var ToDate = $('#DateTo').val();
        var Product = $('#ProductId').val();
        var Dept = $('#Dept').val();
        var Entryno = $('#Entryno').val();
        var JobCode = $('#JobCodeId').val();
        var Userid = ERPUserId;

        if ($('#Product').val() == '') {
            $('#ProductId').val(0);
        }
        if ($('#JobCode').val() == '') {
            $('#JobCodeId').val(0);
        }

        Condition = 'CONVERT(datetime,ProEntryDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,ProEntryDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'
     
        if (Product != 0) { Condition += ' and ItemId = ' + Product; }

        if (Dept != 0) { Condition += ' and PM.DeptId = ' + Dept; }

        if (Entryno != '') { Condition += ' and PM.ProEntryNo=' + Entryno; }

        if (JobCode != 0) { Condition += ' and PM.ProjectJobId=' + JobCode; }
        if (Userid != 0) { Condition += 'and PM.DeptId  in (select DeptId from Mst_UserDeptDivision where UserId= ' + Userid + ')'; }



            var data = {};
            data.Condition = Condition;
            console.log(data.Condition)

            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/DetailedProduction",
                data: data,
                success: function (result) {
                    $('#divreport').show();
                    $('#popupdiv').hide();


                    disable_datatable('Tblreport', 'buttonPlace');
                    var responseText = "<thead><tr><th>Sl#</th><th>Entry#</th><th>Date</th><th>Item Code</th><th>Item Name</th><th>Location</th><th>Production Qty.</th><th>Cost Per Item</th><th>Total OtherCost</th><th>Total Production Cost</th><th>Job Code</th><th>Dept.Code</th></thead><tbody>";
                    for (var i = 0; i < result.length; i++) {
                        var slno = parseInt(i + 1);
                        if (result[i].ProEntryNo == '' && result[i].InvDate != '') {
                            responseText += '<tr style=background-color:#b0bec5><td align=center>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemName + '</td><td>' + result[i].Location + '</td><td style=text-align:right>' + result[i].Quantity + '</td><td style=text-align:right>' + parseFloat(result[i].Price || 0).toFixed(decimal) + '</td><td></td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</td><td>' + result[i].JobCode + '</td><td>' + result[i].Department + '</td></tr>';
                        }
                        else if (result[i].ItemCode == 'Total') {
                            responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td>' + result[i].InvDate + '</td><td><b>' + result[i].ItemCode + '</b></td><td><b>' + result[i].ItemName + '</b></td><td>' + result[i].Location + '</td><td style=text-align:right><b>' + result[i].Quantity + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Price || 0).toFixed(decimal) + '</b><td style=text-align:right><b>' + parseFloat(result[i].OtherCost || 0).toFixed(decimal) + '</b></td></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</b></td><td>' + result[i].JobCode + '</td><td>' + result[i].Department + '</td></tr>';
                        }
                        else if (result[i].ItemCode == 'Other Cost') {
                            responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td>' + result[i].InvDate + '</td><td><b>' + result[i].ItemCode + '</b></td><td><b>' + result[i].ItemName + '</b></td><td>' + result[i].Location + '</td><td style=text-align:right><b>' + result[i].Quantity + '</b></td><td style=text-align:right><b></b><td style=text-align:right><b>' + parseFloat(result[i].OtherCost || 0).toFixed(decimal) + '</b></td></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</b></td><td>' + result[i].JobCode + '</td><td>' + result[i].Department + '</td></tr>';
                        }
                        else if (result[i].ItemCode == 'Grand Total') {
                            responseText += '<tr style=background-color:#cfd8dc><td align=center>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td>' + result[i].InvDate + '</td><td><b>' + result[i].ItemCode + '</b></td><td><b>' + result[i].ItemName + '</b></td><td>' + result[i].Location + '</td><td style=text-align:right><b>' + result[i].Quantity + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Price || 0).toFixed(decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].OtherCost || 0).toFixed(decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</b></td><td>' + result[i].JobCode + '</td><td>' + result[i].Department + '</td></tr>';
                        }
                        else {
                            responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].InvoiceNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemName + '</td><td>' + result[i].Location + '</td><td style=text-align:right>' + result[i].Quantity + '</td><td style=text-align:right>' + parseFloat(result[i].Price || 0).toFixed(decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].OtherCost || 0).toFixed(decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(decimal) + '</td><td>' + result[i].JobCode + '</td><td>' + result[i].Department + '</td></tr>';

                        }
                    }
                    $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Entry#</th><th>Date</th><th>Item Code</th><th>Item Name</th><th>Location</th><th> </th><th> </th><th> </th><th> </th><th>Job Code</th><th>Dept.Code</th></tr></tfoot>');

                    var title = "Detailed Production Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
                    datatableWithsearch('Tblreport', true, title, 'buttonPlace');
                    $('#header').text(title);
                }
            });

    });

 
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            if (title == 'Entry#')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Date')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Dept.Code')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Job Code')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Location')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Item Code')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:200px" />');
            if (title == 'Item Name')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:400px" />');

        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

</script>





