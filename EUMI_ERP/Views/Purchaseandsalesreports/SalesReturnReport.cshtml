
@{
    ViewBag.Title = "SalesReturnReport";
}



<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>

<div class="myData" data-x="M249" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">


                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>


                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#suppliername').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                @* <td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('PURCHASEREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>*@

                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">

                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <hr style="margin-top:-.3%;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:110%">
    <div class="modal-dialog" role="document" style="top:5%;max-width:35%;margin-left:28.5%">
        <div class="modal-content" >
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Sales Return Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">From</label>
                        <div class="col-md-3">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label  class="col-md-2 text-right" style="font-weight:bold;">To</label>
                        <div class="col-md-3">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-1"></div>

                    </div>

                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:2%"></div>

                    <div class="row" style="margin-top:2%;">
                        <div class="col-md-1"></div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Customer</label>
                        <div class="col-md-8">
                            <table width="100%">
                                <tr>
                                    <td width="30%">
                                        <input type="text" id="suppliername" class="form-control" onkeyup="$('#custnames').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="supplierId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="custnames" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-1"></div>
                    </div>

                    <div class="row" style="margin-top:2%;">
                        <div class="col-md-1"></div>

                        @*<label class="col-md-2 text-right" style="font-weight:bold;">Customer </label>
                        <div class="col-md-3">
                            <input type="text" id="suppliername" class="form-control">
                            <input type="hidden" id="supplierId" class="form-control" />
                        </div>*@


                        <label class="col-md-2 text-right" style="font-weight:bold;">Salesman</label>
                        <div class="col-md-3">
                            <select id="salesman" name="priority" class="form-control"></select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Pay Type</label>
                        <div class="col-md-3">
                            <select id="PayType" class="form-control" name="priority">
                                <option value="0">-All-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>
                        <div class="col-md-1"></div>

                    </div>

                    <div class="row" style="margin-top:2%;">
                        <div class="col-md-1"></div>

                        
                        <label class="col-md-2 text-right" style="font-weight:bold;">Dept.</label>
                        <div class="col-md-3" >
                            <select id="department" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="col-md-1"></div>

                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:42%" id="btnsubmit"  class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />
                </div>


            </form>
        </div>
    </div>
</div>

<script>
        //Suppliername Autocomplete

        $("#suppliername").autocomplete({
            source: function (request, response) {
                var data = {};
                data.CustName = $("#suppliername").val();
                data.CustType = 'C';

                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWOEnq',
                                label: item.CustAccount,
                                label1: item.CustName,
                                CustId: item.CustId,
                                CustName: item.CustName,
                                headers: ["Customer Code", "Customer Name"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#supplierId').val(ui.item.CustId)
                $('#supplier').val(ui.item.CustName)
                $("#custnames").val(ui.item.CustName);
                $('#salesman').focus();
            },

        });

        function popuprefresh() {
            $('#popupdiv').hide();
        }



        function Showreport(result) {

            disable_datatable('Tblreport', 'buttonPlace');
            var responseText = "<thead><tr><th style=width:2px;text-align:center>Sl#</th><th style='width:10px'>Dept.</th><th style='width:3px'>Return#</th><th style='width:10px;text-align:center'>Date</th><th style='width:10px'>Customer</th><th style='width:10px'>Salesman</th><th style='width:4px;text-align:left'>Pay Type</th><th style='width:10px;text-align:right'>Disc.</th><th style='width:10px;text-align:right'>Round off</th><th style='width:10px;text-align:right'>Taxable Amount</th><th style='width:10px;text-align:right' >Tax Amount</th><th style='width:10px;text-align:right'>Sales Return Amount</th></tr></thead><tbody>";

            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);

                if (result[i].InvoNo == '')
                {
                    responseText += '<tr style=background-color:#cfd8dc><td style=text-align:center;width:5px  style="width:2px">' + slno + '</td><td  id="Col1_' + slno + '" >' + result[i].Dept + '</td><td></td><td  id="Col3_' + slno + '" style=text-align:center><b>' + result[i].InvoDate + '</b></td><td id="Col4_' + slno + '" style=text-align:left><b>' + result[i].Supplier + '</b></td><td  style=text-align:left><b>' + result[i].Salesman + '</b></td><td  id="Col6_' + slno + '" >' + result[i].PayType + '</td><td style=text-align:right><b>' + parseFloat(result[i].Discount || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Roundoff || 0).toFixed(Decimal) + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</b></td><td  id="Col9_' + slno + '" style=text-align:right><b>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</b></td><td  id="Col10_' + slno + '"  style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</b></td></tr>';

                }
                else
                {
                    responseText += '<tr><td style=text-align:center;width:5px  style="width:2px">' + slno + '</td><td  id="Col1_' + slno + '" >' + result[i].Dept + '</td><td style=text-align:left>' + result[i].BillSeries + '- ' + result[i].InvoNo + '</td><td  id="Col3_' + slno + '" style=text-align:center>' + result[i].InvoDate + '</td><td id="Col4_' + slno + '" style=text-align:left>' + result[i].Supplier + '</td><td  style=text-align:left>' + result[i].Salesman + '</td><td  id="Col6_' + slno + '" >' + result[i].PayType + '</td><td style=text-align:right>' + parseFloat(result[i].Discount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].Roundoff || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td><td  id="Col9_' + slno + '" style=text-align:right>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td><td  id="Col10_' + slno + '"  style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td></tr>';

                }


            }
            $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th> </th><th>Dept.</th><th>Return#</th><th>Date</th><th>Customer</th><th>Salesman</th><th>Pay Type</th><th> </th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');
            $('#Tblreportprint').html(responseText);
            var title = "Sales Return Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
            datatableWithsearchs('Tblreport', true, title, 'buttonPlace');

            $('#header').text(title);
            $('#ResultLength').val(result.length);
        }

        function GetSalesMan(id) {
            var data = {};
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Master/UserSalesmanGetandGets",
                data: data,
                success: function (result) {
                    SalesManLoad(result.oList, id);
                }
            });
        }

        function SalesManLoad(result, a) {
            console.log(result)
            $("#salesman").empty();
            //$("#salesman").append("<option value='0'>-All-</option>")
            for (var i = 0; i < result.length; i++) {
                $("#salesman").append("<option value='" + result[i].SalesmanId + "'>" + result[i].FirstName + "</option>");
            }
        }




        function GetLocation(id) {
            var data = {};
            data.LocationId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/LocationGetandGets",
                data: data,
                success: function (result) {
                    LocationLoad(result.oList, id);


                }
            });

        }

        function LocationLoad(result, a) {
            $("#location,#locn_0,#locn_job").empty();
            LocationSelect = "<option value='0'>-All-</option>";
            for (var i = 0; i < result.length; i++) {
                LocationSelect += "<option value='" + result[i].LocationId + "'locname='" + result[i].LocationName + "'>" + result[i].LocationName + "</option>";

            }
            $("#location,#locn_0,#locn_job").append(LocationSelect);
            if (a == 0) {
                $('#location').val(0);
            }
            else {
                $('#location').val(a);
            }
        }



        function GetArea(id) {
            var data = {};
            data.Id = 0;
            $.ajax({
                type: "POST",
                url: "../Master/AreaGetandGets",
                data: data,
                success: function (result) {
                    AreaLoad(result.oList, id);


                }
            });
        }

        function AreaLoad(result, a) {
            $("#placeofsupply").empty();
            $("#placeofsupply").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#placeofsupply").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaCode + "</option>");
            }
            if (a == 0) {
                $('#placeofsupply').val(0);
            }
            else {
                $('#placeofsupply').val(a);
            }
        }




        function GetDepartment(id) {
            var data = {};
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Master/UserDepartmentGetandGets",
                data: data,
                success: function (result) {
                    DepartmentLoad(result.oList, id);


                }
            });
        }

        function DepartmentLoad(result, a) {
            $("#department").empty();
            $("#department").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }
        }

        $(function () {
            $('#suppliername').focus();
            GetLocation(0);
            GetArea(0);
            GetDepartment(0);
            GetSalesMan(0);
            //$("#suppliername").keydown(function (e) {
            //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            //    $('#supplierId').val(0);
            //    if (key == 13) {
            //        e.preventDefault();
            //        $('#purchasetype').focus();
            //    }

            //});

            $('#salesman').keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#PayType').focus();
                    e.preventDefault();
                }
            });

            $('#PayType').keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#department').focus();
                    e.preventDefault();
                }
            });
            $('#department').keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#btnsubmit').focus();
                    e.preventDefault();
                }
            });
            //$('#PayType').keydown(function (e) {
            //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            //    if (key == 13) {
            //        $('#department').focus();
            //        e.preventDefault();
            //    }
            //});
            //$('#department').keydown(function (e) {
            //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            //    if (key == 13) {
            //        $('#btnsubmit').focus();
            //        e.preventDefault();
            //    }
            //});
            $('#DateFrom').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#DateTo').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });



            $("#btnsubmit").click(function (e) {
                $('#Loading').show();


                var Condition = '', Supplier = '', Payterms = '', PayType = '', Department=''
                var data = {};
                var FromDate = $('#DateFrom').val();
                var ToDate = $('#DateTo').val();
                var Salesman = $('#salesman').val();
                var PayType = $('#PayType').val();
                var Department = parseInt($('#department').val() || 0);


                if ($('#suppliername').val() == '') {
                    $('#supplierId').val(0);
                }

                var Supplier = parseInt($('#supplierId').val() || 0);

                Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'


                if (Supplier != 0) { Condition += ' and P.CustId=' + Supplier; }

                if (Salesman != 0) { Condition += ' and P.SalesManId=' + Salesman; }

                if (PayType != 0) { Condition += ' and P.PayType=' + PayType; }

                if (Department != 0) { Condition += ' and P.DeptId=' + Department; }



                    var data = {};
                    data.Condition = Condition;
                    data.UserId = ERPUserId;
                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/SalesReturnReport",
                        data: data,
                        success: function (result) {

                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                                Showreport(result);
                        }
                    });



            });

        });




        function datatableWithsearchs(tablename, download, title, tableButtonContainerId) {

            var a = '#' + tablename + ' tfoot th'
            $(a).each(function () {
                var title = $(this).text();
                if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                    $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
                }
                if ( title == 'Date') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:50px" />');
                }
                if (title == 'Return#') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Supplier' ) {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:180px" />');
                }
                if ( title == 'Terms' || title == 'Area'|| title == 'Purchase Type') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
                }
                if (title == 'Due Date' || title=='Ship Date') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:90px" />');
                }
                if (title == 'Fx.') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Sup.Inv.#') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Pay Type' ) {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Account#' ) {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:80px" />');
                }
                if ( title == 'Dept.') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Due Date') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Ship Date') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
                if (title == 'Area') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }
            });
            var table = null;
            if (download) {
                if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


                table = $('#' + tablename).DataTable({
                    //dom: 'Blfrtip',
                    dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                   "<'row'<'col-sm-12'tr>>" +
                   "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                    buttons: [],
                    "columnDefs": [
                         { "width": "5%", "text-align": "center", "targets": 0 },
                         { "width": "5%", "targets": 1 },
                         { "width": "5%", "targets": 2 },
                         { "width": "5%", "targets": 4},

                    ]

                });
                new $.fn.dataTable.Buttons(table, {
                    buttons: [
                    {
                        extend: 'collection',
                        text: 'Export',
                        className: 'excelexport',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'print',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            }
                        ]
                    },
                    'colvis'
                    ]
                });
                table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
                $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

            } else {
                table = $('#' + tablename).DataTable();
            }
            table.columns().every(function () {
                var that = this;
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that
                            .search(this.value)
                            .draw();

                    }
                });
            });
            if (ExcelExport == 0) {
                $('.excelexport').hide();
            }
        }



</script>










