
@{
    ViewBag.Title = "DetailedStockReport";
}


<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>


<table style="display:none" id="Tblreportprint"></table>

<div class="myData" data-x="M312" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="35%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#ItemCode').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                @*<td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('SALESREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>*@
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        </table>
                        <div align="center">
                            <br /><hr style="margin-top:-1%" />
                            <div class="heading-elements">

                                <div id="divreport" style="overflow:auto;display:none;">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:100%;">
    <div class="modal-dialog " role="document" style="top:5%;max-width:30%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Detailed Stock Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">

                    <div class="row">

                        <div class="col-md-2">
                            <label style="font-weight:bold;">From</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>
                        <div class="col-md-2 text-center">
                            <label style="font-weight:bold;">To</label>
                        </div>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="margin-top:3%">
                        <div class="col-md-2">
                            <label style="font-weight:bold;">Product</label>
                        </div>
                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="40%">
                                        <input type="text" id="ItemCode" class="form-control" onkeyup="$('#ItemName').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="ItemId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="ItemName" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>

                </div>
                <div class="modal-footer">
                    <button type="button" style="width:80px" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />

                </div>

            </form>
        </div>
    </div>
</div>

<script>

    $("#ItemCode").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#ItemCode").val();
            data.LocId = UserLocationId;
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../SalesInvoice/ProductSearchSales',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.ItemCode,
                            label1: item.Description,
                            Description: item.Description,
                            ProductId: item.ItemId,
                            Product: item.ItemCode,
                            headers: ["Item Code", "Item Description"]
                        })
                    }));
                }
            })
        },

        autoFocus: true,
        select: function (event, ui) {
            $('#ItemCode').val(ui.item.Product);
            $('#ItemName').val(ui.item.Description);
            $('#ItemId').val(ui.item.ProductId);
            $('#btnsubmit').focus();
        },
    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }





    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }


    $(function () {
        $('#ItemCode').focus();
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            $('#Loading').show();

            if ($('#ItemCode').val() == '') {
                $('#ItemId').val('');
            }

            var data = {};
            data.FromDate = $('#DateFrom').val();
            data.ToDate = $('#DateTo').val();
            data.ItemId = $('#ItemId').val();

            $.ajax({
                type: "POST",
                url: "../SalesReport/DetailedStockReportGets",
                data: data,
                success: function (result) {

                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);
                }
            });

        });
    });
    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Item Code</th><th>Description</th>" +
            "<th style=text-align:right>Open.Qty.</th><th style=text-align:right>Open.Cost</th><th style=text-align:right>Open.Value</th>" +
            "<th style=text-align:right>Pur.Qty.</th><th style=text-align:right>Pur.Cost</th><th style=text-align:right>Pur.Value</th>" +
            "<th style=text-align:right>SalesQty.</th><th style=text-align:right>SalesPrice</th><th style=text-align:right>SalesValue</th>" +
             "<th style=text-align:right>PRQty.</th><th style=text-align:right>PRCost</th><th style=text-align:right>PRValue</th>" +
            "<th style=text-align:right>SRQty.</th><th style=text-align:right>SRPrice</th><th style=text-align:right>SRValue</th>" +
             "<th style=text-align:right>ClosingQty.</th><th style=text-align:right>ClosingCost</th><th style=text-align:right>ClosingValue</th>" +
            "</tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].ItemDescription == 'Total') {
                responseText += '<tr style=background-color:#cfd8dc;font-weight:bold><td style=text-align:center;>' + slno + '</td>' +
                    '<td id="Col1_' + slno + '">' + result[i].ItemCode + '</td>' +
                    '<td id="Col2_' + slno + '">' + result[i].ItemDescription + '</td>' +
                    '<td id="Col3_' + slno + '" style=text-align:right>' + parseFloat(result[i].OpQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col4_' + slno + '" style=text-align:right>' + parseFloat(result[i].OpCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col5_' + slno + '" style=text-align:right>' + parseFloat(result[i].OpSV).toFixed(Decimal) + '</td>' +
                    '<td id="Col6_' + slno + '" style=text-align:right>' + parseFloat(result[i].PurchaseQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col7_' + slno + '" style=text-align:right>' + parseFloat(result[i].PCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col8_' + slno + '" style=text-align:right>' + parseFloat(result[i].PStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col9_' + slno + '" style=text-align:right>' + parseFloat(result[i].SalesQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col10_' + slno + '" style=text-align:right>' + parseFloat(result[i].SPrice).toFixed(Decimal) + '</td>' +
                    '<td id="Col11_' + slno + '" style=text-align:right>' + parseFloat(result[i].SStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col12_' + slno + '" style=text-align:right>' + parseFloat(result[i].PurchaseReturnQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col13_' + slno + '" style=text-align:right>' + parseFloat(result[i].PRCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col14_' + slno + '" style=text-align:right>' + parseFloat(result[i].PRStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col15_' + slno + '" style=text-align:right>' + parseFloat(result[i].SalesReturnQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col16_' + slno + '" style=text-align:right>' + parseFloat(result[i].SRPrice).toFixed(Decimal) + '</td>' +
                    '<td id="Col17_' + slno + '" style=text-align:right>' + parseFloat(result[i].SRStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col18_' + slno + '" style=text-align:right>' + parseFloat(result[i].ClosingQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col19_' + slno + '" style=text-align:right>' + parseFloat(result[i].ClosingAvgCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col20_' + slno + '" style=text-align:right>' + parseFloat(result[i].ClosingStockValue).toFixed(Decimal) + '</td>' +
                    '</tr>';
            }
            else {
                responseText += '<tr><td style=text-align:center>' + slno + '</td>' +
                    '<td id="Col1_' + slno + '">' + result[i].ItemCode + '</td>' +
                    '<td id="Col2_' + slno + '">' + result[i].ItemDescription + '</td>' +
                    '<td id="Col3_' + slno + '" style=text-align:right>' + parseFloat(result[i].OpQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col4_' + slno + '" style=text-align:right>' + parseFloat(result[i].OpCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col5_' + slno + '" style=text-align:right>' + parseFloat(result[i].OpSV).toFixed(Decimal) + '</td>' +
                    '<td id="Col6_' + slno + '" style=text-align:right>' + parseFloat(result[i].PurchaseQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col7_' + slno + '" style=text-align:right>' + parseFloat(result[i].PCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col8_' + slno + '" style=text-align:right>' + parseFloat(result[i].PStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col9_' + slno + '" style=text-align:right>' + parseFloat(result[i].SalesQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col10_' + slno + '" style=text-align:right>' + parseFloat(result[i].SPrice).toFixed(Decimal) + '</td>' +
                    '<td id="Col11_' + slno + '" style=text-align:right>' + parseFloat(result[i].SStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col12_' + slno + '" style=text-align:right>' + parseFloat(result[i].PurchaseReturnQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col13_' + slno + '" style=text-align:right>' + parseFloat(result[i].PRCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col14_' + slno + '" style=text-align:right>' + parseFloat(result[i].PRStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col15_' + slno + '" style=text-align:right>' + parseFloat(result[i].SalesReturnQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col16_' + slno + '" style=text-align:right>' + parseFloat(result[i].SRPrice).toFixed(Decimal) + '</td>' +
                    '<td id="Col17_' + slno + '" style=text-align:right>' + parseFloat(result[i].SRStockValue).toFixed(Decimal) + '</td>' +
                    '<td id="Col18_' + slno + '" style=text-align:right>' + parseFloat(result[i].ClosingQty).toFixed(Decimal) + '</td>' +
                    '<td id="Col19_' + slno + '" style=text-align:right>' + parseFloat(result[i].ClosingAvgCost).toFixed(Decimal) + '</td>' +
                    '<td id="Col20_' + slno + '" style=text-align:right>' + parseFloat(result[i].ClosingStockValue).toFixed(Decimal) + '</td>' +
                    '</tr>';
            }
        }

        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th style=text-align:center>Sl#</th><th>Item Code</th><th>Description</th>' +
        "<th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>");
        $('#Tblreportprint').html(responseText)
        var title = "Detailed Stock Report - From " + $("#DateFrom").val() + " to  " + $("#DateTo").val();
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#ResultLength').val(result.length);

    }


    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Item Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:200px" />');
            }

            if (title == 'Description') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:300px" />');
            }

        });

        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            table = $('#' + tablename).DataTable({
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
               
            });



            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }

</script>







