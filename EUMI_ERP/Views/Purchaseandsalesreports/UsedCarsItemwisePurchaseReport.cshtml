        function previmg(i) {
            var j = i - 1;
            if ($('#slimg-' + j).length) {
                $('#slimg-' + i).hide();
                $('#slimg-' + j).show();
            }
        }

        function nextimg(i) {
            var j = i + 1;
            if ($('#slimg-' + j).length) {
                $('#slimg-' + i).hide();
                $('#slimg-' + j).show();
            }
        }

        var slideIndex = 1;

        function plusDivs(n) {
            slideIndex = Number(slideIndex) + Number(n)
            showDivs(slideIndex);
        }

        function showDivs(n) {
            var i;
            var x = document.getElementsByClassName("mySlides");
            if (n > x.length) { slideIndex = 1 }
            if (n < 1) { slideIndex = x.length }
            for (i = 0; i < x.length; i++) {
                x[i].style.display = "none";
            }
            x[slideIndex - 1].style.display = "block";
        }


        function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

            var a = '#' + tablename + ' tfoot th'
            $(a).each(function () {
                var title = $(this).text();
                if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ') {
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
                }
                if (title == 'Sup.Inv.#' || title == 'Inv.#' || title == 'Date' || title == 'Qty.' || title == 'Unit Rate' || title == 'FC Amount' || title == 'SubCategory' || title == 'Dept.Code' || title == 'Taxable Amount' || title == 'Tax Amount' || title == 'Amount' || title == 'Other Cost' || title == 'Account#' || title == 'Supplier' || title == 'Terms' || title == 'Area' || title == 'Location' || title == 'Pay Type' || title == 'Purchase Type' || title == 'Fx.' || title == 'Rate' || title == 'Due Date' || title == 'Ship Date' || title == 'Group' || title == 'SubGroup' || title == 'Category' || title == 'SubCategory' || title == 'Dept.Code' || title == 'User') {
                    $(this).html('<input type="text" placeholder="' + title + '"  style="width:100%" />');
                }
                if(title=='Item Code')
                {
                    $(this).html('<input type="text" placeholder="' + title + '"  style="width:200px" />');
                }
                if (title == 'Item Name') {
                    $(this).html('<input type="text" placeholder="' + title + '"  style="width:300px" />');
                }
            });
            var table = null;
            if (download) {
                if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


                table = $('#' + tablename).DataTable({
                    dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
            "<'row'<'col-sm-12'tr>>" +
            "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                    buttons: [],


                });
                new $.fn.dataTable.Buttons(table, {
                    buttons: [
                    {
                        extend: 'collection',
                        text: 'Export',
                        className: 'excelexport',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'print',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            }
                        ]
                    },
                    'colvis'
                    ]
                });
                table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
                $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

            } else {
                table = $('#' + tablename).DataTable();
            }
            table.columns().every(function () {
                var that = this;
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that
                            .search(this.value)
                            .draw();

                    }
                });
            });
            if (ExcelExport == 0) {
                $('.excelexport').hide();
            }
        }



        function disable_datatable(tablename, tableButtonContainerId) {
            $('#Warningpopup').fadeOut();
            if ($.fn.DataTable.isDataTable('#' + tablename)) {
                var table = $('#' + tablename).DataTable();
                table.destroy();
                if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
                return;
            }
        }
