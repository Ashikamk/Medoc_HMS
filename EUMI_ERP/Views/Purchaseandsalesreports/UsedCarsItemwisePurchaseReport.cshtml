<script>
        //Customername Autocomplete

    $("#customer").autocomplete({
            source: function (request, response) {
                var data = {};
                data.CustName = $("#customer").val();
                data.CustType = 'S';

                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWOEnq',
                                label: item.CustAccount,
                                label1: item.CustName,
                                CustId: item.CustId,
                                headers: ["Customer Code", "Customer Name"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#customerId').val(ui.item.CustId)
                $('#customer').val(ui.item.CustName)
            },

        });

        $(function () {

            $('#Area').focus();

           
            GetArea(0);
            GetSalesMan(0);
            GroupPageLoad(0);
            CategoryPageLoad(0);


            $('#Area').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#Location').focus();
                    e.preventDefault();
                }
            });

            $('#Location').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#customer').focus();
                    e.preventDefault();
                }
            });
            $("#customer").keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if ($("#customer").val() == '')
                    $('#customerId').val(0);
                if (key == 13) {
                    $("#PayType").focus();
                    e.preventDefault();
                }
            });
            $("#customer").keyup(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if ($("#customer").val() == '')
                    $('#customerId').val(0);

            });
            //$('#Supplier').keypress(function (e) {
            //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            //    if (key == 13) {
            //        $('#PayType').focus();
            //        e.preventDefault();
            //    }
            //});

            $('#PayType').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#vDept').focus();
                    e.preventDefault();
                }
            });
            $('#vDept').keypress(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#btnsubmit').focus();
                    e.preventDefault();
                }
            });
            $(document).keydown(function (e) {
                if (e.keyCode == 27) { //ESC       :   Popup Close
                    formrefresh1();
                }
            });
            $('#dateFrom').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#dateTo').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });
        });
        //load Department

        function GetDepartment(id) {
            var data = {};
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Master/UserDepartmentGetandGets",
                data: data,
                success: function (result) {
                    DepartmentLoad(result.oList, id);


                }
            });
        }

        function DepartmentLoad(result, a) {
            $("#vDept").empty();
            $("#vDept").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#vDept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }
        }
        function GetLocation(id) {
            var data = {};
            data.LocationId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/LocationGetandGets",
                data: data,
                success: function (result) {
                    $.each(result.oList, function (index, ele) {
                        $("#Location").append($("<option>").attr("value", ele.LocationId).text(ele.LocationName));
                    });


                }
            });

        }
        //Load Area
        function GetArea(id) {
            var data = {};
            data.Id = 0;
            $.ajax({
                type: "POST",
                url: "../Master/AreaGetandGets",
                data: data,
                success: function (result) {
                    $.each(result.oList, function (index, ele) {
                        $("#Area").append($("<option>").attr("value", ele.AreaId).text(ele.AreaCode));
                    });
                }
            });
        }

        //Load Salesman

        function GetSalesMan(id) {
            var data = {};
            data.Id = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SalesmanGetandGets",
                data: data,
                success: function (result) {
                    SalesManLoad(result.oList, id);
                }
            });
        }

        function SalesManLoad(result, a) {
            $("#Salesman").empty();
            $("#Salesman").append("<option value='0'>-All-</option>")
            for (var i = 0; i < result.length; i++) {
                $("#Salesman").append("<option value='" + result[i].Id + "'>" + result[i].FirstName + "</option>");
            }
        }

        //Load Group
        function GroupPageLoad(id) {
            var data1 = {};
            data1.GrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/GroupGetandGets",
                data: data1,
                success: function (result) {
                    GroupLoad(result.oList, id);
                }
            });
        }

        function GroupLoad(result) {
            $("#Group").empty();
            $("#Group").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {

                $("#Group").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
            }
            SubGroupGets();
        }

        //Load SubGroup

        function SubGroupGets() {
            var data = {};
            data.GroupId = $("#Group").val();


            if (data.GroupId == 0) {
                data.SbgrpId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubGroupGetandGets",
                    data: data,
                    success: function (result) {
                        SubGroupLoad(result.oList);
                    }
                });
            }
            else {
                data.SbgrpId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubGroupGetForGroup",
                    data: data,
                    success: function (result) {
                        SubGroupLoad(result.oList);
                    }
                });
            }
        }

        function SubGroupLoad(result) {
            $("#SubGroup").empty();
            $("#SubGroup").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#SubGroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
            }
        }

        //Load Category

        function CategoryPageLoad(id) {
            var data2 = {};
            data2.CategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/CategoryGetandGets",
                data: data2,
                success: function (result) {
                    CategoryLoad(result.oList, id);
                }
            });
        }


        function CategoryLoad(result) {
            $("#Category").empty();
            $("#Category").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#Category").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
            }
            SubCategoryGets();
        }
        //Load SubCategory

        function SubCategoryGets() {

            var data = {};
            data.CategoryId = $("#Category").val();

            if (data.CategoryId == 0) {
                data.SubCategoryId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubCategoryGetandGets",
                    data: data,
                    success: function (result) {
                        SubCategoryLoad(result.oList);

                    }
                });
            }

            else {
                data.SubCategoryId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubCategoryGetforCategory",
                    data: data,
                    success: function (result) {
                        SubCategoryLoad(result.oList);
                    }
                });
            }
        }



        function SubCategoryLoad(result) {
            $("#SubCategory").empty();
            $("#SubCategory").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#SubCategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
            }
        }

        function popuprefresh() {
            $('#popupdiv').hide();
        }

        function Showreport(result) {
            //alert('fgjhikjfg')
            disable_datatable('Tblreport', 'buttonPlace');
            var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Image</th><th >Inv.#</th><th >Sup.Inv.#</th><th >Date</th><th style='text-align:center'>Account#</th><th style='text-align:center' >Supplier</th><th >Item Code</th><th width=100%>Item Name</th><th >Qty.</th><th >Unit Rate</th><th style='text-align:center'>Terms</th><th style='text-align:right' >Area</th><th >Location</th><th>Pay Type</th><th>Purchase Type</th><th>Other Cost</th><th style='text-align:right'>Taxable Amount</th><th style='text-align:right'>Tax Amount</th><th>Amount</th><th>Fx.</th><th style='text-align:right'>Rate</th><th style='text-align:center'>FC Amount</th><th>Due Date</th><th style='text-align:right'>Ship Date</th><th>Buyer Name</th><th>Group</th><th>SubGroup</th><th>Category</th><th>SubCategory</th><th >Dept.Code</th><th>User</th></tr></thead><tbody>";


            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);
                if (result[i].InvoDate == 'Grand Total') {

                    responseText += '<tr style=background-color:#cfd8dc;font-weight:bold;><td style=text-align:center>' + slno + '</td><td></td><td id="Col11_' + slno + '">' + result[i].SlNo + '</td><td id="Col1_' + slno + '">' + result[i].InvoNo + '</td><td id="Col3_' + slno + '" style=text-align:center>' + result[i].InvoDate + '</td><td id="Col4_' + slno + '" style=text-align:center>' + result[i].CustAccount + '</td><td id="Col5_' + slno + '">' + result[i].CustName + '</td><td>' + result[i].ItemCode + '</td><td id="Col6_' + slno + '">' + result[i].ItemDescription + '</td><td id="Col7_' + slno + '">' + result[i].Quantity + '</td><td align=right>' + parseFloat(result[i].Cost).toFixed(Decimal) + '</td><td id="Col8_' + slno + '" style=text-align:left>' + result[i].TermDescription + '</td><td id="Col10_' + slno + '" style=text-align:left>' + result[i].Name + '</td><td>' + result[i].LocationName + '</td><td>' + result[i].Payterms + '</td><td>' + result[i].PurchaseType + '</td><td align=right>' + parseFloat(result[i].OtherCost || 0).toFixed(Decimal) + '</td><td align=right>' + parseFloat(result[i].TaxableAmt || 0).toFixed(Decimal) + '</td><td align=right>' + parseFloat(result[i].TaxAmt || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].LineTotal || 0).toFixed(Decimal) + '</td><td  style=text-align:left>' + result[i].CurrencyName + '</td><td style=text-align:right>' + result[i].CurrencyRate + '</td><td id="Col9_' + slno + '" style=text-align:right>' + parseFloat(result[i].FCLineTotal || 0).toFixed(Decimal) + '</td><td style=text-align:center>' + result[i].DueDate + '</td><td style=text-align:right>' + result[i].ShipDate + '</td><td>' + result[i].BuyerNo + ' </td><td>' + result[i].GrpName + ' </td><td>' + result[i].SbgrpName + ' </td><td>' + result[i].CategoryName + ' </td><td>' + result[i].SubCategoryName + ' </td><td>' + result[i].DepartmentName + ' </td><td>' + result[i].Username + ' </td></tr>';
                }

