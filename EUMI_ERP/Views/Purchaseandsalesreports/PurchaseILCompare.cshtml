<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');

        var RespnsText = "<thead><tr><th>SL#</th><th>ItemCode</th><th>Description</th><th>Local Purchase Qty.</th><th>AvgCost</th><th>LPCost</th><th>Stock</th></tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno = i + 1;

            RespnsText += "<tr onclick='SelectRow("+slno+")'>" +
                "<td><input type='hidden' id='TItemId_" + slno + "' value=" + result[i].ItemId + ">" + slno + "</td>" +
                "<td id='TItemCode_" + slno + "'>" + result[i].ItemCode + "</td>" +
                "<td id='TItemDesc_" + slno + "'>" + result[i].Description + "</td>" +
                "<td><center>" + result[i].Quantity + "</center></td>" +
                "<td align=right>" + parseFloat(result[i].AvgCost).toFixed(Decimal) + "</td>" +
                "<td align=right>" + parseFloat(result[i].LPCost).toFixed(Decimal) + "</td>" +
                "<td><center>" + result[i].Stock + "</center></td>" +
                "</tr>";

        }
        RespnsText += "</tbody><tfoot><tr><th> </th><th>ItemCode</th><th>Description</th><th>Quantity</th><th>AvgCost</th><th>LPCost</th><th>Stock</th></tr></tfoot>";
        $("#Tblreport").html(RespnsText)
        var title = "Purchase Comparison Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";

        console.log(RespnsText)

        datatableWithsearchOne('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#ResultLength').val(result.length);
    }

    function SelectRow(Slno) {
        $("#ProductId").val($("#TItemId_"+Slno).val());
        $("#ItemCode").val($("#TItemCode_" + Slno).text());
        $("#ItemDescription").val($("#TItemDesc_" + Slno).text());
        itempopup( $("#ProductId").val())
    }

    $(function () {


        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            $('#Loading').show();

            var data = {};
            data.FromDate = $('#DateFrom').val();
            data.ToDate = $('#DateTo').val();
            data.SupplierId = 0;
            data.ItemId = 0;
            data.Variable1 = 0;
            data.Variable2 = 0;
            data.UserId = ERPUserId;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/Rpt_PurchaseImportLocalCompare",
                data: data,
                success: function (result) {

                    Showreport(result);

                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                }
            });
        });

    });


    $(document).keydown(function (e) {


        var x = event.keyCode;
        if ((x > 111 && x < 124)) {
            //Purchase Popup
            if (x == 119) {                     // F8 - Pop Up to Show Purchase Transaction Details of Selected Product 
                if ((usermenu1.indexOf("M31") != -1) || (usermenu1.indexOf("M35") != -1) || (usermenu1.indexOf("M159") != -1) || (usermenu1.indexOf("M233") != -1)) {

                    Purchasespopup($('#ProductId').val());
                    hidepopup(1);
                    $('#productpdiv').hide();
                    $('#salestranspopupdiv').hide();
                    $('#TransactionPopup').hide();
                    $('#MonthwisePurchase').hide();
                    $('#PurchaseTransactionPopup').show();
                }
                else {
                    $('#PurchaseTransactionPopup').hide();
                    $('#purchasetrans').hide();

                    warningshow('Invalid User Rights')
                }
            }


                //Sales Popup
            else if (x == 118) {           // F7 - Pop Up to Show Sales Transaction Details of Selected Product 
                if ((usermenu1.indexOf("M54") != -1) || (usermenu1.indexOf("M162") != -1) || (usermenu1.indexOf("M173") != -1) || (usermenu1.indexOf("M192") != -1) || (usermenu1.indexOf("M227") != -1)) {

                    Salespopup($('#ProductId').val());
                    //$('#totalnosalesqty').text('');
                    //$('#totalnosales').text('');
                    hidepopup(1);
                    $('#productpdiv').hide();
                    $('#TransactionPopup').hide();
                    $('#PurchaseTransactionPopup').hide();
                    $('#MonthwisePurchase').hide();
                    $('#salestranspopupdiv').show();
                }
                else {
                    $('#salestranspopupdiv').hide();
                    $('#salestransdiv').hide();
                    warningshow('Invalid User Rights')
                }

            }
                //All Transaction Popup
            else if (x == 120) {                                 // F9 :   All Transaction details Popup  
                TransactionPopup($('#ProductId').val());
                hidepopup(1);
                $('#productpdiv').hide();
                $('#PurchaseTransactionPopup').hide();
                $('#salestranspopupdiv').hide();
                $('#MonthwisePurchase').hide();
                $('#TransactionPopup').show();

                $('#alltranscheckboxdivsales').show();
                $('#idforlabeltype').text('Previous');
                $('#status_type').prop("checked", false);
            }
                //Monthwise Details Popup
            else if (x == 121) {                // F10 :   Monthwise details Popup                                                           
                if (((usermenu1.indexOf("M31") != -1) || (usermenu1.indexOf("M233") != -1) || (usermenu1.indexOf("M35") != -1) || (usermenu1.indexOf("M159") != -1))
                    &&
                        ((usermenu1.indexOf("M54") != -1) || (usermenu1.indexOf("M227") != -1) || (usermenu1.indexOf("M162") != -1) || (usermenu1.indexOf("M173") != -1) || (usermenu1.indexOf("M192") != -1))) {
                    $('#PurchaseDetails').show();
                    $('#SalesDetails').show();

                    MonthwisePurchasePopup($('#ProductId').val());
                    hidepopup(1);
                    $('#productpdiv').hide();
                    $('#PurchaseTransactionPopup').hide();
                    $('#salestranspopupdiv').hide();
                    $('#TransactionPopup').hide();
                    $('#MonthwisePurchase').show();
                }

                else if (((usermenu1.indexOf("M31") != -1) || (usermenu1.indexOf("M233") != -1) || (usermenu1.indexOf("M35") != -1) || (usermenu1.indexOf("M159") != -1))
                    &&
                    ((usermenu1.indexOf("M54") == -1) || (usermenu1.indexOf("M227") == -1) || (usermenu1.indexOf("M162") == -1) || (usermenu1.indexOf("M173") == -1) || (usermenu1.indexOf("M192") == -1))) {

                    $('#SalesDetails').hide();
                    $('#PurchaseDetails').show();

                    MonthwisePurchasePopup($('#ProductId').val());
                    hidepopup(1);
                    $('#productpdiv').hide();
                    $('#PurchaseTransactionPopup').hide();
                    $('#salestranspopupdiv').hide();
                    $('#TransactionPopup').hide();
                    $('#MonthwisePurchase').show();
                }
                else if (((usermenu1.indexOf("M31") == -1) || (usermenu1.indexOf("M233") == -1) || (usermenu1.indexOf("M35") == -1) || (usermenu1.indexOf("M159") == -1))
                    &&
                        ((usermenu1.indexOf("M54") != -1) || (usermenu1.indexOf("M227") != -1) || (usermenu1.indexOf("M162") != -1) || (usermenu1.indexOf("M173") != -1) || (usermenu1.indexOf("M192") != -1))) {
                    $('#PurchaseDetails').hide();
                    $('#SalesDetails').show();

                    MonthwisePurchasePopup($('#ProductId').val());
                    hidepopup(1);
                    $('#productpdiv').hide();
                    $('#PurchaseTransactionPopup').hide();
                    $('#salestranspopupdiv').hide();
                    $('#TransactionPopup').hide();
                    $('#MonthwisePurchase').show();
                }

                else {
                    $('#MonthwisePurchase').hide();
                    $('#MonthwisePurchasediv').hide();
                    warningshow('Invalid User Rights')
                }
            }
            event.cancelBubble = true;
            event.returnValue = false;
            event.keyCode = false;
            return false;

        }
        else if (e.keyCode == 27) { //ESC       :   Popup Close
            hidepopup(1);
            productpopuprefresh();
            transpopuprefresh();
            salestranspopuprefresh();
            ClosePurTransPopup();
            MonthwisePurchasepopuprefresh();
        }
    });




    function datatableWithsearchOne(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
            }
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
            "columnDefs": [

                            { "width": "1%", "targets": 0 },
                            { "width": "15%", "targets": 1 },
                            { "width": "20%", "targets": 2 },
                            { "width": "5%", "targets": 3 },
                            { "width": "5%", "targets": 4 },
                            { "width": "5%", "targets": 5 },
                            { "width": "5%", "targets": 6 },


            ]

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
