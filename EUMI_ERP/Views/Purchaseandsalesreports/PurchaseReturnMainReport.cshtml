
@{
    ViewBag.Title = "PurchaseReturnMainReport";
}


<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>

<div class="myData" data-x="M246" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">


                    <div>
                        <table width="100%" style="table-layout:fixed;">
                            <tr>
                                <td><h4 id="header"></h4></td>

                                <td align="right">
                                    <button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#placeofsupply').focus()" id="btnback" class="btn btn-outline-primary">Back</button>
                                    <div class="btn-group" id="buttonPlace">

                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <hr />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" width="120%" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="background:rgba(0,0,0,0.5);display: block;">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Purchase Return Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup">
                <div class="modal-body">
                    <div class="row">
                        <label class="col-md-2" style="font-weight:bold;">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label class="col-md-2 text-right" style="font-weight:bold;">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>

                    <hr class="mt-1 mb-1" />

                    <div class="row mb-1">
                        <label class="col-md-2" style="font-weight:bold;">Supplier </label>
                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="31%">
                                        <input type="text" id="suppliercode" class="form-control" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="supplierId" class="form-control" />

                                    </td>
                                    <td>
                                        <input type="text" id="suppliername" class="form-control" name="acnt1" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>



                    </div>

                    <div class="row mb-1">

                        <label class="col-md-2" style="font-weight:bold;">Pay Type</label>
                        <div class="col-md-4">
                            <select id="PayType" class="form-control">
                                <option value="0">-All-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Pur.Type</label>
                        <div class="col-md-4">
                            <select id="purchasetype" class="form-control">
                                <option value="0">-All-</option>
                                <option value="Local">Local</option>
                                <option value="Import">Import</option>

                            </select>
                        </div>
                    </div>
                    <div class="row mb-1">
                        <label class="col-md-2" style="font-weight:bold;">Dept.</label>
                        <div class="col-md-4">
                            <select id="department" class="form-control"></select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Location</label>
                        <div class="col-md-4">
                            <select id="Location" class="form-control"></select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:35%" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />
                </div>


            </form>
        </div>
    </div>
</div>

<script>
    //Suppliername Autocomplete

    $("#suppliercode").autocomplete({
        source: function (request, response) {

            $('#supplierId').val(0);
            $('#suppliername').val('');

            var data = {};
            data.CustName = $("#suppliercode").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.CustAccount,
                            label1: item.CustName,
                            CustId: item.CustId,
                            CustName:item.CustName,
                            headers: ["Supplier Code", "Supplier Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId)
            $('#suppliername').val(ui.item.CustName)
            $('#purchasetype').focus();
        },

    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }



    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr>" +
            "<th>Sl#</th>" +
            
            "<th>Return#</th>" +
            "<th>Date</th>" +
            "<th>Account</th>" +
            "<th>Supplier</th>" +          
            "<th>PayType</th>" +
            "<th>Pur.Type</th>" +
            "<th>Taxable</th>" +
            "<th>Tax</th>" +
            "<th>Cess</th>" +
            "<th>Disc.</th>" +
            "<th>Amount</th>" +
            "<th>Location</th>" +
            "<th>Dept.</th>" +
            "</tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            var Style = "";
            if (parseInt(result[i].HFlag || 0) == 1) { Style = "background-color:#cfd8dc;font-weight:bold;"; }

            
            responseText += '<tr style="' + Style + '">' +
                '<td align="center">' + slno + '</td>' +
                
                '<td>' + result[i].PurchaseSlNo + '</td>' +
                '<td align="center">' + result[i].InvoDate + '</td>' +
                '<td align="center">' + result[i].CustAccount + '</td>' +
                '<td>' + result[i].Supplier + '</td>' +
                '<td>' + result[i].PayType + '</td>' +
                '<td>' + result[i].PurchaseType + '</td>' +
                '<td align="right">' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td>' +
                '<td align="right">' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td>' +
                '<td align="right">' + parseFloat(result[i].CessAmount || 0).toFixed(Decimal) + '</td>' +
                '<td align="right">' + parseFloat(result[i].BillDiscount || 0).toFixed(Decimal) + '</td>' +
                '<td align="right">' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td>' +
                '<td>' + result[i].Location + '</td>' +
                '<td>' + result[i].Dept + '</td>' +
                '</tr>';

        }

        $('#Tblreportprint').html(responseText+'</tbody>');

        responseText = responseText + "</tbody><tfoot><tr>" +
            "<th></th>" +
            
            "<th>Return#</th>" +
            "<th></th>" +
            "<th>Account</th>" +
            "<th>Supplier</th>" +
            "<th>PayType</th>" +
            "<th>Pur.Type</th>" +
            "<th></th>" +
            "<th></th>" +
            "<th></th>" +
            "<th></th>" +
            "<th></th>" +
            "<th>Location</th>" +
            "<th>Dept.</th>" +
            "</tr></tfoot>";

        $('#Tblreport').html(responseText);
        
        var title = "Purchase Return Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearchs('Tblreport', true, title, 'buttonPlace');

        $('#header').text(title);
        $('#ResultLength').val(result.length);
    }




    function GetLocation() {
        var data = {};
        data.LocationId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/LocationGetandGets",
            data: data,
            success: function (result) {
                LocationLoad(result.oList);


            }
        });

    }

    function LocationLoad(result) {
        $("#Location").empty();
        LocationSelect = "<option value='0'>-All-</option>";
        for (var i = 0; i < result.length; i++) {
            LocationSelect += "<option value='" + result[i].LocationId + "'locname='" + result[i].LocationName + "'>" + result[i].LocationName + "</option>";

        }
        $("#Location").append(LocationSelect);
    }



    function GetArea(id) {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AreaGetandGets",
            data: data,
            success: function (result) {
                AreaLoad(result.oList, id);


            }
        });
    }

    function AreaLoad(result, a) {
        $("#placeofsupply").empty();
        $("#placeofsupply").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#placeofsupply").append("<option value='" + result[i].AreaId + "'>" + result[i].AreaCode + "</option>");
        }
        if (a == 0) {
            $('#placeofsupply').val(0);
        }
        else {
            $('#placeofsupply').val(a);
        }
    }




    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#department").empty();
        $("#department").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }

    $(function () {
        $('#placeofsupply').focus();
        GetLocation();
        GetArea(0);
        GetDepartment(0);

        //$("#suppliername").keydown(function (e) {
        //    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        //    $('#supplierId').val(0);
        //    if (key == 13) {
        //        e.preventDefault();
        //        $('#purchasetype').focus();
        //    }

        //});

        $('#placeofsupply').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#location').focus();
                e.preventDefault();
            }
        });

        $('#location').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#suppliername').focus();
                e.preventDefault();
            }
        });
        $('#purchasetype').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#PayType').focus();
                e.preventDefault();
            }
        });
        $('#PayType').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#department').focus();
                e.preventDefault();
            }
        });
        $('#department').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {
            $('#Loading').show();


            var Condition = '', Supplier = '', Payterms = '', PayType = '', Department = ''
            var data = {};
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();

            var Payterms = $('#purchasetype').val();
            var PayType = $('#PayType').val();
            var Department = parseInt($('#department').val() || 0);
            var Location = parseInt($("#Location").val() || 0);


            if ($('#suppliername').val() == '') {
                $('#supplierId').val(0);
            }

            var Supplier = parseInt($('#supplierId').val() || 0);

            Condition = 'CONVERT(datetime,PRDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,PRDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'


            if (Supplier != 0) { Condition += ' and P.SupplierId=' + Supplier; }

            if (Payterms != 0) { Condition += ' and P.PurchaseType=' + "'" + Payterms + "'"; }

            if (PayType != 0) { Condition += ' and P.PayType=' + PayType; }

            if (Department != 0) { Condition += ' and P.DepartmentId=' + Department; }
            if (Location != 0) { Condition += ' and P.LocnId=' + Location; }



            var data = {};
            data.Condition = Condition;
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/PurchaseReturnMainReport",
                data: data,
                success: function (result) {

                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);
                }
            });



        });

    });




    function datatableWithsearchs(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ' && title != '') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width:100%" />');
            }
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
                "columnDefs": [
                     { "width": "2%", "targets": 0 },
                     
                     { "width": "4%", "targets": 1 },
                     { "width": "4%", "targets": 2 },
                     { "width": "4%", "targets": 3 },
                     { "width": "20%", "targets": 4 },
                     { "width": "4%", "targets": 5 },
                     { "width": "4%", "targets": 6 },
                     { "width": "10%", "targets": 12 },
                     { "width": "10%", "targets": 13 },

                ],
                "autowidth":false,

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }



</script>






