                            headers: ["Patient", "RegNo", "IP No"]
                        })
                    }));
                }
            })
        },
                autoFocus: true,
        select: function (event, ui) {
            $('#CustomerID').val(ui.item.PatientId)
            $('#cmbCustomerName').val(ui.item.PatientName)
            $('#UserId').val(ui.item.OPNumber); 
            $('#cmbPayType').focus();
        },

    });

