
@{
    ViewBag.Title = "LocationTransferMain";
}


<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>



<table style="display:none" id="Tblreportprint"></table>

<div class="myData" data-x="M191" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">


                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>

                                <td width="30%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#fromlocation').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('LocationTransferMAIN', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>
                               
                                 <td align="right">
                                    <div class="btn-group" id="buttonPlace">

                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <div align="right">

                            <div class="heading-elements">
                                <hr style="margin-top:.1%;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                               
                               
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:110%" >
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content" style="width:66%">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Location Transfer Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
        
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:12%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:6%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">
                        <label style="font-weight:bold;margin-left:5%">From Loc.</label>
                        <div class="col-md-4">
                            <select id="fromlocation" name="priority" class="form-control"></select>
                        </div>
                        <label style="font-weight:bold;margin-left:-1%">To Loc.</label>
                        <div class="col-md-4">
                            <select id="tolocation" name="priority" class="form-control"></select>
                        </div>
                    </div>
                </div>
               
                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:40%" id="btnsubmit" class="btn btn-primary">Go</button>
                    <input type="hidden" id="ResultLength" class="form-control" />
                </div>

            </form>
        </div>
    </div>
</div>

<script>

   


        function popuprefresh() {
            $('#popupdiv').hide();
        }


        function Showreport(result) {

            disable_datatable('Tblreport', 'buttonPlace');
            var responseText = "<thead><tr><th>Sl#</th><th style='text-align:centre'>Date</th><th>Transfer#</th><th>Item Code</th><th style='width:200%'>Item Name</th><th>FromLoc.</th><th>ToLoc.</th><th>Qty.</th><th>Rate</th><th>Amount</th></tr></thead><tbody>";

            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);
                var DD = (result[i].Department).split("##")

                if (result[i].ItemName == 'Total')
                {
                    responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td   id="Col1_' + slno + '" >' + result[i].InvDate + '</td><td   id="Col8_' + slno + '" >' + result[i].LocTransferId + '</td><td   id="Col2_' + slno + '" >' + result[i].ItemCode + '</td><td   id="Col3_' + slno + '" ><b>' + result[i].ItemName + '</b></td><td   id="Col4_' + slno + '" >' + result[i].FromLocation + '</td><td   id="Col5_' + slno + '" >' + result[i].ToLocation + '</td><td   id="Col6_' + slno + '"><b>' + result[i].Quantity + '</b></td><td align=right>' + DD[0] + '</td><td align=right>' + DD[1] + '</td></tr>';
                }
                 else
                {
                    responseText += '<tr><td>' + slno + '</td><td   id="Col1_' + slno + '" style="text-align:centre">' + result[i].InvDate + '</td><td   id="Col8_' + slno + '" >' + result[i].LocTransferId + '</td><td   id="Col2_' + slno + '" >' + result[i].ItemCode + '</td><td   id="Col3_' + slno + '" >' + result[i].ItemName + '</td><td   id="Col4_' + slno + '" >' + result[i].FromLocation + '</td><td   id="Col5_' + slno + '" >' + result[i].ToLocation + '</td><td   id="Col6_' + slno + '">' + result[i].Quantity + '</td><td align=right>' + DD[0] + '</td><td align=right>' + DD[1]+'</td></tr>';
                }
            }
            $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Date</th><th>Transfer#</th><th>Item Code</th><th>Item Name</th><th>FromLoc.</th><th>ToLoc.</th><th>Qty.</th><th></th><th></th></tr></tfoot>');
            $('#Tblreportprint').html(responseText)
            var title = "Location Transfer Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
            datatableWithsearch('Tblreport', true, title, 'buttonPlace');
            $('#header').text(title);
            $('#ResultLength').val(result.length);
        }




        function GetLocation(id) {
            var data = {};
            data.LocationId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/LocationGetandGets",
                data: data,
                success: function (result) {
                    LocationLoad(result.oList, id);


                }
            });

        }

        function LocationLoad(result, a) {
            $("#fromlocation,#tolocation").empty();
            LocationSelect = "<option value='0'>-All-</option>";
            for (var i = 0; i < result.length; i++) {
                LocationSelect += "<option value='" + result[i].LocationId + "'locname='" + result[i].LocationName + "'>" + result[i].LocationName + "</option>";

            }
            $("#fromlocation,#tolocation").append(LocationSelect);
        }



        $(function () {
            $('#fromlocation').focus();
            GetLocation(0);


            $('#fromlocation').keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#tolocation').focus();
                    e.preventDefault();
                }
            });

           
            $('#tolocation').keydown(function (e) {
                var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                if (key == 13) {
                    $('#btnsubmit').focus();
                    e.preventDefault();
                }
            });


            $('#DateFrom').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });

            $('#DateTo').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }
            });



            $("#btnsubmit").click(function (e) {



                var Condition = '', FromLocation = '', ToLocation = ''
                var FromDate = $('#DateFrom').val();
                var ToDate = $('#DateTo').val();

                var FromLocation = $('#fromlocation').val();
                var ToLocation = $('#tolocation').val();


            
                Condition = 'CONVERT(datetime,TRDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,TRDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

                if (FromLocation != 0) { Condition += ' and FromLocation = ' + FromLocation; }

                if (ToLocation != 0) { Condition += ' and ToLocation = ' + ToLocation; }

                    var data = {};

                    data.Condition = Condition;
                    data.UserId = ERPUserId;
                    $.ajax({
                        type: "POST",
                        url: "../Purchaseandsalesreports/LocationTransferMain",
                        data: data,
                        success: function (result) {

                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            Showreport(result);
                        }
                    });



            });

        });



        function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

            var a = '#' + tablename + ' tfoot th'
            $(a).each(function () {
                var title = $(this).text();
                if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
                if (title == 'Date')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
                if (title == 'Transfer#')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
                
                if (title == 'Qty.')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
               
                if (title == 'Dept.Code')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');

                if (title == 'FromLoc.')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');

                if (title == 'ToLoc.')
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
            });
            var table = null;
            if (download) {
                if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

                // AddColumnSelectionButton(tableButtonContainerId, tablename)

                table = $('#' + tablename).DataTable({
                    // dom: 'Bfrtip',
                    dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                            "<'row'<'col-sm-12'tr>>" +
                            "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                    buttons: []

                });
                new $.fn.dataTable.Buttons(table, {
                    buttons: [
                    {
                        extend: 'collection',
                        text: 'Export',
                        className: 'excelexport',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'print',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            }
                        ]
                    },
                    'colvis'
                    ]
                });
                table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
                $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");
               
            } else {
                table = $('#' + tablename).DataTable();
            }
            table.columns().every(function () {
                var that = this;
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that
                            .search(this.value)
                            .draw();

                    }
                });
            });
            if (ExcelExport == 0) {
                $('.excelexport').hide();
            }
        }
        function disable_datatable(tablename, tableButtonContainerId) {
            $('#Warningpopup').fadeOut();
            if ($.fn.DataTable.isDataTable('#' + tablename)) {
                var table = $('#' + tablename).DataTable();
                table.destroy();
                if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
                return;
            }
        }
</script>








