        function GetExpiryItems() {

            var Condition = 'CONVERT(datetime,VDate,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,VDate,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103)'
            var Condition1 = 'CONVERT(datetime,Expiry,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,Expiry,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103)'
            var Condition2 = 'CONVERT(datetime,ToPeriod,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,ToPeriod,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103)'

            var data = {};
            data.Condition = Condition;
            data.Condition1 = Condition1;
            data.Condition2 = Condition2;
            $.ajax({
                type: "POST",
                url: "../Master/PDCandToDoReminder",
                data: data,
                success: function (result) {
                    if (usermenu1.indexOf("M267") != -1) {
                        ShowTopExpiryItemsreport(result);
                    }
                }
            });
        }
        function ShowTopExpiryItemsreport(result) {
            $('.eumi-reminder-lists').html("");
            if (result.length != 0) {

                var newrow = "";
                for (var i = 0; i < result.length; i++) {
                    if (result[i].PendingQty != 0) {
                        $('#PendingPopup').show();
                        if (result[i].PendingName == "PDC") {
                            newrow +=
                   ' <a class="dropdown-item dihover" onclick=GetExpiryDetailedItems(0,1) >' +
                   '<i class="fa fa-bell-o float-left  mt-1 mr-2"></i>' +
                   '<span class="d-block">' +
                   ' <strong id="pending_' + i + '" >' + result[i].PendingQty + ' ' + result[i].PendingName + '</strong> Pending' +
                   '</span>' +
                   '<span class="d-block" style="clear:both"></span>' +
                   '</a>';
                        }
                        else if (result[i].PendingName == "Contract") {
                            newrow +=
                   ' <a class="dropdown-item dihover" onclick=GetExpiryDetailedItems("' + (result[i].PendingName).substring(0, 1) + '",3) >' +
                   '<i class="fa fa-bell-o float-left  mt-1 mr-2"></i>' +
                   '<span class="d-block">' +
                   ' <strong id="pending_' + i + '" >' + result[i].PendingQty + ' ' + result[i].PendingName + '</strong> Near Expiry' +
                   '</span>' +
                   '<span class="d-block" style="clear:both"></span>' +
                   '</a>';
                        }
                        else {
                            newrow +=
                  ' <a class="dropdown-item dihover" onclick=GetExpiryDetailedItems("' + (result[i].PendingName).substring(0, 1) + '",2) >' +
                  '<i class="fa fa-bell-o float-left  mt-1 mr-2"></i>' +
                  '<span class="d-block">' +
                  ' <strong id="pending_' + i + '" >' + result[i].PendingQty + ' ' + result[i].PendingName + '</strong> Near Expiry' +
                  '</span>' +
                  '<span class="d-block" style="clear:both"></span>' +
                  '</a>';
                        }
                    }
                }
                //console.log(newrow)
                $('.eumi-reminder-lists').append(newrow);
            }

        }

        function GetExpiryDetailedItems(PendingName, type) {
            console.log('PendingName')
            console.log(PendingName)
            var Condition = 'CONVERT(datetime,VDate,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,VDate,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103)'
            var Condition1 = 'CONVERT(datetime,Expiry,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,Expiry,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103)'
            var Condition2 = 'CONVERT(datetime,ToPeriod,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,ToPeriod,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103)'

            var data = {};
            data.Condition = Condition;
            data.Condition1 = Condition1;
            data.Condition2 = Condition2;
            data.Type = type;
            $.ajax({
                type: "POST",
                url: "../Master/PDCTODOReminderDetailed",
                data: data,
                success: function (result) {
                    for (var i = 0; i < result.length; i++) {
                        var amount = result[i].Amount;
                        if (type == 1) {
                            $('#reminderheader').text('Pending PDC');
                            ReminderPDCShow(result);
                        }
                        else if (type == 2) {
                            $('#reminderheader').text('Expiry Documents');
                            ReminderToDoShow(result, PendingName);
                        }
                        else if (type == 3) {
                            $('#reminderheader').text('Contract');
                            ReminderContractShow(result);
                        }
                    }
                }
            });
        }

