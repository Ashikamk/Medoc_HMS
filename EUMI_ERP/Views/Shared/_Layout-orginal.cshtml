        function ChangeDepartment() {
            var datadep = {};
            datadep.UserId = ERPUserId;
            datadep.DepartmentId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Home/UserDepartmentGets",
                data: datadep,
                success: function (result) {
                    ShowotherDepartments(result.oList);
                }
            });
        }
        function ShowotherDepartments(result) {
            console.log(result)
            $("#newdeptfprlogin").empty();
            for (var i = 0; i < result.length; i++) {
                $("#newdeptfprlogin").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }
            if (result.length > 0) {
                $('#ChangeDepDiv').show();
                $("#newdeptfprlogin").prop("disabled", false);
                $("#newdeptfprlogin").focus();
            }


        }
        function ChangetoNewDeparment() {
            var datadepnew = {};
            datadepnew.UserId = ERPUserId;
            datadepnew.DeptId = $("#newdeptfprlogin").val();
            $.ajax({
                type: "POST",
                url: "../Home/UserLoginOtherDepartment",
                data: datadepnew,
                success: function (result) {
                    if (result.oList.length > 0) {
                        NewLoginDepartment(result.oList);
                    }
                }
            });
