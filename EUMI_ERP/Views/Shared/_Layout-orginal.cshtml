    //*************************************************************AUTOMATICALLY LOGOUT AFTER IDLE 30 MINUTE************************************

    function idleTimer() {

        //window.onload = resetTimer;
        window.onmousemove = resetTimer; // catches mouse movements
        window.onmousedown = resetTimer; // catches mouse movements
        window.onclick = resetTimer;     // catches mouse clicks
        window.onscroll = resetTimer;    // catches scrolling
        window.onkeypress = resetTimer;  //catches keyboard actions

        function resetTimer() {

            localStorage.setItem("LogoutTimerStart", new Date());   //Change Idle Time on Change

            $('#timeoutoverlay').hide(); // Hide popup on Movement

        }
    } idleTimer();

    function timout() {

        localStorage.setItem("LogoutTimerStart", new Date());

        setInterval(function () {

            var LogoutTimerStartV = new Date(localStorage.getItem("LogoutTimerStart"));  // Idle Start Time

            var TimeInterval = new Date(LogoutTimerStartV);
            var TimeForAlert = new Date(LogoutTimerStartV);
            var CurrentTime = new Date();

            TimeInterval.setSeconds(TimeInterval.getSeconds() + 7200); // timestamp 2 hr

            TimeForAlert.setSeconds(TimeForAlert.getSeconds() + 7140); // timestamp before 2 hr

            if (CurrentTime.getTime() >= TimeInterval.getTime()) {
                UserLogout();  //Adapt to actual logout script
            }
            else if (CurrentTime.getTime() >= TimeForAlert.getTime()) {

                $('#timeoutoverlay').show();    // Alert Popup
            }
            else {
                $('#timeoutoverlay').hide();    // Hide popup on Movement
            }


        }, 1000);
    } timout();

    //******************************************************************************************************************************************
    $(document).ready(function () {
        $("body").tooltip({ selector: '[data-toggle=tooltip]' });
        SetLayout();
    });

    function SetLayout() {
        var LayoutType = localStorage.getItem('LayoutSel');
        if (LayoutType == null) {
           // localStorage.setItem('LayoutSel', 'Fixed');
            localStorage.setItem('LayoutSel', 'Collapsed');
        }
        //else if (LayoutType == 'Collapsed') {
        //    $('#menustyle').addClass('nav-collapsed');
        //    $('#iconnavi').attr('data-toggle', 'collapsed');
        //    $('#iconnavi').removeClass('ft-toggle-right');
        //    $('#iconnavi').addClass('ft-toggle-left');
        //}
        else if (LayoutType == 'Fixed') {
            $('#menustyle').removeClass('nav-collapsed');
            $('#iconnavi').attr('data-toggle', 'expanded');
            $('#iconnavi').removeClass('ft-toggle-left');
            $('#iconnavi').addClass('ft-toggle-right');
        }
    }

    function LayoutChange() {
        if ($('#menustyle').hasClass('nav-collapsed'))
        { localStorage.setItem('LayoutSel', 'Fixed'); }
        else
        { localStorage.setItem('LayoutSel', 'Collapsed'); }
    }

</script>

