        function CmnAccTransGet() {
            var dataacc = {};
            dataacc.VouNo = $("#CmnVoucherNo").val();
            dataacc.Prefix = $("#CmnPref0").val();
            dataacc.Prefix1 = $("#CmnPref1").val();
            dataacc.Prefix2 = $("#CmnPref2").val();
            dataacc.Prefix3 = $("#CmnPref3").val();
            dataacc.DeptId = $("#CmnDeptId").val();
            dataacc.UserId = $("#CmnUserId").val();
            dataacc.Condition = $("#CmnCondition").val();
            console.log(dataacc)

            $.ajax({
                type: "POST",
                url: "../Common/CommonGetAccountTrans",
                data: dataacc,
                success: function (result) {

                    CmnAccTransGetList(result.oList)
                }
            });
        }

        function CmnAccTransClose() {
            $('#ComnAccTranPopup').modal("hide");
        }

        function CmnAccTransGetList(result) {
            console.log(result)
            if (result.length > 0) {
                if (!($('#ComnAccTranPopup').is(':visible'))) {
                    $('#ComnAccTranPopup').modal("show");
                    $("#ComnAccTranPopup").appendTo("body");

                }

                disable_datatableForCmnAcc('tblCmnAccTrans');

                var ProdRow = "<thead><tr><th>Sl#</th><th>Account Name</th><th>Account</th><th>Description</th><th>Currency</th><th>Type</th><th>Amount</th></tr>" +   
                         "<tr><th> </th><th>Account</th><th>Acc Code</th><th>Description</th><th>Currency</th><th>Type</th><th>Amount</th></tr></thead><tbody>";      

                var Type = ''; var Style = '';
                for (var x = 0; x < result.length; x++) {
                    Type = ''; Style = '';
                    if (result[x].VType == 'C') { Type = 'Credit'; }
                    else if (result[x].VType == 'D') { Type = 'Debit'; }

                    if (result[x].VDescription == 'Total Credit' || result[x].VDescription == 'Total Debit') { Style = 'font-weight:bold;' }

                    ProdRow = ProdRow + "<tr style='" + Style + "'>" +
                        "<td align='center'>" + (x + 1) + "</td>" +
                        "<td>" + result[x].AccountName + "</td>" +
                        "<td>" + result[x].AccCode + "</td>" +
                        "<td>" + result[x].VDescription + "</td>" +
                        "<td>" + result[x].CurrencyName + "</td>" +
                        "<td align='center'>" + Type + "</td>" +
                        "<td align='right'>" + parseFloat(result[x].BaseAmount).toFixed(Decimal) + "</td>" +
                       
                        "</tr>";

                }

                $('#tblCmnAccTrans').html(ProdRow + "</tbody>");


                datatableWithsearchForCmnAcc('tblCmnAccTrans', 'Single');
            }
        }

        function datatableWithsearchForCmnAcc(tablename, Type) {

            var a = '#' + tablename + ' tr:eq(1) th'

            $(a).each(function () {
                var title = $(this).text();
                if (title != ' ')
                    $(this).html('<input type="text" class=""  style="width:100%"  placeholder="' + title + '"/>')
            });

            var table = null;

            if (Type == 'Single') {

                table = $('#' + tablename).DataTable({
                    dom: 'tipr',
                    orderCellsTop: true,
                    "autoWidth": false,
                    "columnDefs": [
                    { "width": "3%", "targets": 0 },
                    { "width": "20%", "targets": 1 },
                    { "width": "5%", "targets": 2 },
                    { "width": "25%", "targets": 3 },
                    { "width": "6%", "targets": 4 },
                    { "width": "4%", "targets": 5 },
                    { "width": "6%", "targets": 6 },
                    ],
                });

            }
            table.columns().every(function (index) {
                $('#' + tablename + ' thead tr:eq(1) th:eq(' + index + ') input').on('keyup change', function () {
                    table.column($(this).parent().index() + ':visible')
                        .search(this.value)
                        .draw();
                });
            });
        }


        function disable_datatableForCmnAcc(tablename) {
            $('#Warningpopup').fadeOut();
            if ($.fn.DataTable.isDataTable('#' + tablename)) {
                var table = $('#' + tablename).DataTable();
                table.destroy();
                return;
            }
        }

        //----------------------------------------------------END COMON ACCOUNT DETAILS LOAD
    </script>




