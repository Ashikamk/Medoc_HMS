<script type="text/javascript">
    var i; var a = "0.00"; var total = 0; var CopyFlag = 0; var InvoDate = ""; var JobId = 0; var x = 0;
    function Upload() {
        //Reference the FileUpload element.
        var fileUpload = document.getElementById("fileUpload");

        //Validate whether File is valid Excel file.
        var regex = /^([a-zA-Z0-9\s_\\.\-:])+(.xls|.xlsx)$/;
        if (regex.test(fileUpload.value.toLowerCase())) {
            if (typeof (FileReader) != "undefined") {
                var reader = new FileReader();

                //For Browsers other than IE.
                if (reader.readAsBinaryString) {
                    reader.onload = function (e) {
                        ProcessExcel(e.target.result);
                    };
                    reader.readAsBinaryString(fileUpload.files[0]);
                } else {
                    //For IE Browser.
                    reader.onload = function (e) {
                        var data = "";
                        var bytes = new Uint8Array(e.target.result);
                        for (var i = 0; i < bytes.byteLength; i++) {
                            data += String.fromCharCode(bytes[i]);
                        }
                        ProcessExcel(data);
                    };
                    reader.readAsArrayBuffer(fileUpload.files[0]);
                }
            } else {
                alert("This browser does not support HTML5.");
            }
        } else {
            alert("Please upload a valid Excel file.");
        }
    };
    function ProcessExcel(data) {


        

        

        //Read the Excel File data.
        var workbook = XLSX.read(data, {
            type: 'binary'
        });

        //Fetch the name of First Sheet.
        var firstSheet = workbook.SheetNames[0];

        //Read all rows from First Sheet into an JSON array.
        var excelRows = XLSX.utils.sheet_to_row_object_array(workbook.Sheets[firstSheet]);




        $('#popupdiv').show();
        $("#tblpurchaseinvoice tr").remove();
        //Add the data rows from Excel file.
        for (var i = 0; i < excelRows.length; i++) {

            if (excelRows[i]["Date ofloading"] == undefined || excelRows[i]["Date ofloading"] == '')
                var DOLformatted = '';
                else
                var DOLformatted = GetFormattedDate(excelRows[i]["Date ofloading"])

            if (excelRows[i]["expectedarival date"] == undefined || excelRows[i]["expectedarival date"] == '')
                var EADformatted = '';
            else
                var EADformatted = GetFormattedDate(excelRows[i]["expectedarival date"])

            if (excelRows[i]["Date of release"] == undefined || excelRows[i]["Date of release"] == '')
                var DORformatted = '';
            else
                var DORformatted = GetFormattedDate(excelRows[i]["Date of release"])

            if (excelRows[i]["Containerarrivaldate"] == undefined || excelRows[i]["Containerarrivaldate"] == '')
                var CADformatted = '';
            else
                var CADformatted = GetFormattedDate(excelRows[i]["Containerarrivaldate"])

            //alert('final   ::: ' + DOLformatted)


            if (excelRows[i]["Container Nr."] == undefined) { var ContainerNo = '' } else { var ContainerNo = excelRows[i]["Container Nr."] }
            if (excelRows[i]["Booking number"] == undefined) { var BookingNo = '' } else { var BookingNo = excelRows[i]["Booking number"] }
            if (excelRows[i]["Lines"] == undefined) { var Lines = '' } else { var Lines = excelRows[i]["Lines"] }
            if (excelRows[i]["Size"] == undefined) { var Size = '' } else { var Size = excelRows[i]["Size"] }
            if (excelRows[i]["Point of loading"] == undefined) { var POL = '' } else { var POL = excelRows[i]["Point of loading"] }
            if (excelRows[i]["Port"] == undefined) { var Port = '' } else { var Port = excelRows[i]["Port"] }
            //if (excelRows[i]["Date ofloading"] == undefined) { var DateOfLoading = '' } else { var DateOfLoading = excelRows[i]["Date ofloading"] }
            //if (excelRows[i]["expectedarival date"] == undefined) { var ExArrivalDate = '' } else { var ExArrivalDate = excelRows[i]["expectedarival date"] }
            //if (excelRows[i]["Date of release"] == undefined) { var DateofRelease = '' } else { var DateofRelease = excelRows[i]["Date of release"] }
            //if (excelRows[i]["Containerarrivaldate"] == undefined) { var ConArrivalDate = '' } else { var ConArrivalDate = excelRows[i]["Containerarrivaldate"] }


            if (excelRows[i]["Invoice"] == undefined) { var Invoice = '' } else { var Invoice = excelRows[i]["Invoice"] }
            if (excelRows[i]["Invoice amount"] == undefined) { var InvoiceAmt = '' } else { var InvoiceAmt = excelRows[i]["Invoice amount"] }
            if (excelRows[i]["Paid amount"] == undefined) { var PaidAmount = '' } else { var PaidAmount = excelRows[i]["Paid amount"] }
            var slno = parseInt(i + 1)

            //Add the data row.id=' + "locID" + i + '

            var row = '<tr class="jsgrid-row" id="row_' + slno + '">' +
                    '<td align=center        style= "width:50px;text-align:center">' + slno + '</td>' +
                    '<td class= jsgrid-cell  style= "width:200px;text-align:left" id=" + "td' + slno + ' "><input type="text" id=' + "Containerno" + slno + ' class="form-control" disabled style="height:30px;background-color:white;;text-align:left" value="' + ContainerNo + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:200px;text-align:left"><input type="text" id=' + "BookingNo" + slno + ' class="form-control" disabled style="height:30px;background-color:white;;text-align:left" value="' + BookingNo + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:left"><input type="text" id=' + "Lines" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:left" value="' + Lines + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "Size" + slno + ' class="form-control" disabled style="height:30px;background-color:white;;text-align:center" value="' + Size + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:left"><input type="text" id=' + "POL" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:left" value="' + POL + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:160px;text-align:left"><input type="text" id=' + "Port" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:left" value="' + Port + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "DateOfLoading" + slno + ' class="form-control" disabled style="height:30px;background-color:white;;text-align:center" value="' + DOLformatted + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "ExArrivalDate" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:center" value="' + EADformatted + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "DateofRelease" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:center" value="' + DORformatted + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "ConArrivalDate" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:center" value="' + CADformatted + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "Invoice" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:center" value="' + Invoice + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "InvoiceAmt" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:center" value="' + InvoiceAmt + '"></td>' +
                    '<td class= jsgrid-cell  style= "width:100px;text-align:center"><input type="text" id=' + "PaidAmount" + slno + ' class="form-control" disabled style="height:30px;background-color:white;text-align:center" value="' + PaidAmount + '"></td>' +

            '</tr>'
            $("#tblpurchaseinvoice").append(row);
        }
        $('#popupdiv').hide();
        $('#RowLength').val(i);
        //Othercosttotal();
    };

    function GetFormattedDate(datetoformat) {
        var todayTime = new Date(datetoformat);
        var month = todayTime.getMonth() + 1;
        var day = todayTime.getDate();
        var year = todayTime.getFullYear();

        if (day < 10)
            day = '0' + day
        if (month < 10)
            month = '0' + month

        return day + "/" + month + "/" + year;
    }


</script>

