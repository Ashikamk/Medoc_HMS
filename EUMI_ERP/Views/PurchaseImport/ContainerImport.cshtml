<script>
   


    function Defaultfocus() {
        $('#containerslno1').focus();
    }

    function SaveAndUpdate(flag) {

        if ($("#tblpurchaseinvoice tr").length > 0) {
            $('#btnsubmit').prop('disabled', true);
            var oArray = new Array();
            for (var k = 1; k <= $('#RowLength').val() ; k++) {                
                var BookingNumber = $('#BookingNo' + k).val();
                var ContainerNumber = $.trim($('#Containerno' + k).val());
                var Lines = $('#Lines' + k).val();
                var Size = $('#Size' + k).val();
                var PointOfLoading = $('#POL' + k).val();
                var Port = $('#Port' + k).val();
                var LoadDate = $('#DateOfLoading' + k).val();
                var ExpectArrivalDate = $('#ExArrivalDate' + k).val();
                var ReleaseDate = $('#DateofRelease' + k).val();
                var ContArrivalDate = $('#ConArrivalDate' + k).val();
                var Invoice = $('#Invoice' + k).val();
                var InvoiceAmount = $('#InvoiceAmt' + k).val();
                var PaidAmount = $('#PaidAmount' + k).val();
                var DelFlag = flag;
                var ContainerSlno = $('#containerslno').val();
                var ContainerBillNo = $('#containerslno1').val();
                var ContainerDate = $('#containerdate').val();
                var DeptId = ERPDeptId;
                var Reference = $('#txtreference').val();
                var UId = ERPUserId;
                if (ContainerNumber != undefined) {
                    oArray.push({
                        'ContainerNumber': ContainerNumber,
                        'BookingNumber': BookingNumber,
                        'Lines': Lines,
                        'Size': Size,
                        'PointOfLoading': PointOfLoading,
                        'Port': Port,
                        'LoadDate': LoadDate,
                        'ExpectArrivalDate': ExpectArrivalDate,
                        'ReleaseDate': ReleaseDate,
                        'ContArrivalDate': ContArrivalDate,
                        'Invoice': Invoice,
                        'InvoiceAmount': InvoiceAmount,
                        'PaidAmount': PaidAmount,
                        'DelFlag': DelFlag,
                        'ContainerSlno': ContainerSlno,
                        'ContainerBillNo': ContainerBillNo,
                        'ContainerDate': ContainerDate,
                        'DeptId': DeptId,
                        'Reference': Reference,
                        'UId': UId,

                    })
                }
            }
            if (oArray != "") {
                $('#LoadingSmall').show();
                var data = { 'ContainerManagement': oArray };
                $.ajax(
            {
                type: "POST",
                url: "../LocationTransfer/ContainerImportInsertandUpdate",
                data: data,
                success: function (result) {
                    //for (var i = 0; i < result.oList.length; i++) {
                    if (result.oList.length > 0) {
                        var status = result.oList[0].Status;
                        var billno = result.oList[0].ContainerSlno;
                        $('#LoadingSmall').hide();
                        Showalerts(status, billno);
                        $('#btnsubmit').prop('disabled', false);

                        var datax = {};
                        datax.DeptId = ERPDeptId;
                        $.ajax({
                                   type: "POST",
                                   url: "../LocationTransfer/AutoLocTransferUtilityForUC",
                                   data: datax,
                                   success: function (result) { }
                               });

                    }
                   // }
                }
            });
            }
        }
        else
            warningshow('Please Select Excel File');
    }


    var total = 0; var x = 1;
    function Showalerts(Status, Invonum) {
        if (Status == 1) {
            formrefresh();
            swal('Data Saved Successfully', " ", "success");
            $('.swal-button swal-button--confirm').focus();
        }
        if (Status == 2) {
            swal('Invo No:' + Invonum, " Updated Successfully", "success");
            $('.swal-button swal-button--confirm').focus();
            formrefresh(0);
        }
    }
    function formrefresh() {
        $('#containerslno1').val('');
        $('#txtreference').val('');
        $('#tblpurchaseinvoice tr').remove();
        $('#containerdate').val(CurDate);
        Serialnoload();
        $('#purchaseinv').show();
        $('#copypurchase').hide();
        $('#fileUpload').prop("disabled", false);
        $('#upload').prop("disabled", false);
        $('#txtreference').prop("disabled", false);
        $('#containerdate').prop("disabled", false);
        $('#containerdate').val(CurDate);
        $('#containerslno1').prop("disabled", false);
        $('#containerslno1').focus();
        $('#btnsubmit,#btnlist').show();
        $('.form-control').prop('disabled', false);
        $('#containerslno').prop("disabled", false);
    }

    function formrefreshconfirm() {
        if ($("#tblpurchaseinvoice tr").length > 1 && CopyFlag == 0) {
            $('#confirm').show();
            $('#confirmOk').focus();
            $('#Confirmflag').val('refresh'); $('#ConfirmRowId').val(0);
            $('#confirmmessage').text('Data will be lost.Do you want to Continue?');
        }
        else {
            formrefresh();
        }
    }

    function ConfirmboxResult(Result, status, rowid) {
        if (Result == 'true' && status == 'refresh') {
            formrefresh(0);
        }

        else if (Result == 'true' && status == 'copy') {
            formrefresh(0);
            GetRows();
        }
        $('#confirm').fadeOut();
    }

    $(document).ready(function () {
        $("#btnsubmit").click(function (e) {
            SaveAndUpdate(1);
        });
        Defaultfocus();
        Serialnoload();
        $('#containerdate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#containerslno1').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#containerdate').focus();
            }
        });
        $('#containerdate').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#txtreference').focus();
            }
        });

    });

    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').fadeOut();
        }, 3000);
    }


    function Serialnoload() {
        var srlno = {};
        srlno.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Common/SlNoGetandGets",
            data: srlno,
            success: function (result) {
                getslno(result.oList);

            }
        });
    }
    function getslno(result) {
        $('#containerslno').val(result[0].ContainerImportNO);
        $('#hiddencontainerslno').val(result[0].ContainerImportNO);
    }


    $("#copypurchaseinvo").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ContainerSlno = $("#copypurchaseinvo").val();
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../LocationTransfer/ContainerNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3',
                            label1: item.ContainerBillNo,
                            label: item.ContainerSlno,
                            label2: item.ContainerDate,
                            ContainerSlno: item.ContainerSlno,
                            ContainerBillNo: item.ContainerBillNo,
                            ContainerDate: item.ContainerDate,
                            headers: ["Sl No", "", "Date"]
                        })
                    }));
                }
            })
        },

        autoFocus: true,
        select: function (event, ui) {
            var data = {};
            data.ContainerSlno = ui.item.ContainerSlno;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../../LocationTransfer/ContainerSearch",
                data: data,
                success: function (result) {
                    ShowContainerlist(result.oList);
                }
            });
            $('#containerslno').prop('disabled', true);
            $('#copypurchaseinvo').prop('disabled', false);
            $('#containerdate').prop('disabled', true);       
        },
    });

    function GetRows() {
        CopyFlag = 1;
        var rowCount = document.getElementById('tblpurchaseinvoice').rows.length;
        if (rowCount == 0) {
            NextInvoiceNo = parseInt($('#hiddencontainerslno').val() || 0);
            $('#purchaseinv,#productpdiv,#Othercostpopup').hide();
            $('#copypurchase').show();
            $('#btnprvs').prop("disabled", false);
            $('#btnnxt').prop("disabled", false);
            $('.form-control').prop('disabled', true);
            $('#copypurchaseinvo').prop("disabled", false);
            $('.jsgrid-button').prop('disabled', true);
            $('#btnadd').prop("disabled", true);
            $('#btncrncysave,#btncrncyclear').prop("disabled", true);
            $('#copypurchaseinvo').focus();
            $('#copypurchaseinvo').select();
            $('.butndis').prop("disabled", true);
            $('#fileUpload').prop("disabled", true);
            $('#upload').prop("disabled", true);
            $('#btnsubmit,#btnlist').hide();
        }
        else {
            $('#Confirmflag').val('copy'), $('#ConfirmRowId').val(1);
            $('#confirmmessage').text('Data Will be Lost. Do you want to Continue?')
            $('#confirm').show();
            $('#confirmOk').focus();
        }
    }


    function GetBillPrevousornext(Value) {
        $('#Warningpopup').fadeOut();
        var SlNo = parseInt($('#containerslno').val() || 0);
        SlNo = SlNo + Value;
        if ((SlNo <= 0) || (SlNo >= NextInvoiceNo)) {
            warningshow('SL Number Not Valid', 'copypurchaseinvo');
            return false;
        }
        else {
            $('#containerslno').val(SlNo);
            var data = {};
            data.ContainerSlno = $('#containerslno').val();
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../LocationTransfer/ContainerSearch",
                data: data,
                success: function (result) {
                    ShowContainerlist(result.oList);
                    $('#btnnew').focus();
                    $('.form-control').prop('disabled', true);
                    $('#copypurchaseinvo').prop("disabled", false);
                    $('.jsgrid-button').prop('disabled', true);
                    $('#btnsubmit').hide();
                    $('#btnlist').hide();
                    //$('#btnedit').show();
                    $('#btnadd').prop("disabled", true);
                    $('#btncrncysave').prop("disabled", true);
                    $('#btnaddcost').prop("disabled", true);
                    $('#fileUpload').prop("disabled", true);
                }
            });
        }
    }
    function ShowContainerlist(result) {
        var responseText = "";
        $("#tblpurchaseinvoice tr").remove();
        $('#containerslno').val(result[0].ContainerSlno);
        $('#containerslno1').val(result[0].ContainerBillNo);
        $('#copypurchaseinvo').val(result[0].ContainerBillNo);
        $('#containerdate').val(result[0].ContainerDate);
        $('#txtreference').val(result[0].Reference);        
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);           
            responseText += '<tr class="jsgrid-row"><td class=jsgrid-cell style="width:50px" align=center>' + slno + '</td><td class= jsgrid-cell style="width:200px" >' + result[i].ContainerNumber + '</td><td class= jsgrid-cell style="width:200px" >' + result[i].BookingNumber + '</td><td class= jsgrid-cell style="width:100px" align=center>' + result[i].Lines + '</td><td class= jsgrid-cell style="width:100px" align=center>' + result[i].Size + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].PointOfLoading + '</td><td align=center class= jsgrid-cell style="width:160px" >' + result[i].Port + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].LoadDate + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].ExpectArrivalDate + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].ReleaseDate + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].ContArrivalDate + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].Invoice + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].InvoiceAmount + '</td><td align=center class= jsgrid-cell style="width:100px" >' + result[i].PaidAmount + '</td></tr>';
        }
        $('#tblpurchaseinvoice').append(responseText);
    }



    function Editdata()
    {
        $('#fileUpload').prop("disabled", false);
        $('#upload').prop("disabled", false);
        $('#txtreference').prop("disabled", false);
        $('#containerdate').prop("disabled", false);
        $('#containerdate').val(CurDate);
    }
</script>



