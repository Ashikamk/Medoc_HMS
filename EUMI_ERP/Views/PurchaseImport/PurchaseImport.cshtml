<script>
    $("#btncnclsave").focus(function (e) {
        $("#btncnclsave").removeClass("btn btn-outline-warning");
        $("#btncnclsave").addClass("btn btn-warning");
    });

    $("#btncnclsave").focusout(function (e) {
        $("#btncnclsave").removeClass("btn btn-warning");
        $("#btncnclsave").addClass("btn btn-outline-warning");
    });

    var total = 0; var x = 1;

    function Basetotal() {
       
        total = 0;
        var x = document.getElementById('tblpurchaseinvoice').rows.length;

            for (z = 0; z <= x; z++) {
                total = total + parseFloat($('#Exprice' + z).val() || 0);
            }
        
            $('#gndtotal').text(total.toFixed(Decimal));
            $('#SupInvoTotal').val(total.toFixed(Decimal));
            
    }
    function Deliverytotal() {
        var x = document.getElementById('tblpurchaseinvoice').rows.length;
        var deltotal = 0;
        var shippingtotal = 0;
        var dealertotal = 0; var storagetotal = 0; var loadingtotal = 0; var latefee = 0; var insurance = 0; var currentbalance = 0; var payedamt = 0; var balance = 0; var CustomsDuty = 0;
        var TotalExcelOthercost = 0; var AdditionalService = 0;
        var OtherCost1 = 0; var OtherCost2 = 0; var OtherCost3 = 0; var OtherCost4 = 0;

        for (z = 0; z <= x ; z++) {
          

            deltotal = deltotal + parseFloat($('#Exdvry' + z).val() || 0);
            shippingtotal = shippingtotal + parseFloat($('#Exship' + z).val() || 0);        
            dealertotal = dealertotal + parseFloat($('#Dealerfee' + z).val() || 0);
            storagetotal = storagetotal + parseFloat($('#Exstorfee' + z).val() || 0);         
            loadingtotal = loadingtotal + parseFloat($('#Exloadfee' + z).val() || 0);
            latefee = latefee + parseFloat($('#Exlatefee' + z).val() || 0);
            insurance = insurance + parseFloat($('#Exinsurance' + z).val() || 0);
            currentbalance = currentbalance + parseFloat($('#ExCbalance' + z).val() || 0);
            payedamt = payedamt + parseFloat($('#Expayedamt' + z).val() || 0);
            balance = balance + parseFloat($('#Exbalnce' + z).val() || 0);
            CustomsDuty = CustomsDuty + parseFloat($('#ExCustomsDuty' + z).val() || 0);
            AdditionalService = AdditionalService + parseFloat($('#Exaddservices' + z).val() || 0);
            OtherCost1 = OtherCost1 + parseFloat($('#Exothercost11' + z).val() || 0);
            OtherCost2 = OtherCost2 + parseFloat($('#Exothercost22' + z).val() || 0);
            OtherCost3 = OtherCost3 + parseFloat($('#Exothercost33' + z).val() || 0);
            OtherCost4 = OtherCost4 + parseFloat($('#Exothercost44' + z).val() || 0);
        }
        TotalExcelOthercost = deltotal + shippingtotal + dealertotal + storagetotal + loadingtotal + latefee + insurance + CustomsDuty + AdditionalService + OtherCost1 + OtherCost2 + OtherCost3 + OtherCost4;
        
        $('#totalexcelothercost').val(TotalExcelOthercost.toFixed(Decimal));
        $('#txtAdditionalService').val(AdditionalService.toFixed(Decimal));
        $('#txtdelivery').val(deltotal.toFixed(Decimal));
        $('#txtshipping').val(shippingtotal.toFixed(Decimal));      
        $('#txtloading').val(loadingtotal.toFixed(Decimal));
        $('#txtlate').val(latefee.toFixed(Decimal));
        $('#txtinsurance').val(insurance.toFixed(Decimal));
        $('#txtcurrentbalance').val(currentbalance.toFixed(Decimal));
        $('#txtbalance').val(balance.toFixed(Decimal));
        $('#txtpayedamt').val(payedamt.toFixed(Decimal));
        $('#textcustomesduty').val(CustomsDuty.toFixed(Decimal));
        $('#txtothercost1').val(OtherCost1.toFixed(Decimal));
        $('#txtothercost2').val(OtherCost2.toFixed(Decimal));
        $('#txtothercost3').val(OtherCost3.toFixed(Decimal));
        $('#txtothercost4').val(OtherCost4.toFixed(Decimal));
        if (!isNaN(dealertotal)) {
            $('#txtdealer').val(dealertotal.toFixed(Decimal));
        }
        if (!isNaN(storagetotal)) {
            $('#txtstorage').val(storagetotal.toFixed(Decimal));

        }

        if(CopyFlag!=1|| EditFlag==1)
        GetOtherCostDetails();
    }

    function GetOtherCostDetails() {

        var data = {};
        data.SupplierId = $('#supplierId').val();
        data.DeptId = DepId;

        $.ajax({
            type: "POST",
            url: "../PurchaseImport/UsedCarsOtherCostGets",
            data: data,
            success: function (result) {
                AddOtherCostDefualtToGrid(result);

            }
        });


    }


    function AddOtherCostDefualtToGrid(result) {

        $('#accountdescription').val('Other Cost Against Purchase InvNo: ' + $('#purchaseinvoiceno').val());
        $("#tblOtherCost tr").remove();

        for (var f = 0; f < result.length; f++) {
            var Type = '';
            var Amount=0
            var no = $('#tblOtherCost tr').length + 1;
            var tid = parseInt(x);

            if (result[f].OtherCostName == 'Supplier') {
                 Type = 'C';
                 Amount = $('#totalexcelothercost').val();
            }
            else {
                 Type = 'D'
                if (result[f].OtherCostName == 'Delivery') {
                     Amount = $('#txtdelivery').val();
                }
                else if (result[f].OtherCostName == 'Shipping') {
                     Amount = $('#txtshipping').val();
                }
                else if (result[f].OtherCostName == 'DealerFee') {
                     Amount = $('#txtdealer').val();
                }
                else if (result[f].OtherCostName == 'StorageFee') {
                     Amount = $('#txtstorage').val();
                }
                else if (result[f].OtherCostName == 'LoadingFee') {
                     Amount = $('#txtloading').val();
                }
                else if (result[f].OtherCostName == 'LateFee') {
                     Amount = $('#txtlate').val();
                }
                else if (result[f].OtherCostName == 'Insurance') {
                     Amount = $('#txtinsurance').val();
                }
                else if (result[f].OtherCostName == 'AdditionalService') {
                     Amount = $('#txtAdditionalService').val();
                }
                else if (result[f].OtherCostName == 'OtherCost1') {
                    Amount = $('#txtothercost1').val();
                }
                else if (result[f].OtherCostName == 'OtherCost2') {
                    Amount = $('#txtothercost2').val();
                }
                else if (result[f].OtherCostName == 'OtherCost3') {
                    Amount = $('#txtothercost3').val();
                }
                else if (result[f].OtherCostName == 'OtherCost4') {
                    Amount = $('#txtothercost4').val();
                }
