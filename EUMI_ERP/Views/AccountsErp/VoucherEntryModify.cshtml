            warningshow('Please Select Voucher Number', "VoucherNo");
        }
        else if ($('#VoucherType').val() == 0) {
            warningshow('Please Select Voucher Type', "VoucherType");
        }
        else {
            var VDetails = {};
            VDetails.DeptId = ERPDeptId;
            VDetails.VoucherNo = $('#VoucherNo').val();
            VDetails.VoucherTypeId = $('#VoucherType').val();
            VDetails.UserId = ERPUserId;

            $.ajax({
                type: "POST",
                url: "../AccountsErp/VoucherDelete",
                data: VDetails,
                success: function (result) {
                    Showalerts(3);
                }
            });
        }
    }
</script>


