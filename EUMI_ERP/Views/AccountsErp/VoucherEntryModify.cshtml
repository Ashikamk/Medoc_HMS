<script>
   function deletethisvouche()
   {
       if ($('#VoucherNo').val()=='') {
           warningshow('Please Select Voucher Number', "VoucherNo");
       }
       else if ($('#VoucherType').val() == 0) {
           warningshow('Please Select Voucher Type', "VoucherType");
       }
       else {
           $("#confirmOk").prop('disabled', false);
           $('#Confirmflag').val('deletevoucher'), $('#ConfirmRowId').val(1)
           $('#confirmmessage').text('Do You Want Delete This Voucher ?')
           $('#confirm').show();
           $('#confirmOk').focus();

       }
   }



</script>



