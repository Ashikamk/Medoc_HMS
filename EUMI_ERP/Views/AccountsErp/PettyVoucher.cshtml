<script>
$("#BankAccount").autocomplete({
    source: function (request, response) {
        var data = {};
        data.AccCode = $("#BankAccount").val();
        $.ajax({
            url: '../AccountsErp/PCAccSearch',
            type: "POST",
            data: data,
            dataType: "json",
            success: function (data) {
                response($.map(data, function (item) {
                    return ({
                        ColCount: '2',
                        label: item.AccCode,
                        label1: item.AccDescription,
                        Acc_Id: item.AccId,
                        headers: ["Account Code", "Account Name"]
                    })
                }));
            }
        })
    },
    autoFocus: true,

    select: function (event, ui) {
        $('#BankAccountId').val(ui.item.Acc_Id);
        $('#BankAccountName').val(ui.item.label1);

    },

});
$("#AccountName").autocomplete({
    source: function (request, response) {
        var data = {};
        data.AccCode = $("#AccountName").val();
        $.ajax({
            url: '../AccountsErp/PCAccSearch',
            type: "POST",
            data: data,
            dataType: "json",
            success: function (data) {
                response($.map(data, function (item) {
                    return ({
                        ColCount: '-2',
                        label: item.AccDescription,
                        label1: item.AccCode,

                        AccountName: item.AccDescription,
                        AccCode: item.AccCode,
                        AccountId: item.AccId,                     
                        headers: ["Account Name", "Account Code"]
                    })
                }));

            }
        })
    },
    autoFocus: true,
    select: function (event, ui) {
        $('#AccountName').val(ui.item.label)
        $('#AccCode').val(ui.item.label1)
        $('#supplierId0').val(ui.item.AccountId)      
        $('#AccountType').focus();
     


    },

});
function Enable() {
    var value = $('#select_type').val();
    if (value == 2) {
        document.getElementById("Type").disabled = false;
        document.getElementById("Date").disabled = false;
        document.getElementById("Bank").disabled = false;
        document.getElementById("ChequeNo").disabled = false;
        
    }
    else if (value == 3) {
        document.getElementById("Type").disabled = false;
        document.getElementById("Date").disabled = false;
        document.getElementById("Bank").disabled = false;
        document.getElementById("ChequeNo").disabled = false;
    }
    else {
    
        document.getElementById("Type").disabled = true;
        document.getElementById("Date").disabled = true;
        document.getElementById("Bank").disabled = true;
        document.getElementById("ChequeNo").disabled = true;
    }
}
</script>