</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Pending PDC Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:10%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>

                        <label style="font-weight:bold;margin-left:-1%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:2.5%;"></div>
                    <div class="row" style="margin-top:3%">
                        <label style="font-weight:bold;margin-left:4%">Customer</label>
                        <div class="col-md-8">
                            <table width="104%">
                                <tr>
                                    <td width="120px">
                                        <input type="text" id="CustomerCode" class="form-control editds"  style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left;height:40px;">
                                        <input type="hidden" id="CustomerId" value="0" class="form-control" />
                                    </td>
                                    <td width="280px">
                                        <input type="text" id="CustomerName" class="form-control editds" name="acnt1" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                 
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:43%;" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>
<script>


    $("#CustomerCode").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#CustomerId').val('');
            $("#CustomerName").val('');
            var data = {};
            data.TenantAccount = $("#CustomerCode").val();
            $.ajax({
                url: '../Realestate/TenantSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.TenantAccount,
                            label1: item.TenantName,
                            TenantId: item.TenantId,
                            Rent: item.Rent,
                            TenantName: item.TenantName,
                            TenantAccount:item.TenantAccount,
                            headers: ["Name", "Account"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustomerId').val(ui.item.TenantId);
            $("#CustomerCode").val(ui.item.TenantAccount);
            $("#CustomerName").val(ui.item.TenantName);
            $('#btnsubmit').focus();
        },
    })
</script>