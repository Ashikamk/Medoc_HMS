

@{
    ViewBag.Title = "PendingPDCReport";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>


<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
    .modal-lg{
        width:35%;
    }
</style>

<script>


    function popuprefresh() {
        $('#popupdiv').hide();
    }
    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');

        var responseText = "<thead><tr><th>Sl#</th><th style='width:50px'>Voucher#</th><th style='width:50px'>Type</th><th style='width:150px'>Voucher Date</th><th style='width:500px'>Description</th><th>Cheque#</th><th style='width:150px'>Cheque Date</th><th>Bank</th><th>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
           
           
            responseText += '<tr ><td align="center">' + slno + '</td><td>' + result[i].VoucherNo + '</td><td>' + result[i].VoucherType + '</td><td>' + result[i].Voucherdate + '</td><td>' + result[i].Description + '</td><td>' + result[i].cheqNo + '</td><td>' + result[i].CheqDate + '</td><td>' + result[i].Bank + '</td><td  align="right">' + parseFloat(result[i].Amount).toFixed(Decimal) + '</td></tr>';

           
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Voucher#</th><th>Voucher Type</th><th>Voucher Date</th><th>Description</th><th>cheque#</th><th>Cheque Date</th><th>Bank</th><th>Amount</th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Pending PDC Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');

        $('#header').text(title);
    }













    $(function () {


        $('#CustomerCode').focus();

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 50, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 50, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            if ($('#DateFrom').val() == '')
            {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {
                $('#Loading').show();
               
                if ($('#CustomerCode').val() == '') {
                  var  CustCode = 0;
                }
                else {
                    var CustCode = $('#CustomerCode').val();
                }
                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.CustAccount = CustCode;
             
                $.ajax({
                    type: "POST",
                    url: "../AccountsErp/Rpt_GetPendingPDC",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();

                    }
                });
            }


        });

    });

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            if (title == 'Voucher#'||title == 'Voucher Type'||title == 'Voucher Date'||title == 'Description'||title == 'cheque#'||title == 'Cheque Date'||title == 'Bank'||title == 'Amount')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');


        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

</script>

<div class="myData" data-x="M313" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="35%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">

                                <hr style="margin-top:.1%;" />
