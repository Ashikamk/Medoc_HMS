<script>

    function PrintthisBill() {

        if (VoucherBillType == 'LOCAL') {
            if (CopyFlag == 1)
                PrintthisBillWindows('VoucherEntry', $('#tblvoucherentry tr').length, 'COPY')
            else                                                                                                           //windowsprint 

                PrintthisBillWindows('VoucherEntry', $('#tblvoucherentry tr').length, 'SAVE')
        }
       else  if (VoucherBillType == 'DEFAULT') {
            if (CopyFlag == 1)
                PrintthisBillWindows('VoucherEntry', $('#tblvoucherentry tr').length, 'DEFAULTCOPY')
            else                                                                                                           //windowsprint 

                PrintthisBillWindows('VoucherEntry', $('#tblvoucherentry tr').length, 'DEFAULTSAVE')
       }
           //USEDCARS
       else if (VoucherBillType == 'USEDCARS-LAZOR') {
           if (CopyFlag == 1)
               PrintthisBillWindows('VoucherEntry', $('#tblvoucherentry tr').length, 'LAZORCOPY')
           else
               PrintthisBillWindows('VoucherEntry', $('#tblvoucherentry tr').length, 'LAZORSAVE')
       }
        else {

            PrintthisVoucherEntry($('#tblvoucherentry tr').length)
        }
    }
    
</script>


