                function FileUploadDB(Flag) {
                    // Database Save>copy

                    var data = {};
                    data.VoucherNo = $('#VEfileUploadValue').val();
                    data.FileName = $("#VEfileUpload").get(0).files[Flag].name;
                    data.Extension = $("#VEfileUpload").get(0).files[Flag].name.split('.').pop();
                    data.Flag = Flag;
                    data.DeptId = ERPDeptId;
                    data.UserId = ERPUserId;
                    data.VoucherType = $('#VEVoucherType').val();
                    data.VoucherEntryDescription = $('#VEVoucherTypeDesc').val();
                    $.ajax({
                        type: "POST",
                        url: "../AccountsErp/RVFileInsert",
                        data: data,
                        success: function (result) {
                            var DBFlag = result.dList[0].Flag;
                            var status = result.dList[0].Status;
                            var VoucherNoNew = result.dList[0].VoucherNo;
                            var VoucherTypeNew = result.dList[0].VoucherType;
                            $('#VEfileInsertOnebyone').val(VoucherNoNew);
                            $('#VEVoucherType').val(VoucherTypeNew);
                            if (status == 1) {
                                FileUploadFolder(Flag, DBFlag, status);
                            }

                        }
                    });




                }
                function FileUploadFolder(Flag, DBFlag, status) {
                    // Folder Save
                    //alert($('#VEfileInsertOnebyone').val())
                    var formData = new FormData();
                    var imageName = DBFlag
                    var browsedFile = document.getElementById("VEfileUpload").files[Flag];
                    var Extension = $("#VEfileUpload").get(0).files[Flag].name.split('.').pop();
                    var SlNo = $('#VEfileInsertOnebyone').val();
                    var DeptId = ERPDeptId;
                    var FileVocType = $('#VEVoucherTypeDesc').val();

                    formData.append("FileUpload", browsedFile);
                    formData.append("FileName", imageName);
                    formData.append("SlNo", SlNo);
                    formData.append("DeptId", DeptId);
                    formData.append("Extension", Extension);
                    formData.append("VoucherType", FileVocType);

                    $.ajax({
                        type: "POST",
                        url: '/AccountsErp/VEFileUpload',
                        data: formData,
                        dataType: "html",
                        contentType: false,
                        processData: false,
                        success: function (result) {
                            if (Flag < document.getElementById('VEfileUpload').files.length - 1) {
                                Flag++;
                                FileUploadDB(Flag);
                            }
                            else {
                                $("#LoadingSmall").hide();                                
                                $("#VEfileUpload").val('');
                                $('#VEfileUploadValue').val('');
                                $('#VEfileInsertOnebyone').val('');
                                $('#VEVoucherType').val('');
                                $('#VEVoucherTypeDesc').val('');
                                //ViewSavedFiles();
                            }
                        }
                    });
                   

                }
                function ViewSavedFiles() {
                    var data = {};
                    data.VoucherNo = $("#VoucherNo").val();
                    data.DeptId = ERPDeptId;
                    data.VoucherType = $('#VEVoucherType').val();
                    $.ajax({
                        type: "POST",
