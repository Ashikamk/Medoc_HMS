<div style="display:none">
    <input type="text" class="clrval" value="0" id="CashBookId" />
    <input type="text" id="BookId" />
    <input type="text" id="BookCode" />
    <input type="text" id="CashCode" />

    <input type="text" class="clrval" value="0" id="AccountHeadId0" />
    <input type="text" class="clrval" id="AccountCode0" />
</div>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script>
    var TbId = 1; var TbIdnew = 2;
    $(document).ready(function () {
        LoadDate();
        Defaultfocus();
        LoadAccount(0);
        LoadBook();
      //  CalcColsing();
        LoadDefaultAcnt();
        $('.clrval:not(.Avdfc)').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                var inputs = $(this).closest('form').find(':input.clrval:enabled');
                inputs.eq(inputs.index(this) + 1).focus();
                inputs.eq(inputs.index(this) + 1).select();
            }
        });
        $('#Narration0').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                window.setTimeout(function () {
                    $('#AddBtns').focus();
                });
            }
        });

        BtnFocusClr();

        $("#btnsubmit").click(function (e) {
            SaveCashBook();
        });

        $("#btnsubmit1").click(function (e) {
            SaveAccounts();
        });

        //  AddToTable(0,0);
        // Rowcntcheck();

        LoadAccount2(1);
        window.setTimeout(function () {
            LoadResult(0);
        }, 400);

    });

    function Defaultfocus()
    {
        $('#AccountHead0').focus();
    }

    function LoadDate()
    {
        $('#BookDate').daterangepicker({
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth()+1, new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: { format: 'DD/MM/YYYY' },
        }).val(CurDate);
    }

    function formrefresh() {
        $('.clrval').val('');
        $('#TblCashBook').html('');

        Defaultfocus();
        LoadDate();
        LoadDefaultAcnt();

        TbId = 1; TbIdnew = 2;

        $('#Accounts1').val(''); $('#AccountsId1').val(''); $('#AccAmt1').val(''); $('#AcRemarks1').val('');
        $('.TblNewRowcls').remove('');

        LoadResult(1);
        //CalcColsing();

    }

    function LoadDefaultAcnt()
    {

        var srlno = {};
        srlno.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Company/CompanyItemSlNoGetandGets",
            data: srlno,
            success: function (result) {
              Getslno(result.oList);
            }
        });
    }

    function Getslno(result) {
        debugger;
        for (var k = 0; k < result.length; k++) {
          
            $('#BookName').val(result[k].PettyCashAccount);
            $('#BookCode').val(result[k].PettyCashAccount);
            $('#CashCode').val(result[k].GICash);

            $('#BookId').val(1);
            balload123(result[k].AdditionalService, result[k].GICash);
        }
    }

    function LoadAccount(Id)
    {
        $("#AccountHead" + Id).autocomplete({
            source: function (request, response) {
                $('#AccountHeadId' + Id).val(0);
                $("#AccountCode" + Id).val('');
                var data = {};
                data.AccCode = $("#AccountHead" + Id).val();
                $.ajax({
                    url: '../AccountsErp/AccSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2',
                                label: item.AccDescription,
                                label1: item.AccCode,

                                AccountName: item.AccDescription,
                                AccCode: item.AccCode,
                                AccountId: item.AccId,
                                headers: ["Account Name", "Account Code"]
                            })
                        }));

                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#AccountHeadId' + Id).val(ui.item.AccountId);
                $("#AccountCode" + Id).val(ui.item.AccCode);
            },
        }).on('keydown', function (e) {
            //if (Id == 0)
            //{
            if ((e.which == 13) && (($('#AccountHead' + Id).val() != '') && (($('#AccountHeadId' + Id).val() || 0) != 0))) {
                $('#CreditAmt' + Id).focus().select();
                }
            //}
        });
    }

    function LoadAccount2(Id) {
        $("#Accounts" + Id).autocomplete({
            source: function (request, response) {
                $('#AccountsId' + Id).val(0);
                var data = {};
                data.AccCode = $("#Accounts" + Id).val();
                $.ajax({
                    url: '../AccountsErp/AccSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2',
                                label: item.AccDescription,
                                label1: item.AccCode,
                                AccountName: item.AccDescription,
                                AccCode: item.AccCode,
                                AccountId: item.AccId,
                                headers: ["Account Code", "Account Name"]
                            })
                        }));

                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#AccountsId' + Id).val(ui.item.AccountId);
            },
        }).on('keydown', function (e) {
            //if (Id == 0)
            //{
            if ((e.which == 13) && (($('#Accounts' + Id).val() != '') && (($('#AccountsId' + Id).val() || 0) != 0))) {
                $('#AccAmt' + Id).focus().select();
            }
            //}
        });
    }

    function LoadBook()
    {
        $("#BookName").autocomplete({
            source: function (request, response) {
                $('#BookId').val(0);
                $('#OpenBalance0,#OpenBalanceNew,#BookCode').val('');
                var data = {};
                data.AccCode = $("#BookName").val();
                $.ajax({
                    url: '../AccountsErp/AccSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2',
                                label: item.AccDescription,
                                label1: item.AccCode,

                                AccountName: item.AccDescription,
                                AccCode: item.AccCode,
                                AccountId: item.AccId,
                                headers: ["Account Name", "Account Code"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#BookId').val(ui.item.AccountId);
                $("#BookCode").val(ui.item.AccCode);
                balload(ui.item.AccCode);
            },
        }).on('keydown', function (e) {
            if ((e.which == 13) && (($('#BookName').val() != '') && (($('#BookId').val() || 0) != 0))) {
                $('#BookDate').focus();
            }
        });
    }


    function balload123(ACCode, CASHCODE) {

        var data = {};
        data.CashBook = ACCode;
        data.SalesBook = CASHCODE;
        data.VoucherDate = $('#BookDate').val();
        data.Flag = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../../AccountsErp/AccountbalGetandGetssalesandcash",
            data: data,
            success: function (result) {

                if (result.oList.length == 0) { $('#OpenBalance0,#OpenBalanceNew').val(parseFloat(0).toFixed(Decimal)); }
                else
                {

                    $('#Cashsales0').val(parseFloat(result.oList[0].SalesAmt).toFixed(Decimal));
                    $('#OpenBalance0').val(parseFloat(result.oList[0].bal).toFixed(Decimal));

                    $('#Cashsalesdis').val(parseFloat(-1*result.oList[0].SalesAmt).toFixed(Decimal));
                    $('#OpenBalancedis').val(parseFloat(-1 * result.oList[0].bal).toFixed(Decimal));

                    $('#salesremarks').text(result.oList[0].remarks);

                }
                CalcColsing();
            }
        });
    }



    function balload(ACCode) {
        var data = {};
        data.BankAccount = ACCode;
        data.VoucherDate = $('#BookDate').val();
        data.Flag = 0;
        $.ajax({
            type: "POST",
            url: "../../AccountsErp/AccountbalGetandGets",
            data: data,
            success: function (result) {

                if (result.oList.length == 0) { $('#OpenBalance0,#OpenBalanceNew').val(parseFloat(0).toFixed(Decimal)); }
                else
                {
                    balo = result.oList[0].bal;

                    $('#OpenBalance0').val(parseFloat(balo).toFixed(Decimal));

                   
                    $('#OpenBalancedis').val(parseFloat(-1 * balo).toFixed(Decimal));

                    if (balo < 0) {
                        // balo = balo * -1;
                       // $('#OpenBalance0').val(parseFloat(0).toFixed(Decimal));  //+ ' CR'
                       // $('#OpenBalanceNew').val(parseFloat(balo).toFixed(Decimal));
                    }
                    else {
                       // $('#OpenBalance0').val(parseFloat(balo).toFixed(Decimal)); // + ' DR'
                       // $('#OpenBalanceNew').val(parseFloat(0).toFixed(Decimal));
                    }
                }
               // CalcColsing();
            }
        });
    }

    function CalcColsing()
    {
        $('#ClosingBalance').text((0).toFixed(Decimal));


        var TotClosing = 0;
        if (parseFloat($('#OpenBalance0').val() || 0) != 0) { TotClosing = parseFloat($('#OpenBalance0').val() || 0); }
        else if (parseFloat($('#OpenBalanceNew').val() || 0) != 0) { TotClosing = parseFloat($('#OpenBalanceNew').val() || 0); }
        for (var j = 1; j <= TbId; j++) {
            if ($('#CBTbRow' + j).length != 0) {

                var DrAmt = 0; var CrAmt = 0;
                if (parseFloat($('#DebitAmt' + j).val()) > 0) { DrAmt = parseFloat($('#DebitAmt' + j).val() || 0); }
                else if (parseFloat($('#CreditAmt' + j).val()) > 0) { CrAmt = parseFloat($('#CreditAmt' + j).val() || 0); }

                TotClosing = TotClosing + DrAmt - CrAmt;

            }
        }
        var Amt = parseFloat($('#Cashsales0').val() || 0) + TotClosing;
        if (Amt < 0)
        {
            Amt = -1 * Amt;
        }

        $('#ClosingBalance').text((Amt).toFixed(Decimal));
    }

    function Rowcntcheck()
    {
        if ($('#TblCashBook tr').length==0)
        {
            TbId = 1;
            AddToTable(0, 0);
        }
    }
    function Rowcntcheck2() {
        if ($('.TblNewRowcls').length == 0) {
            TbIdnew = 1;
        }
    }

    function NextRow(e,Id)
    {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            AddCheck(Id);
        }
        else if (key == 37) {
            e.preventDefault();
            $('#CreditAmt' + Id).focus().select();
        }
    }
    function NextRow2(e, Id) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            AddCheck2(Id);
        }
        else if (key == 37) {
            e.preventDefault();
            $('#AccAmt' + Id).focus().select();
        }
    }

    function AddCheck(Id)
    {
        if ($.trim($('#AccountHead' + Id).val()) == '') {
            warningshow('Please select an Account', 'AccountHead' + Id)
        }
        else if(($('#AccountHeadId' + Id).val()||0)==0)
        {
            warningshow('Please select a valid Account', 'AccountHead' + Id)
        }
        else if ((($('#DebitAmt' + Id).val() || 0) == 0) && (($('#CreditAmt' + Id).val() || 0) == 0)) {
            warningshow('Please Enter Amount', 'DebitAmt' + Id)
        }
        else
        {
            AddToTable(0, 0);
        }
    }

    function AddToTable(flg, Id)  // flg: 0 - Add   ::::
    {
            if (flg == 0)   //Add
            {
                var TId = parseInt(TbId); var SlNo = parseInt($('.TblNewRow').length) + 1;
                var TbRow = '<tr class="TblNewRow" id="CBTbRow' + TId + '">' +
                            '<td class="jsgrid-header-cell jsgrid-align-center p-0" style="width:5%"><i class="icon-trash font-medium-2" style="cursor:pointer" onclick=RemoveTblRow(' + TId + ')></i></td>' +
                            '<td class="jsgrid-header-cell jsgrid-align-center p-0" style="width:5%" id="SlNum' + TId + '">' + SlNo + ' </td>' +
                            '<td class="jsgrid-header-cell jsgrid-align-left p-0" style="width:20%"> <input type="text" id="AccountHead' + TId + '" class="form-control tbtxt"  value=""></td>' +
