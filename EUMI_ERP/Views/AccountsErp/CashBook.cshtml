    function FocusMove()
    {
        $('input.fcscls').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            var Id = $(this).attr('id').match(/\d+/)[0];
            if (key == 13 || key == 39) {
                e.preventDefault();
                $('#Narration' + Id).focus().select();
            }
            else if (key == 37) {
                e.preventDefault();
                $('#AccountHead' + Id).focus();
            }

        });








        $('input.fcscls2').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            var Id = $(this).attr('id').match(/\d+/)[0];
            if (key == 13 || key == 39) {
                e.preventDefault();
                window.setTimeout(function () {
                    $('#AcRemarks' + Id).focus().select();

                }, 200);
            }
            else if (key == 37) {
                e.preventDefault();
                $('#Accounts' + Id).focus().select();
            }
        });








        $('input.fcscls1').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            var Id = $(this).attr('id').match(/\d+/)[0];
