
@{
    ViewBag.Title = "PettyCashVoucher";
}
<script type="text/javascript" src="~/ProjectScript/PettyCashVoucher.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<link rel="stylesheet" type="text/css" href="../../../app-assets/vendors/css/tables/jsgrid/jsgrid-theme.min.css">
<link rel="stylesheet" type="text/css" href="../../../app-assets/vendors/css/tables/jsgrid/jsgrid.min.css">

<style>
    #customView {
        border: 1px solid #CCD6E6;
    }
</style>
<div class="myData" data-x="M81" />
<div id="Entry" style="margin-top:-20px;">
  
    <section class="grid-row-label" id="grid-row-label">
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                        <h3 class="card-title mb-0" style="float:left">Petty Cash Voucher</h3>
                    </div>

                    <div class="card-content collapse show">
                        <div class="card-body" style="margin-top:-75px">
                            <form action="#">
                                <div class="form-body">
                                    <hr style="margin-top:75px" />

                                    <div class="row" style="background-color:#F0F6F6;margin-left:3px;width:1777px;margin-top:-20px;height:177px;">
                                        <div class="col-md-12" style="margin-top:-5px;">
                                            <br />
                                            <div class="form-group">

                                                <div class="row" style="margin-left:1px">
                                                    <label class="text-lg-right" for="VoucherNo">Voucher No</label>
                                                    <div class="col-md-2">
                                                        <input type="text" id="VoucherNo" class="form-control" disabled>
                                                    </div>
                                                    <label class="text-lg-right" for="AccountType">Account Type<span class="danger">*</span></label>
                                                    <div class="col-md-2">
                                                        <select id="AccountType" onchange="AccTypeChange(this.id)" class="form-control"></select>
                                                    </div>
                                                    <label class="text-lg-right" for="ChequeNo">&nbsp;Cheque No</label>
                                                    <div class="col-md-1">
                                                        <input type="text" id="ChequeNo" class="form-control" onkeypress="isNumberInt(event,this)" disabled/>
                                                    </div>
                                                    <label class="text-lg-right" for="ChequeDate">ChequeDate</label>
                                                    <div class="col-md-2">
                                                        <input type="text" id="ChequeDate" class="form-control" disabled placeholder="dd/mm/yyyy" />                                                       
                                                    </div>
                                                    <label class="text-lg-right" for="Bank">Bank</label>
                                                    <div class="col-md-2">
                                                        <select id="Bank" class="form-control" disabled></select>
                                                    </div>
                                                </div>

                                                <div class="row" style="margin-top:10px;margin-left:1px">
                                                    <label class="text-lg-right" for="VoucherDate">&emsp;&emsp;&nbsp;&nbsp;Date<span class="danger">*</span></label>
                                                    <div class="col-md-2">
                                                        <input type="text" id="VoucherDate" class="form-control" />
                                                    </div>
                                                    <label class="text-lg-right">&emsp;&nbsp;&nbsp;&nbsp;Credit A/c<span class="danger">*</span></label>
                                                    <div class="col-md-2">
                                                        <input type="text" id="CreditAc" class="form-control" onkeyup="CrAccountClear()">                                                        
                                                        <input type="text" id="CreditAcId" style="display:none">
                                                    </div>                                                    
                                                    <label class="text-lg-right">Cost Center</label>
                                                    <div class="col-md-1">
                                                        <select id="CostCenterCode" class="form-control"></select>
                                                        <input type="text" id="CostCenterId" value="0" style="display:none">
                                                    </div>
                                                    <label class="text-lg-right">&emsp;Job Code</label>
                                                    &nbsp;<div class="col-md-2">
                                                        <input type="text" id="JobDesc" class="form-control" onkeyup="JobClear()">
                                                        <input type="text" id="JobCode" value="0" style="display:none">
                                                    </div>
                                                    <label class="text-lg-right" style="margin-top:7px;"><b>&nbsp;&nbsp;Deb</b></label>
                                                    <div class="col-md-1">
                                                        <input type="text" id="Debit" class="form-control" style="color:darkturquoise;background-color:#f0f6f6;border:none;" readonly="readonly">
                                                    </div>
                                                    <label class="text-lg-right" style="margin-top:7px;"><b>Cred</b></label>
                                                    <div class="col-md-1">
                                                        <input type="text" id="Credit" class="form-control" style="color:darkturquoise;background-color:#f0f6f6;border:none;" readonly="readonly">
                                                    </div>                                                    
                                                </div>

                                                <div class="row" style="margin-top:10px;margin-left:1px">
                                                    <label class="text-lg-right" for="Amount">&emsp;Amount<span class="danger">*</span></label>
                                                    <div class="col-md-2">
                                                        <input type="text" id="Amount" onkeyup="CalculateFC()" onkeypress="isNumber(event,this)" class="form-control">                                                                                                           
                                                    </div>                                                    
                                                    <label class="text-lg-right">&emsp;&emsp;&emsp;&emsp;&emsp;&nbsp;&nbsp;FC</label>
                                                    <div class="col-md-2">
                                                        <select id="Currency" onchange="CurrencyChange(this.id)" class="form-control"></select>
                                                    </div>
                                                    <label class="text-lg-right">&emsp;&emsp;&emsp;&nbsp;Rate</label>
                                                    <div class="col-md-1">
                                                        <input type="text" id="Rate" onkeyup="CalculateFC()" onkeypress="isNumber(event, this)" class="form-control">
                                                    </div>
                                                    <label class="text-lg-right" for="FCAmount">&nbsp;&nbsp;FC Amount</label>
                                                    <div class="col-md-2">
                                                        <input type="text" id="FCAmount" onkeyup="CalculateAmount()" onkeypress="isNumber(event, this)" class="form-control">
                                                    </div>
                                                    <label class="text-lg-right" style="margin-top:7px;"><b>&nbsp;&nbsp;&nbsp;Diff</b></label>
                                                    <div class="col-md-1">
                                                        <input type="text" id="Diff" class="form-control" style="color:crimson;background-color:#f0f6f6;border:none;" readonly="readonly">
                                                    </div>
                                                    <label class="text-lg-right" style="margin-top:7px;"><b>Total</b></label>
                                                    <div class="col-md-1">
                                                        <input type="text" id="Total" class="form-control" style="color:crimson;background-color:#f0f6f6;border:none;" readonly="readonly">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <hr style="margin-top:5px;" />
                                    <div class="row col-md-12" style="margin-top:-10px;">
                                        <div class="col-md-12">
                                            <div class="row" style="height:26px;">
                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label>Type</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label>Account Name</label><span class="danger">*</span>
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label>Description</label>
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label>Amount</label><span class="danger">*</span>
                                                    </div>
                                                </div>
                                                <div class="col-md-1">
                                                    <div class="form-group">
                                                        <label>Reference</label>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row">
                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <select id="VType" class="form-control">
                                                            <option>Debit</option>
                                                            <option>Credit</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="col-md-2 input-group">
                                                    <input type="text" id="AccountName" class="form-control" style="height:66%;" onkeyup="AccountClear()">
                                                    <input type="text" style="display:none" id="supplierId0" />
                                                    <input type="text" style="display:none" id="AccCode" />
                                                    <div class="input-group-append" id="addVisa">
                                                        <button class="btn btn-outline-primary" id="AccountNamebtn" type="button" style="height:66%" onclick="window.open('../master/CustomerMaster')">+</button>
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <input type="text" id="VEDescription" class="form-control">
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <input type="text" id="GAmount" onkeypress="isNumber(event, this)" onkeyup="CheckAmount()" class="form-control">
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <input type="text" id="ReferenceNo" class="form-control">
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <button type="button" id="btnadd" class="btn btn-primary" onclick="AddToGrid()">+</button>
                                                </div>
                                                <div class="form-group" style="margin-left:15px;">
                                                    <button type="button" id="JobandTax" class="btn btn-primary" onclick="ShowJobandTax()">Job&Tax</button>
                                                </div>                                               
                                            </div>
                                        </div>
                                    </div>

                                    <div id="customView" class="jsgrid dataTables_scrollBody" style="overflow:auto;height: 310px; width: 99%; margin-left:9px;margin-top:-15px;">
                                        <table class="jsgrid-table" id="tblpettycash">
                                            <tr class="jsgrid-header-row">
                                                <th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width:50px;border-bottom:1px solid #CCD6E6">No</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width:120px;border-bottom:1px solid #CCD6E6">Type</th>                                               
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="width:150px;border-bottom:1px solid #CCD6E6">Acc Code</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center jsgrid-header-sortable" style="width:180px;border-bottom:1px solid #CCD6E6">Account Name</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="width:150px;border-bottom:1px solid #CCD6E6">Description</th>                                                
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="width:100px;border-bottom:1px solid #CCD6E6">Amount</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="width:120px;border-bottom:1px solid #CCD6E6">Ref No</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thJobCode">Job Code</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thCostCode">Cost Code</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thFC">FC</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thBank">Rate</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thFCAmount">FC Amount</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thBank">Bank</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thBank">ChequeNo</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thBank">Cheque Date</th>
                                                <th class="jsgrid-header-cell jsgrid-align-center" style="display:none;width:150px;border-bottom:1px solid #CCD6E6" id="thPDCAc">PDC Ac</th>
                                                <th class="jsgrid-header-cell jsgrid-control-field jsgrid-align-center" style="width:100px;border-bottom:1px solid #CCD6E6" id="Del">Delete</th>
                                            </tr>
                                        </table>
                                    </div>
                                    <div class="form-actions">
                                        <div class="text-right">
                                            <input type="text" id="BaseAmt" class="form-control col-md-1" style="display:none">
                                            <input type="text" id="DCDiff" class="form-control col-md-1" style="display:none">
                                            <input type="text" id="slnotxt" class="form-control col-md-1" value="1" style="display:none">
                                            <input type="text" id="hiddenrow" class="form-control col-md-1" value="1" style="display:none">
                                            <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                            <button type="button" style="width:100px" id="btnlist" onclick="window.open('../ABDataTable/AccountReports')" class="btn btn-primary btn-min-width mr-1 mb-1">Report <i class="ft-align-justify"></i></button>
                                            <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                            <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                        </div>
                                    </div>

                                    </div>
</form>
</div>
                        </div>

                    </div>
                </div>
            </div>
</section>
</div>


<div class="modal fade text-left show" id="Popup" tabindex="-1" role="dialog" aria-labelledby="myModalLabel17" style="padding-right: 17px;background:rgba(0,0,0,0.5);display:none">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content" style="width:200%; margin-left:-200px">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="MyHeader">Job & Tax</h4>
                <button type="button" class="close" data-dismiss="modal" onclick="($('#Popup').hide())" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <div id="TJTab">
                <ul class="nav nav-tabs nav-topline">
                    <li class="nav-item">
                        <a class="nav-link active" id="tab1" data-toggle="tab" aria-controls="div1" href="#div1" aria-expanded="true">&nbsp;Job & FC Details</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="tab2" data-toggle="tab" aria-controls="div2" href="#div2" aria-expanded="true">Tax Details</a>
                    </li>
                </ul>
                <div class="tab-content px-1 pt-1  border-lighten-2 border-0-top">
                    <div role="tabpanel" class="tab-pane active" id="div1" aria-expanded="true" aria-labelledby="tab1">
                        <form id="JobAndFC">
                            <div class="modal-body">
                                <div class="row" style="margin-left:2px;">
                                    <label class="text-md-right" id="JobCodelb">Job Code</label>
                                    <div class="col-md-3">
                                        <input type="text" id="PJobDesc" class="form-control">
                                        <input type="text" id="PJobCode" value="0" style="display:none">
                                    </div>
                                    <label class="text-md-right" id="CostCodelb">Cost Code</label>
                                    <div class="col-md-3">
                                        <select id="PCostCenterCode" class="form-control"></select>
                                    </div>
                                </div>
                                <div class="row" style="margin-left:2px;margin-top:10px;">
                                    <label class="text-md-right">Currency</label>
                                    <div class="col-md-3">
                                        <select id="PCurrency" onchange="CurrencyChange(this.id)" class="form-control" style="margin-left:2px;"></select>
                                    </div>
                                    <label class="col-md-1 text-md-right">Rate</label>
                                    <div class="col-md-3">
                                        <input type="text" style="margin-left:-2px;" id="PRate" onkeyup="CalculateFC()" onkeypress="isNumber(event, this)" class="form-control">
                                    </div>
                                    <label>FC Amount</label>
                                    <div class="col-md-3">
                                        <input type="text" onkeyup="CalculateAmount(),CheckAmount()" onkeypress="isNumber(event, this)" id="PFCAmount" class="form-control">
                                    </div>
                                </div>
                                <div class="row" style="margin-top:10px;">
                                    <label class="text-md-right">&emsp;&emsp;&emsp;Bank</label>
                                    <div class="col-md-3">
                                        <select id="PBank" name="priority" class="form-control"></select>
                                    </div>
                                    <label class="text-md-right">ChequeNo</label>
                                    <div class="col-md-3">
                                        <input type="text" id="PChequeNo" onkeypress="isNumber(event, this)" class="form-control" style="margin-left:-3px;">
                                    </div>
                                    <label>ChequeDt</label>
                                    <div class="col-md-3">
                                        <input type="text" id="PChequeDate" class="form-control">
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <input type="text" id="AmountFC" style="display:none">
                                <input type="text" id="AmountCon" style="display:none">

                                <label id="PDClb">PDCAc</label>
                                <div class="col-md-3" style="margin-right:53%">
                                    <input type="text" id="PDCAccount" class="form-control" style="margin-left:-7px">
                                    <input type="text" id="PDCAccountId" style="display:none">
                                </div>


                                <input type="button" id="btnaddtogrid" class="btn btn-outline-secondary " onclick="GetJob(),($('#Popup').hide())" value="Add">
                                <input type="button" id="btnclosegrid" class="btn btn-outline-secondary " onclick="($('#Popup').hide())" value="Close">
                            </div>
                        </form>
                    </div>

                    <div class="tab-pane" id="div2" aria-labelledby="tab2">
                        <form id="TaxDetails">
                            <div class="modal-body">
                                <div class="row" style="margin-left:2px;">
                                    <label class="text-md-right" id="TaxGrouplb">Tax Group</label>
                                    <div class="col-md-3">
                                        <select id="TaxGroup" class="form-control" onchange="TaxChange(this.id)"></select>
                                    </div>
                                    <label class="text-md-right">Tax %</label>
                                    <div class="col-md-3">
                                        <input type="text" id="TaxPer" onkeypress="isNumber(event, this)" class="form-control">
                                    </div>
                                </div>
                                <div class="row" style="margin-left:2px;margin-top:10px;">
                                    <label class="text-md-right">&emsp;Tax Acc</label>
                                    <div class="col-md-3">
                                        <input type="text" id="TaxAcc" class="form-control">
                                        <input type="text" id="TaxAccId" style="display:none">
                                        <input type="text" id="TaxAccName" style="display:none">
                                    </div>
                                    <label class="text-md-right">&nbsp;&nbsp;TRN</label>
                                    <div class="col-md-3">
                                        <input type="text" id="TRN" class="form-control">
                                    </div>
                                </div>
                            </div>
                            <input type="text" id="TaxAmount" style="display:none">
                            <div class="modal-footer">
                                <div class="d-inline-block custom-control custom-checkbox">
                                    <input type="checkbox" checked class="custom-control-input" id="Inclusive" />
                                    <label class="custom-control-label" for="Inclusive">Inclusive</label>
                                </div>
                                <input type="button" id="btnaddtogridtax" class="btn btn-outline-secondary " onclick="GetTax()" value="Add">
                                <input type="button" id="btnclosetaxgrid" class="btn btn-outline-secondary " onclick="AccountLoad(),($('#Popup').hide())" value="Close">

                            </div>
                        </form>
                    </div>
                </div>
            </div>
            </div>
    </div>
</div>
