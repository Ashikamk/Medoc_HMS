<script>

    function CalcTotal(id) {
        if (id != 22) {
            var qty = parseFloat($('#Qty' + id).val() || 0);
            var Denom = parseFloat($('#Denom' + id).text() || 0);
            var Total = (qty * Denom);
            Total = Total.toFixed(Decimal);
            $('#Total' + id).text(Total);
        }
        else {
            var qty = parseFloat($('#Qty22').val() || 0);
            var Denom = 1;
            var Total = (qty * Denom);
            Total = Total.toFixed(Decimal);
            $('#Total22').text(Total);
        }


        CalcGrandTotal();
    }

    function CalcGrandTotal() {
        var TotAed = 0; 
        for (var x = 1; x <= 9; x++) {
           
            TotAed = parseFloat(TotAed) + parseFloat($('#Total' + x).text()||0);
        }
        TotCoins = parseFloat($('#Total22').text()||0);
        $('#AEDTOT').text('');
        $('#AEDTOT').text(TotAed.toFixed(Decimal)); 
        $('#COINTOT').text(TotCoins.toFixed(Decimal));
        $('#TotalCashhand').text((TotCoins + TotAed).toFixed(Decimal))
        $('#TotalCashdiff').text((parseFloat($('#TotalCashcolect').text() || 0) - (TotCoins + TotAed)).toFixed(Decimal));
    }




    $('.qty').keypress(function (e) {
        isNumberInt(event, this);
    });


    $('.qty').keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        var Id = $(this).attr('id').match(/\d+/)[0];
        if (key == 40)                 //Down Arrow
        {
            e.preventDefault();
            var Nextid = parseInt(Id) + 1;
            if ($('#Qty' + Nextid)) {
                $('#Qty' + Nextid).focus();
                $('#Qty' + Nextid).select();
            }
            else {
                $('#Qty' + Id).focus();
                $('#Qty' + Id).select();
            }
        }
        else if (key == 38) {           //Up Arrow
            e.preventDefault();
            var Nextid = parseInt(Id) - 1;
            if ($('#Qty' + Nextid)) {
                $('#Qty' + Nextid).focus();
                $('#Qty' + Nextid).select();
            }
            else {
                $('#Qty' + Id).focus();
                $('#Qty' + Id).select();
            }
        }
    });




    $("#PDCAccount").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data1 = {};
            data1.UserName = $("#PDCAccount").val();

            $.ajax({
                url: '../Master/UserSearchInUserMenuSettings',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {

                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            UserRole: item.UserRole,
                            MenuCode: item.MenuCode,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#PDCAccountId').val(ui.item.UserId);
        },
    });


  

