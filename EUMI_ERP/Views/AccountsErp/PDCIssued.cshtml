<script>

    function SPFeePopup(flg) {

        if (parseFloat($('#TotalAmount').val()) == 0) {
            warningshow('Please select Bills', '');
        }
        else {


            if (flg == 0) {
                $('#SpecialFeeDiv').modal('show');
                $('#SpecialFeeDiv').appendTo('body');
            }
            else if (flg == 1) {
                $('#SpecialFeeDiv').modal('hide');
            }

            $('#TotalCashcolect').text($('#TotalAmount').val());
            $('#TotalCashdiff').text($('#TotalAmount').val());


            for (var x = 1; x <= 9; x++) {
                $('#Qty' + x).val('');
                $('#Total' + x).text('');
            }
            CalcGrandTotal();
        }


        
    }



</script>


