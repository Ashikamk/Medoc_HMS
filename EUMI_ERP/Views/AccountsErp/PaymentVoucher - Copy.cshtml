            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../AccountsErp/VoucherNoSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.VoucherNo,
                            label1: item.VoucherTypePrefix,
                            label2: item.VoucherTypeId,
                            VoucherNo: item.VoucherNo,
                            VoucherTypePrefix: item.VoucherTypePrefix,
                            VoucherTypeId: item.VoucherTypeId,
                            headers: ["Voucher Number", "VoucherType Prefix"]

                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#VoucherNo').val(ui.item.VoucherNo);
            $("#btnprint").show();
            $("#btnsubmit").hide();
            $("#btncopy").hide();
            $('#VoucherType').prop('disabled', true);
            $('#VoucherDate').prop('disabled', true);
            var vtype = "PV";        
            var srlno = {};
            srlno.VoucherNo = ui.item.VoucherNo;
            srlno.VoucherType = vtype;
            $.ajax({
                type: "POST",
                url: "../AccountsErp/PaymentVoucherGetandGets",
                data: srlno,
                success: function (result) {
                    VoucherNoGets(result);
                    // serialnoload();
                    $('#btnsubmit').focus();
                    if ((usermenu1.indexOf("M305") != -1)) {
                        $('#RVViewFiles').show();
                    }
                   
                }
            });
        },
    });
</script>
