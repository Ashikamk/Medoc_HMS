<script>

    function PrintthisBill() {

        if (VoucherBillType == 'LOCAL') {
            if (CopyFlag == 1)
                PrintthisBillWindows('PaymentEntry', $('#PendingInvoices tr').length, 'COPY')
            else
                PrintthisBillWindows('PaymentEntry1', $('#PendingInvoices tr').length, 'SAVE')
        }
        else if (VoucherBillType == 'DEFAULT') {
            if (CopyFlag == 1)
                PrintthisBillWindows('PaymentEntry', $('#PendingInvoices tr').length, 'DEFAULTCOPY')
            else                                                                                                           //windowsprint 

                PrintthisBillWindows('PaymentEntry', $('#PendingInvoices tr').length, 'DEFAULTSAVE')
        }
            //USEDCARS
        else if (VoucherBillType == 'USEDCARS-LAZOR') {
            if (CopyFlag == 1)
                PrintthisBillWindows('PaymentEntry', $('#PendingInvoices tr').length, 'LAZORCOPY')
            else
                PrintthisBillWindows('PaymentEntry', $('#PendingInvoices tr').length, 'LAZORSAVE')
        }
    }
</script>

