<script>
    function UploadPVFiles() {
        if (document.getElementById('PVfileUpload').files.length > 0) {

            $('#Confirmflag').val('PVFiles'), $('#ConfirmRowId').val(0)
            $('#confirmmessage').text('Do You Want To Upload These Files?')
            $('#confirm').show();
            $('#confirmOk').prop("disabled", false);
            $('#confirmOk').focus();
        }
        else {
            warningshow('No Files Selected', 'RVfileUpload');
            return false;
        }
    }
    function OKUploadPVFiles() {
        swal('Documents Uploaded Successfully', "", "success");
        $('.swal-button swal-button--confirm').focus();
        $('#PVDocument').hide();
    }
    function CreateFolder() {
        var data = {};
        data.DeptId = ERPDeptId;
        data.VoucherNo = $('#PVfileUploadValue').val();
        $.ajax({
            type: "POST",
            url: "../AccountsErp/PVFolderCreate",
            data: data,
            success: function (result) {
                FileUploadDB(0);

            }
        });
    }
    function FileUploadDB(Flag) {
        // Database Save>copy

        var data = {};
        data.VoucherNo = $('#PVfileUploadValue').val();
        data.FileName = $("#PVfileUpload").get(0).files[Flag].name;
        data.Extension = $("#PVfileUpload").get(0).files[Flag].name.split('.').pop();
        data.Flag = Flag;
        data.DeptId = ERPDeptId;
        data.UserId = ERPUserId;
        data.VoucherType = 'PV';
        $.ajax({
            type: "POST",
            url: "../AccountsErp/RVFileInsert",
            data: data,
            success: function (result) {
                var DBFlag = result.dList[0].Flag;
                var status = result.dList[0].Status;
                var VoucherNoNew = result.dList[0].VoucherNo;
                $('#PVfileInsertOnebyone').val(VoucherNoNew);

                if (status == 1) {
                    FileUploadFolder(Flag, DBFlag, status);
                }

            }
        });




    }
    function FileUploadFolder(Flag, DBFlag, status) {
        // Folder Save

        var formData = new FormData();
        var imageName = DBFlag
        var browsedFile = document.getElementById("PVfileUpload").files[Flag];
        var Extension = $("#PVfileUpload").get(0).files[Flag].name.split('.').pop();
        var SlNo = $('#PVfileInsertOnebyone').val();
        var DeptId = ERPDeptId;

        formData.append("FileUpload", browsedFile);
        formData.append("FileName", imageName);
        formData.append("SlNo", SlNo);
        formData.append("DeptId", DeptId);
        formData.append("Extension", Extension);

        $.ajax({
            type: "POST",
            url: '/AccountsErp/PVFileUpload',
            data: formData,
            dataType: "html",
            contentType: false,
            processData: false,
            success: function (result) {
                if (Flag < document.getElementById('PVfileUpload').files.length - 1) {
                    Flag++;
                    FileUploadDB(Flag);
                }
                else {
                    $("#LoadingSmall").hide();
                    $("#PVfileUpload").val('');
                    $('#PVfileUploadValue').val('');
                    $('#PVfileInsertOnebyone').val('');
                    //Showalerts(1);
                    //ViewSavedFiles();
                }
            }
        });


    }
    function ViewSavedFiles() {
        var data = {};
        data.VoucherNo = $("#VoucherNo").val();
        data.DeptId = ERPDeptId;
        data.VoucherType = 'PV';
        $.ajax({
            type: "POST",
            url: "../AccountsErp/RVFileGets",
            data: data,
            success: function (result) {
                ShowSavedFiles(result.oList);

            }
        });
    }
    function ShowSavedFiles(result) {

        disable_datatable('tbl_documentlist');
        $("#PVDocument").show();

        var responseText = "<tbody>";

        if (result.length > 0) {
            for (var l = 0; l < result.length; l++) {
                var slno = parseInt(l + 1);

                var Icon = '<img src="../app-assets/Project_Icons/DOC_ICON.png" style="width:50px;height:40px" />';

                var Extension = (result[l].Extension).toLowerCase();

                if (Extension == 'pdf') {
                    Icon = '<img src="../app-assets/Project_Icons/PDF_ICON.jpg" style="width:50px;height:40px" />';
                }
                else if (Extension == 'jpeg' || Extension == 'jpg' || Extension == 'png' || Extension == 'gif' || Extension == 'tif') {
                    Icon = '<img src="../app-assets/Project_Icons/IMG_ICON.jpg" style="width:50px;height:40px" />';
                }
                else if (Extension == 'xlsx' || Extension == 'xls' || Extension == 'xlsm' || Extension == 'xlm' || Extension == 'xltx' || Extension == 'xltm' || Extension == 'xlt') {
                    Icon = '<img src="../app-assets/Project_Icons/EXCEL_ICON.png" style="width:50px;height:40px" />';
                }


                responseText += "<tr id='doctr_" + result[l].FileId + "'>" +
                    "<td align='center'>" + Icon + "</td>" +
                    "<td>" + result[l].FileName + "</td>" +

                    "<td  align='center'>" +
                    "<a onclick=\"ViewDocuments(\'" + result[l].Flag + "'\,\'" + result[l].Extension + "'\)\"><i class='fa fa-download' style='color:darkorange'></i><a>" +
                    "</td>" +

                    //"<td align='center' class='hideedit'>" +
                    //"<a onclick=\"DeleteDocument(\'" + result[l].FileId + "'\,\'" + slno + "'\)\">" + DeleteButton + "</a>" +
                    //"</td>" +

                    "</tr>";


            }
        }
        else {
            responseText = "<tr><td style='text-align:center;color:red;font-weight:500'>NO DOCUMENTS</td></tr>"
        }

        $('#tbl_documentlist').html(responseText + '</tbody>');

        if (PurchaseEditFlag != 1) {
            $('.hideedit').hide();
        }

    }
    function ViewDocuments(DocumentId, Extension) {
        var flname = '../ProjectImages/PaymentVoucher/' + ERPDeptId + '/' + $("#VoucherNo").val() + '/' + DocumentId + '.' + Extension;
        window.open(flname);
    }

    $("#AccountName").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountName = $("#AccountName").val();
            $.ajax({
                url: '../AccountsErp/AccountNumberSearchCust',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        if (item.Flag == 2) {
                            return ({
                                ColCount: '-2',
                                label: item.AccountName,
                                label1: item.AccCode,
                                AccountName: item.AccountName,
                                AccCode: item.AccCode,
                                AccountId: item.AccountId,
                                CurrencyId: item.CurrencyId,
                                headers: ["Account Name", "Account Code"]
                            })
                        }
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#AccountName').val(ui.item.label)
            $('#AccCode').val(ui.item.label1)
            $('#supplierId0').val(ui.item.AccountId)
            $('#Currency').val(ui.item.CurrencyId)
            $("#Rate").val($("#Currency").find("option:selected").attr("name"))
            $('#AccountType').focus();
            GetList(0);
        },
    });

