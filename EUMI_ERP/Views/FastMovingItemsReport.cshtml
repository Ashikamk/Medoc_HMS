
@{
    ViewBag.Title = "FastMovingItemsReport";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>

<div id="Entry">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="39%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">




                                <div id="divreport" style="display:none; overflow:auto">
                                    <hr />

                                    <table id="Tblreport" class="table table-striped table-bordered dataTable" style="margin: 0 auto 0 0;"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</div>



<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Fast Moving Items Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">

                    <fieldset class="form-group floating-label-form-group">
                        <label for="DateFrom">From Date</label>
                        <input type="text" id="DateFrom" class="form-control">
                    </fieldset>
                    <br>
                    <fieldset class="form-group floating-label-form-group">
                        <label for="DateTo">To Date</label>
                        <input type="text" id="DateTo" maxlength="100" class="form-control">
                    </fieldset>
                    <br />
                    <fieldset class="form-group floating-label-form-group">
                        <label for="Values">Top 'N' Values</label>
                        <input type="text" id="Values" class="form-control" autocomplete="off">
                    </fieldset>
                    <br />



                </div>
                <div class="modal-footer">

                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-outline-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>




<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }

   


    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Slno</th><th>Code</th><th>Description</th><th>Name</th><th>Sub Group</th><th>Category</th><th>Sub Category</th><th>Quantity</th><th style=text-align:right>Average Cost</th><th style=text-align:right>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].ItemCode == '') {
                responseText += '<tr style=background-color:#8ee4f1><td>' + slno + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDesc + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubGroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + result[i].AvgCost + '</td><td style=text-align:right>' + result[i].Amount + '</td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDesc + '</td><td>' + result[i].GroupName + '</td><td>' + result[i].SubGroupName + '</td><td>' + result[i].CategoryName + '</td><td>' + result[i].SubCategoryName + '</td><td>' + result[i].Qty + '</td><td style=text-align:right>' + result[i].AvgCost + '</td><td style=text-align:right>' + result[i].Amount + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>Code</th><th>Description</th><th>Group</th><th>Sub Group</th><th>Category</th><th>Sub Category</th><th>Quantity</th><th style=text-align:right> </th><th style=text-align:right> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Fast Moving Items Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    $(function () {



        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {


            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {


                $('#Loading').show();


                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.Number = parseInt($('#Values').val() || 0);

                $.ajax({
                    type: "POST",
                    url: "../Purchaseandsalesreports/FastMovingItemsGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }


        });

    });


</script>






