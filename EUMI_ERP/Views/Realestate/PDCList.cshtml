
@{
    ViewBag.Title = "PDCList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>

<div class="myData" data-x="M274" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td> 
                                <td style="display:none;"><h5 id="header2"></h5></td> 
                                <td width="30%"></td>                              
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td><button type="button" style="width:100px;margin-left:30%;" id="btnprint" onclick="PrintthisReportWindows('PDCLIST', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>

                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <hr style="margin-top:-1px;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<input type="hidden" id="ResultLength" class="form-control" />

<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%;max-width:26%;margin-left:40%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">PDC List</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row">

                        <label class="col-md-2 text-right" style="font-weight:bold;">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:40%" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>


<script>

    function popuprefresh() {
        $('#popupdiv').hide();
    }
     
    $(function () {

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {
           
           
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();
            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();
            }
            else {
                $('#Loading').show();
                var data = {};
                data.FromDate = $('#DateFrom').val();;
                data.ToDate = $('#DateTo').val();;
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                data.Variable1 = '';
                data.Variable2 = '';
                data.Condition = '';
                $.ajax({
                    type: "POST",
                    url: "../Realestate/Rpt_RealEstatePDCList",
                    data: data,
                    success: function (result) {
                        Showreport(result.oList);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }

        });

    });

    function Showreport(result) {
        const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        var FromDate = []; var ToDate = [];
        FromDate = ($("#DateFrom").val()).split('/');
        ToDate = ($("#DateTo").val()).split('/');

        var FromDatePrint = FromDate[0] + '-' + monthNames[parseInt(FromDate[1] - 1)] + '-' + FromDate[2];
        var ToDatePrint = ToDate[0] + '-' + monthNames[parseInt(ToDate[1] - 1)] + '-' + ToDate[2];


        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Cheque#</th><th>Date</th><th>Bank</th><th>Contract#</th><th>Tenant</th><th>Building</th><th>Flat#</th><th>Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
          
            if (result[i].Flag == 1)
                {
                responseText += '<tr style="background-color:#cfd8dc;font-weight:bold">' +
                 '<td>' + slno + '<input type="hidden" id="Type_' + slno + '" value="' + result[i].Flag + '" /></td>' +
                 '<td id="Col1_' + slno + '">' + result[i].ChequeNo + '</td>' +
                 '<td id="Col2_' + slno + '">' + result[i].VDate + '</td>' +
                 '<td id="Col3_' + slno + '">' + result[i].BankName + '</td>' +
                 '<td id="Col4_' + slno + '"></td>' +
                 '<td id="Col5_' + slno + '">' + result[i].Tenant + '</td>' +
                 '<td id="Col6_' + slno + '">' + result[i].Building + '</td>' +
                 '<td id="Col7_' + slno + '">' + result[i].FlatNo + '</td>' +
                 '<td id="Col8_' + slno + '">' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td>' +
                '</tr>';
                }
                else
                {
                responseText += '<tr>'+
                        '<td>' + slno + '<input type="hidden" id="Type_' + slno + '" value="' + result[i].Flag + '" /></td>' +
                        '<td id="Col1_' + slno + '">' + result[i].ChequeNo + '</td>' +
                        '<td id="Col2_' + slno + '">' + result[i].VDate + '</td>' +
                        '<td id="Col3_' + slno + '">' + result[i].BankName + '</td>' +
                        '<td id="Col4_' + slno + '">' + result[i].ContraNo + '</td>' +
                        '<td id="Col5_' + slno + '">' + result[i].Tenant + '</td>' +
                        '<td id="Col6_' + slno + '">' + result[i].Building + '</td>' +
                        '<td id="Col7_' + slno + '">' + result[i].FlatNo + '</td>' +
                        '<td id="Col8_' + slno + '">' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td>' +
                    '</tr>';
                }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th> </th><th>Cheque#</th><th> </th><th>Bank</th><th>Contract#</th><th>Tenant</th><th>Building</th><th>Flat#</th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "PDC List - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearchRep('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#header2').text("From " + FromDatePrint + " to " + ToDatePrint + "");
        $('#ResultLength').val($("#Tblreportprint tbody tr").length);
    }

    function datatableWithsearchRep(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
            }
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                "<'row'<'col-sm-12'tr>>" +
                "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }
</script>







