
@{
    ViewBag.Title = "Agent";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script type="text/javascript" src="../Projectscript/Agent.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>

<div class="myData" data-x="M272" />
<div id="Entry" style="">

    <div class="row">
        <div class="col-md-2"></div>        
        <div class="col-md-8" style="">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="text-align:center;font-weight:bold">Agent</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                
                                <form action="#">
                                    <div class="form-body ">

                                        <div class="row">
                                            <div class="col-md-6" style="border-right:1px solid #d3dce9">
                                                <div class="row mt-3 mb-2">
                                                   
                                                    <div class="col-md-2">
                                                        <div>
                                                            <label style="font-weight:bold">Name<span class="danger">*</span></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-10" style="">
                                                        <div>
                                                            <input type="text" onkeyup="changetoupper(this.id)" id="AgentName" class="form-control">
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                <div class="row  mb-1">
                                                    
                                                    <div class="col-md-2">
                                                        <div>
                                                            <label style="font-weight:bold">Address<span class="danger">*</span></label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-10" style="">
                                                        <div>
                                                            <input type="text" onkeyup="changetoupper(this.id)" id="Address1" class="form-control">
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                <div class="row  mb-1">
                                                    
                                                    <div class="col-md-2"></div>
                                                    <div class="col-md-10" style="">
                                                        <div>
                                                            <input type="text" onkeyup="changetoupper(this.id)" id="Address2" class="form-control">
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                <div class="row  mb-2">
                                                   
                                                    <div class="col-md-2"></div>
                                                    <div class="col-md-10" style="">
                                                        <div>
                                                            <input type="text" onkeyup="changetoupper(this.id)" id="Address3" class="form-control">
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                                <div class="row mb-2">
                                                   
                                                    <div class="col-md-2">
                                                        <div>
                                                            <label style="font-weight:bold">Ph#</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-10" style="">
                                                        <div>
                                                            <input type="text" id="Phonenumber" class="form-control">
                                                        </div>
                                                    </div>
                                                    
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mt-3">
                                                    <div class="text-center mb-1">
                                                        <img id="myImg" src="~/app-assets/img/portrait/small/avatar-s-1.png" alt="" width="150" height="190" class="img-thumbnail  gradient-back-to-earth" onerror="this.onerror = null;this.src = '../app-assets/img/portrait/small/avatar-s-1.png';">
                                                    </div>
                                                    <div class="text-center">
                                                        <input type="file" id="selectedImage" name="files[]"  accept="image/*"  class="btn btn-lg gradient-back-to-earth font-small-2 white p-2 mr-2" />
                                                    </div>
                                                    
                                                </div>
                                                
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-actions center">

                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>

                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div  class="col-md-2"></div>
    </div>
</div>


<div style="display:none"><input type="text" id="AgentId" value="0"/></div>


<div id="listing" style="display:none;">
    <section>
        <div class="row">
            <div class="col-md-2"></div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold;">AGENT-LIST</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto;">
                            <table id="tblagent" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-2"></div>
        </div>
    </section>
</div>


