
@{
    ViewBag.Title = "PremiseMaster";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    #outPopUp {
        position: absolute;
        width: 300px;
        height: 200px;
        z-index: 15;
        top: 50%;
        left: 50%;
        margin: -100px 0 0 -150px;
    }
</style>



<script type="text/javascript" src="../Projectscript/PremiseMaster.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>
@*<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>*@

<div class="myData" data-x="M277" />
<div id="Entry" style="width:40%;margin-left:30%;height:100%;">

    <div class="row">
        <div class="col-md-12" style="margin-top:30%;">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="text-align:center;font-weight:bold">PREMISE</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>
                                <form action="#">
                                    <div class="form-body ">


                                        <div class="row">
                                            <div class="col-md-3">

                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Code<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-2%">
                                                <div class="form-group">
                                                    <input type="text" onkeyup="changetoupper(this.id)" id="Code" class="form-control" name="Code">
                                                </div>
                                            </div>
                                            <div class="col-md-3">

                                            </div>
                                        </div>




                                        <div class="row">
                                            <div class="col-md-3">

                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Description</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-2%">
                                                <div class="form-group">
                                                    <input type="text" id="Description" class="form-control">
                                                </div>
                                            </div>
                                            <div class="col-md-3">

                                            </div>
                                        </div>
                                    </div>


                                    <div class="row">
                                        <div class="col-md-3">

                                        </div>
                                        <div class="col-md-2">
                                            <div class="form-group">
                                                <label style="font-weight:bold">Remarks</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4" style="margin-left:-2%">
                                            <div class="form-group">
                                                <input type="text" id="Remarks" class="form-control">
                                            </div>
                                        </div>
                                        <div class="col-md-3">

                                        </div>
                                    </div>
                                    @*<div class="row">
                                        <div class="col-md-3">

                                        </div>
                                        <div class="col-md-2">
                                            <div class="form-group">
                                                <label style="font-weight:bold">Building</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4" style="margin-left:-2%">
                                            <div class="form-group">
                                                <input type="text" id="Building" class="form-control">
                                            </div>
                                        </div>
                                        <div class="col-md-3">

                                        </div>
                                    </div>*@



                                    <div class="form-actions center">

                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>

                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





<div id="listing" style="margin-left:20%;display:none;width:60%;">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold;">PREMISE-LIST</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto;">
                            <table id="tblcategory" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
















<div style="display:none"><input type="text" value="0" id="PremiseId" /></div>

