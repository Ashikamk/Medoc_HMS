    function ShowReport(result)
    {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th>Sl#</th><th>Flat#</th><th>Building</th><th>DEWA#</th><th>Type</th><th>Status</th><th>Tenant Name</th><th>Period</th><th>Start Date</th><th>Expiry Date</th><th>Rent</th><th>Security Deposit</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            var fltype = '';
            if (result[i].FlatName == 1) { fltype = 'Residential' }
            else if (result[i].FlatName == 2) { fltype = 'Commercial' }
            else if (result[i].FlatName == 3) { fltype = 'Other' }

            var ContractStatus = '';
            if (result[i].Status == 0) { ContractStatus = 'VACANT' }
            else if (result[i].Status == 1) { ContractStatus = 'OCCUPIED' }

            var PeriodType = "";
            var PeriodInWords = "";
            if (result[i].Period == 1) {
                PeriodType = 'Months'
                PeriodInWords = result[i].PaymentTerms;
            }
            else if (result[i].Period == 2) {
                fltype = 'Year';
                PeriodInWords='1'
            }
          

            ResponseEntity += '<tr><td style="text-align:center">' + slno + '</td><td id="Col1_' + slno + '">' + result[i].FlatNumber + '</td><td id="Col2_' + slno + '">' + result[i].NameofBuilding + '</td><td id="Col3_' + slno + '">' + result[i].DEWANO + '</td><td id="Col4_' + slno + '">' + fltype + '</td><td id="Col5_' + slno + '">' + ContractStatus + '</td><td id="Col6_' + slno + '" style="width:300px">' + result[i].TenantName + '</td><td id="Col7_' + slno + '">' + PeriodInWords + ' ' + PeriodType + '</td><td id="Col8_' + slno + '" style="text-align:center">' + result[i].FromDate + '</td><td id="Col9_' + slno + '" style="text-align:center">' + result[i].ToDate + '</td><td id="Col10_' + slno + '" style="text-align:right">' + addCommas(parseFloat(result[i].Rent).toFixed(Decimal), 0) + '</td><td id="Col11_' + slno + '" style="text-align:right">' + addCommas(parseFloat(result[i].securityDeposit).toFixed(Decimal), 0) + '</td></tr>';
        }
        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th>Sl#</th><th>Flat#</th><th>Building</th><th>DEWA#</th><th>Type</th><th>Status</th><th>Tenant Name</th><th>Period</th><th>Start Date</th><th>Expiry Date</th><th>Rent</th><th>Security Deposit</th></tr></tfoot>');

        var title = "Flat Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        var titles = "From " + $("#dpDateFrom").val() + " To " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#header1').text(titles);
        $('#ResultLength').val($("#Tblreport tbody tr").length);

    }


    function Detail() {
        var data = {};
        data.FromDate = $('#dpDateFrom').val();
        data.ToDate = $('#dpDateTo').val();
        //data.FlatNo = $('#FlatNoId').val();
        $.ajax({
            type: "POST",
            url: "../Realestate/Rpt_FlatDetails",
            data: data,
            success: function (result) {
                ShowReport(result);
                $('#Loading').hide();
                $('#divreport').show();
                $('#tdsummarypopup').show();
                $('#tddetailpopup').show();
                $('#popupdiv').hide();

            }
        });
    }
    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            if (title == 'Tenant' || title == 'Flat#' || title == 'Building' || title == 'DEWA#' || title == 'Type' || title == 'Status' || title == 'Tenant Name' || title == 'Period' || title == 'Start Date' || title == 'Expiry Date' || title == 'Rent' || title == 'Security Deposit')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');

        });

        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }
</script>
