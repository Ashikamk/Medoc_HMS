    $(function () {
        function addCommas(x, flg) {
            var amt = x || 0;
            if (flg == 0) {
                var parts = amt.toString().split(".");
                parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
                return parts.join(".");
            }
            else {
                var currency = amt;
                var number = Number(currency.replace(/[^0-9.-]+/g, ""));
                return number;
            }
        }
