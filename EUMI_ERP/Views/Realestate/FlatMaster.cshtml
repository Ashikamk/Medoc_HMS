    function GetRows(FlatMasterId) {
        $('#FlatMasterId').val(FlatMasterId) 
        var data = {};
        data.FlatMasterId = FlatMasterId;
        $.ajax({
            type: "POST",
            url: "../Realestate/FlatMasterGetandGets",
            data: data,
            success: function (result) {
                if (FlatMasterId == 0)
                    ShowFlatlist(result.oList);
                else
                    ShowFlatGet(result.oList);
            }
        });
    }


    function AddPopup(Id) {

        if (Id == 1) {
            $("#Agent,#Address1,#Address2,#Address3,#Phonenumber").val('');
            $("#Agent,#Address1,#Address2,#Address3,#Phonenumber").prop("disabled", false);
            $("#popupdiv").show();
            $("#Agent").focus();
        }
    }

    function SaveAgent() {
        if ($('#Agent').val() == "") {
            warningshow('Please Enter Name', 'Agent');
        }
        else {
            var data = {};   //array
            data.AgentId = 0;
            data.AgentName = $('#Agent').val();
            data.Address1 = $('#Address1').val();
            data.Address2 = $('#Address2').val();
            data.Address3 = $('#Address3').val();
            data.PhoneNumber = $('#Phonenumber').val();
            data.DelFlag = 1;
            $.ajax({
                type: "POST",
                url: "../Realestate/AgentInsertandUpdates",
                data: data,
                success: function (result) {
                   
                    var status = result.oList[0].Status;
                    var AgentId = result.oList[0].AgentId;
                    if (status == 1) {
                        $("#popupdiv").hide();
                    }
                    ShowalertsSub(status);
                    
                }
            });

        }


    }
