</div>

<script>
    $(document).ready(function () {
        //Defaultfocus();
         //Getflat(0);
     
        Getfeatures(); 
        Getbuild(0);
        $("#btnsubmit").click(function (e) {
            if ($('#FlatMasterId').val() == 0) {
                SaveAndUpdate(1);
            }
            else {
                EditFlatMaster(0)
            }
        });
        Defaultfocus();
        $("#otp").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#otpremarks').focus();
            }

        });
        $("#otpremarks").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#btncnclsave').focus();
            }

        });
        $("#btncnclsave").focus(function (e) {
            $("#btncnclsave").removeClass("btn btn-outline-warning");
            $("#btncnclsave").addClass("btn btn-warning");
        });
        $("#btnok").focus(function (e) {
            $("#btnok").removeClass("btn btn-outline-primary");
            $("#btnok").addClass("btn btn-primary");
        });
        $("#btnok").focusout(function (e) {
            $("#btnok").removeClass("btn btn-primary");
            $("#btnok").addClass("btn btn-outline-primary");
        });
        $("#btncnclalrt").focus(function (e) {
            $("#btncnclalrt").removeClass("btn btn-outline-primary");
            $("#btncnclalrt").addClass("btn btn-primary");
        });
        $("#btncnclalrt").focusout(function (e) {
            $("#btncnclalrt").removeClass("btn btn-primary");
            $("#btncnclalrt").addClass("btn btn-outline-primary");
        });
        $('#FlatStartDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });
        $('#AgentName').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $('#AgentContact').focus();
            }
        });
        
    });
    function closelist() {
        $('#Entry').show();
        $('#listing').hide();
        formrefresh();
    }
    //edit Flat Master
    function EditFlatMaster(Flag) {
        $("#btncnclsave").attr("onclick", "CheckEditFlatMaster(" + Flag + ")");
        $('#otp,#otpremarks').prop("disabled", false);
        $('#OTPDiv').show();
        $("#otp,#otpremarks").val('');
        $("#otp").focus();

    }

    //OTP Check
    function CheckEditFlatMaster(Flag) {
        if ($.trim($('#otp').val()) == '') {
            warningshow('Enter OTP', 'otp');
        }
        else if ($.trim($('#otpremarks').val()) == '') {
            warningshow('Enter Remarks', 'otpremarks');
        }
        else {
            var Operation = '';
            if (Flag == 0)
                Operation = 'Flat Master Edit- OTP';
            else if (Flag == 1)
                Operation = 'Flat Master Delete- OTP';

            var data = {};
            data.UserId = ERPUserId;
            data.OTP = $("#otp").val();
            data.Remarks = $('#otpremarks').val();
            data.Operation = Operation;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../Home/OTPCheckforUser",
                data: data,
                success: function (result) {
                    for (var i = 0; i < result.oList.length; i++) {
                        var status = result.oList[i].Status;
                        OTPCheck(status, Flag)
                    }
                }
            });
        }
    }


    function OTPCheck(status, Flag) {
        if (status == 1) {
            if (Flag == 0) {
                SaveAndUpdate(1);
            }
            else if (Flag == 1) {
                SaveAndUpdate(0);
            }
        }
        else {
            warningshow('Invalid OTP', 'otp');
            $("#otp").select();
        }
    }

    function DeleteFlatMaster() {

        $('#Confirmflag').val('delete'), $('#ConfirmRowId').val(0)
        $('#confirmmessage').text('Do you want to Delete?')
        $('#confirm').show();
        $('#confirmOk').focus();
    }

    function ConfirmboxResult(Result, status, rowid) {

       if (Result == 'true' && status == 'update') {
            ConfirmUpdateProcessTransfer();
        }
        else if (Result == 'true' && status == 'delete') {

            EditFlatMaster(1);
        }
        else if (Result == 'true') {
          SaveandUpdate(1);
        }

        $('#confirm').fadeOut();

    }


    function isNumberchk(evt, selectedvalue) {
        var charCode = (evt.which) ? evt.which : event.keyCode
        $(selectedvalue).val($(selectedvalue).val().replace(/[^0-9\.]/g, ''));
        if (charCode != 8 && (charCode != 46 || $(selectedvalue).val().indexOf('.') != -1) && charCode != 13 && (charCode < 48 || charCode > 57)) {
            evt.preventDefault();
            warningshow('Digits Only')
            return false;
        }
        return true;
    }

    function Defaultfocus() {
        $('#FlatNumber').focus().select(); 
    }

    function Getfeatures() {
        var data = {};
        data.FeaturesModelId = 0;
        $.ajax({
            type: "POST",
            url: "../Realestate/FeaturesGetandGets",
            data: data,
            success: function (result) {
                FeaturesLoad(result.oList);
            }
        });

    }

    function FeaturesLoad(result) {
        $('.remvrow').remove();
        for (var i = 0; i < result.length; i++) {
            $("#Features").append("<fieldset class=remvrow><div class='custom-control custom-checkbox' style='float:left;margin-left:-20px'><input type='checkbox' class='custom-control-input chkdivi' id='chkdivision_" + (i + 1) + "' checked=''><label class='custom-control-label' for='chkdivision_" + (i + 1) + "'>" + result[i].Facilities + "</label><input type='hidden' id='featuretxt" + (i + 1) + "' value=" + result[i].FeaturesModelId + "></div></fieldset>");
        }
    }

    function getfeaturetext()
    {
        var Features = '';
        for (var k=1;k<=$('.remvrow').length;k++ )
        {
            if($('#chkdivision_'+k).prop('checked')==true)
            {
                if (Features == '')
                { Features =  $('#featuretxt' + k).val(); }
                else
                { Features = Features + ',' + $('#featuretxt' + k).val(); }
            }
        }
        return Features;
    }

    function Getbuild(id) {
        var data = {};
        data.BuildingManagementId = 0;

        $.ajax({
            type: "POST",
            url: "../Realestate/BuildingManagementGetandGets",
            data: data,
            success: function (result) {
                buildLoad(result.oList, id);
            }
        });

    }

    function buildLoad(result) {
        $("#Building").empty();
        $("#Building").append("<option value='0'>Select</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Building").append("<option value='" + result[i].BuildingManagementId + "'>" + result[i].NameofBuilding + "</option>"); 
        }
    }

    $("#LandLoard").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#LandLoardId').val(''); 
            var data = {};
            data.LandName = $("#LandLoard").val(); 
            $.ajax({
                url: '../Realestate/LandLordsearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        console.log('item')
                        console.log(item)
                        return ({
                            ColCount: '-2ph',
                            label: item.LandName,
                            label1: item.Email,
                            label2: item.Mobno,
                            LanId: item.Lan_Id,
                            headers: ["Name", "Email","Mob"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {          
            $('#LandLoardId').val(ui.item.LanId); 
        },
    });

    $("#AgentName").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#AgentId').val('');
            var data = {};
            data.AgentName = $("#AgentName").val();
            $.ajax({
                url: '../Realestate/AgentNameSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        console.log('item')
                        console.log(item)
                        return ({
                            ColCount: '-2ph',
                            label: item.AgentName,
                            label1: item.Address1 + ',' + item.Address2, 
                            label2: item.PhoneNumber,
                            AgentId: item.AgentId,
                            PhoneNumber: item.PhoneNumber,
                            headers: ["Name", "Address", "Phone"] 
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#AgentId').val(ui.item.AgentId);
            $('#AgentContact').val(ui.item.PhoneNumber); 
            
        },
    });

    function SaveAndUpdate(Flag) {

        var Fetur = getfeaturetext();

        console.log((($('#AgentName').val() != '') && ($('#AgentId').val() || 0 == 0)))
        console.log((($('#AgentName').val() != '')))
        console.log((($('#AgentId').val() || 0 == 0))) 

        if (($('#FlatNumber').val() || 0) == 0) {
            warningshow('Please Enter FlatNumber', 'FlatNumber');
        }
        else if (($('#Building').val()||0) == 0) {
            warningshow('Please select Building', 'Building');
        }
        else if (($('#LandLoardId').val() || 0) == 0) {
            warningshow('Please select LandLoard', 'LandLoard'); 
        }
        else if ($('#AgentName').val() != '' && $('#AgentId').val() == 0) {
            warningshow('Please select a valid Agent', 'AgentName'); 
        }
        else
        {
            $('#OTPDiv').hide();
            var data = {};   //array
            data.FlatMasterId = $('#FlatMasterId').val();
            data.FlatNumber   = $('#FlatNumber').val();
            data.Building     = $('#Building').val();
            data.DEWANO       = $('#DEWANO').val();
            data.Rent         = $('#Rent').val();
            data.RentType     = ''
            data.LandLoard    = $('#LandLoardId').val(); 
            data.AgentName    = $('#AgentId').val(); 
            data.AgentContact = $('#AgentContact').val(); 
            data.TypeOfFlat   = $('#TypeOfFlat').val();
            data.Features = Fetur;
            data.Remarks      = $('#Remarks').val();
            data.DelFlag = Flag;
            data.CurDate = CurDate;
            data.UserId = ERPUserId;
            data.DeptId = ERPDeptId;
            data.VaccantDate =$('#FlatStartDate').val();
            data.ContractStatus = 0;
            $.ajax({
                type: "POST",
                url: "../Realestate/FlatMasterInsertandUpdate", 
                data: data,
                success: function (result) {
                        var status = result.oList[0].Status;
                        var a = parseInt(status);
                        Showalerts(a);
                }
            });
        }
    }


    function formrefresh() {
        $('.form-control').val('');
       
        $('#TypeOfFlat').val(1);
        $('#Building').val(0); 
        
        Getfeatures();
       
        Defaultfocus();
        $('#FlatStartDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });

    }
    function closetable(value) {
        $('#Entry').show();
        $('#listing').hide();
        if (value == 1)
            formrefresh();
    }

    function ShowFlatlist(result) { 
        disable_datatable('tblFlat');
        $('#Entry').hide();
        $('#listing').show();
        var responseText = "<thead><tr><th width=15px>Sl#</th><th>Flat No.</th><th>Building</th><th>Type of Flat</th><th>Rent</th><th width=15px>Edit</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            var fltype = '';
            if (result[i].TypeOfFlat == 1) { fltype = 'Residential' }
            else if (result[i].TypeOfFlat == 2) { fltype = 'Commercial' }
            else if (result[i].TypeOfFlat == 3) { fltype = 'Other' } 

            responseText += '<tr><td>' + slno + '</td><td>' + result[i].FlatNumber + '</td><td>' + result[i].NameofBuilding + '</td><td>' + fltype + '</td><td style="text-align:right">' + parseFloat(result[i].Rent).toFixed(Decimal) + '</td><td align=center><a onclick="GetRows(' + result[i].FlatMasterId + ')">' + Editbutton + '</a></td></tr>';
        }
        $('#tblFlat').html(responseText + '</tbody><tfoot><tr><th >Sl#</th><th>Flat No.</th><th>Building</th><th>Type of Flat</th><th>Rent</th><th width=15px>Edit</th></tr></tfoot>');
        datatableWithsearch1('tblFlat');
    }

    function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Serial#' && title != ' ' && title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            }
            
        });

        table = $('#' + tablename).DataTable({
            dom: 'Blfrtip',
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    }
                ]
            },
            //'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#itemListButtonPlace"));
        $("#itemListButtonPlace").find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
    }




