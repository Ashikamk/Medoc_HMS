           $('#LandLoard').val(result[0].LandLoardName);
           $('#LandLoardId').val(result[0].LandLoard);
           $('#AgentName').val(result[0].AgentName);
           $('#AgentId').val(result[0].AgentId); 
           $('#AgentContact').val(result[0].AgentContact);
           $('#TypeOfFlat').val(result[0].TypeOfFlat);
           $('#Remarks').val(result[0].Remarks);
           $('#FlatStartDate').val(result[0].VaccantDate);
           $('.chkdivi').prop('checked', false)
           var Features = (result[0].Features).split(','); 
         
               for (var k = 1; k <= $('.remvrow').length; k++) {                
