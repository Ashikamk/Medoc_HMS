
@{
    ViewBag.Title = "VacantFlatLossAnalysis";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

    .modal-md {
        max-width: 600px;
    }
</style>

<div class="myData" data-x="M278" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td style="display:none;"><h5 id="header2"></h5></td>
                                <td width="30%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td><button type="button" style="width:100px;margin-left:30%;" id="btnprint" onclick="PrintthisReportWindows('VacantFlat', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>

                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <hr style="margin-top:-1px;" />
                                <div id="divreport" style="overflow:auto;">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable" style="width:100%"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<input type="hidden" id="ResultLength" class="form-control" />

<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%;">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">Vacant Flat Loss Analysis</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row mb-2">
                        <div class="col-md-2"></div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">As On</label>
                        <div class="col-md-6">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <hr style="border-top: 1px solid #cdcfd0;" />
                    <div class="row mb-2">
                        <div class="col-md-2"></div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">Building</label>
                        <div class="col-md-6">
                            <input type="text" id="Building" class="form-control" autocomplete="off">
                            <input type="hidden" id="BuildingId" value="0" />
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-2"></div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">Flat</label>
                        <div class="col-md-6">
                            <input type="text" id="Flat" class="form-control" autocomplete="off">
                            <input type="hidden" id="FlatId" value="0" />
                        </div>

                    </div>

                </div>

                <div class="modal-footer" style="display:inherit">
                    <div class="text-center">
                        <button type="button" style="width:100px;" id="btnsubmit" class="btn btn-primary">Go</button>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>


<script>
    $("#Flat").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#FlatId').val('0');
            var data = {};
            data.FlatNumber = $("#Flat").val();
            $.ajax({
                url: '../Realestate/FlatNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        console.log(data)
                        return ({
                            ColCount: 'ONE',
                            label: item.FlatNumber,
                            FlatMasterId: item.FlatMasterId,
                            FlatNumber: item.FlatNumber,
                            headers: ["Flat No"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#FlatId').val(ui.item.FlatMasterId);
            $('#btnGo').focus();
        },
    });
    $("#Building").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#BuildingId').val('0');
            var data = {};
            data.Building = $("#Building").val();
            $.ajax({
                url: '../Realestate/BuildingNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        console.log(data)
                        return ({
                            ColCount: '2',
                            label: item.Building,
                            label1: item.NameofBuilding,
                            buildingManagementId: item.buildingManagementId,
                            NameofBuilding: item.NameofBuilding,
                            headers: ["Code", "Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#BuildingId').val(ui.item.buildingManagementId);
        },
    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    $(function () {

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnsubmit").click(function (e) {


            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();
            }
            else {
                $('#Loading').show();
                var data = {};
                data.FromDate = $('#DateFrom').val();
                data.FlatId = $('#FlatId').val();
                data.BuildingId = $('#BuildingId').val();
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                data.Variable1 = '';
                data.Variable2 = '';
                data.Condition = '';
                $.ajax({
                    type: "POST",
                    url: "../Realestate/Rpt_RealEstateVacantFlatLoss",
                    data: data,
                    success: function (result) {
                        Showreport(result.oList);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }

        });

    });

    function Showreport(result) {
        const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        var FromDate = [];
        FromDate = ($("#DateFrom").val()).split('/');

        var FromDatePrint = FromDate[0] + '-' + monthNames[parseInt(FromDate[1] - 1)] + '-' + FromDate[2];


        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th>Sl#</th><th>Flat</th><th>DEWA#</th><th>Type</th><th>Rent</th><th>Vacant Days</th><th>Vacant On</th><th>Loss Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].Flag == 2) {
                responseText += '<tr style="background-color:#cfd8dc;font-weight:bold">' +
                 '<td>' + slno + '<input type="hidden" id="Type_' + slno + '" value="' + result[i].Flag + '" /></td>' +
                 '<td id="Col1_' + slno + '"></td>' +
                 '<td id="Col2_' + slno + '">' + result[i].FlatNo + '</td>' +
                 '<td id="Col3_' + slno + '"></td>' +
                 '<td id="Col4_' + slno + '"></td>' +
                 '<td id="Col5_' + slno + '"></td>' +
                 '<td id="Col6_' + slno + '"></td>' +
                 '<td id="Col7_' + slno + '"  align="right">' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td>' +
                '</tr>';
            }
            else if (result[i].Flag == 1) {
                responseText += '<tr style="background-color:#cfd8dc;font-weight:bold">' +
                 '<td>' + slno + '<input  type="hidden" id="Type_' + slno + '" value="' + result[i].Flag + '" </td>' +
                 '<td id="Col1_' + slno + '">' + result[i].FlatNo + '</td>' +
                 '<td id="Col2_' + slno + '"></td>' +
                 '<td id="Col3_' + slno + '"></td>' +
                 '<td id="Col4_' + slno + '"></td>' +
                 '<td id="Col5_' + slno + '"></td>' +
                 '<td id="Col6_' + slno + '"></td>' +
                 '<td id="Col7_' + slno + '"></td>' +
                '</tr>';
            }
            else {
                responseText += '<tr>' +
                        '<td>' + slno + '<input  type="hidden" id="Type_' + slno + '" value="' + result[i].Flag + '" </td>' +
                        '<td id="Col1_' + slno + '">' + result[i].FlatNo + '</td>' +
                        '<td id="Col2_' + slno + '">' + result[i].DEWANo + '</td>' +
                        '<td id="Col3_' + slno + '">' + result[i].FlatType + '</td>' +
                        '<td id="Col4_' + slno + '" align="right">' + parseFloat(result[i].Rent || 0).toFixed(Decimal) + '</td>' +
                        '<td id="Col5_' + slno + '" align="center">' + result[i].VacantDays + '</td>' +
                        '<td id="Col6_' + slno + '">' + result[i].VacantOn + '</td>' +
                        '<td id="Col7_' + slno + '" align="right">' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td>' +
                    '</tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th> </th><th>Flat</th><th>DEWA#</th><th>Type</th><th> </th><th>Vacant Days</th><th>Vacant On</th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Vacant Flat Loss Analysis - As On " + $("#DateFrom").val();
        datatableWithsearchRep('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#header2').text("As On " + $("#DateFrom").val());
        $('#ResultLength').val($("#Tblreportprint tbody tr").length);
    }

    function datatableWithsearchRep(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
            }
        });
        var table = null;
        table = $('#' + tablename).DataTable({
            dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                "<'row'<'col-sm-12'tr>>" +
                "<'row'<'col-sm-1'i><'col-sm-11'p>>",
            buttons: [],
            "columnDefs": [
                                { "width": "1%", "targets": 0 },
                                { "width": "20%", "targets": 1 },
                                { "width": "10%", "targets": 2 },
                                { "width": "10%", "targets": 3 },
                                { "width": "5%", "targets": 4 },                              
                                { "width": "2%", "targets": 5 },
                                { "width": "2%", "targets": 6 },
                                { "width": "5%", "targets": 7 },
                                
            ],

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                className: 'excelexport',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }
</script>







