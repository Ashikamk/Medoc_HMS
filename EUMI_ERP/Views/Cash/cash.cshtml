
@{
    ViewBag.Title = "cash";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

</style>


<script>


    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function ShowReport(result)
    {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Total Amount</th><th>Received Amount</th><th>Balance</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].mBillSeriesId + '</td><td>' + result[i].mBillSlNo + '</td><td>' + result[i].mcurdate + '</td><td>' + result[i].mCustomer + '</td><td style=text-align:right>' + parseFloat(result[i].mTotalAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].mReceivedAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].mBalanceAmount || 0).toFixed(Decimal) + '</td></tr>';
            
        }

        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Customer</th><th> </th><th> </th><th> </th></tr> </tfoot>');

        var title = "Cash Collection Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function showcurrencyReport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Customer</th><th>Total Amount</th><th>Received Amount</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].mBillSeriesId=='') {
                ResponseEntity += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td>' + result[i].mBillSeriesId + '</td><td>' + result[i].mBillSlNo + '</td><td><b>' + result[i].mcurdate + '</b></td><td>' + result[i].mCustomer + '</td><td style=text-align:right></td><td style=text-align:right></td></tr>';
            }
            else
            {
            ResponseEntity += '<tr><td>' + slno + '</td><td>' + result[i].mBillSeriesId + '</td><td>' + result[i].mBillSlNo + '</td><td>' + result[i].mcurdate + '</td><td>' + result[i].mCustomer + '</td><td style=text-align:right>' + parseFloat(result[i].mTotalAmount || 0).toFixed(Decimal) + '</td><td style=text-align:right>' + parseFloat(result[i].mReceivedAmount || 0).toFixed(Decimal) + '</td></tr>';

        }

        }

        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th>Sl#</th><th>Bill Series</th><th>Bill#</th><th>Date</th><th>Customer</th><th> </th><th> </th></tr> </tfoot>');

        var title = "Cash Collection Report - from " + $("#dpDateFrom").val() + " to " + $("#dpDateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Bill#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Bill Series') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Customer') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:900px" />');
            }
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }


    $(function () {

        $('#dpDateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $('#dpDateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        });


        $("#btnGo").click(function (e) {
            $('#Loading').show();

            if ($("#grpbycur").prop("checked")) {
                var data = {};
                data.mfromdate = $('#dpDateFrom').val();
                data.mtodate = $('#dpDateTo').val();



                $.ajax({
                    type: "POST",
                    url: "../Cash/CurrencyGetandGets",
                    data: data,
                    success: function (result) {
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();

                        showcurrencyReport(result);
                    }
                });

            }
            else {
                var data = {};
                data.mfromdate = $('#dpDateFrom').val();
                data.mtodate = $('#dpDateTo').val();

                $.ajax({
                    type: "POST",
                    url: "../Cash/cashGetandGets",
                    data: data,
                    success: function (result) {

                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                        ShowReport(result);
                    }
                });
            }
        });
    });

   

</script>

<div class="myData" data-x="M202" />
<div id="Main">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="38%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">
                            <div class="heading-elements">
                                <div id="divreport" style="display:none; overflow:auto">
                                    <hr style="margin-top:2px;" />
                                    <table id="Tblreport" class="table table-striped table-bordered dataTable" style="margin: 0 auto 0 0;"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader"> Currencywise Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
             
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:10%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="dpDateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:-1%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="dpDateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                </div>
               
                <div class="modal-footer">
                    <fieldset class="form-group floating-label-form-group" style="margin-right:8%">
                        <div class="row">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="grpbycur">
                                <label class="custom-control-label" for="grpbycur" style="font-weight:bold">Group by Currency</label>
                            </div>

                        </div>
                    </fieldset>
                    <button type="button" style="width:100px;margin-right:35%" id="btnGo" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>

