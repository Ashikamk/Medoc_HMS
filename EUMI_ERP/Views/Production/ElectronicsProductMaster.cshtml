<script>
    var createQRCode = function () {
        var data = $('#code').val();
        $('#qrcode').empty();
        $('#qrcode').qrcode(data);
        //$('#qrcode').append('</br><strong>' + data + '</strong>');
    };

    $('#code').keyup(createQRCode);
    $('#code').change(createQRCode);
    createQRCode();
    generatebarcode();

    function AccessoriesLoad(Id) {
        console.log(Id)
        $("#" + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#" + Id).val();

                $.ajax({
                    url: '../Purchase/ProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWO',
                                label: item.ItemCode,
                                label1: item.Description,
                                ItemId: item.ItemId,
                                headers: ["Accessories"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#' + Id + '_Id').val(ui.item.ItemId);

            },
        });
    }


    function LoadSupplier(Id) {
        $('#' + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.CustName = $('#' + Id).val();
                data.CustType = 'S';

                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWO',
                                label: item.CustName,
                                label1: item.CustAccount,
                                CustId: item.CustId,
                                headers: ["Supplier Name", "Account Code", "Phone Number"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#' + Id+'_Id').val(ui.item.CustId)

            },

        });
    }



    $('#btnlist').click(function (e) {

        GetRows(0);
    });



    function validate(file) {
        var ext = file.split(".");
        ext = ext[ext.length - 1].toLowerCase();
        var arrayExtensions = ["jpg", "jpeg", "png", "bmp", "gif"];

        if (arrayExtensions.lastIndexOf(ext) == -1) {
            warningshow("Wrong extension type.");
            $("#selectedImage").val("");
        }
    }


    function imagemaxsize() {
    }


    function printbarcode() {
        var divToPrint = document.getElementById("barcode1");
        newWin = window.open("");
        newWin.document.write(divToPrint.outerHTML + "  " + divToPrint.outerHTML + "  " + divToPrint.outerHTML);
        newWin.print();
        newWin.close();
    }

    function generatebarcode() {
        var Code=$('#code').val(); if($('#code').val()=='') { Code=0;}  JsBarcode("#barcode1", Code);
    }
</script>