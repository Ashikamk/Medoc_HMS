<script type="text/javascript">
    $(document).ready(function () {

        if ("@Request.QueryString["from"]" == "productlist") {
            var id = sessionStorage.getItem("inventory_productlist_id");
            sessionStorage.removeItem("inventory_productlist_id");
            var numId = parseInt(id, 10);
            if (!isNaN(numId)) {
                $('#Loading').show();
                jQuery(window).load(function () {
                    //alert('page is loaded');
                    setTimeout(GetRows(numId), 3000);

                });

            }
        }

        $("#searchcode").autocomplete({
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#searchcode").val();

                $.ajax({
                    url: '../Purchase/ProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {

                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWOEnq',
                                label: item.ItemCode,
                                label1: item.Description,
                                ItemId: item.ItemId,
                                Product: item.Description,
                                productcode: item.ItemCode,
                                GrpId: item.GrpId,
                                CategoryId: item.CategoryId,
                                headers: ["Product Code", "Product Name"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#Loading').show();
                $('#productid').val(ui.item.ItemId)
                $('#productdesc').val(ui.item.Product);
                $('#btnsubmit').focus();

                GetItem(ui.item.ItemId, ui.item.GrpId, ui.item.CategoryId);
                $('#code').show();
                $('#searchcode').hide();
                $('#btnsubmit').prop("disabled", false);
                $('#btnsubmit').show();
                $('#searchbutton').removeClass();
                $('#searchbutton').addClass('btn btn-outline-primary');
            },
        });
    });

    function locationwiseqtyupdateclear() {
        $('#opqty').val(0);
    }


    function locationwiseqtyupdate()
    {
        var Qty = 0;
        $('#popupdiv').hide();
        var num = parseInt($('#NoOfLocations').val()-1);
        for (var i = 0; i <= num ; i++) {
            var LocationID = $('#locID' + i).val();
            var LocationQty = parseInt($('#lqty' + LocationID).val()||0);
            if (LocationQty != 0) {
                Qty +=LocationQty;
            }
        }
        $('#opqty').val(Qty);
    }


    function AddmoreImages()
    {
        var Imgcount=parseInt($('#Imagecount').val())
        var file = '<div id=' + "Imgdiv" + Imgcount + '><input type="file" id=' + 'SelmultiImage' + Imgcount + ' accept="image/*" onchange="readMultipleimageURL(this,' + Imgcount + ')"" class="btn btn-lg gradient-back-to-earth font-small-1 white p-2 mr-2"><img id=' + "Mimg" + Imgcount + ' src="../app-assets/img/elements/04.png" alt="Gini" width="50" style="margin-top:-18px" class="img-thumbnail multiimagebox" onerror="this.onerror=null; this.src=../app-assets/img/elements/04.png;">&#160;&#160;<button type="button" class="btn btn-danger" onclick="RemoveImages(' + Imgcount + ')"> <i class="ft-x"></i>Remove</button></div>'
        $('#divmultimage').append(file).show('slow');
        $('#Imagecount').val(Imgcount+1)
    }


    function RemoveImages(ImgId)
    {
        $('#Imgdiv' + ImgId).slideUp( function () { $('#Imgdiv' + ImgId).remove(); });
        //$('#Imgdiv' + ImgId).remove();

    }









</script>

