    function ProductLoad(Id) {
        $("#" + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#" + Id).val();

                $.ajax({
                    url: '../Purchase/ProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWO',
                                label: item.ItemCode,
                                label1: item.Description,
                                ItemId: item.ItemId,
                                headers: ["Item Code", "Description"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#' + Id + 'Id').val(ui.item.ItemId);
                $('#bb3').focus();

            },
        });
    }

    //Copy or Purchase Invoice Autocomplete

    $("#copypurchaseinvo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.InvoNo = $("#copypurchaseinvo").val();
            data.LocnId = ULocId;
            data.DepartmentId = ERPDeptId;
            $.ajax({
                url: '../Purchase/SerialNoSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '4',
                            label: item.SlNo,
                            label1: item.InvoNo,
                            label2: item.InvoDate,
                            label3: item.SupplierName,
                            SlNo: item.SlNo,
                            DepartmentId:item.DepartmentId,
                            headers: ["Serial No", "Invoice No", "Date", "Supplier"]


                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            var data = {};
            data.SlNo = ui.item.SlNo;
            data.DepartmentId = ui.item.DepartmentId;
            $.ajax({
                type: "POST",
                url: "../Purchase/PurchaseInvoiceGetandGets",
                data: data,
                success: function (result) {
                    formrefresh(1);
