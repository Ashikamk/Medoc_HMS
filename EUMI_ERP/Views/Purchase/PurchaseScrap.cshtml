<script type="text/javascript">
    $(document).ready(function () {
        if ("@Request.QueryString["from"]" == "AccountStatement") {
            var id = sessionStorage.getItem("purchase_slno");
            var dep = sessionStorage.getItem("pur_deptid");
            sessionStorage.removeItem("purchase_slno");
            sessionStorage.removeItem("pur_deptid");
            var numId = parseInt(id);
            var deprtid=parseInt(dep)
            if (!isNaN(numId) && !isNaN(deprtid)) {
                ReportGetCopy(numId,deprtid);
            }
        }
        else if ("@Request.QueryString["from"]" == "PurchaseReport") {
            var id = sessionStorage.getItem("purchase_slno");
            var dep = sessionStorage.getItem("pur_deptid");
            sessionStorage.removeItem("purchase_slno");
            sessionStorage.removeItem("pur_deptid");
            var numId = parseInt(id);
            var deprtid=parseInt(dep)
            if (!isNaN(numId) && !isNaN(deprtid)) {
                ReportGetCopy(numId, deprtid);
            }
        }
    });

    $(document).ready(function () {
        if ("@Request.QueryString["from"]" == "PriceManager") {
            var Id = sessionStorage.getItem("purchase_invono");
            var dept = sessionStorage.getItem("pur_Deptid");
            sessionStorage.removeItem("purchase_invono");
            sessionStorage.removeItem("pur_Deptid");
            var numId = parseInt(Id);
            var deprtid=parseInt(dept)
            if (!isNaN(numId) && !isNaN(deprtid)) {
                ReportGetCopy(numId, deprtid);
            }
        }
    });
</script>

