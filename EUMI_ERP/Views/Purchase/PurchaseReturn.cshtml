<script type="text/javascript">
    $(document).ready(function () {
        if ("@Request.QueryString["from"]" == "AccountStatement") {
            var id = sessionStorage.getItem("purchase_slno");
            var dep = sessionStorage.getItem("pur_deptid");
            sessionStorage.removeItem("purchase_slno");
            sessionStorage.removeItem("pur_deptid");
            var numId = parseInt(id);
            var deprtid = parseInt(dep)
            if (!isNaN(numId) && !isNaN(deprtid)) {
                ReportGetCopy(numId, deprtid);
            }
        }
    });
    function ReportGetCopy(PRNo, DepId) {

        var data = {};
        data.PRNo = PRNo;
        data.DepartmentId = DepId;
        $.ajax({
            type: "POST",
            url: "../Purchase/PurchaseReturnGetandGets",
            data: data,
            success: function (result) {
                formrefresh(1);
                PurchaseReturnGets(result.oList);
                $('#purchaseinvoiceno1').val(PRNo);
                $('#btnnew').focus();
                $('.form-control').prop('disabled', true);
                $('#copypurchaseinvo').prop("disabled", false);
                $('.jsgrid-button').prop('disabled', true);
                $('#btnsubmit').prop("disabled", true);
                $('#btnlist').prop("disabled", true);
                $('#btnadd').prop("disabled", true);
                $('#btncrncysave').prop("disabled", true);
                $('#btnaddcost').prop("disabled", true);

            }
        });
    }
</script>

