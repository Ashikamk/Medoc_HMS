    function GetFirstDayMonth() {
        var date = new Date();
        var firstDay = new Date(date.getFullYear(), date.getMonth(), 1);

        var month = firstDay.getMonth() + 1;
        var day = firstDay.getDate();
        var year = firstDay.getFullYear();

        if (day < 10)
            day = '0' + day
        if (month < 10)
            month = '0' + month

        return day + "/" + month + "/" + year;
    }
