    function savepo() {
       

        if (0 != 0) {
            warningshow('Please Select Supplier', 'suppliername');
        }
       

        else {                                                  //ajax code for insert and update to  controller
            $('#LoadingSmall').show();
           
            var oArray = new Array();
            for (var k = 1; k < len; k++) {

                var Prodid = $('#Vpid' + k).val()
                var Qty = parseInt($('#orderQty' + k).val() || 0)
                var Supplier = $('#vDept' + k).val()


                var EnquiryNo = 1;
                var EnquiryDate = $('#LayouEOD').text();
                var SupplierId = 1
                var LocnId = 1
                var CurrencyId = 1
                var CurrencyRate = 1
                var Remarks = '';

                var TotalDiscount = 0;          //Base Currency          
                var FCDiscount = 0;            //Foregin Currency
                var TotalTaxable = 0;         //Base Currency
                var TotalTax = 0;            //Base Currency               
                var GrandTotal = 0;         //Base Currency                 
                var FCTaxable = 0;         //Foreign Currency
                var FCTax = 0;            //Foreign Currency
                var FCGrandTotal = 0;    //Foreign Currency
                var DepartmentId = 1;
                var UserId = 1;
                var DeleteFlag = 1;

                var PurchaseEnquirySubId = 0;
                var ItemId = Prodid;
                var ItemCode = $('#Proddesc' + k).text();
                var ItemDescription = $('#Proddesc' + k).text();
                var LocationId = 1;
                var UnitId = 1;
                var Quantity = Qty;
                var Rate = 0;
                var BaseRate = 0;
                var Discount = 0;
                var BaseDiscount =0;
                var TaxId = 1;
                var TaxRate =0;
                var TaxableAmount = 0;
                var TaxAmount = 0;
                var TotalAmount =0;
                var BaseTaxable =0;
                var BaseTax = 0;
                var BaseAmount =0;
                var PurchaseAnalysisId = 0;
                var Models = 0;

                if (!(typeof ItemCode == "undefined")) {
                    if (Qty > 0) {
                        oArray.push({
                            'EnquiryNo': EnquiryNo,
                            'EnquiryDate': EnquiryDate,
                            'SupplierId': SupplierId,
                            'LocnId': LocnId,
                            'CurrencyId': CurrencyId,
                            'CurrencyRate': CurrencyRate,
                            'Remarks': Remarks,
                            'TotalDiscount': TotalDiscount,
                            'FCDiscount': FCDiscount,
                            'TotalTaxable': TotalTaxable,
                            'TotalTax': TotalTax,
                            'GrandTotal': GrandTotal,
                            'FCTaxable': FCTaxable,
                            'FCTax': FCTax,
                            'FCGrandTotal': FCGrandTotal,
                            'DepartmentId': DepartmentId,
                            'UserId': UserId,
                            'DeleteFlag': DeleteFlag,
                            'PurchaseEnquirySubId': PurchaseEnquirySubId,
                            'ItemId': ItemId,
                            'ItemCode': ItemCode,
                            'ItemDescription': ItemDescription,
                            'LocationId': Supplier,
                            'UnitId': UnitId,
                            'Quantity': Quantity,
                            'Rate': Rate,
                            'BaseRate': BaseRate,
                            'Discount': Discount,
                            'BaseDiscount': BaseDiscount,
                            'TaxId': TaxId,
                            'TaxRate': TaxRate,
                            'TaxableAmount': TaxableAmount,
                            'TaxAmount': TaxAmount,
                            'TotalAmount': TotalAmount,
                            'BaseTaxable': BaseTaxable,
                            'BaseTax': BaseTax,
                            'BaseAmount': BaseAmount,
                            'PurchaseAnalysisId': PurchaseAnalysisId,
                            'Models': Models,
                        })
                    }
                }
            }
            if (oArray != "") {

                var data = { 'PurchaseEnquiry': oArray };
                $.ajax({
                    type: "POST",
                    url: "../Purchase/PurchaseEnquiryInsertandUpdate",
                    data: data,
                    success: function (result) {
                        for (var i = 0; i < result.oList.length; i++) {
                            var status = result.oList[i].Status;
                            var no = result.oList[i].EnquiryNo;
                            $('#btnsubmit').prop("disabled", false);
                            $('#LoadingSmall').hide();
                            $('#Tblreport').html('')
                            $('#popupdiv').show(), $('#txtproduct').focus()
                            swal('PO No' + ' ', "Saved Successfully", "success");
                            $('.swal-button swal-button--confirm').focus();
                        }
                    }
                });
            }
            else {
                warningshow('No Products Added', 'product_0');
                $('#btnsubmit').prop("disabled", false);
            }

        }



    }





