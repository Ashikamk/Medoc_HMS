            var ProdDisc = $('#discount_' + k).val(); var FcProdDisc = $('#discount_' + k).val();
            var TaxableAmount = $('#txttaxable_' + k).val();
            var FCTaxableAmount = $('#txttaxable_' + k).val();
            var TaxId = $('#tax_' + k).val(); var TaxPercent = $('#taxpercentage_' + k).val();
            var TaxAmount = $('#txttax_' + k).val(); var FCTaxAmount = $('#txttax_' + k).val();
            var Amount = $('#amount_' + k).val(); var FCAmount = $('#amount_' + k).val();
            var LocnId = $('#locn_' + k).val();
            row += '<tr><td>' + ProductCode + '</td><td>' + ProductDescr + '</td><td>' + UnitName + '</td><td>' + ProdQty + '</td><td>' + ProdRate + '</td><td>' + ProdDisc + '</td><td>' + TaxableAmount + '</td><td>' + TaxAmount + '</td><td>' + Amount + '</td></tr>'
        }
