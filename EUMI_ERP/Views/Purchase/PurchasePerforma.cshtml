                    success: function (result) {
                        ProductPopuprefresh();
                        CustPrdctLoad(result.oList);
                    }
                })
            },
        });
    }
    function ProductLoad(Id) {
        $("#" + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#" + Id).val();

                $.ajax({
                    url: '../Purchase/ProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'TWO',
                                label: item.ItemCode,
                                label1: item.Description,
                                ItemId: item.ItemId,
                                headers: ["Item Code", "Description"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#' + Id + 'Id').val(ui.item.ItemId);
                $('#bb3').focus();
            },
        });
    }
