    function EditInvoice(Flag) {
        $("#btncnclsave").attr("onclick", "CheckEditInvoce(" + Flag + ")");
        $('#otp,#otpremarks').prop("disabled", false);
        $('#OTPDiv').show();
        $("#otp,#otpremarks").val('');
        $("#otp").focus();

    }

    function CheckEditInvoce(Flag) {
        if ($.trim($('#otp').val()) == '') {
            warningshow('Enter OTP', 'otp');
        }
        else if ($.trim($('#otpremarks').val()) == '') {
            warningshow('Enter Remarks', 'otpremarks');
        }
        else {
            var Operation = '';
            if (Flag == 0)
                Operation = 'Purchase Order Edit- OTP , Order No : ' + $("#purchaseOrderno").val();
            else if (Flag == 1)
                Operation = 'Purchase Order Delete- OTP , Order No : ' + $("#purchaseOrderno").val()

            var data = {};
            data.UserId = UId;
            data.OTP = $("#otp").val();
            data.Remarks = $('#otpremarks').val();
            data.Operation = Operation;
            data.DeptId = DepId;
            $.ajax({
                type: "POST",
                url: "../Home/OTPCheckforUser",
                data: data,
                success: function (result) {
                    for (var i = 0; i < result.oList.length; i++) {
                        var status = result.oList[i].Status;
                        OTPCheck(status, Flag)
                    }
                }
            });
        }
    }

    function OTPCheck(status, Flag) {
        if (status == 1) {
            if (Flag == 0) {
                EDitThisPO();
            }
            else if (Flag == 1) {
                DeleteThisPurchaseOrder();
            }

        }
        else {
            warningshow('Invalid OTP', 'otp');
            $("#otp").select();
        }
    }
    function DeleteThisPurchaseOrder() {
        $('#OTPDiv').hide();
        var data = {};
        data.OrderNo = $('#purchaseOrderno').val();
        data.DepartmentId = DepId;
        data.UserId = UId;
        $.ajax({
            type: "POST",
            url: "../Purchase/DeletePurchaseOrder",
            data: data,
            success: function (result) {

                var status = result.oList[0].Status;
                var slno = result.oList[0].OrderNo;
                Showalerts(status, slno);
            }
        })

    }
