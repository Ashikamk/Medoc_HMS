                    if (excelRows[j]["Product"] == undefined) { Product = '' } else { Product = excelRows[j]["Product"] }
                    if (excelRows[j]["Description"] == undefined) { Description = '' } else { Description = excelRows[j]["Description"] }
                    if (excelRows[j]["Unit"] == undefined) { Unit = '' } else { Unit = excelRows[j]["Unit"] }
                    if (excelRows[j]["Location"] == undefined) { Location = '' } else { Location = excelRows[j]["Location"] }
                    if (excelRows[j]["Quantity"] == undefined) { Quantity = '' } else { Quantity = excelRows[j]["Quantity"] }
                    if (excelRows[j]["Rate"] == undefined) { Rate = '' } else { Rate = excelRows[j]["Rate"] }
                    if (excelRows[j]["Discount"] == undefined) { Discount = '' } else { Discount = excelRows[j]["Discount"] }
                    if (excelRows[j]["Taxable"] == undefined) { Taxable = '' } else { Taxable = excelRows[j]["Taxable"] }
                    if (excelRows[j]["Tax"] == undefined) { Tax = '' } else { Tax = excelRows[j]["Tax"] }
                    if (excelRows[j]["TaxAmount"] == undefined) { TaxAmount = '' } else { TaxAmount = excelRows[j]["TaxAmount"] }
                    if (excelRows[j]["Amount"] == undefined) { Amount = '' } else { Amount = excelRows[j]["Amount"] }
                    if (excelRows[j]["AvgCost"] == undefined) { AvgCost = '' } else { AvgCost = excelRows[j]["AvgCost"] }

