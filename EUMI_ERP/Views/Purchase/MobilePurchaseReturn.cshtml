<script>

    $("#btnadd").focus(function (e) {
        $("#btnadd").removeClass("btn btn-outline-primary");
        $("#btnadd").addClass("btn btn-primary");
    });

    $("#btnadd").focusout(function (e) {
        $("#btnadd").removeClass("btn btn-outline-primary");
        $("#btnadd").addClass("btn btn-outline-primary");
    });

    //Job AutoComplete


    $('#baseicon').append(BaseCurrency)

    function Fnaddjobautocomplete(ID) {
        $("#jobcode_" + ID).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.JobCode = $("#jobcode_" + ID).val();

                $.ajax({
                    url: '../SalesInvoice/JobSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '2',
                                label: item.JobCode,
                                label1: item.Description,
                                JobCode: item.JobCode,
                                ProjectJobId: item.ProjectJobId,
                                headers: ["Job Code", "Description"]
                            })
                        }));
                    }



                })
            },
            autoFocus: true,

            select: function (event, ui) {
                $('#jobcode_' + ID).val(ui.item.JobCode)
                $('#jobcodeid_' + ID).val(ui.item.ProjectJobId)
            },

        });
        $("#jobcode_" + ID).keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                $('#jobcodeid_' + ID).val(0);


        });
    }


    $("#jobcode").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.JobCode = $("#jobcode").val();

            $.ajax({
                url: '../SalesInvoice/JobSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWO',
                            label: item.JobCode,
                            label1: item.Description,
                            ProjectJobId: item.ProjectJobId,
                            JobCode: item.JobCode,
                            headers: ["Job Code", "Description"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $('#jobcode').val(ui.item.JobCode)
            $('#jobid').val(ui.item.ProjectJobId)
            $('#jobcode_0').val(ui.item.JobCode)
            $('#jobcodeid_0').val(ui.item.ProjectJobId)
            $('#product_0').focus();
        },

    });

    $("#jobcode_0").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.JobCode = $("#jobcode_0").val();

            $.ajax({
                url: '../SalesInvoice/JobSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.JobCode,
                            label1: item.Description,
                            ProjectJobId: item.ProjectJobId,
                            headers: ["Job Code", "Description"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $('#jobcode_0').val(ui.item.JobCode)
            $('#jobcodeid_0').val(ui.item.ProjectJobId)
            $('#btnadd').focus();
        },

    });

    //Supplier AutoComplete

    $("#suppliername").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType ='S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '-2ph',
                            label: item.CustName,
                            label1: item.CustAccount,
                            label2: item.PhoneNumber,
                            CustId: item.CustId,
                            CurncyId: item.CurrencyId,
                            CustTermsId: item.CustTermsId,
                            AreaId: item.AreaId,
                            headers: ["Supplier Name", "Account Code", "Phone Number"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId);
            GetCurrency(ui.item.CurncyId)
            $('#terms').val(ui.item.CustTermsId);
