<script>
    function exportbilltotable() {
        var row = ""
        var EnqDate = $('#enquirydate').val();
        var EnqNo = $("#CopyEnquiryno").val(); var Supplier = $("#suppliername").val();

        row += '<tr><td><b>PE#</b></td><td><b>' + EnqNo + '</b></td><td><b>Enq.Date#<b></td><td><b>' + EnqDate + '</b></td></tr>';
        row += '<tr><td></td><td></td><td><b>Supplier</b></td><td><b>' + Supplier + '</b></td></tr>';
        row +='<tr></tr>'
        row += '<tr><td><b>Sl#</b></td><td><b>Item Code</b></td><td><b>Description</b></td><td><b>Quantity</b></td><td><b>Model</b></td></tr>'

        var Slno = 0;
        for (k = 1; k <= $('#tblpurchase_enquiry tr').length; k++) {
            Slno++;
            var ItemCode = $('#product_' + k).val();
            var Description = $('#productdesc_' + k).val();
            var Qunatity = $('#quantity_' + k).val();
            var Model = $('#Models_' + k).val();

         

            row += '<tr><td>' + Slno + '</td><td>' + ItemCode + '</td><td>' + Description + '</td><td>' + Qunatity + '</td><td>' + Model + '</td></tr>'
        }
        $('#tbExport').html('')
        $('#tbExport').append(row);
    }



    $(function () {
        $("#btnExporttoExcel").click(function () {

            if ($('#tblpurchase_enquiry tr').length > 0 && $("#CopyEnquiryno").val()!='') {
                exportbilltotable();
                var PENo = 'PE#-' + $('#CopyEnquiryno').val();
                $("#tbExport").table2excel({
                    filename: PENo + ".xls"
                });
            }
            else if ($('#tblpurchase_enquiry tr').length > 0 && $("#CopyEnquiryno").val() == '')
            {
                warningshow('Select a Valid Enquiry Number!', 'CopyEnquiryno');
                return false;
            }
            else {
                warningshow("No Transaction!");
            }
        });

    });



