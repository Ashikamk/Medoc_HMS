
@{
    ViewBag.Title = "salesreportsub";
}


<script type="text/javascript" src="~/ProjectScript/ReportPrint.js"></script>

<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>





<table style="display:none" id="Tblreportprint"></table>

<div class="myData" data-x="M420" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>
                        <table width="100%" style="table-layout:fixed">
                            <tr>
                                <td><h4 id="header">Sales Report</h4></td>

                                <td align="right">
                                    <div style="display:none;margin-left:4%" id="divsummary" class="d-inline-block custom-control custom-radio mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btnsummary" value="normal" onclick="LoadReport()" checked>
                                        <label class="custom-control-label" for="btnsummary">Summary </label>
                                    </div>
                                    <div style="display:none;margin-left:2%" id="divdetail" class="d-inline-block custom-control custom-radio mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btndetail" onchange="LoadReport()" value="normal">
                                        <label class="custom-control-label" for="btndetail">Detailed </label>
                                    </div>
                                    <button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#customername').focus()" id="btnback" class="btn btn-outline-primary">Back</button>
                                    @*<button type="button" style="width:100px;" id="btnprint" onclick="PrintthisReportWindows('SALESREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button>*@

                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>
                            </tr>
                        </table>
                        <div align="center">
                            <br /><hr style="margin-top:-1%" />
                            <div class="heading-elements" style="width:100%;">

                                <div id="divreport" style="overflow:auto;display:none;">
                                    <table id="Tblreport" width="100%" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:100%;">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Sales Report</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">

                    <div class="row">

                        <label class="col-md-2" style="font-weight:bold;">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>

                    </div>

                    <hr class="mt-1 mb-1" />

                    <div class="row mb-1">

                        <label class="col-md-2" style="font-weight:bold;">Customer</label>
                        <div class="col-md-10">
                            <table width="100%">
                                <tr>
                                    <td width="30%">
                                        <input type="text" id="customername" class="form-control" onkeyup="$('#custnames').val('')" style="border-right:none;border-top-right-radius:0px;border-bottom-right-radius:0px;text-align:left">
                                        <input type="hidden" id="customerId" class="form-control" />
                                    </td>
                                    <td>
                                        <input type="text" id="custnames" class="form-control" onchange="" autocomplete="off" style="border-top-left-radius:0px;border-bottom-left-radius:0px;border-left:none;background-color:white" disabled>
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>


                    <div class="row mb-1">

                        <label class="col-md-2" style="font-weight:bold;">Doctor</label>
                        <div class="col-md-4">
                            <select id="Doctor" name="priority" class="form-control"></select>
                        </div>
                        <label class="col-md-2 text-right" style="font-weight:bold;">Pay Type</label>
                        <div class="col-md-4">
                            <select id="PayType" class="form-control" name="priority">
                                <option value="0">-All-</option>
                                <option value="1">Cash</option>
                                <option value="2">Credit</option>
                                <option value="3">Card</option>
                            </select>
                        </div>

                    </div>

                    <div class="row mb-1">

                        <label class="col-md-2" style="font-weight:bold;">Dept.</label>
                        <div class="col-md-4">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>

                        <label class="col-md-2 text-right" style="font-weight:bold;">User</label>
                        <div class="col-md-4">
                            <input type="text" id="User" maxlength="100" class="form-control">
                            <input type="hidden" id="UserId" class="form-control" />
                        </div>


                    </div>

                    <div class="row mb-1">

                        <label class="col-md-2" style="font-weight:bold;">Loc.</label>
                        <div class="col-md-4">
                            <select id="location" name="priority" class="form-control"></select>
                        </div>


                        <label class="col-md-2 text-right" style="font-weight:bold;">Series </label>
                        <div class="col-md-4">
                            <select id="placeofsupply" name="priority" class="form-control"></select>
                        </div>



                    </div>
                    <div class="row mb-1">

                        <label class="col-md-2" style="font-weight:bold;">Salesman </label>
                        <div class="col-md-4">
                            <select id="salesman" name="priority" class="form-control"></select>
                        </div>



                    </div>
                </div>
                <div class="modal-footer">
                    <table class="p-2" style="table-layout:fixed" width="100%">
                        <tr>
                            <td>
                                <fieldset class="form-group floating-label-form-group pl-2" style="">
                                    <div class="row">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" checked class="custom-control-input" name="customCheck" id="grpbyall">
                                            <label class="custom-control-label" for="grpbyall" style="font-weight:bold">Detailed</label>
                                        </div>

                                    </div>
                                </fieldset>
                            </td>
                            <td>
                                <fieldset class="form-group floating-label-form-group" style="">
                                    <div class="row">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" checked name="customCheck" id="grpbySR">
                                            <label class="custom-control-label" for="grpbySR" style="font-weight:bold">Sales Return</label>
                                        </div>
                                    </div>

                                </fieldset>
                            </td>
                            <td>
                                <fieldset class="form-group floating-label-form-group" style="">
                                    <div class="row">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" name="grpbymonth" id="grpbymonth">
                                            <label class="custom-control-label" for="grpbymonth" style="font-weight:bold">Monthly</label>
                                        </div>
                                    </div>

                                </fieldset>
                            </td>
                            <td align="right">
                                <button type="button" style="width:80px" id="btnsubmit" class="btn btn-primary">Go</button>
                            </td>
                        </tr>
                    </table>





                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />

                </div>

            </form>
        </div>
    </div>
</div>
<div style="display:none;">

    <label class="col-md-2 text-right" style="font-weight:bold;">Salesman</label>
    <div class="col-md-3">
        <select id="salesman" name="priority" class="form-control"></select>
    </div>
</div>
<script>
    var SummaryFlag = 0;
    //Customername Autocomplete



    $("#customername").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#customerId').val(0);
            var data = {};
            data.PatientName = $("#customername").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Revisit/HMS_PatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.OPSerName + '-' + item.OPNumber,
                            label1: item.PatientName,
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            PatientName: item.PatientName,
                            headers: ["RegNo", "Patient"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {

            //dropdownbind
            $('#customerId').val(ui.item.PatientId)
            $('#customername').val(ui.item.PatientName)
            $("#custnames").val(ui.item.PatientName);

        },

    });
    //User Autocomplete

    $("#User").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.UserName = $("#User").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        console.log(data)
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            value2: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#UserId').val(ui.item.value2)
            $('#User').val(ui.item.UserName)
        },

    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function LoadReport() {

        if ($("#btndetail").prop("checked")) { $('#grpbyall').prop("checked", true); }
        else { $('#grpbyall').prop("checked", false); }
        $("#btnsubmit").click();
    }

    function Showreport(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Bill#</th><th style='text-align:center'>Date</th><th style='text-align:center'>Time</th><th style='text-align:center'>Reg#</th><th>Patient</th><th>In fee</th><th style=display:none>SalesmanCode</th><th style=display:none>Disc.</th><th style='text-align:right;display:none'>Taxable</th><th style='text-align:right;display:none'>Tax</th><th style=display:none style='text-align:right'>Proc</th><th style=display:none style='text-align:right'>RoundOff</th><th style='text-align:right'>Pharma</th><th style=display:nonee>Vacc Fee</th>   <th style=display:nonee>Dres Fee</th> <th style=display:nonee>Con Fee</th> <th style=display:nonee>Neb Fee</th> <th style=display:nonee>Total</th> </tr></thead><tbody>";


        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            console.log(slno)
            var XX = (result[i].InvDate+'##').split("##")
            if (result[i].CustoName == 'GRAND TOTAL' || result[i].CustoName == 'Cash Sales' || result[i].CustoName == 'Cash Sales Total' || result[i].CustoName == 'CARD SALES TOTAL' || result[i].CustoName == 'CARD SALES' || result[i].CustoName == 'Grand Total' || result[i].CustoName == 'Credit Sales' || result[i].CustoName == 'Credit Total' || result[i].CustoName == 'UPI Total' || result[i].CustoName == 'UPI Sales' || result[i].CustoName == 'Sales Return' || result[i].CustoName == 'Sales Return Total' || result[i].CustoName == 'Sales Total') {
                var salesman = (result[i].FirstName);
                salesman = salesman.substring(0, 10);
                //responseText += '<tr  style=background-color:#cfd8dc><td style=text-align:center>' + slno + '</td><td id="Col2x_' + slno + '"></td><td id="Col3_' + slno + '" style=text-align:center ><b>' + result[i].InvDate + '</b></td> <td></td><td  id="Col8x_' + slno + '" >' + result[i].AccCode + '</td><td id="Col4_' + slno + '"><b>' + result[i].CustoName + '</b></td><td id="Col5_' + slno + '">' + result[i].FirstName + '</td><td id="Col5x_' + slno + '" style=display:none>' + result[i].Code + '</td><td style=display:none style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].BillDiscount || 0).toFixed(Decimal)) + '</b></td><td style=text-align:right;display:none><b>' + ReplaceNumberWithCommas(parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal)) + '</b></td><td  style=text-align:right;display:none><b>' + ReplaceNumberWithCommas(parseFloat(result[i].TotalTax || 0).toFixed(Decimal)) + '</b><td style=display:none style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].ReceivedAmount || 0).toFixed(Decimal)) + '</b></td><td style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].RoundGrandTotal || 0).toFixed(Decimal)) + '</b></td><td style=display:none id="Col6_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].SalesAmount || 0).toFixed(Decimal)) + '</b></td><td id="Col7x_' + slno + '" style=text-align:right><b>' + result[i].DepartmentCode + ' </td> <td id="Col8x_' + slno + '"style=text-align:right><b>' + result[i].DepartmentName + ' </td> <td id="Col9x_' + slno + '" style=text-align:right><b>' + result[i].CurrencyName + ' </td> <td id="Col10x_' + slno + '" style=text-align:right><b>' + result[i].CurrencyRate + ' </td>  <td id="Col10x_' + slno + '" style=text-align:right><b>' + (result[i].CessAmount).toFixed(2) + ' </td> </tr>';
                responseText += '<tr style=background-color:#cfd8dc><td style=text-align:center>' + slno + '</td><td id="Col2x_' + slno + '">' + result[i].Billdescription + '-' + result[i].BillSlNo + '</td><td id="Col3_' + slno + '" style=text-align:center>' + XX[0] + '</td>   <td id="Col3_' + slno + '" style=text-align:center>' + XX[1] + '</td>     <td id="Col8x_' + slno + '">' + result[i].AccCode + '</td><td id="Col4_' + slno + '"><b>' + result[i].CustoName + '</td><td id="Col5_' + slno + '"><b>' + result[i].FirstName + '</b></td><td id="Col5x_' + slno + '" style=display:none>' + result[i].Code + '</td><td style=display:none style=text-align:right>' + parseFloat(result[i].BillDiscount || 0).toFixed(Decimal) + '</td><td style=text-align:righ;display:none>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td><td  style=text-align:right;display:none>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td><td style=display:none style=text-align:right>' + parseFloat(result[i].ReceivedAmount || 0).toFixed(Decimal) + '</td><td style=display:none style=text-align:right>' + parseFloat(result[i].RoundGrandTotal || 0).toFixed(Decimal) + '</td><td id="Col6_' + slno + '" style=text-align:right><b>' + parseFloat(result[i].SalesAmount || 0).toFixed(Decimal) + '</td><td id="Col7x_' + slno + '" style=text-align:right><b>' + result[i].DepartmentCode + ' </td>  <td id="Col8x_' + slno + '" style=text-align:right><b>' + result[i].DepartmentName + ' </td> <td id="Col9x_' + slno + '" style=text-align:right><b>' + result[i].CurrencyName + ' </td> <td id="Col10x_' + slno + '" style=text-align:right><b>' + result[i].CurrencyRate + ' </td>  <td id="Col10x_' + slno + '" style=text-align:right><b>' + (result[i].CessAmount).toFixed(2) + ' </td>  </tr>';

            }

            else {
                var salesman = (result[i].FirstName);
                salesman = salesman.substring(0, 10);
                responseText += '<tr><td style=text-align:center>' + slno + '</td><td id="Col2x_' + slno + '">' + result[i].Billdescription + '-' + result[i].BillSlNo + '</td><td id="Col3_' + slno + '" style=text-align:center>' + XX[0] + '</td>   <td id="Col3_' + slno + '" style=text-align:center>' + XX[1] + '</td>     <td id="Col8x_' + slno + '">' + result[i].AccCode + '</td><td id="Col4_' + slno + '">' + result[i].CustoName + '</td><td id="Col5_' + slno + '">' + result[i].FirstName + '</td><td id="Col5x_' + slno + '" style=display:none>' + result[i].Code + '</td><td style=display:none style=text-align:right>' + parseFloat(result[i].BillDiscount || 0).toFixed(Decimal) + '</td><td style=text-align:righ;display:none>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td><td  style=text-align:right;display:none>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td><td style=display:none style=text-align:right>' + parseFloat(result[i].ReceivedAmount || 0).toFixed(Decimal) + '</td><td style=display:none style=text-align:right>' + parseFloat(result[i].RoundGrandTotal || 0).toFixed(Decimal) + '</td><td width=25px  id="Col6_' + slno + '" style=text-align:right>' + parseFloat(result[i].SalesAmount || 0).toFixed(Decimal) + '</td><td width=25px  id="Col7x_' + slno + '" style=text-align:right>' + result[i].DepartmentCode + ' </td>  <td width=25px  id="Col8x_' + slno + '" style=text-align:right>' + result[i].DepartmentName + ' </td> <td width=25px  id="Col9x_' + slno + '" style=text-align:right>' + result[i].CurrencyName + ' </td> <td width=25px  id="Col10x_' + slno + '" style=text-align:right>' + result[i].CurrencyRate + ' </td>  <td width=25px id="Col10x_' + slno + '" style=text-align:right><b>' + (result[i].CessAmount).toFixed(2) + ' </td>  </tr>';
            }

        }
        $('#Tblreport').html(responseText + '</tbody>');
        $('#Tblreportprint').html(responseText)
        var title = "Sales Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace', 1);
        $('#header').text(title);
        $('#ResultLength').val(result.length);

    }


    function Showreportuncheckedmonthly(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Dept.Code</th><th style='text-align:center'>Date</th><th style='text-align:right'>Taxable Amount</th><th style='text-align:right'>Tax Amount</th><th style='text-align:right'>Amount</th></tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            responseText += '<tr><td style=text-align:center>' + slno + '</td>' +
                '<td  style=text-align:center>' + result[i].DepartmentCode + '</td>' +
                '<td  style=text-align:center>' + result[i].InvDate + '</td>' +
                '<td  style=text-align:right>' + parseFloat(result[i].TotalTaxable || 0).toFixed(Decimal) + '</td>' +
                '<td  style=text-align:right>' + parseFloat(result[i].TotalTax || 0).toFixed(Decimal) + '</td> ' +
                '<td  style=text-align:right>' + parseFloat(result[i].SalesAmount || 0).toFixed(Decimal) + '</td></tr>';

        }
        $('#Tblreport').html(responseText + '</tbody>');
        //$('#Tblreportprint').html(responseText)
        var title = "Sales Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace', 3);
        $('#header').text(title);
        $('#ResultLength').val(result.length);
    }




    function Showreportunchecked(result) {

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th style='text-align:center'>Sl#</th><th>Dept.Code</th><th style=display:none>Dept Code1</th><th>Bill#</th><th style='text-align:center'>Date</th style='text-align:center'><th>Reg#</th><th>Patient</th><th>Doctor</th><th>SalesmanCode</th><th style='text-align:right'>Total Amount</th><th style='text-align:right'>Proce Amount</th><th style='text-align:right'>Spl Fee</th></tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].InvDate == 'Grand Total') {
                var salesman = (result[i].FirstName);
                salesman = salesman.substring(0, 10);
                responseText += '<tr  style=background-color:#cfd8dc><td style=text-align:center>' + slno + '</td><td id="Col7_' + slno + '">' + result[i].DepartmentName + '</td><td id="Col7x_' + slno + '" style=display:none>' + result[i].DepartmentCode + ' </td><td id="Col2x_' + slno + '"></td><td id="Col3_' + slno + '" style=text-align:center><b>TOTAL</b></td><td id="Col8x_' + slno + '">' + result[i].AccCode + '</td><td id="Col4_' + slno + '">' + result[i].CustoName + '</td><td id="Col5_' + slno + '">' + result[i].FirstName + '</td><td id="Col5x_' + slno + '" style=display:none>' + result[i].Code + '</td><td id="Col6_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].SalesAmount || 0).toFixed(Decimal)) + '</b></td><td id="Col6_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].SpecialAmount || 0).toFixed(Decimal)) + '</b></td><td id="Col6_' + slno + '" style=text-align:right><b>' + ReplaceNumberWithCommas(parseFloat(result[i].ProcedAount || 0).toFixed(Decimal)) + '</b></td></tr>';
            }
            else {
                var salesman = (result[i].FirstName);
                salesman = salesman.substring(0, 10);
                responseText += '<tr ondblclick=gotoInvoNo(' + result[i].BillSlNo + "," + result[i].BillSeriesId + ",'" + result[i].SType + "'," + result[i].DeptId + ')><td style=text-align:center>' + slno + '</td><td id="Col7_' + slno + '">' + result[i].DepartmentName + '</td><td id="Col7x_' + slno + '" style=display:none>' + result[i].DepartmentCode + ' </td><td id="Col2x_' + slno + '">' + result[i].Billdescription + '-' + result[i].BillSlNo + '</td><td id="Col3_' + slno + '" style=text-align:center>' + result[i].InvDate + '</td><td id="Col8x_' + slno + '">' + result[i].AccCode + '</td><td id="Col4_' + slno + '">' + result[i].CustoName + '</td><td id="Col5_' + slno + '">' + result[i].FirstName + '</td><td id="Col5x_' + slno + '" style=display:none>' + result[i].Code + '</td><td id="Col6_' + slno + '" style=text-align:right>' + parseFloat(result[i].SalesAmount || 0).toFixed(Decimal) + '</td> <td id="Col6_' + slno + '" style=text-align:right>' + parseFloat(result[i].ProcedAount || 0).toFixed(Decimal) + '</td> <td id="Col6_' + slno + '" style=text-align:right>' + parseFloat(result[i].SpecialAmount || 0).toFixed(Decimal) + '</td></tr>';
