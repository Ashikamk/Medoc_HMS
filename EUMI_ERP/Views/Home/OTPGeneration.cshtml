
@{
    ViewBag.Title = "OTPGeneration";
}


<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>



<div class="myData" data-x="M156" />

<div id="" style="margin-top:2%; margin-left:30%">
    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0"> OTP GENERATION</h4>
                </div>
                <div class="card-body">
                    <div class="px-5">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>
                                <form action="#">
                                    <div class="form-body">

                                        <div class="form-group row">
                                            <label class="col-md-3 label-control" for="userinput2">User<span class="danger">*</span></label>
                                            <div class="col-md-9">
                                                <input type="text" id="otptouser" class="form-control" autofocus="" /><input type="hidden" id="OTPUID" value="0" class="form-control" maxlength="10" /> 
                                            </div>
                                        </div>


                                        <div class="form-group row">
                                            <label class="col-md-3 label-control" for="userinput2">OTP<span class="danger">*</span></label>
                                            <div class="col-md-9">
                                                <input type="text" id="otpcode" class="form-control" maxlength="10" onkeypress="isNumberInt(event,this)" />
                                            </div>
                                        </div>

                                        <div class="form-group row">
                                            <label class="col-md-3 label-control" for="userinput2">Count<span class="danger">*</span></label>
                                            <div class="col-md-9">
                                                <input type="text" value="1" id="otpcount" class="form-control" onkeypress="isNumberInt(event,this)"/>
                                            </div>
                                        </div>

                                        <div class="form-group row">
                                            <label class="col-md-3 label-control" for="userinput2">Remarks<span class="danger">*</span></label>
                                            <div class="col-md-9">
                                                <textarea class="form-control" id="otpremarks" style="height:100px"></textarea>
                                            </div>
                                        </div>

                                    </div>
                                    <div class="form-actions">
                                        <div class="text-right">
                                            <button type="button" onclick="OTPUpdate(0)" class="btn btn-outline-warning" autofocus="">DeActivate</button>
                                            <button type="button" onclick="formrefresh()" class="btn grey btn-outline-secondary" data-dismiss="modal">Cancel</button>
                                            <button type="button" onclick="OTPUpdate(1)" class="btn btn-outline-primary" autofocus="">Activate</button>
                                            
                                           
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>

    $(document).ready(function () {
        $('#otptouser').focus();
    });


 


    $("#otptouser").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data1 = {};
            data1.UserName = $("#otptouser").val();

            $.ajax({
                url: '../Master/UserSearchInUserMenuSettings',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        console.log(data)
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            UserRole: item.UserRole,
                            MenuCode: item.MenuCode,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#OTPUID').val(ui.item.UserId)
            $('#otpcode').focus();
            GetOTP();

        },
    });


    function GetOTP() {
        var data = {};   //array
        data.UserId = $('#OTPUID').val();
        $.ajax({
            type: "POST",
            url: "../Home/OTPGetandGets",
            data: data,
            success: function (result) {
                for (var i = 0; i <= result.oList.length; i++) {
                    var status = result.oList[i].Status;
                    if (status == 1) {
                        $('#otpcode').val(result.oList[i].OTP);
                        $('#otpcount').val(result.oList[i].OTPCount);
                        $('#otpremarks').val(result.oList[i].Remarks);
                    }
                    else {
                        $('#otpcode').val('');
                        $('#otpcount').val(1);
                        $('#otpremarks').val('');
                    }
                }

            }
        });
    }
    function OTPUpdate(Flag) {

        if ($('#OTPUID').val() == 0) {
            warningshow("Select Valid User", 'otptouser');
        }
        else if ($.trim($('#otpcode').val())=='') {
            warningshow("Please Enter OTP", 'otpcode');
        }
        else if ($.trim($('#otpcount').val()) == '') {
            warningshow("Please Enter OTP Count", 'otpcount');
        }
        else if($.trim($('#otpremarks').val()) == ''){
            warningshow("Please Enter Remarks", 'otpremarks');
        }
        else {

            var data = {};   //array
            data.UserId = $('#OTPUID').val();
            data.OTP = $('#otpcode').val();
            data.OTPCount = $('#otpcount').val();
            data.Remarks = $('#otpremarks').val();
            data.Deactivate = Flag;
            $.ajax({
                type: "POST",
                url: "../Home/OTPInsertandUpdate",
                data: data,
                success: function (result) {
                    for (var i = 0; i <= result.oList.length; i++) {
                        var status = result.oList[i].Status;
                        Showalerts(status);
                    }

                }
            });
        }



    }

    function formrefresh (){
        $('#OTPUID').val(0);
        $('#otpcode').val('');
        $('#otpcount').val(1);
        $('#otpremarks').val('');
        $('#otptouser').val('');
        Defaultfocus()
    }
    function Defaultfocus() {
        $('#otptouser').focus();
    }

    function isNumberInt(evt, selectedvalue) {
        var charCode = (evt.which) ? evt.which : event.keyCode
        $(selectedvalue).val($(selectedvalue).val().replace(/[^0-9\.]/g, ''));
        if (charCode != 8 && charCode != 13 && (charCode < 48 || charCode > 57)) {
            evt.preventDefault();
            warningshow('Digits Only')
            return false;
        }
        return true;

    }

    //Show Window Alert Insert,update delete  Modify
    function Showalerts(Status) {
        if (Status == 1) {
            formrefresh();
            swal('OTP Activated', "", "success");
            $('.swal-button swal-button--confirm').focus();
        }
        else if (Status == 2) {
            formrefresh();
            swal('OTP Updated', "", "success");
            $('.swal-button swal-button--confirm').focus();

        }
        else if (Status == 3) {
            formrefresh();
            swal('OTP Deactivated', "", "error");
            $('.swal-button swal-button--confirm').focus();
        }
    }
    //Show Warnig Popup right top
    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

</script>





  

      
