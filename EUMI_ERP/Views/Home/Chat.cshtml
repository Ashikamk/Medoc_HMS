<script>
window.addEventListener('error', function(e) {
    console.log(e);

}, true);

    var Count = 0;
    GetUsers();
    function GetUsers() {
        var data = {};
        data.UserId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/UsersGetandGets",
            data: data,
            success: function (result) {
                ShowUserslist(result.oList);

               

            }
        });
    }


   
    function Getmessage(Flag) {

        if (Flag == 'All')
        {
            $('#chatwindow').html('')
        }
       
        if (Count == 0) {
            Count=1
            var data = {};
            data.SenderId = ERPUserId;
            data.ReceiverId = $('#chatreceverId').val();
            data.Viewflag = 0;
            data.DelFlag = 0;
            data.Status = Flag;


            $.ajax({
                type: "POST",
                url: "../Home/Ex_ChatGet",
                data: data,
                success: function (result) {
                    result = result.oList;
                    for (var i = 0; i < result.length; i++) {
                        var Sender = result[i].SenderId
                        if (ERPUserId != Sender)
                        {
                            var MsgRow = ' <div class="chat chat-left"><div class="chat-avatar"><a class="avatar" data-toggle="tooltip" href="#" data-placement="left" title="" data-original-title=""><img src="../app-assets/img/portrait/small/avatar-s-7.png" class="width-50 rounded-circle" alt="avatar" ></a></div><div class="chat-body"><div class="chat-content"><p>' + result[i].ChatMessage + '</p></div></div></div>';
                        }
                        else
                        {
                            var MsgRow = ' <div class="chat"><div class="chat-avatar"><a class="avatar" data-toggle="tooltip" href="#" data-placement="right" title="" data-original-title=""><img src="../app-assets/img/portrait/small/avatar-s-1.png" class="width-50 rounded-circle" alt="avatar"></a></div><div class="chat-body"><div class="chat-content"><p>' + result[i].ChatMessage + '</p></div></div></div>';

                        }
                        $('#chatwindow').append(MsgRow)
                    }
                    Count = 0
                   
                }
            });
        }

    }





    setInterval(function () {
        if($('#chatreceverId').val()!=0)
        {
            Getmessage('Now');
        }
        
    }, 5000);

    

  


