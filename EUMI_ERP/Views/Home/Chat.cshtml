    //});
   
    function imgLoaded(imgElement) {
        return $('#image_2').complete && imgElement.naturalHeight !== 0; 
    }
 


    function ShowUserslist(result) {
        var data = "";

        for (var i = 0; i < result.length; i++) {
            
           
            var status = result[i].Status;
            var userid = result[i].UserId;
            var username = result[i].Name;
            if (status==404) {
                data = '<a id=' + "rec" + userid + ' onclick="sennmessagetothis(' + userid + ')" class="list-group-item no-border"><span class="media">' +
                   '<span class="avatar avatar-md avatar-online">' +
                   '<img class="media-object d-flex mr-3 bg-primary height-50 rounded-circle" src= "../app-assets/img/portrait/small/avatar-s-1.png" ><i></i></span><div class="media-body"><h6  class="list-group-item-heading"><span id=' + "Recname" + userid + '>' + username + '</span><span class="font-small-3 float-right primary">4:14 AM</span></h6><p class="list-group-item-text text-muted"><i class="ft-check primary font-small-2"></i> demo<span class="float-right primary"><i class="font-medium-1 icon-pin blue-grey lighten-3"></i></span></p></div></span></a>';
                $('#userlist').append(data);
            }
            else {
                data = '<a id=' + "rec" + userid + ' onclick="sennmessagetothis(' + userid + ')" class="list-group-item no-border"><span class="media">' +
                    '<span class="avatar avatar-md avatar-online">' +
                    '<img class="rounded-circle" height="45" width="45" src="../ProjectImages/User/Image/' + userid + '.png" alt=""><i></i></span><div class="media-body"><h6  class="list-group-item-heading"><span id=' + "Recname" + userid + '>' + username + '</span><span class="font-small-3 float-right primary">4:14 AM</span></h6><p class="list-group-item-text text-muted"><i class="ft-check primary font-small-2"></i> demo<span class="float-right primary"><i class="font-medium-1 icon-pin blue-grey lighten-3"></i></span></p></div></span></a>';
                $('#userlist').append(data);

            }

 
        

        }
       
    }


    function sennmessagetothis(UID)
    {
        var userid = UID;
       $('#chatreceverId').val(UID);
       $('#recever').html('');
       var recever = '<div class="media-body"><img src="../ProjectImages/User/Image/' + userid + '.png" width="37" class="rounded-circle mr-1" alt="avatar"><span>' + $('#Recname' + UID).text() + '</span><i class="ft-more-vertical float-right mt-1"></i></div>'
       $('#recever').append(recever);
       Getmessage('All')

    }


    function sendmessage() {

        var Message = $('#iconLeft4').val();
        var MsgRow = ' <div class="chat"><div class="chat-avatar"><a class="avatar" data-toggle="tooltip" href="#" data-placement="right" title="" data-original-title=""><img src="../app-assets/img/portrait/small/avatar-s-1.png" class="width-50 rounded-circle" alt="avatar"></a></div><div class="chat-body"><div class="chat-content"><p>' + Message + '</p></div></div></div>';
        $('#chatwindow').append(MsgRow)

        var data = {};
        data.Ex_ChatId = 1;
        data.SenderId = ERPUserId;
        data.ReceiverId =$('#chatreceverId').val();
        data.ChatMessage = $('#iconLeft4').val();
        data.Date = $('#Date').val();
        data.DelFlag = 1;
        $.ajax({
            type: "POST",
            url: "../Home/Ex_ChatInsert",
            data: data,
            success: function (result) {
                $('#iconLeft4').val('');
                $('#iconLeft4').focus();
                  
            }
        });

    }

   
  

