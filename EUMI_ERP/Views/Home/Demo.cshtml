<body>

    <input id="data" type="text" value="Enter QR-Code data">

    <div id="qrcode"></div>



    <script>

        var createQRCode = function () {
            var data = $('#data').val();
            $('#qrcode').empty();
            $('#qrcode').qrcode(data);
            $('#qrcode').append('</br><strong>' + data + '</strong>');
        };

        $('#data').keyup(createQRCode);
        $('#data').change(createQRCode);
    </script>



    <script type="text/javascript">
    $(document).ready(function () {

        if ("@Request.QueryString["from"]" == "productlist") {
            var id = sessionStorage.getItem("inventory_productlist_id");
            sessionStorage.removeItem("inventory_productlist_id");
            var numId = parseInt(id, 10);
            if (!isNaN(numId)) {
                $('#Loading').show();
                jQuery(window).load(function () {
                    //alert('page is loaded');
                    setTimeout(GetRows(numId), 3000);

                });

            }
        }
    });

    function locationwiseqtyupdateclear() {
        $('#opqty').val(0);
    }


    function locationwiseqtyupdate()
    {
        var Qty = 0;
        $('#popupdiv').hide();
        var num = parseInt($('#NoOfLocations').val()-1);
        for (var i = 0; i <= num ; i++) {
            var LocationID = $('#locID' + i).val();
            var LocationQty = parseInt($('#lqty' + LocationID).val()||0);
            if (LocationQty != 0) {
                Qty +=LocationQty;
            }
        }
        $('#opqty').val(Qty);
    }


    function AddmoreImages()
    {
        var Imgcount=parseInt($('#Imagecount').val())
        var file = '<div id=' + "Imgdiv" + Imgcount + '><input type="file" id=' + 'SelmultiImage' + Imgcount + ' accept="image/*" onchange="readMultipleimageURL(this,' + Imgcount + ')"" class="btn btn-lg gradient-back-to-earth font-small-1 white p-2 mr-2"><img id=' + "Mimg" + Imgcount + ' src="../app-assets/img/portrait/small/avatar-s-12.png" alt="Gini" width="50" style="margin-top:-18px" class="img-thumbnail multiimagebox" onerror="this.onerror=null; this.src=../app-assets/img/portrait/small/avatar-s-12.png;">&#160;&#160;<button type="button" class="btn btn-danger" onclick="RemoveImages(' + Imgcount + ')"> <i class="ft-x"></i>Remove</button></div>'
        $('#divmultimage').append(file).show('slow');
        $('#Imagecount').val(Imgcount+1)
    }


    function RemoveImages(ImgId)
    {
        $('#Imgdiv' + ImgId).slideUp( function () { $('#Imgdiv' + ImgId).remove(); });
        //$('#Imgdiv' + ImgId).remove();

    }









