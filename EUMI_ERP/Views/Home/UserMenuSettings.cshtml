    </div>
    </div>

<script>
    var MenuLength = 0;
    $(document).ready(function () {
        $('#Loading').fadeIn();
        getallmenus();
        // GetRows(0);

        Defaultfocus();

        $("#btnsubmit").click(function () {

         if ($('#User').val() == '') 
            {
                warningshow("Please Select User", 'User');
                $('#User').select();
            }
         else if ($('#UserId').val() == 0 || $('#UserId').val() == '')
           {
            warningshow("Please Select Valid User", 'User');
            $('#User').select();
           }
          else { 
                var a = '';
                for (var i = 1; i <= MenuLength; i++) {
                    if ($("#checklabel" + i).is(":checked")) {
                        if ($('#head' + i).val() != 'MM') {
                            a += $('#Menucodeid' + i).val() + ','
                        }
                    }
                }

                var data = {};
                data.UserId = $('#UserId').val();
                data.UserRole = '';
                data.MenuCode = a;
                $.ajax({
                    type: "POST",
                    url: "../Master/UserMenuUpdate",
                    data: data,
                    success: function (result) {
                        for (var i = 0; i <= result.oList.length; i++) {
                            var status = result.oList[i].Status;
                            Showalerts(status);
                        }
                    }
                });

            }           
                
        });


       
    });


    function checkemptyuser(evt) {
        var charCode = (evt.which) ? evt.which : event.keyCode;
        if (charCode != 13) {
            $('#UserId').val(0);
            $('#UserRole').val(0);
            $('.chebox').prop('checked', false);
        }
    }


    function Defaultfocus() {
        $('#User').focus();
    }


    function formrefresh() {
        $('#User').val('');
        $('#UserId').val(0);
        $('#CopyUserId').val(0);
        $('#UserRole').val(0);
        $('.chebox').prop('checked', false);

    }

    function getallmenus() {
        var datax = {};
        datax.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../LocationTransfer/SubMenuGetandGets",
            data:datax,
            success: function (result) {
                showMenulist(result.oList)

            }
        });

    }


    function showMenulist(result) {
        MenuLength = result.length;
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            var row = '<li id="row' + slno + '" class="list-group-item"><div style="float:left"><a class="menu-item" target="_blank"><i class="fa fa-paper-plane-o mr-1"></i>  ' + result[i].MenuName + '</a></div> <div style="float:right"<fieldset><div class="custom-control custom-checkbox"><input type="checkbox" class="custom-control-input chebox" onchange=check(' + slno + ') id="checklabel' + slno + '"><label class="custom-control-label" for="checklabel' + slno + '" ></label><input style=display:none type=text value=' + result[i].HFlag + ' id="head' + slno + '" /><input style=display:none type=text value=' + result[i].MasterId + ' id="Masterid' + slno + '" /><input style=display:none type=text  value=' + result[i].MenuCode + ' id="Menucodeid' + slno + '" /></div></fieldset></div></li>';

            if (result[i].MasterId == 25 || result[i].MasterId == 1 || result[i].MasterId == 2 || result[i].MasterId == 3 || result[i].MasterId == 16 || result[i].MasterId == 23 || result[i].MasterId == 17) {
                $('#um0').append(row);
                $('#UMDiv1').show();
            }
            else if (result[i].MasterId == 26 || result[i].MasterId == 4 || result[i].MasterId == 5 || result[i].MasterId == 12 || result[i].MasterId == 21 || result[i].MasterId == 24) {
                $('#um1').append(row);
                $('#UMDiv2').show();
            }
            else if (result[i].MasterId == 27 || result[i].MasterId == 6 || result[i].MasterId == 7 || result[i].MasterId == 14 || result[i].MasterId == 20 || result[i].MasterId == 18) {
                $('#um2').append(row);
                $('#UMDiv3').show();
            }
            else if (result[i].MasterId == 8 || result[i].MasterId == 9 || result[i].MasterId == 10 || result[i].MasterId == 11 || result[i].MasterId == 13  || result[i].MasterId == 22 || result[i].MasterId == 15 || result[i].MasterId == 19) {
                $('#um3').append(row);
                $('#UMDiv4').show();
            }
            if ($('#head' + slno).val() == 'MM') {
                $('#row' + slno).css('background-color', '#009DA0')
                $("#row" + slno).css("color", "white");
            }

        }
        $('#Loading').fadeOut();
    }

    function check(id) {

        var flag = $("#checklabel" + id).is(":checked")
        if ($('#head' + id).val() == 'MM') {

            for (var j = 1; j <= MenuLength; j++) {


                if ($('#Masterid' + id).val() == $('#Masterid' + j).val()) {
                    document.getElementById("checklabel" + j).checked = flag;
                }
            }
        }
    }

    $("#User").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data1 = {};
            data1.UserName = $("#User").val();

            $.ajax({
                url: '../Master/UserSearchInUserMenuSettings',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {

                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            UserRole: item.UserRole,
                            MenuCode:item.MenuCode,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('.chebox').prop('checked', false);
            $('#UserId').val(ui.item.UserId);
            
            if (ui.item.UserRole == 0 || ui.item.UserRole == '') {
                $('#UserRole').val(0);
            } else {
                $('#UserRole').val(ui.item.UserRole);
            }
            GetCurrentMenu(ui.item.MenuCode)
        },
    });


    $("#copyuser").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data1 = {};
            data1.UserName = $("#copyuser").val();

            $.ajax({
                url: '../Master/UserSearchInUserMenuSettings',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {

                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CopyUserId').val(ui.item.UserId);
        },
    });



    function GetCurrentMenu(MenuCode) {
        var array = MenuCode.split(',');
        console.log(array)
        for (var i = 1; i <= MenuLength; i++) {
            console.log(array.indexOf($('#Menucodeid' + i).val()));            
            if(array.indexOf($('#Menucodeid'+i).val())!=-1)
            {
                $('#checklabel'+i).prop('checked', true);
            }
        }
        $('#CopyDiv').hide();
    }












    function UserRoleLoad(result) {
        $("#UserRole").empty();
        $("#UserRole").append("<option value='0'>Select UserRole</option>");
        for (var i = 0; i < result.length; i++) {
            $("#UserRole").append("<option value='" + result[i].Name + "</option>");
        }
    }




    function ShowPopup()
    {
        if ($('#UserId').val() == 0) {
            warningshow("Please Select User", 'User');
        }
        else {
            $('#copyuser').val('');
            $('#CopyUserId').val(0);
            $('#CopyDiv').show();
            $('#copyuser').focus();
        }
    }

    function CopyUserRights() {
        if ($('#CopyUserId').val() == 0) {
            warningshow("Please Select User", 'copyuser');
        }
        else if ($('#CopyUserId').val() == $('#UserId').val()) {
            warningshow("Cannot Copy From Same User", 'copyuser');
        }
        else {
            var data = {};
            data.UserId = $('#CopyUserId').val();
            $.ajax({
                type: "POST",
                url: "../Master/UserMenuSearch",
                data: data,
                success: function (result) {
                    console.log(result.oList[0].MenuCode)
                    $('.chebox').prop('checked', false);

                    if (result.oList[0].UserRole == 0 || result.oList[0].UserRole == '') {
                        $('#UserRole').val(0);
                    } else {
                        $('#UserRole').val(result.oList[0].UserRole);
                    }
                    GetCurrentMenu(result.oList[0].MenuCode);
                    
                }
            });
        }

    }
</script>
