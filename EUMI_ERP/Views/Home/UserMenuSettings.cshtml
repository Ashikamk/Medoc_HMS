<div id="CopyDiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="background:rgba(0,0,0,0.5); display: block;margin-top:0%;display: none;">
    <div class="modal-dialog modal-dialog-centered" role="document" style="top:-25%">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" onclick="$('#CopyDiv').hide()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="col-md-12">
                    <div class="row" id="panel" style="margin-top:2%;">

                        <label class="col-md-5" style="text-align:left" id="reason">Copy From User:</label>
                        <div class="col-md-7">
                            <input type="text" id="copyuser" class="form-control" autocomplete="off">
                        </div>
                        <input type="hidden" id="CopyUserId" value="0"/>
                    </div>
                    <div class="row" id="panel" style="margin-top:2%;">

                    </div>
            <div class="modal-footer">
                <button type="button" style="width:100px;" id="btndivdelete" onclick="$('#CopyDiv').hide()" class="btn btn-outline-secondary">Cancel</button>
                <button type="button" style="width:100px" id="btncnclsave" onclick="CopyUserRights()" class="btn btn-outline-warning">Continue</button>
            </div>


        </div>
    </div>
