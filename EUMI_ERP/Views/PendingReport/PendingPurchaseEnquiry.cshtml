                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#enquiryno').val(ui.item.EnquiryNo);
                    }             
        });
        $("#btnsubmit").click(function (e) {
            $('#Loading').show();
            var GroupID = '', SubgroupID = '', SubCategoryID = '', CategoryID = '', Condition = '', EnquiryNO = '', JobNo = '', Supplier = '', Material = ''
            var data = {};
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var Supplier = $('#supplierId').val();
            var s = $('#suppliername').val();
            var Material = $('#txtproductId').val();
            var GroupID = $('#cmbGroup').val();
            var SubgroupID = $('#cmbSubgroup').val();
            var CategoryID = $('#cmbCategory').val();
            var SubCategoryID = $('#cmbSubcategory').val();
            var EnquiryNO = $('#enquiryno').val();
            var DEPTId = $('#department').val();
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {
                $('#Loading').show();
                Condition += 'CONVERT(datetime,EnquiryDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,EnquiryDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)' 

                if (GroupID != 0) { Condition += ' and GroupId=' + GroupID; }

                if (SubgroupID != 0) {  Condition += ' and SubGroupId=' + SubgroupID ; }

                if (CategoryID != 0) { Condition += ' and CategoryId=' + CategoryID; }

                if (SubCategoryID != 0) { Condition += ' and SubCategoryID=' + SubCategoryID; }


                //if (JobNo != '') {  Condition += ' and JobNo=' + JobNo; }

                //if (EnquiryNO != '') { Condition += ' and EnquiryNo=' + EnquiryNO; }

                if (Material != 0) { Condition += ' and Inv_PurchaseEnquirySub.ItemId=' + Material; }

                if (Supplier != 0) { Condition += ' and SupplierId = ' + Supplier; }
                if (DEPTId != 0) { Condition += ' and Inv_PurchaseEnquiryMain.DepartmentId = ' + DEPTId; }
            }           
            var data = {};
            data.Condition = Condition;
            data.UserId = ERPUserId;

            $.ajax({
                type: "POST",
                url: "../PendingReport/PendingPurchaseEnquiryGet",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showpendingenquiryreport(result);
                }
            });
        
       
        });


        function Showpendingenquiryreport(result) {
                disable_datatable('Tblreport', 'buttonPlace');
                var responseText = "<thead><tr><th align=center>Sl#</th><th>Enquiry#</th><th text-align:center>Date</th><th style=width:100px>Supplier</th><th style=width:90px>Item Code</th><th>Item Name</th><th style=text-align:center>Enquiry Qty.</th><th style=text-align:center>Order Qty.</th><th style=text-align:center>Pending Qty.</th><th style=text-align:right>Rate</th></thead><tbody>";
            for (var i = 0; i < result.length; i++) {
                console.log('a')
                var slno = parseInt(i + 1);
                if (result[i].EnquiryNo == '') {
                    var Itemcode = (result[i].ItemCode);
                    Itemcode = Itemcode.substring(0, 6);
                    responseText += '<tr style=background-color:#cfd8dc><td align=center>' + slno + '</td><td>' + result[i].EnquiryNo + '</td><td><b>' + result[i].EnquiryDate + '</b></td><td><b>' + result[i].CustName + '</b></td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDescription + '</td><td style=text-align:center><b>' + result[i].Quantity + '</b></td><td style=text-align:center><b>' + result[i].Purchase_Qty + '</b></td><td style=text-align:center><b>' + result[i].Bal_qty + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Rate || 0).toFixed(Decimal) + '</b></td></tr>';
                }
                else {
                    var Itemcode = (result[i].ItemCode);
                    Itemcode = Itemcode.substring(0, 6);
                    responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].EnquiryNo + '</td><td>' + result[i].EnquiryDate + '</td><td>' + result[i].CustName + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDescription + '</td><td style=text-align:center>' + result[i].Quantity + '</td><td style=text-align:center>' + result[i].Purchase_Qty + '</td><td style=text-align:center>' + result[i].Bal_qty + '</td><td style=text-align:right>' + parseFloat(result[i].Rate || 0).toFixed(Decimal) + '</td></tr>';
                }
            }
            $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Enquiry#</th><th>Date</th><th>Supplier</th><th>Item Code</th><th>Item Name</th><th style=width:9px> </th><th style=width:9px> </th><th style=width:9px> </th><th style=width:120px> </th></tr></tfoot>');

            var title = "Purchase Enquiry Pending Report with Purchase Order - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
            datatableWithsearch1('Tblreport', true, title, 'buttonPlace');
            $('#header').text(title);
        }
        function GetDepartment(id) {
            var data = {};
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Master/UserDepartmentGetandGets",
                data: data,
                success: function (result) {
                    DepartmentLoad(result.oList, id);


                }
            });
        }

        function DepartmentLoad(result, a) {
            $("#department").empty();
            $("#department").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }
        }

     function DepartmentLoad(result, a) {
         $("#department").empty();
         $("#department").append("<option value='0'>-All-</option>");
         for (var i = 0; i < result.length; i++) {
             $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
         }
         if (a == 0) {
             $('#department').val(0);
         }
         else {
             $('#department').val(a);
         }
     }

     function checkproduct() {
         $('#txtproductId').val('');
     }
     function checkaccount() {
         $('#supplierId').val('');
     }


     function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

         var a = '#' + tablename + ' tfoot th'
         $(a).each(function () {
             var title = $(this).text();
             if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                 $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
             }
             if (title == 'Enquiry#') {
                 $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
             }

             if (title == 'Date') {
                 $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
             }
             if (title == 'Supplier') {
                 $(this).html('<input type="text" placeholder="' + title + '" style="width:100px" />');
             }

             if (title == 'Item Code') {
                 $(this).html('<input type="text" placeholder="' + title + '" style="width:250px" />');
             }

             if (title == 'Item Name') {
                 $(this).html('<input type="text" placeholder="' + title + '" style="width:650px" />');
             }
             if (title == 'Qty.') {
                 $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
             }
         });
         var table = null;
         table = $('#' + tablename).DataTable({
             //dom: 'Bfrtip',
             dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
             buttons: [],
         
         });

         new $.fn.dataTable.Buttons(table, {
             buttons: [
             {
                 extend: 'collection',
                 text: 'Export',
                 className: 'excelexport',
                 buttons: [
                     {
                         extend: 'excelHtml5',
                         title: title,
                         messageTop: 'MEDOC HMS',
                         exportOptions: { columns: ":visible" }
                     },
                     {
                         extend: 'pdfHtml5',
                         title: title,
                         messageTop: 'MEDOC HMS',
                         exportOptions: { columns: ":visible" }
                     },
                     {
                         extend: 'print',
                         title: title,
                         messageTop: 'MEDOC HMS',
                         exportOptions: { columns: ":visible" }
                     }
                 ]
             },
             'colvis'
             ]
         });
         table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
         $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


         table.columns().every(function () {
             var that = this;
             $('input', this.footer()).on('keyup change', function () {
                 if (that.search() !== this.value) {
                     that
                         .search(this.value)
                         .draw();

                 }
             });
         });
         if (ExcelExport == 0) {
             $('.excelexport').hide();
         }
     }




</script>