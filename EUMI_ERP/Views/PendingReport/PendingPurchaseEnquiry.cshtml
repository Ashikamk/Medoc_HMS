<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%;width:580px;">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">Purchase Enquiry Pending Report with Purchase Order</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">

                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:10.5%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:10%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">
                        <label style="margin-top:2%;font-weight:bold;margin-left:6%">Material</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" class="form-control"  id="txtproduct" />
                            <input type="hidden" class="form-control" id="txtproductId" />
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:1.5%">Account</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text"  class="form-control" id="suppliername" />
                            <input type="hidden" class="form-control" id="supplierId" />
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:9%">Group</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbGroup" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:-0.5%">SubGroup</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:4.5%">Category</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbCategory" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:2.5%">SubCat.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Department</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>
                    </div>
                </div>
            
                <div class="modal-footer ">
                    <button type="button"  style="margin-right:45%;" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    function popuprefresh() {
        $('#popupdiv').hide();
    }
    $(function () {
       
        $("#txtproduct").focus();

        GetDepartment(0);

        CategoryPageLoad(0);
        GroupPageLoad(0);

       // $("#txtproduct").focus();

        $("#txtproduct").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#txtproduct").val() == '')
                $('#txtproductId').val(0);
            if (key == 13) {
                $("#suppliername").focus();
                e.preventDefault();
            }
        });
        $("#txtproduct").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#txtproduct").val() == '')
                $('#txtproductId').val(0);

        });
        $("#suppliername").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);
            if (key == 13) {
                $("#cmbGroup").focus();
                e.preventDefault();
            }
        });
        $("#suppliername").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);

        });

        $("#cmbGroup").keydown(function (e) {
