            }

        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
       
    });

        function CategoryPageLoad(id) {
            var data2 = {};
            data2.CategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/CategoryGetandGets",
                data: data2,
                success: function (result) {
                    CategoryLoad(result.oList, id);
                }
            });
        }


        function CategoryLoad(result) {
            $("#cmbCategory").empty();
            $("#cmbCategory").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#cmbCategory").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
            }
            SubCategoryGets();

        }
        function SubCategoryGets() {

            var data = {};
            data.CategoryId = $("#cmbCategory").val();

            if (data.CategoryId == 0) {
                data.SubCategoryId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubCategoryGetandGets",
                    data: data,
                    success: function (result) {
                        SubCategoryLoad(result.oList);

                    }
                });
            }

            else {
                data.SubCategoryId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubCategoryGetforCategory",
                    data: data,
                    success: function (result) {
                        SubCategoryLoad(result.oList);
                    }
                });
            }
        }



        function SubCategoryLoad(result) {
            $("#cmbSubcategory").empty();
            $("#cmbSubcategory").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#cmbSubcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
            }
        }
        function GroupPageLoad(id) {
            var data1 = {};
            data1.GrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/GroupGetandGets",
                data: data1,
                success: function (result) {
                    GroupLoad(result.oList, id);
                }
            });
        }

        function GroupLoad(result) {
            $("#cmbGroup").empty();
            $("#cmbGroup").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {

                $("#cmbGroup").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
            }
            SubGroupGets();
        }

        function SubGroupGets() {
            var data = {};
            data.GroupId = $("#cmbGroup").val();


            if (data.GroupId == 0) {
                data.SbgrpId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubGroupGetandGets",
                    data: data,
                    success: function (result) {
                        SubGroupLoad(result.oList);
                    }
                });
            }
            else {
                data.SbgrpId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubGroupGetForGroup",
                    data: data,
                    success: function (result) {
                        SubGroupLoad(result.oList);
                    }
                });
            }
        }

        function SubGroupLoad(result) {
            $("#cmbSubgroup").empty();
            $("#cmbSubgroup").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#cmbSubgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
            }
        }
        $("#txtproduct").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#txtproduct").val();
                data.LocId = UserLocationId;
                data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../SalesInvoice/ProductSearchSales',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.ItemCode,
                                label1: item.Description,
                                Description: item.Description,
                                ProductId: item.ItemId,
                                Product: item.ItemCode,
                                headers: ["Material Code", "Material Description"]
                            })
                        }));
                    }
                })
            },

            autoFocus: true,
            select: function (event, ui) {
                $('#txtproduct').val(ui.item.Product);
                $('#txtproductId').val(ui.item.ProductId);
                $("#suppliername").focus();
           
            },
        });
        function change() {
            if ($('#txtproduct').val() == '') {
                $('#txtproductId').val(0);
            }
        }
        $("#txtaccnt").autocomplete({
            source: function (request, response) {
                var data = {};
                data.AccountDescription = $("#txtaccnt").val();
                data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../Inventory/AccountNumberSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.DebitAccount,
                                label1: item.AccountDescription,
                                DebitAccount: item.DebitAccount,
                                AccountDescription: item.AccountDescription,
                                AccountId: item.AccountId,
                                headers: ["Account Code", "Account Name"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#txtaccntId').val(ui.item.AccountId)
                $('#txtaccnt').val(ui.item.DebitAccount);
            },
        });

        $("#suppliername").autocomplete({
            
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.CustName = $("#suppliername").val();
                data.CustType = 'S';

                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.CustName,
                                label1: item.CustAccount,
                                CustId: item.CustId,
                                CustName: item.CustName,
                                headers: ["Supplier Name", "Account Code"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#supplierId').val(ui.item.CustId);
                $('#suppliername').val(ui.item.CustName);
                $("#cmbGroup").focus();
            },

        });
        function changes() {
            if ($('#suppliername').val() == '') {
                $('#supplierId').val(0);
            }
        }
        $("#select_jobno").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.JobCode = $("#select_jobno").val();

                $.ajax({
                    url: '../SalesInvoice/JobSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '2',
                                label: item.JobCode,
                                label1: item.Description,
                                ProjectJobId: item.ProjectJobId,
                                headers: ["Job Code", "Description"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,

            select: function (event, ui) {
                $('#ProjectJobId').val(ui.item.ProjectJobId);
            },

        });
       
    
        $("#enquiryno").autocomplete({
            
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.EnquiryNo = $("#enquiryno").val();
                data.DepartmentId = ERPDeptId;
                $.ajax({
                    url: '../../Purchase/EnquiryNoSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.EnquiryNo,
                                label1: item.EnquiryDate,
                                EnquiryNo: item.EnquiryNo,
