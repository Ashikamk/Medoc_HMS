                            <input type="text" class="form-control" id="txtproduct" onkeyup="ProductClear()"/>
                            <input type="hidden" class="form-control" id="txtproductId" />
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:1%">Account</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" class="form-control" id="suppliername" onkeyup="Clear()" />
                            <input type="hidden" class="form-control" id="supplierId" />
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:10%">Group</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbGroup" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <label style="margin-top:2%;font-weight:bold;margin-left:-1%">SubGroup</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:5.5%">Category</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbCategory" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <label style="margin-top:2%;font-weight:bold;margin-left:2%">SubCat.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>


                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:2.5%">Quotation#</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" class="form-control" id="enquiryno" />
                        </div>

                        <label style="margin-top:2%;font-weight:bold;margin-left:5.5%">Dept.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="vDept" class="form-control">
