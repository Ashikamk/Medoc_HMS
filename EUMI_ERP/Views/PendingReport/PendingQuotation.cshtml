    </div>
</div>

<script>
    function Clear() {
        if ($('#suppliername').val() == '') {
            $('#supplierId').val(0);
        }
    }
    function ProductClear() {
        if ($('#txtproduct').val() == '') {
            $('#txtproductId').val(0);
        }

    }
    $("#enquiryno").autocomplete({        
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.QuotationNo = $("#enquiryno").val();
            data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../SalesInvoice/QuotationNoSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '3',
                                label: item.QuotationNo,
                                label1: item.CustName,
                                label2: item.InvDate,
                                QuotationNo: item.QuotationNo,
                                QuotationEntryMainId: item.QuotationEntryMainId,
                                headers: ["Quotation No", "Customer Name", "Inv Date"]
                            })
                        }));
                    }
                })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#enquiryno').val(ui.item.QuotationNo);
                }
    });

    $("#txtproduct").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#txtproduct").val();
            data.LocId = UserLocationId;
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../SalesInvoice/ProductSearchSales',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.ItemCode,
                            label1: item.Description,
                            Description: item.Description,
                            ProductId: item.ItemId,
                            Product: item.ItemCode,
                            headers: ["Material Code", "Material Description"]
                        })
                    }));
                }
            })
        },

        autoFocus: true,
        select: function (event, ui) {
            $('#txtproduct').val(ui.item.Product);
            $('#txtproductId').val(ui.item.ProductId);
            $("#suppliername").focus();
        },
    });

    $("#suppliername").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType = 'C';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.CustName,
                            label1: item.CustAccount,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Supplier Name", "Account Code"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#supplierId').val(ui.item.CustId);
            $('#suppliername').val(ui.item.CustName);
            $("#cmbGroup").focus();
        },
    });


    $("#btnsubmit").click(function (e) {
        var GroupID = '', SubgroupID = '', SubCategoryID = '', CategoryID = '', Condition = '', Customer = '', Material = '', vDept = '', EnquiryNO=''
        var data = {};
        var FromDate = $('#DateFrom').val();
        var ToDate = $('#DateTo').val();
        var Customer = $('#supplierId').val();
        var Material = $('#txtproductId').val();
        var GroupID = $('#cmbGroup').val();
        var SubgroupID = $('#cmbSubgroup').val();
        var CategoryID = $('#cmbCategory').val();
        var SubCategoryID = $('#cmbSubcategory').val();
        var Dept = $('#vDept').val();
        var EnquiryNO = $('#enquiryno').val();


        Condition += 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

        if (GroupID != 0) { Condition += ' and GroupId=' + GroupID; }

        if (SubgroupID != 0) { Condition += ' and SubGroupId=' + SubgroupID; }

        if (CategoryID != 0) { Condition += ' and CategoryId=' + CategoryID; }

        if (SubCategoryID != 0) { Condition += ' and SubCategoryID=' + SubCategoryID; }

        if (Material != 0) { Condition += ' and qs.ProductId=' + Material; }

        if (Customer != 0) { Condition += ' and qm.CustId = ' + Customer; }

        if (Dept != 0) { Condition += ' and qm.DeptId = ' + Dept; }

        if (EnquiryNO != '') { Condition += ' and qm.QuotationNo=' + EnquiryNO; }



        var data = {};
        data.Condition = Condition;
        data.UserId = ERPUserId;

        $.ajax({
            type: "POST",
            url: "../PendingReport/PendingQuotationGet",
            data: data,
            success: function (result) {
                $('#divreport').show();
                $('#popupdiv').hide();
                Showreport(result);
            }
        });
    });

    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th align=center>Sl#</th><th>Quotation#</th><th>Date</th><th>Customer</th><th>Item Code</th><th>Item Name</th><th>Salesman</th><th align=center>Quotation Qty.</th><th align=center>Order Qty.</th><th align=center>Pending Qty.</th><th>Order Rate</th></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].QtnNo == '') {
                responseText += '<tr style=background-color:#cfd8dc><td hidden>' + slno + '</td><td></td><td>' + result[i].QtnNo + '</td><td>' + result[i].InvDate + '</td><td><b>Grand Total</b></td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemName + '</td><td>' + result[i].Salesman + '</td><td align=center><b>' + result[i].QtnQty + '</b></td><td align=center><b>' + result[i].OrderQty + '</b></td><td align=center><b>' + result[i].BalanceQty + '</b></td><td style=text-align:right><b>' + (result[i].OrderRate).toFixed(decimal) + '</b></td></tr>';
            }
            else {
                responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].QtnNo + '</td><td>' + result[i].InvDate + '</td><td>' + result[i].Customer + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemName + '</td><td>' + result[i].Salesman + '</td><td align=center>' + result[i].QtnQty + '</td><td align=center>' + result[i].OrderQty + '</td><td align=center>' + result[i].BalanceQty + '</td><td style=text-align:right>' + (result[i].OrderRate).toFixed(decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Quotation#</th><th>Date</th><th>Customer</th><th>Item Code</th><th>Item Name</th><th>Salesman</th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');

        var title = "Quotation Pending Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'O Balance' && title != ' ') {
                $(this).html('<input type="text" placeholder=" ' + title + '" style="width=100%" />');
            }
            if (title == 'Date') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Quotation#') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }

            if (title == 'Dept.Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            }
            if (title == 'Customer') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:150px" />');
            }
            if (title == 'Salesman') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:150px" />');
            }
            if (title == 'Item Code') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:200px" />');
            }
            if (title == 'Item Name') {
                $(this).html('<input type="text" placeholder="' + title + '" style="width:450px" />');
            }
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


            table = $('#' + tablename).DataTable({
                //dom: 'Blfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
               "<'row'<'col-sm-12'tr>>" +
               "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],


            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }
</script>