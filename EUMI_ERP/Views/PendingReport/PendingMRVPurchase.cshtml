
@{
    ViewBag.Title = "PendingMRVPurchase";
}
<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>

<div class="myData" data-x="M50" />
<div id="Entry">
  
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="25%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#txtproduct').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>
                        <div align="right">
                            <div class="heading-elements">
                                <hr style="margin-top:.1%;" />
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                             
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%;width:580px;">
        <div class="modal-content">
            <div class="modal-header bg-primary white" style="height:60px">
                <h5 class="modal-title" id="myheader">MRV Pending Report with Purchase Invoice</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
   
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:10%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:10.5%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">
                        <label style="margin-top:2%;font-weight:bold;margin-left:6%">Material</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" class="form-control" id="txtproduct" />
                            <input type="hidden" class="form-control" id="txtproductId" />
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:1.5%">Account</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text"  class="form-control" id="suppliername" />
                            <input type="hidden" class="form-control" id="supplierId" />
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:9%">Group</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbGroup" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:-0.5%">SubGroup</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:4.5%">Category</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbCategory" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:2.5%">SubCat.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:5%">JobCode</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" onkeyup="checkjob()" class="form-control" id="select_jobno" />
                            <input type="hidden" class="form-control" id="ProjectJobId" />
                        </div>
                    </div>
                </div>
             
                <div class="modal-footer ">
                    <button type="button" style="margin-right:45%;" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>
<script>
    $(function () {
        $('#txtproduct').focus()

        $("#txtproduct").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#txtproduct").val() == '')
                $('#txtproductId').val(0);
            if (key == 13) {
                $("#suppliername").focus();
                e.preventDefault();
            }
        });
        $("#txtproduct").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#txtproduct").val() == '')
                $('#txtproductId').val(0);

        });
        $("#suppliername").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);
            if (key == 13) {
                $("#cmbGroup").focus();
                e.preventDefault();
            }
        });
        $("#suppliername").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);

        });
        $("#cmbGroup").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#cmbSubgroup").focus();
            }
        });
        $("#cmbSubgroup").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#cmbCategory").focus();
            }

        });
        $("#cmbCategory").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#cmbSubcategory").focus();
            }

        });
        $("#cmbSubcategory").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#select_jobno").focus();
            }

        });

        $("#select_jobno").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#btnsubmit").focus();
            }

        });




        CategoryPageLoad(0);
        GroupPageLoad(0);
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    });

        function CategoryPageLoad(id) {
            var data2 = {};
            data2.CategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/CategoryGetandGets",
                data: data2,
                success: function (result) {
                    CategoryLoad(result.oList, id);
                }
            });
        }


        function CategoryLoad(result) {
            $("#cmbCategory").empty();
            $("#cmbCategory").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#cmbCategory").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
            }
            SubCategoryGets();

        }
        function SubCategoryGets() {

            var data = {};
            data.CategoryId = $("#cmbCategory").val();

            if (data.CategoryId == 0) {
                data.SubCategoryId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubCategoryGetandGets",
                    data: data,
                    success: function (result) {
                        SubCategoryLoad(result.oList);

                    }
                });
            }

            else {
                data.SubCategoryId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubCategoryGetforCategory",
                    data: data,
                    success: function (result) {
                        SubCategoryLoad(result.oList);
                    }
                });
            }
        }



        function SubCategoryLoad(result) {
            $("#cmbSubcategory").empty();
            $("#cmbSubcategory").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#cmbSubcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
            }
        }
        function GroupPageLoad(id) {
            var data1 = {};
            data1.GrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/GroupGetandGets",
                data: data1,
                success: function (result) {
                    GroupLoad(result.oList, id);
                }
            });
        }

        function GroupLoad(result) {
            $("#cmbGroup").empty();
            $("#cmbGroup").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {

                $("#cmbGroup").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
            }
            SubGroupGets();
        }

        function SubGroupGets() {
            var data = {};
            data.GroupId = $("#cmbGroup").val();


            if (data.GroupId == 0) {
                data.SbgrpId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubGroupGetandGets",
                    data: data,
                    success: function (result) {
                        SubGroupLoad(result.oList);
                    }
                });
            }
            else {
                data.SbgrpId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/SubGroupGetForGroup",
                    data: data,
                    success: function (result) {
                        SubGroupLoad(result.oList);
                    }
                });
            }
        }

        function SubGroupLoad(result) {
            $("#cmbSubgroup").empty();
            $("#cmbSubgroup").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#cmbSubgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
            }
        }
        $("#txtproduct").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.ItemCode = $("#txtproduct").val();
                data.LocId = UserLocationId;
                data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../SalesInvoice/ProductSearchSales',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.ItemCode,
                                label1: item.Description,
                                Description: item.Description,
                                ProductId: item.ItemId,
                                Product: item.ItemCode,
                                headers: ["Material Code", "Material Description"]
                            })
                        }));
                    }
                })
            },

            autoFocus: true,
            select: function (event, ui) {
                $('#txtproduct').val(ui.item.Product);
                $('#txtproductId').val(ui.item.ProductId);
               // $("#suppliername").focus();
            },
        });
        function change() {
            if ($('#txtproduct').val() == '') {
                $('#txtproductId').val(0);
            }
        }
        $("#txtaccnt").autocomplete({
            source: function (request, response) {
                var data = {};
                data.AccountDescription = $("#txtaccnt").val();
                data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../Inventory/AccountNumberSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.DebitAccount,
                                label1: item.AccountDescription,
                                DebitAccount: item.DebitAccount,
                                AccountDescription: item.AccountDescription,
                                AccountId: item.AccountId,
                                headers: ["Account Code", "Account Name"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#txtaccntId').val(ui.item.AccountId)
                $('#txtaccnt').val(ui.item.DebitAccount);
            },
        });

        $("#suppliername").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.CustName = $("#suppliername").val();
                data.CustType = 'S';

                $.ajax({
                    url: '../Master/CustomerOrSupplierSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+2',
                                label: item.CustName,
                                label1: item.CustAccount,
                                CustId: item.CustId,
                                CustName: item.CustName,
                                headers: ["Supplier Name", "Account Code"]
                            })
                        }));
                    }

                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#supplierId').val(ui.item.CustId);
                $('#suppliername').val(ui.item.CustName);
                //$("#cmbGroup").focus();
            },

        });
        function changes() {
            if ($('#suppliername').val() == '') {
                $('#supplierId').val(0);
            }
        }
        $("#select_jobno").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.JobCode = $("#select_jobno").val();

                $.ajax({
                    url: '../SalesInvoice/JobSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '2',
                                label: item.JobCode,
                                label1: item.Description,
                                ProjectJobId: item.ProjectJobId,
                                headers: ["Job Code", "Description"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,

            select: function (event, ui) {
                $('#ProjectJobId').val(ui.item.ProjectJobId);
            },

        });

        $("#MRVNo").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.DONo = $("#MRVNo").val();
                //data.LocnId = ULocId;
                data.DepartmentId = ERPDeptId;

                $.ajax({
                    url: '../MRVPurchase/MRVSerialNoSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        console.log(data);
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '+3',
                                label: item.MRVNo,
                                label1: item.DONo,
                                label2: item.MRVDate,                                
                                MRVNo: item.MRVNo,
                                headers: ["Serial No", "Invoice No", "Date"]


                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#MRVNo').val(ui.item.MRVNo);
            },
        });       
        $("#btnsubmit").click(function (e) {
            $('#Loading').show();
            var GroupID = '', SubgroupID = '', SubCategoryID = '', CategoryID = '', Condition = '', EnquiryNO = '', JobNo = '', Supplier = '', Material = ''
            var data = {};
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var Supplier = $('#supplierId').val();
            var Material = $('#txtproductId').val();
            var GroupID = $('#cmbGroup').val();
            var SubgroupID = $('#cmbSubgroup').val();
            var CategoryID = $('#cmbCategory').val();
            var SubCategoryID = $('#cmbSubcategory').val();
            var MRVNo = $('#MRVNo').val();
            var JobNo = $('#ProjectJobId').val();
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {
                $('#Loading').show();
                Condition += 'CONVERT(datetime,MRVDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,MRVDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

                if (GroupID != 0) { Condition += ' and GroupId=' + GroupID; }

                if (SubgroupID != 0) {  Condition += ' and SubGroupId=' + SubgroupID ; }

                if (CategoryID != 0) { Condition += ' and CategoryId=' + CategoryID; }

                if (SubCategoryID != 0) {  Condition += ' and SubCategoryID=' + SubCategoryID; }

                if (JobNo != 0) {  Condition += ' and JobNo=' + JobNo; }

                //if (MRVNo != '') { Condition += ' and MRVNo=' + MRVNo; }

                if (Material != 0) { Condition += ' and Inv_MRVSub.ItemId=' + Material; }

                if (Supplier != 0) { Condition += ' and SupplierId = ' + Supplier; }


            }
            var data = {};
            data.Condition = Condition;
            data.UserId = ERPUserId;

            $.ajax({
                type: "POST",
                url: "../PendingReport/PendingMRVPurchaseGet",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();
                    Showreport(result);
                }
            });


        });


        function Showreport(result) {
                disable_datatable('Tblreport', 'buttonPlace');
                var responseText = "<thead><tr><th align=center>Sl#</th><th width:1px>MRV#</th><th width:1px>Inv.#</th><th style=text-align:center;width:3px>Date</th><th width:22px>Supplier</th><th>Item Code</th><th width:110px>Item Name</th><th style=text-align:center;width:14px>MRV Qty.</th><th style=text-align:center;width:14px>Purchase Qty.</th><th style=text-align:center;width:14px>Pending Qty.</th><th style=text-align:right;width:140px>Rate</th></thead><tbody>";
            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);
                if (result[i].MRVNo == '') {
                    var Itemcode = (result[i].ItemCode);
                    Itemcode = Itemcode.substring(0, 6);
                    responseText += '<tr style=background-color:#cfd8dc><td align=center>' + slno + '</td><td>' + result[i].MRVNo + '</td><td>' + result[i].InvoNo + '</td><td><b>' + result[i].MRVDate + '</b></td><td><b>' + result[i].CustName + '</b></td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDescription + '</td><td style=text-align:center><b>' + result[i].Quantity + '</b></td><td style=text-align:center><b>' + result[i].Purchase_Qty + '</b></td><td style=text-align:center><b>' + result[i].Bal_qty + '</td><td style=text-align:right><b>' + parseFloat(result[i].Rate || 0).toFixed(Decimal) + '</b></td></tr>';

                }
                else if (result[i].MRVNo != '') {
                    var Itemcode = (result[i].ItemCode);
                    Itemcode = Itemcode.substring(0, 6);
                    responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].MRVNo + '</td><td>' + result[i].InvoNo + '</td><td>' + result[i].MRVDate + '</td><td>' + result[i].CustName + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDescription + '</td><td style=text-align:center>' + result[i].Quantity + '</td><td style=text-align:center>' + result[i].Purchase_Qty + '</td><td style=text-align:center>' + result[i].Bal_qty + '</td><td style=text-align:right>' + parseFloat(result[i].Rate || 0).toFixed(Decimal) + '</td></tr>';
                }
 

            }
            $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>MRV#</th><th>Inv.#</th><th>Date</th><th>Supplier</th><th>Item Code</th><th>Item Name</th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');

            var title = "MRV Pending Report with Purchase Invoice - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
                datatableWithsearch1('Tblreport', true, title, 'buttonPlace');
            $('#header').text(title);
        }
        function popuprefresh() {
            $('#popupdiv').hide();
        }
        function checkjob() {
            $('#ProjectJobId').val('');
        }
        function checkproduct() {
            $('#txtproductId').val('');
        }
        function checkaccount() {
            $('#supplierId').val('');
        }



        function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

            var a = '#' + tablename + ' tfoot th'
            $(a).each(function () {
                var title = $(this).text();
                if (title != 'Edit' && title != 'Select' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != 'Sl#' && title != ' ' && title != ' ') {
                    $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
                }
                if (title == 'MRV#') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }

                if (title == 'Date') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }

                if (title == 'Inv.#') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
                }

                if (title == 'Supplier') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:150px" />');

                }
                if (title == 'Item Code') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:250px" />');
                }
                if (title == 'Item Name') {
                    $(this).html('<input type="text" placeholder="' + title + '" style="width:500px" />');
                }
            });
            var table = null;
            table = $('#' + tablename).DataTable({
                //dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: [],
               
            });

            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    className: 'excelexport',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


            table.columns().every(function () {
                var that = this;
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that
                            .search(this.value)
                            .draw();

                    }
                });
            });
            if (ExcelExport == 0) {
                $('.excelexport').hide();
            }
        }






</script>