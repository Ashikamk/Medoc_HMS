
@{
    ViewBag.Title = "PendingPurchaseOrder";
}

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>

<div class="myData" data-x="M48" />
<div id="Entry">
  
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">

                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>
                                <td width="15%"></td>
                                <td  style="display:none;" id="divsummary">
                                    <div style="margin-left:4%"  class="d-inline-block custom-control custom-radio mr-1">
                                        <input type="radio" checked="" name="sd" class="custom-control-input" id="btnsummary" value="normal" onchange="Summary()">
                                        <label class="custom-control-label" for="btnsummary">Summary </label>
                                    </div>
                                </td>
                                <td style="display:none;" id="divdetail">
                                    <div style="margin-left:2%"  class="d-inline-block custom-control custom-radio mr-1">
                                        <input type="radio" name="sd" class="custom-control-input" id="btndetail" onchange="Detailed()" value="normal">
                                        <label class="custom-control-label" for="btndetail">Detailed </label>
                                    </div>
                                </td>


                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#txtproduct').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>

                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">
                               <hr  style="margin-top:.1%;"/>
                                <div id="divreport" style="overflow:auto;display:none">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable"></table><br />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%;width:580px;">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">Purchase Order Pending Report</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
               

                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:10%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:10.5%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%">
                        <label style="margin-top:2%;font-weight:bold;margin-left:6%">Material</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" class="form-control" id="txtproduct" />
                            <input type="hidden" class="form-control" id="txtproductId" />
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:1.5%">Account</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text"  class="form-control" id="suppliername" />
                            <input type="hidden" class="form-control" id="supplierId" />
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:9%">Group</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbGroup" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:-0.5%">SubGroup</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:4.5%">Category</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbCategory" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                        <label style="margin-top:2%;font-weight:bold;margin-left:2.5%">SubCat.</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select id="cmbSubcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:5.2%">JobCode</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <input type="text" onkeyup="checkjob()" class="form-control" id="select_jobno" />
                            <input type="hidden" class="form-control" id="ProjectJobId" />
                        </div>
                    </div>
                </div>
              
                <div class="modal-footer ">
                    <button type="button" style="margin-right:45%;" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>


<script>
    $(function () {
       
        $("#txtproduct").focus();

        $("#txtproduct").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#txtproduct").val() == '')
                $('#txtproductId').val(0);
            if (key == 13) {
                $("#suppliername").focus();
                e.preventDefault();
            }
        });
        $("#txtproduct").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#txtproduct").val() == '')
                $('#txtproductId').val(0);

        });
        $("#suppliername").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);
            if (key == 13) {
                $("#cmbGroup").focus();
                e.preventDefault();
            }
        });
        $("#suppliername").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if ($("#suppliername").val() == '')
                $('#supplierId').val(0);

        });

        $("#cmbGroup").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#cmbSubgroup").focus();
            }
        });
        $("#cmbSubgroup").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#cmbCategory").focus();
            }

        });
        $("#cmbCategory").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#cmbSubcategory").focus();
            }

        });
        $("#cmbSubcategory").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#select_jobno").focus();
            }

        });
       
        $("#select_jobno").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#btnsubmit").focus();
            }

        });
        CategoryPageLoad(0);
        GroupPageLoad(0);
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
        
    });
        $("#btnsubmit").click(function (e) {
            $('#Loading').show();

            if ($('#btndetail').prop("checked"))
            {
                Detailed();
            }
            else
            {
                Summary();
            }
        });

        function Detailed()
        {
            var GroupID = '', SubgroupID = '', SubCategoryID = '', CategoryID = '', Condition = '', PONO = '', JobNo = '', Supplier = '', Material = ''
            var data = {};
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var Supplier = $('#supplierId').val();
            var Material = $('#txtproductId').val();
            var GroupID = $('#cmbGroup').val();
            var SubgroupID = $('#cmbSubgroup').val();
            var CategoryID = $('#cmbCategory').val();
            var SubCategoryID = $('#cmbSubcategory').val();
            var PONO = $('#PONO').val();
            var JobNo = $('#ProjectJobId').val();
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {
                $('#Loading').show();


                Condition += 'CONVERT(datetime,OrderDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,OrderDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

                if (GroupID != 0) { Condition += ' and GroupId=' + GroupID; }

                if (SubgroupID != 0) { Condition += ' and SubGroupId=' + SubgroupID; }

                if (CategoryID != 0) { Condition += ' and CategoryId=' + CategoryID; }

                if (SubCategoryID != 0) { Condition += ' and SubCategoryID=' + SubCategoryID; }

                if (JobNo != 0) { Condition += ' and JobNo=' + JobNo; }

                if (Material != 0) { Condition += ' and ps.ItemId=' + Material; }

                if (Supplier != 0) { Condition += ' and pm.SupplierId = ' + Supplier; }

            }
            var data = {};
            data.Condition = Condition;
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../PendingReport/PendingPurchaseOrderGet",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();

                    $('#divsummary').show();
                    $('#divdetail').show();
                    Showreport(result);
                }
            });
        }

        function Summary()
        {
            var GroupID = '', SubgroupID = '', SubCategoryID = '', CategoryID = '', Condition = '', PONO = '', JobNo = '', Supplier = '', Material = ''
            var data = {};
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var Supplier = $('#supplierId').val();
            var Material = $('#txtproductId').val();
            var GroupID = $('#cmbGroup').val();
            var SubgroupID = $('#cmbSubgroup').val();
            var CategoryID = $('#cmbCategory').val();
            var SubCategoryID = $('#cmbSubcategory').val();
            var PONO = $('#PONO').val();
            var JobNo = $('#ProjectJobId').val();
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {
                $('#Loading').show();


                Condition += 'CONVERT(datetime,OrderDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,OrderDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

                if (GroupID != 0) { Condition += ' and GroupId=' + GroupID; }

                if (SubgroupID != 0) { Condition += ' and SubGroupId=' + SubgroupID; }

                if (CategoryID != 0) { Condition += ' and CategoryId=' + CategoryID; }

                if (SubCategoryID != 0) { Condition += ' and SubCategoryID=' + SubCategoryID; }

                if (JobNo != 0) { Condition += ' and JobNo=' + JobNo; }

                if (Material != 0) { Condition += ' and ps.ItemId=' + Material; }

                if (Supplier != 0) { Condition += ' and pm.SupplierId = ' + Supplier; }

            }
            var data = {};
            data.Condition = Condition;
            data.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../PendingReport/PendingPurchaseOrderSummaryGet",
                data: data,
                success: function (result) {
                    $('#Loading').hide();
                    $('#divreport').show();
                    $('#popupdiv').hide();

                    $('#divsummary').show();
                    $('#divdetail').show();
                    ShowreportSummary(result);
                }
            });
        }
    function Showreport(result) {
     
            disable_datatable('Tblreport', 'buttonPlace');
        
            var responseText = "<thead><tr><th align=center>Sl#</th><th>PO#</th><th style=text-align:center>Date</th><th>Doc.Ref.</th><th>Supplier</th><th>Item Code</th><th>Item Name</th><th style='text-align:center'>Order Qty.</th><th style='text-align:center'>Shipped Qty.</th><th style='text-align:center' width=10%>Back Order Qty.</th><th style='text-align:center'>FC Rate</th></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].OrderNo == '') {
                responseText += '<tr style=background-color:#cfd8dc><td align=center>' + slno + '</td><td>' + result[i].OrderNo + '</td><td><b>' + result[i].OrderDate + '</b></td><td><b>' + result[i].DocRef + '</b></td><td><b>' + result[i].CustName + '</b></td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDescription + '</td><td style=text-align:center><b>' + result[i].Quantity + '<b></td><td style=text-align:center><b>' + result[i].Performa_Qty + '</b></td><td style=text-align:center><b>' + result[i].Bal_qty + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Rate || 0).toFixed(Decimal) + '</b></td></tr>';

            }
            else {
                responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].OrderNo + '</td><td>' + result[i].OrderDate + '</td><td>' + result[i].DocRef + '</td><td>' + result[i].CustName + '</td><td>' + result[i].ItemCode + '</td><td>' + result[i].ItemDescription + '</td><td style=text-align:center>' + result[i].Quantity + '</td><td style=text-align:center>' + result[i].Performa_Qty + '</td><td style=text-align:center>' + result[i].Bal_qty + '</td><td style=text-align:right>' + parseFloat(result[i].Rate || 0).toFixed(Decimal) + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>PO#</th><th>Date</th><th>Doc.Ref.</th><th>Supplier</th><th>Item Code</th><th>Item Name</th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');

        var title = "Purchase Order Pending Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch1('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    function ShowreportSummary(result) {

        disable_datatable('Tblreport', 'buttonPlace');

        var responseText = "<thead><tr><th align=center>Sl#</th><th>PO#</th><th>Date</th><th>Supplier</th><th style='text-align:right'>FC Amount</th><th style='text-align:center'>Arrival Date</th></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            if (result[i].OrderNo == '') {
                responseText += '<tr style=background-color:#cfd8dc><td align=center>' + slno + '</td><td>' + result[i].OrderNo + '</td><td><b>' + result[i].OrderDate + '</b></td><td><b>' + result[i].CustName + '</b></td><td style=text-align:right><b>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '<b></td><td style=text-align:center><b>' + result[i].ArrivalDate + '</b></td></tr>';

            }
            else {
                responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].OrderNo + '</td><td  align=center>' + result[i].OrderDate + '</td><td>' + result[i].CustName + '</td><td style=text-align:right>' + parseFloat(result[i].Amount || 0).toFixed(Decimal) + '</td><td style=text-align:center>' + result[i].ArrivalDate + '</td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>PO#</th><th>Date</th><th>Supplier</th><th> </th><th>Arrival Date</th></tr></tfoot>');

        var title = "Purchase Order Pending Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch2('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }
    function CategoryPageLoad(id) {
        var data2 = {};
        data2.CategoryId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CategoryGetandGets",
            data: data2,
            success: function (result) {
                CategoryLoad(result.oList, id);
            }
        });
    }


    function CategoryLoad(result) {
        $("#cmbCategory").empty();
        $("#cmbCategory").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbCategory").append("<option value='" + result[i].CategoryId + "'>" + result[i].CategoryName + "</option>");
        }
        SubCategoryGets();

    }
    function SubCategoryGets() {

        var data = {};
        data.CategoryId = $("#cmbCategory").val();

        if (data.CategoryId == 0) {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetandGets",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);

                }
            });
        }

        else {
            data.SubCategoryId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubCategoryGetforCategory",
                data: data,
                success: function (result) {
                    SubCategoryLoad(result.oList);
                }
            });
        }
    }



    function SubCategoryLoad(result) {
        $("#cmbSubcategory").empty();
        $("#cmbSubcategory").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbSubcategory").append("<option value='" + result[i].SubCategoryId + "'>" + result[i].SubCategoryName + "</option>");
        }
    }
    function GroupPageLoad(id) {
        var data1 = {};
        data1.GrpId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/GroupGetandGets",
            data: data1,
            success: function (result) {
                GroupLoad(result.oList, id);
            }
        });
    }

    function GroupLoad(result) {
        $("#cmbGroup").empty();
        $("#cmbGroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {

            $("#cmbGroup").append("<option value='" + result[i].GrpId + "'>" + result[i].GrpName + "</option>");
        }
        SubGroupGets();
    }

    function SubGroupGets() {
        var data = {};
        data.GroupId = $("#cmbGroup").val();


        if (data.GroupId == 0) {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetandGets",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
        else {
            data.SbgrpId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/SubGroupGetForGroup",
                data: data,
                success: function (result) {
                    SubGroupLoad(result.oList);
                }
            });
        }
    }

    function SubGroupLoad(result) {
        $("#cmbSubgroup").empty();
        $("#cmbSubgroup").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#cmbSubgroup").append("<option value='" + result[i].SbgrpId + "'>" + result[i].SbgrpName + "</option>");
        }
    }
    $("#txtproduct").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {           
            var data = {};
            data.ItemCode = $("#txtproduct").val();
            data.LocId =UserLocationId;
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../SalesInvoice/ProductSearchSales',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.ItemCode,
                            label1: item.Description,                               
                            Description: item.Description,                              
                            ProductId: item.ItemId,
                            Product: item.ItemCode,
                            headers: ["Material Code", "Material Description"]
                        })
                    }));
                }               
            })
        },
           
        autoFocus: true,
        select: function (event, ui) {                          
            $('#txtproduct').val(ui.item.Product);
            $('#txtproductId').val(ui.item.ProductId);
            $("#suppliername").focus();
    },
    });
    function change() {
        if ($('#txtproduct').val() == '') {
            $('#txtproductId').val(0);
        }
    }
    $("#txtaccnt").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountDescription = $("#txtaccnt").val();
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../Inventory/AccountNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            DebitAccount: item.DebitAccount,
                            AccountDescription: item.AccountDescription,
                            AccountId: item.AccountId,
                            headers: ["Account Code", "Account Name"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#txtaccntId').val(ui.item.AccountId)
            $('#txtaccnt').val(ui.item.DebitAccount);
        },
    });

    $("#suppliername").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#suppliername").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.CustName,
                            label1: item.CustAccount,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            headers: ["Supplier Name", "Account Code"]
                        })
                    }));
                }

