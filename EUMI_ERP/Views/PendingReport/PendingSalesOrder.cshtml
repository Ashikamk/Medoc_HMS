    function GetViewList(result) {


        disable_datatable('tbl_WorkSheet');
        $('#tbl_WorkSheet tr').remove();

        var ProdRow = "<thead><tr><th style='width:5%' class='text-right' ></th>" +
            "<th style='width:8%' class='text-center'>Bill No</th>" +
            "<th style='width:5%' class='text-center'>BillDate</th>" +
            "<th style='width:17%' class='text-center'>Name</th>" +
            "<th style='width:5%' class='text-center'>OpNo</th>" +
            "<th style='width:5%' class='text-center'>Age</th>" +
            "<th style='width:5%' class='text-center'>Doctor</th>" +
            "<th style='width:5%' class='text-right'>TotalAmt</th>" +
            "</tr>" +

            "<tr><th > </th>" +
            "<th>Bill No</th>" +
            "<th>BillDate</th>" +
            "<th>Name</th>" +
            "<th>OpNo</th>" +
            "<th>Age</th>" +
            "<th>Doctor</th>" +
            "<th> </th>" +
            "</tr></thead><tbody>";

        if (result.length != 0) {
          //  $('#Loadingsave').show();
            for (var n = 0; n < result.length; n++) {

                ProdRow += "<tr class='jsgrid-row' ondblclick='ngOnDestroy(),copyrefresh(2),GetBillDetails(" + result[n].BillYear + "," + result[n].BillNo + ", " + result[n].DeptId + ");'>" +
                    "<td style='width:3%' class='text-center'>" +
                    "<button class='btn white btn-round btn-xs' type='button' style='background-color:#FF9800;font-size:smaller;margin:0' onclick='ngOnDestroy(),copyrefresh(2),GetBillDetails(" + result[n].BillYear + "," + result[n].BillNo + ", " + result[n].DeptId + ");' data-toggle='tooltip' data-placement='top' data-original-title=View><i class='ft-eye'></i></button>" +
                    "</td>" +
                    "<td class='text-center'> " + result[n].BillYear + "-" + result[n].BillNo + "</td>" +
                    "<td class='text-center'> " + result[n].BillDate + "</td>" +
                    "<td class='text-left'> " + result[n].Name + "</td>" +
                    "<td class='text-center'> " + result[n].OpNo + "</td>" +
                    "<td class='text-center'> " + result[n].Age + "</td>" +
                    "<td class='text-center'> " + result[n].TestName + "</td>" +
                    "<td class='text-right'> " + parseFloat(result[n].NetAmt).toFixed(Decimal) + "</td>" +

                    "<td class='text-center'> " + parseFloat(result[n].NetAmt).toFixed(Decimal) + "</td>" +


                    "</tr>";
            }
            $('#tbl_WorkSheet').html(ProdRow + '</tbody>');
            datatableWithsearch('tbl_WorkSheet', 'Multiple');
            $('#tbl_WorkSheet').scrollTop(0);

        }
        else {
            $('#tbl_WorkSheet').html(ProdRow + '</tbody>');
            datatableWithsearch('tbl_WorkSheet', 'Multiple');
        }
        $('#LoadingSmall').hide();
        //$('#select_dept').focus();

    }

   
