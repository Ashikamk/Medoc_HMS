                        $('#TotalTax').val((parseFloat(result.oList[0].TotalTax || 0).toFixed(Decimal)));
                        CalcDiscountSplitTax1();
                        SalesGets(result.oList);
                        if (type == 0) {
                            $('#txtBillSlNocopy').focus();
                            $('#txtBillSlNocopy').select();
                        }
                        else {
                            $('.arrow,.tooltip-inner').hide();
                            $('#salesviewpopup').hide();
