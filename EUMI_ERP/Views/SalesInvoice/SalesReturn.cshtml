<script type="text/javascript">
    $(document).ready(function () {
     if ("@Request.QueryString["from"]" == "AccountStatement") {
            var srlsrs = sessionStorage.getItem("sales_srs");
            var srlno = sessionStorage.getItem("sales_slno");
            var dep = sessionStorage.getItem("sales_deptid");
            sessionStorage.removeItem("sales_srs");
            sessionStorage.removeItem("sales_slno");
            sessionStorage.removeItem("sales_deptid");
            var numId = parseInt(srlsrs);
            var num = parseInt(srlno);
            var deprtid = parseInt(dep)
            if (!isNaN(numId) && !isNaN(num)&& !isNaN(deprtid)) {
                ReportGetCopy(numId, num, deprtid);
            }
        }
    });

    function ReportGetCopy(BillSeries, Billno,depid) {

        $('#txtBillSlNocopy').val(Billno);
        var data = {};
        data.BillSeries = BillSeries;
        data.ReturnNo = Billno;
        data.DeptId = depid;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesReturnGetandGets",
            data: data,
            success: function (result) {
                TaxClear();

                $('#disc').val(parseFloat(result.oList[0].BillDiscount).toFixed(Decimal));
                $('#GrandTotal').val((parseFloat(result.oList[0].GrandTotal).toFixed(Decimal)));
                $('#TotalTaxable').val((parseFloat(result.oList[0].TotalTaxable).toFixed(Decimal)));
                $('#HiddenTotal').val((parseFloat(result.oList[0].TotalTaxable).toFixed(Decimal)));
                $('#TotalDiscount').val((parseFloat(result.oList[0].TotalDiscount).toFixed(Decimal)));
                $('#TotalTax').val((parseFloat(result.oList[0].TotalTax).toFixed(Decimal)));
                CalcDiscountSplitTax1();
                SalesGets(result.oList);
                $('.form-control').prop('disabled', true);
                $('.jsgrid-button').prop('disabled', true);
                $('#btnsubmit').prop("disabled", true);
                $('#btnlist').prop("disabled", true);
                $('#btnadd').prop("disabled", true);
                $('#txtBillSlNocopy').focus();

            }
        });
    }
</script>

