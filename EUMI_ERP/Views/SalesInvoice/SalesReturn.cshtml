            success: function (result) {
                Tbldelete();
                copyrefresh();
                TaxClear();
                //$("#btndelete,#btnsaveedit,#btnedit").hide();
                if (result.oList.length > 0) {
                    if (DeptArray.includes(result.oList[0].DeptId)) {
                        if (result.oList[0].DeptId == ERPDeptId) {
                            $('#btnedit').show();
