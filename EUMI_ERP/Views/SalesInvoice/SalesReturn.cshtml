    function getdate() {
        var terms = $($('#select_terms')).find("option:selected").attr("name");
        if ($('#select_terms').val() != 0) {
            var Dt = $('#txtivdate').val();
            var someDate = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));
            someDate.setDate(parseInt(someDate.getDate()) + parseInt(terms));
            var month = +someDate.getMonth() + 1;
            var day = someDate.getDate();

            if (day < 10) {
                day = '0' + day;
            }
            if (month < 10) {
                month = '0' + month;
            }

            newdate = day + "/" + month + "/" + someDate.getFullYear();
            $('#txtduedate').val(newdate);
        }
        else {
            $('#txtduedate').val(CurDate);
        }

    }



