<script type="text/javascript">
    function exportbilltotable() {
        var row = ""
        var PayType = $("#select_payterms option:selected").text();
        var CustName = $('#txtcustomer').val();                      var CustAddress = $('#txtaddress').val();
        var InvDate = $('#txtivdate').val(); var Location = $("#select_location0 option:selected").text();
        var SalesMan = $("#select_salesman option:selected").text(); var SupplyTo = $("#select_place option:selected").text();
        var Amount = $("#gndtotal").text();
        row += '<tr><td><b>Quotation No<b> </td><td><b>' + $('#txtQuotationNocopy').val() + '</b></td><td></td><td></td></tr>';
        row += '<tr><td><b>Customer</b></td><td><b>' + CustName + '</b></td><td><b>Date<b> </td><td><b>' + InvDate + '</b></td><td><b>Supply To</b></td><td><b>' + SupplyTo + '</b></td><td></td><td></b></td></tr>';
        row += '<tr><td><b>Phone</b> </td><td><b>' + CustAddress + '</b></td><td><b></b></td><td><b></b></td><td><b>Total</b></td><td><b>' + Amount + '</b></td><td><b></b></td><td><b></b></td><td></td></tr>'
        row += '<tr><td>Item Code</td><td>Name</td><td>Qantity</td><td>Rate</td><td>Discount</td><td>Taxable Amount</td><td>Tax Amount</td><td>Amount</td></tr>'

        for (k = 1; k <= i; k++) {
            var ProductId = $('#PrdtId' + k).val();                                   var ProductCode = $('#txtproduct' + k).val();
            var ProductDescr = $('#ProductDesc' + k).val();                           var BillSeriesId = $('#txtBillseriesId').val();
            var BillSlNo = $('#txtQuotationNocopy').val(); var UnitId = $('#select_unit' + k).val();
            var UnitName = $('#select_unit' + k).find("option:selected").attr("name");var ProdQty = $('#txtquantity' + k).val();
            var ProdRate = $('#txtfcrate' + k).val();                                 var FcProdRate = $('#txtrate' + k).val();
            var ProdDisc = $('#txtfcdiscount' + k).val();                             var FcProdDisc = $('#txtdiscount' + k).val();
            var TaxableAmount = $('#txtfctaxableamnt' + k).val();                     var FCTaxableAmount = $('#txttaxableamnt' + k).val();
            var TaxId = $('#select_tax' + k).val();                                   var TaxPercent = $('#txttaxpercent' + k).val();
            var TaxAmount = $('#txtfctaxamnt' + k).val();                             var FCTaxAmount = $('#txttaxamnt' + k).val();
            var Amount = $('#txtfcamnt' + k).val();                                   var FCAmount = $('#txtamnt' + k).val();
            var LocnId = $('#select_location' + k).val();
            row += '<tr><td>' + ProductCode + '</td><td>' + ProductDescr + '</td><td>' + ProdQty + '</td><td>' + ProdRate + '</td><td>' + ProdDisc + '</td><td>' + TaxableAmount + '</td><td>' + TaxAmount + '</td><td>' + Amount + '</td></tr>'
        }
        $('#tbExport').html('')
        $('#tbExport').append(row);
    }



    $(function () {
        $("#btnExporttoExcel").click(function () {
            if ($('#tblsalesinvoice tr').length > 0)
            {
                exportbilltotable();
                var BillNo = 'Quotation-' + $('#txtQuotationNocopy').val();
                $("#tbExport").table2excel({
                    filename: BillNo + ".xls"
                });
            }
            else
            {
                warningshow("No Products!");
            }
        });       
    });
</script>

