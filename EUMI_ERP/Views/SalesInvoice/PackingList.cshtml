    //Next-Prev Button For Copy
    function GetBillPrevousornext(Value) {
        $('#btnsubmit').prop("disabled", true);
        $('#txtBillSlNocopy').prop("disabled", false);
        $('#Warningpopup').fadeOut();


        if ($('#txtBillSlNocopy').val() == '' && Value == -1) {
            $('#txtBillSlNocopy').focus();
            $('#txtBillSlNocopy').val(($('#txtBlSlNo').val()));
        }
        else if ($('#txtBillSlNocopy').val() == '' && Value == 1) {
            $('#txtBillSlNocopy').focus();
            $('#txtBillSlNocopy').val(0);
        }

        var Billno = parseInt($('#txtBillSlNocopy').val() || 0);
        Billno = Billno + Value;


        if (((currentbillno == 1) && (Billno == 0))) {
            warningshow('DO Number Not Valid', 'txtBillSlNocopy');
            return false;
        }
        else if ((Billno < 0) || (Billno >= currentbillno)) {
            warningshow('DO Number Not Valid', 'txtBillSlNocopy');
            ($('#txtBillSlNocopy').select());
            return false;
        }
        else if (Billno == 0) {
            warningshow('Bill Number Not Valid', 'txtBillSlNocopy');
            $('#txtBillSlNocopy').select()
            return false;
        }
        else {
            $('#txtBillSlNocopy').val(Billno);
            var data = {};
            data.DeliveryOrderNo = Billno;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../SalesInvoice/PackingListGetandGets",
                data: data,
                success: function (result) {
                    Tbldelete();
                    copyrefresh();
                    DeliveryGets(result.oList);
                    $('#btnsubmit').prop("disabled", true);
                    $('#btnlist').prop("disabled", true);
                    $('#btnadd').prop("disabled", true);
                    $('#txtBillSlNocopy').focus();
                }
            });
        }
    }

