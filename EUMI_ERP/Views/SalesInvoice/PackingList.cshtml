    function PrintthisBill(flg)
    {
        PrintthisBillWindowsNew('PackingHistory', i, flg) 
    }

    //Copy Function
    function GetRows(flg) {
        if (editflag != 0) {
            warningshow('Please Update Edit Mode');
        }
        else if (copyflag == 0) {
            var rowcount = CountRows();
            if (rowcount > 0) {
                $('#confirm').show();
                $('#confirmOk').focus();
                if (flg == 0)
                { $('#Confirmflag').val('copy'); }
                else if (flg == 1)
                { $('#Confirmflag').val('view'); }
                $('#ConfirmRowId').val(flg);
                $('#confirmmessage').text('Data will be lost.Do you want to Continue?');
            }
            else {
                DeliveryOrderCopy(flg);
            }
        }
        else {
            DeliveryOrderCopy(flg);
        }
    }

    function DeliveryOrderCopy(flg) {
        copyflag = 1;

        Tbldelete();

        productpopuprefresh();

        $('#copybill').show();
        $('#bill').hide();
       
        currentbillno = $('#txtBlSlNo').val();
        $('#popupdiv').hide();
