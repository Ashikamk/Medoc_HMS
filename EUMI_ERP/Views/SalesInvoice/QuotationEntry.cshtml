<script>

    function PrintthisBill() {
        PrintthisBillWindows('QUOTATION', i, 'COPY')
    }

    var m = 1;
    var currentbillno;

    //Copy Function
    function GetRows(flg) {
        if (editflag != 0) {
            warningshow('Please Update Edit Mode');
        }
        else if (copyflag == 0) {
            var rowcount = CountRows();
            if (rowcount > 0) {
                $('#confirm').show();
                $('#confirmOk').focus();
                $('#Confirmflag').val('copy'); $('#ConfirmRowId').val(0);
                $('#confirmmessage').text('Data will be lost.Do you want to Continue?');
            }
            else {
                QuotationCopy(flg);
            }
        }
        else {
            QuotationCopy(flg);
        }
    }

    //Disable and Clear Before Copy function
    function QuotationCopy(flg)
    {
        copyflag = 1;
        TaxClear();
        Tbldelete();

        productpopuprefresh(flg);

        $('#QnRow').css("height", '40px');


        $('#copybill').show();
        $('#bill').hide();
        $('.form-control').prop("disabled", true);
        $('#btncrncy,#btnsales,#btnsply,#btnpdct,#btncst,#btntrnsfr,#btnadd').prop("disabled", true);
        $('#editheader').hide();
        $('.jsgrid').prop("disabled", true);

        $('#txtQuotationNocopy').focus();
        $('#txtQuotationNocopy').prop('disabled', false);
        $('#txtQuotationNocopy').select();


        currentbillno = $('#txtBlSlNo').val();
        //  $('#tour1').show();
        $('#txtQuotationNocopy').focus();
        $('#popupdiv').hide();
        $('#txtivdate').val(CurDate);
        $('#txttaxpercent0').val('');
        $('#txtmsg').val('');
        $('#txtcustomer').val('');
        $('#txtaddress').val('');
        $('#PriceGroupId').val(0);
        $('#select_salesman').val(UserSalesmanId);
        $('#select_place').val(0);
        $('#select_crncy').val(BaseCurrency);
        $('#txtcrncyrate').val($('#select_crncy').find("option:selected").attr("name"));
        $('#txtproduct0').val('');
        $('#btndelete').hide();
        $('#select_unit0').val(0);
        $('#txtquantity0').val('');
        $('#txtstocktotloseqty0').val(0);
        $('#txtrate0').val('');
        $('#txtdiscount0').val('');
        $('#select_tax0').val(0);
        $('#txtamnt0').val('');
        $('#TotalDiscount').val('0.00');
        $('#TotalTaxable').val('0.00');
        $('#TotalTax').val('0.00');
        $('#GrandTotal').val('0.00');
        $('#disc').val('');
        $('#gndtotal').text('');
        $('#fc').text('fc');
        $("#fc").css("opacity", '0');
        $('#btndelete').hide();
        $('#select_locn').val(0);
        GrandTotal = 0;
        $('#gndtotal').text('0.00');

        CloseEnquiry();

        $('#txtduedate').css("background-color", '#ECEFF1');
        $('#txttaxpercent0').css("background-color", '#ECEFF1');
        $('#txtamnt0').css("background-color", '#ECEFF1');



        $('#btnsubmit').prop("disabled", true);
        $('#btnlist').prop("disabled", true);
        $('#btnadd').prop("disabled", true);
        $('#txtcustomer').prop("disabled", true);

        $('#txtQuotationNocopy').prop("disabled", false);
        $('#txtQuotationNocopy').select();


        $('#btnprvs').show();
        $('#btnnxt').show();
        $('#btnprvs').prop("disabled", false);
        $('#btnnxt').prop("disabled", false);
        $("#panel1").hide();

        $('#btnprint').show();

        $('#btnsubmit').hide();
        $('#btnlist').hide();
        if (flg == 0) {
            $('#txtQuotationNocopy').focus();
            $('#txtQuotationNocopy').prop('disabled', false);
            $('#txtQuotationNocopy').select();
        }
        else {
            $('#salesviewpopup,#btnviewsales').show();
            $('#select_dept').val(0);
            $('#DateFrom,#DateTo,#select_dept').prop("disabled", false);
            $('#DateFrom').val(CurDate); $('#DateTo').val(CurDate); $('#SelectSalesReports').val(0);
            QuotationEntryListView(1);
            $('.notdis').prop("disabled", false);
            $('#select_dept').focus();
        }
    }
    function QuotationEntryListView() {
        $('#Loadingsave').show();
        var data = {};
        data.FromDate = $('#DateFrom').val();
        data.ToDate = $('#DateTo').val();
        data.DeptId = $('#select_dept').val();
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: '../SalesInvoice/QuotationEntryListView',
            data: data,
            success: function (result) {

                disable_datatable('tblsalesview');
                $("#txtquantity0,#txtproduct0").blur();
                $('#tblsalesview tr').remove();

                var ProdRow = "<thead><tr><th class='text-left' style='width:5%' >Quotation#</th><th style='width:5%' class='text-center'>Department</th><th style='width:5%' class='text-center'>Date</th><th style='width:15%'>CustomerName</th><th style='width:16%'>Address</th><th style='width:2%'>SalesMan</th><th style='width:10%'>User</th><th style='width:5%'>Location</th><th  style='width:5%'  class='text-right' >GrandTotal</th><th style='width:3%'></th></tr>" +
                                   "<tr><th class='text-left' style='width:5%'>Quotation#</th><th style='width:5%' class='text-center'> Department</th><th class='text-center' style='width:5%'>Date</th><th style='width:15%'>CustomerName</th><th style='width:16%'>Address</th><th style='width:2%'>SalesMan</th><th style='width:10%'>User</th><th style='width:5%'>Location</th><th  style='width:5%'  class='text-right'>GrandTotal</th><th style='width:3%'></th></tr></thead><tbody>";

                if (result.length != 0) {

                    for (var n = 0; n < result.length; n++) {

                        ProdRow += "<tr class='jsgrid-row' ondblclick='QuotationGetCall(" + result[n].BillSlNo + "," + result[n].DeptId + ",1)'>" +
                           "<td class='text-left'> " + result[n].BillSlNo + "</td>" +
                            "<td class='text-center'>" + result[n].DepartmentName + " </td>" +
                           "<td class='text-center'>" + result[n].InvDate + "                                   </td>" +
                           "<td  class='text-left'>" + result[n].CustName + "                                   </td>" +
                           "<td  class='text-left'>" + result[n].CustAddress + "                                   </td>" +
                           "<td class='text-left'>" + result[n].SalesMan + "                                   </td>" +
                           "<td class='text-left'>" + result[n].UserName + "                                   </td>" +
                           "<td class='text-left'>" + result[n].Location + "                                   </td>" +
                           "<td class='text-right'>" + parseFloat(result[n].FCGrandTotal || 0).toFixed(Decimal) + " </td>" +
                            "<td style='width:3%' class='text-center'>" +
                            "<button class='btn white btn-round btn-xs' type='button' style='background-color:#FF9800;font-size:smaller;margin:0' onclick='QuotationGetCall(" + result[n].BillSlNo + "," + result[n].DeptId + ",2)' data-toggle='tooltip' data-placement='top' data-original-title=Print><i class='ft-printer'></i></button>" +
                            "</td>" +
                            "</tr>";
                    }
                    $('#tblsalesview').html(ProdRow + '</tbody>');
                    datatableWithsearch('tblsalesview', 'Multiple');
                    $('#tblsalesview').scrollTop(0);

                }
                else {
                    $('#tblsalesview').html(ProdRow + '</tbody>');
                    datatableWithsearch('tblsalesview', 'Multiple');
                }
                $('#Loadingsave').hide();
            }
        });
    }
    function QuotationGetCall(BillSlNo, DeptId, type) {
        var data = {};
        data.QuotationNo = BillSlNo;
        data.QuotationEntryMainId = 0;
        data.DeptId = DeptId;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/QuotationEntryGetandGets",
            data: data,
            success: function (result) {
                Tbldelete();
                copyrefresh();
                QuotationEntryGets(result.oList);
               
                if (type == 0) {
                    $('#txtQuotationNocopy').focus();
                    $('#txtQuotationNocopy').select();
                }
                else {
                    $('.arrow,.tooltip-inner').hide();
                    $('#salesviewpopup').hide();
                    if (type == 2) { PrintthisBill(); }
                }
                $('#btnsubmit').prop("disabled", true);
                $('#btnlist').prop("disabled", true);
                $('#btnadd').prop("disabled", true);
                $('#txtQuotationNocopy').focus();
            }
        });
    }

    //Next-Prev Button For Copy
    function GetBillPrevousornext(Value) {
        TaxClear();
            $('#btnprvs').prop("disabled", false);
            $('#btnnxt').prop("disabled", false);
            $('#txtQuotationNocopy').prop("disabled", false);


            $('#Warningpopup').fadeOut();
           

            if ($('#txtQuotationNocopy').val() == '' && Value == -1) {
                $('#txtQuotationNocopy').focus();
                $('#txtQuotationNocopy').val(($('#txtBlSlNo').val()));
            }
            else if ($('#txtQuotationNocopy').val() == '' && Value == 1) {
                $('#txtQuotationNocopy').focus();
