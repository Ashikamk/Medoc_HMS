<script>
    var m = 1; 
    var currentbillno;

    //Confirm for Disable and Clear Before Copy function
    function GetRows(flg) {
      
        if (editflag != 0) {
            warningshow('Please Update Edit Mode');
        }
        else if (copyflag == 0) {
            var rowcount = CountRows();
            if (rowcount > 0) {
                $('#confirm').show();
                $('#confirmOk').focus();
                $('#Confirmflag').val('copy'); $('#ConfirmRowId').val(flg);
                $('#confirmmessage').text('Data will be lost.Do you want to Continue?');
            }
            else
            {
                SalesCopy(flg);
            }
        }
        else {
            SalesCopy(flg);
        }
    }

    //Disable and Clear Before Copy function
    function SalesCopy(flg)
    {
       
        copyflag = 1;

        Tbldelete();

        productpopuprefresh();
        $('#btnsubmit').prop("disabled", true);
        $('#divcst').css("height", '40px');
        $('#editheader').hide();
        $('#copybill').show();
        $('#bill').hide();
        $('.form-control').prop("disabled", true);
        $('#btncrncy,#btnsales,#btnsply,#btnpdct,#btncst').prop("disabled", true);

        $('.jsgrid').prop("disabled", true);

        $('#txtEnquiryNocopy').focus();
        $('#txtEnquiryNocopy').prop('disabled', false);
        $('#txtEnquiryNocopy').select();


        currentbillno = $('#txtBlSlNo').val();
        //$('#tour1').show();
        $('#popupdiv').hide();
        $('#txtivdate').val(CurDate);
        $('#txttaxpercent0').val('');
        $('#txtmsg').val('');
        $('#txtcustomer').val('');
        $('#txtaddress').val('');
        $('#select_salesman').val(UserSalesmanId);
        $('#select_locn').val(0);
        $('#select_place').val(0);
        $('#select_crncy').val(BaseCurrency);
        $('#txtcrncyrate').val($('#select_crncy').find("option:selected").attr("name"));
        $('#txtproduct0').val('');
        $('#btndelete').hide();
        $('#select_unit0').val(0);
        $('#txtquantity0').val('');
        $('#txtstocktotloseqty0').val(0);
        $('#txtrate0').val('');
        $('#txtdiscount0').val('');
        $('#select_tax0').val(0);
        $('#txtamnt0').val('');
        $('#TotalDiscount').val('0.00');
        $('#TotalTaxable').val('0.00');
        $('#TotalTax').val('0.00');
        $('#GrandTotal').val('');
        $('#disc').val('');
        $('#gndtotal').text('');
        $('#fc').text('fc');
        $("#fc").css("opacity", '0');
        $('#btndelete').hide();
        GrandTotal = 0;
        $('#gndtotal').text('0.00');

        $('#btntrnsfr').css("height", '85%');
        $('#txtduedate').css("background-color", '#ECEFF1');
        $('#txttaxpercent0').css("background-color", '#ECEFF1');
        $('#txtamnt0').css("background-color", '#ECEFF1');



        $('#btnsubmit').prop("disabled", true);
        $('#btnlist').prop("disabled", true);
        $('#btnadd').prop("disabled", true);
        $('#txtcustomer').prop("disabled", true);

        $('#txtEnquiryNocopy').prop("disabled", false);
        $('#txtEnquiryNocopy').select();
        $('#PriceGroupId').val(0);

        $('#btnprvs').show();
        $('#btnnxt').show();
        $('#btnprvs').prop("disabled", false);
        $('#btnnxt').prop("disabled", false);
        $("#panel1").hide();

        $('#btnsubmit').hide();
        $('#btnlist').hide();
       
        if (flg == 0) {
            $('#txtEnquiryNocopy').focus();
            $('#txtEnquiryNocopy').prop('disabled', false);
            $('#txtEnquiryNocopy').select();
        }
        else {
            $('#salesviewpopup,#btnviewsales').show();
            $('#select_dept').val(0);
            $('#DateFrom,#DateTo,#select_dept').prop("disabled", false);
            $('#DateFrom').val(CurDate); $('#DateTo').val(CurDate); $('#SelectSalesReports').val(0);
            CustomerEnquiryList(1);
            $('.notdis').prop("disabled", false);
            $('#select_dept').focus();
        }
    }
    function CustomerEnquiryList() {
        $('#Loadingsave').show();
        var data = {};
        data.FromDate = $('#DateFrom').val();
        data.ToDate = $('#DateTo').val();
        data.DeptId = $('#select_dept').val();
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: '../SalesInvoice/CustomerEnquiryGetList',
            data: data,
            success: function (result) {

                disable_datatable('tblsalesview');
                $("#txtquantity0,#txtproduct0").blur();
                $('#tblsalesview tr').remove();

                var ProdRow = "<thead><tr><th class='text-left' style='width:5%' >Enquiry#</th><th style='width:5%' class='text-center'>Department</th><th style='width:5%' class='text-center'>Date</th><th style='width:15%'>CustomerName</th><th style='width:16%'>Address</th><th style='width:2%'>SalesMan</th><th style='width:10%'>User</th><th style='width:5%'>Location</th><th  style='width:5%'  class='text-right' >GrandTotal</th></tr>" +
                                   "<tr><th class='text-left' style='width:5%'>Enquiry#</th><th style='width:5%' class='text-center'> Department</th><th class='text-center' style='width:5%'>Date</th><th style='width:15%'>CustomerName</th><th style='width:16%'>Address</th><th style='width:2%'>SalesMan</th><th style='width:10%'>User</th><th style='width:5%'>Location</th><th  style='width:5%'  class='text-right'>GrandTotal</th></tr></thead><tbody>";

                if (result.length != 0) {

                    for (var n = 0; n < result.length; n++) {

                        ProdRow += "<tr class='jsgrid-row' ondblclick='EnquiryGetCall(" + result[n].BillSlNo + "," + result[n].DeptId + ",1)'>" +
                           "<td class='text-left'> " + result[n].BillSlNo + "</td>" +
                            "<td class='text-center'>" + result[n].DepartmentName + " </td>" +
