            "</tr>";


            $('#tblsalesinvoice').append(ProdRow1);
            $('#unit' + id).val(result[n].UnitId);
            $('#tax' + id).val(result[n].TaxId);
            $('#location' + id).val(result[n].LocnId);
            id++;
            clearrow();
        }
    }

