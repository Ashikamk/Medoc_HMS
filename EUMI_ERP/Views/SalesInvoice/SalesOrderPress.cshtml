                $("#fc").text('FC : ' + fcur.toFixed(Decimal));
                $("#fc").css("opacity", '100');
            }

            var ProdRow1 = "<tr id=" + 'row' + id + " class='jsgrid-row'><td class='jsgrid-cell' style='width:15px;text-align:center'>" + (n+1) + "</td>" +
            "<td class='jsgrid-cell jsgrid-align-left' style='width:75px'><input type='text' style='display:none' /><input type='text' style='height:30px;background-color:white' disabled='' id=" + 'product' + id + " value='" + result[n].ProductCode + "' class='form-control text-left'></td>" +
            "<td class='jsgrid-cell jsgrid-align-right' style='width:75px;text-align:center'><input type='text' style='height:30px;background-color:white' disabled='' class='form-control text-left' id=" + 'ProductDesc' + id + " value='" + result[n].ProductDescr + "'></td>" +
            "<td class='jsgrid-cell jsgrid-align-center' style='width:30px'><select disabled='' id=" + 'unit' + id + " style='background-color:white;height:30px' class='form-control'>" + UnitSelect + "</select></td>" +
            "<td class='jsgrid-cell jsgrid-align-center' style='width:30px'><input type='text' id=" + 'quantity' + id + " value=" + result[n].ProdQty + " disabled='' class='form-control text-center' style='background-color:white;height:30px'></td>" +
