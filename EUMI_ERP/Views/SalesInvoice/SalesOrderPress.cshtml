            "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' style='width:30px'><input id=" + 'discount' + id + " value=" + parseFloat(result[n].ProdDisc).toFixed(Decimal) + " type='text' disabled='' class='form-control text-center' style='background-color:white;height:30px'></td>" +
            "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' style='width:40px'><input id=" + 'taxableamt' + id + " value=" + parseFloat(result[n].TaxableAmount).toFixed(Decimal) + " type='text' disabled='' class='form-control text-center' style='background-color:white;height:30px'></td>" +
            "<td class='jsgrid-cell jsgrid-align-center' style='width:30px'><select id=" + 'tax' + id + " value=" + result[n].TaxId + " style='background-color:white;height:30px' disabled='' class='form-control'>" + TaxSelect + "</select></td>" +
