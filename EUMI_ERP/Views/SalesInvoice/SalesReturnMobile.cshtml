function Addpopupwindow(Id) {
    $("#popupdiv").css("margin-top", '0px');

    $('#currencydiv').hide(); $('#areadiv').hide();
    $('#locationdiv').hide(); $('#salesmandiv').hide();
    $('#termsdiv').hide();

    $('#popupdiv').show();


    if (Id == 1) {
        $('#myheader').text('Currency');
        $('#currencydiv').show();
        $('#txt_code').focus();

    }

    else if (Id == 2) {
        GetAreaGroupselect(0);
        $('#myheader').text('Area');
        $('#areadiv').show();
        $('#txtcode').focus();
    }
    else if (Id == 3) {
        $('#myheader').text('Location');
        $('#locationdiv').show();
        $('#LocationCode').focus();
    }
    else if (Id == 4) {
        $('#myheader').text('SalesMan');
        $('#salesmandiv').show();
        $("#popupdiv").css("margin-top", '-130px');
        $('#code').focus();
    }
    else if (Id == 5) {
        $('#myheader').text('Terms');
        $('#termsdiv').show();
        $('#txtdesc').focus();
    }
}
