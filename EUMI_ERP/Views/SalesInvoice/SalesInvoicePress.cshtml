<script type="text/javascript">
    $(document).ready(function () {
        if ("@Request.QueryString["from"]" == "SalesReport") {
            var srlsrs = sessionStorage.getItem("sales_srs");
            var srlno = sessionStorage.getItem("sales_slno");
            var dep = sessionStorage.getItem("sales_deptid");
            sessionStorage.removeItem("sales_srs");
            sessionStorage.removeItem("sales_slno");
            sessionStorage.removeItem("sales_deptid");
            var numId = parseInt(srlsrs);
            var num = parseInt(srlno);
            var deprtid=parseInt(dep)
            if (!isNaN(numId) && !isNaN(num) && !isNaN(deprtid)) {
                ReportGetCopy(numId,num,deprtid);
            }
        }
        else if ("@Request.QueryString["from"]" == "WorkItem") {
            var srlsrs = sessionStorage.getItem("sales_srswork");
            var srlno = sessionStorage.getItem("sales_slnowork");
            var dep = sessionStorage.getItem("sales_deptidwork");
            sessionStorage.removeItem("sales_srswork");
            sessionStorage.removeItem("sales_slnowork");
            sessionStorage.removeItem("sales_deptidwork");
            var numId = parseInt(srlsrs);
            var num = parseInt(srlno);
            var deprtid = parseInt(dep)
            if (!isNaN(numId) && !isNaN(num) && !isNaN(deprtid)) {
                ReportGetCopy(numId, num, deprtid);
            }
        }
    });
    function ReportGetCopy(BillSeries, Billno, depid) {

        NextInvoiceNo = parseInt($('#txtBillSlNo').val() || 0);
        var data = {};
        data.BillSeriesId = BillSeries;
        data.BillSlNo = Billno;
        data.DeptId = depid;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesGetandGets",
            data: data,
            success: function (result) {
                $('#txtBillSlNo').val(Billno)
                SalesGets(result.oList);
                $('#btnsubmit').prop("disabled", true);
                $('#btnlist').prop("disabled", true);
                $('#btnadd').prop("disabled", true);
                $('#txtBillSlNo').focus();

            }

        });


    }
</script>


