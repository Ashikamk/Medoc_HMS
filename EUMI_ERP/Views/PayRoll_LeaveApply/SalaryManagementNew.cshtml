            var OTRate = result[l].OTRate;
            var WH = result[l].Workinghrs;
            var Abs = result[l].LeavesTaken;
            var AD = result[l].SalaryAdvance;
            var TDM = result[l].TotalDaysInMonth;
            var BS = parseFloat(result[l].BasicSalary).toFixed(Decimal);

            var HRA = result[l].HRA;
            var DA = result[l].DA;
            var TA = result[l].TA;
            var AL = result[l].Allowance;
            var OE = result[l].Earnings;
            var TE = parseFloat(HRA) + parseFloat(DA) + parseFloat(TA) + parseFloat(AL) + parseFloat(OE);

            var PF = result[l].PF;
            var Tax = result[l].Tax;
            var ESI = result[l].ESI;
            var OD = result[l].Deductions;
            var Sal = BS / TDM;
            var LD = parseFloat(Sal).toFixed(Decimal) * parseFloat(Abs).toFixed(Decimal);
            var TD = parseFloat(PF) + parseFloat(Tax) + parseFloat(ESI) + parseFloat(OD) + parseFloat(LD) + parseFloat(AD).toFixed(Decimal);

            var OTCal = parseFloat(Sal / WH).toFixed(Decimal);
            var OT = parseFloat(OTCal * OTRate).toFixed(Decimal);

            var TS = parseFloat(BS)  + parseFloat(OT) + parseFloat(TE);

            var FTS = parseFloat(TS).toFixed(Decimal) - parseFloat(TD).toFixed(Decimal);

            console.log('---------------------------------------')
            responseText += '<tr style=background-color:white  id=' + 'Srow' + slno + '>' +
                            '<td style="text-align:center">' + slno + '</td>' +
                            '<td id= ' + 'EmployeeId' + slno + '>' + result[l].EmpId + '<input type=hidden id= ' + 'EUId' + slno + '   class="form-control"  value=' + result[l].EmpUserId + '></td>' +
                            '<td id= ' + 'EmployeeCode' + slno + '>' + result[l].EmpCode + '</td>' +
                            '<td id= ' + 'EmployeeName' + slno + '>' + result[l].EmpName + '</td>' +
                            '<td id= ' + 'MainDesignation' + slno + '>' + result[l].Designation + '</td>' +
                            '<td id= ' + 'BasicSalary' + slno + ' style=text-align:right>' + parseFloat(BS).toFixed(Decimal) + '</td>' +
                            '<td id= ' + 'TotalEarnings' + slno + ' style=text-align:right>' + parseFloat(TE).toFixed(Decimal) + '</td>' +
                            '<td id= ' + 'TotalDeductions' + slno + ' style=text-align:right>' + parseFloat(TD).toFixed(Decimal) + '</td>' +
                            '<td id= ' + 'NetSalary' + slno + ' style=text-align:right>' + parseFloat(FTS || 0).toFixed(Decimal) +
                            '<input type=hidden id= ' + 'WorkinghrsM' + slno + '   class="form-control"  value=' + $('#Workinghrs').text() + '>' +
                            '<input type=hidden id= ' + 'LeavesTakenM' + slno + '   class="form-control"  value=' + $('#LeavesTaken').text() + '>' +
                            '<input type=hidden id= ' + 'SalaryAdvanceM' + slno + '   class="form-control"  value=' + $('#SalaryAdvance').val() + '>' +
                            '<input type=hidden id= ' + 'BSM' + slno + '   class="form-control"  value=' + $('#BS').val() + '>' +
                            '<input type=hidden id= ' + 'HRAM' + slno + '   class="form-control"  value=' + $('#HRA').val() + '>' +
                            '<input type=hidden id= ' + 'DAM' + slno + '   class="form-control"  value=' + $('#DA').val() + '>' +
                            '<input type=hidden id= ' + 'TAM' + slno + '   class="form-control"  value=' + $('#TA').val() + '>' +
                            '<input type=hidden id= ' + 'AllowanceM' + slno + '   class="form-control"  value=' + $('#Allowance').val() + '>' +
                            '<input type=hidden id= ' + 'EarningsM' + slno + '   class="form-control"  value=' + $('#Earnings').val() + '>' +
                            '<input type=hidden id= ' + 'PFM' + slno + '   class="form-control"  value=' + $('#PF').val() + '>' +
                            '<input type=hidden id= ' + 'TaxM' + slno + '   class="form-control"  value=' + $('#Tax').val() + '>' +
                            '<input type=hidden id= ' + 'ESIM' + slno + '   class="form-control"  value=' + $('#ESI').val() + '>' +
                            '<input type=hidden id= ' + 'DeductionsM' + slno + '   class="form-control"  value=' + $('#Deductions').val() + '>' +
                            '<input type=hidden id= ' + 'LeaveDeductionsM' + slno + '   class="form-control"  value=' + $('#LeaveDeductions').val() + '>' +
                            '<input type=hidden id= ' + 'OTRateM' + slno + '   class="form-control"  value=' + $('#OTRate').val() + '>' +
                            '<input type=hidden id= ' + 'OTM' + slno + '   class="form-control"  value=' + $('#OT').val() + '>' +
                            '<input type=hidden id= ' + 'TDM' + slno + '   class="form-control"  value=' + result[l].TDM + '>' +
                            '</td>' +

                            '</tr>';
        }
        $('#tblMSSummary').html(responseText + '</tbody>');
        var title = "";
        datatableWithsearchNS('tblMSSummary', true, title, 'buttonPlace');
    }

    function formrefresh() {
        $('#DateSelect').val(CurDate);
        startenddates();

        var date1 = getDateObject(StartingDate);
        var date2 = getDateObject(EndingDate);

        $('#DateFrom').val(StartingDate);
        $('#DateTo').val(EndingDate);

        var d = new Date();
        var n = d.getMonth()+1;
        var data = {};
        data.Month =n;
        $.ajax({
            type: "POST",
            url: "../../PayRoll_LeaveApply/SalaryManagementGets",
            data: data,
            success: function (result) {
                DetailsGets(result);
            }
        });
    }

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {


        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();

            if (title != 'Edit' && title != 'Slno' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != '')
                $(this).html('<input type="text" class="abc" placeholder="Search ' + title + '" style="width=100%" />');
        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                dom: 'Bfrtip',
                buttons: [],

            });



            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: ":visible" }
                        }
                    ]
                },
                'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();

        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });


        table = $('#' + tablename).DataTable();


    }


</script>


