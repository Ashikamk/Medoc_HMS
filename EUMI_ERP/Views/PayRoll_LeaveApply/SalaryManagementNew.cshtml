    function UpdateSalary(RowId)
    {
            var BS = $('#BS' + RowId).val();
            var OT = $('#OT' + RowId).val();
            var HRA = $('#HRA' + RowId).val();
            var DA = $('#DA' + RowId).val();
            var TA = $('#TA' + RowId).val();
            var Allowance = $('#Allowance' + RowId).val();
            var OE = $('#Earnings' + RowId).val();
            var TE = parseFloat(HRA||0) + parseFloat(DA||0) + parseFloat(TA||0) + parseFloat(Allowance||0) + parseFloat(OE||0);
            var AD = $('#SalaryAdvance' + RowId).val();;
            var PF = $('#PF' + RowId).val();
            var Tax = $('#Tax' + RowId).val();
            var ESI = $('#ESI' + RowId).val();
            var Deductions = $('#Deductions' + RowId).val();
            var LD = $('#LeaveDeductions' + RowId).val();
            var TD = parseFloat(PF||0) + parseFloat(Tax||0) + parseFloat(ESI||0) + parseFloat(Deductions||0) + parseFloat(LD||0) + parseFloat(AD||0);
            var TS = parseFloat(BS) + parseFloat(TE) + parseFloat(OT);
            var FTS = parseFloat(TS) - parseFloat(TD);
            $('#TotalSalary' + RowId).val(parseFloat(FTS||0).toFixed(Decimal));

            $('#BasicSalary' + RowId).text(parseFloat(BS).toFixed(Decimal));
            $('#TotalEarnings' + RowId).text(parseFloat(TE).toFixed(Decimal));
            $('#TotalDeductions' + RowId).text(parseFloat(TD).toFixed(Decimal));
            $('#NetSalary' + RowId).text(parseFloat(FTS).toFixed(Decimal));

    }

