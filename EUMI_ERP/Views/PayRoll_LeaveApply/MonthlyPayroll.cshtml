<script>
    $("#ItemCode").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#ItemCode").val();
            data.LocId = UserLocationId;
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../SalesInvoice/ProductSearchSales',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.ItemCode,
                            label1: item.Description,
                            Description: item.Description,
                            ProductId: item.ItemId,
                            Product: item.ItemCode,
                            headers: ["Material Code", "Material Description"]
                        })
                    }));
                }
            })
        },

        autoFocus: true,
        select: function (event, ui) {
            $('#ItemCode').val(ui.item.Product);
            $('#ItemId').val(ui.item.ProductId);
            $('#ItemDescription').val(ui.item.Description);
            $("#Supplier").focus();
        },
    });

    $("#Supplier").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#Supplier").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '+2',
                            label: item.CustName,
                            label1: item.CustAccount,
                            CustId: item.CustId,
                            CustName: item.CustName,
                            CustAccount: item.CustAccount,
                            headers: ["Supplier Name", "Account Code"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#SupplierId').val(ui.item.CustId);
            $('#Supplier').val(ui.item.CustAccount);
            $('#SupplierName').val(ui.item.CustName);
            $("#Group").focus();
        },
    });
</script>

