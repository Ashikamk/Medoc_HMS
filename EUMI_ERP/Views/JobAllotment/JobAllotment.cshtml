<script>

    var Alloted = 0;
    var UId = ERPUserId;
    var DeptId = ERPDeptId;
    var Delflag = 0;
    var CopyRowLen = 0;

    function showpopup() {
        $('#popupdiv1').show();
        $('#JobName').focus();
    }
    // Copy print area.........
    function print()
    {
        var rowlen = $('#CopyRowCount').val();
        var JobName = $('#CopyJobName').val();
        var alloteddate = $('#DateFrom').val();
        var Slno = 1;
        if (rowlen != 0) {

            var mywindow = window.open('', 'Medicine Advice', 'height=1500,width=1500');
            mywindow.document.write('<html><body height="200px">');
            mywindow.document.write('<style type="text/css">   #printbdy{ border-collapse: collapse;} #printbdy td {border:1px solid black;}.tbl1{ }#header, #nav, .noprint{display: none;}.print{ page-break-after: always;} </style>');
            mywindow.document.write('<div id="printpart">');
            mywindow.document.write('<table width="100%"><tr><td><table style="font-weight:bold"><tr><td>Eumi It Solutions Private Limited</td></tr><tr><td>743/20 & 21, Kandathil Building, H.S. Junction ,</td></tr><tr><td> Parakode, Adoor, Pathanamthitta,</td></tr><tr><td> Kerala 691554</td></tr></table></td></tr></table></hr>');
            mywindow.document.write('<table width="100%"><tr><td  valign="top" align="center">Job Allotment List</td></tr></table>');
            mywindow.document.write('<table width="25%"><tr><td  valign="top" align="left">Job Name : </td><td  valign="top" align="left">' + JobName + '</td></tr></table>');
            mywindow.document.write('<table width="25%"><tr><td  valign="top" align="left"> Date : </td><td  valign="top" align="left">' + alloteddate + '</td></tr></table>');
            mywindow.document.write('<table width="25%"><tr></tr></table>');
            mywindow.document.write(' <table width="100%" id="printbdy">');
            mywindow.document.write('<tr><td align="center"  width="10%">Slno:</td><td colspan="1"  width="12%">EmpCode</td><td align="center"  width="30%">EmployeeName</td><td align="center"  width="30%">Designation</td><td align="center"  width="15%">Salary</td></tr>');
            for (var i = 1; i <= rowlen;i++)

            {
                mywindow.document.write('<tr><td align="center"  width="10%">'
               + Slno + '</td><td colspan="1"  width="10%">'
               + document.getElementById('EmpCode' + i).innerText + '</td><td align="center"  width="30%">'
              + document.getElementById('Empname' + i).innerText + '</td><td align="center"  width="30%">'
               + document.getElementById('Des' + i).innerText + '</td><td align="center"  width="15%">'
            + document.getElementById('Sal' + i).innerText + '</td></tr>');
                Slno += 1;
            }
            mywindow.document.write('</table>');
            mywindow.document.write('<table width="25%"><tr></tr></table>');
            mywindow.document.write('<table width=100%><tr><td height=30px></td></tr><tr><td width=60%> Signature</td></tr></table>');
            mywindow.document.write('</div>');
            mywindow.document.write('</body></html>');
            mywindow.print();
            mywindow.close();

        }
        $('#CopyRowCount').val('');
        $('#CopyJobName').val('');
        $('#CopyJobDate').val('');
        $('#txtJobSearch').val('');
        $('#tblEmployesInfo tr').remove();
        $("#btnprint").hide();
        $('#btnsubmit').show();
        
        Refresh();
    }


    //.............
    $(document).ready(function () {

        $("#JobName").focus();
        $("#btnprint").hide();
        $("#chckHead").click(function () {
            var rows = $("#tblEmployesInfo tr").length;
            var flag = $("#chckHead").is(":checked")
            if (flag == true) {
                for (var i = 1; i <= rows; i++) {
                    if ($("#Alloted" + i).val() == 1 && ($("#dstJobAssignedId" + i).val() != $('#JobId').val())) {
                        document.getElementById("chktbl" + i).checked = true;
                        document.getElementById("chktbl" + i).disabled = true;
                        document.getElementById("Active" + i).style.display = "block";
                        document.getElementById("free" + i).style.display = "none";
                    }
                    else if ($("#Alloted" + i).val() == 1) {
                        document.getElementById("chktbl" + i).checked = true;
                        document.getElementById("chktbl" + i).disabled = false;
                        document.getElementById("Active" + i).style.display = "block";
                        document.getElementById("free" + i).style.display = "none";
                    }
                    else {
                        document.getElementById("chktbl" + i).checked = true;
                        document.getElementById("Active" + i).style.display = "block";
                        document.getElementById("free" + i).style.display = "none";
                    }
                }
            }
            else {

                for (var i = 1; i <= rows; i++) {
                    if ($("#Alloted" + i).val() == 1 && ($("#dstJobAssignedId" + i).val() != $('#JobId').val())) {
                        document.getElementById("chktbl" + i).checked = true;
                        document.getElementById("chktbl" + i).disabled = true;
                        document.getElementById("Active" + i).style.display = "block";
                        document.getElementById("free" + i).style.display = "none";
                    }
                    else if ($("#Alloted" + i).val() == 1) {
                        document.getElementById("chktbl" + i).checked = false;
                        document.getElementById("chktbl" + i).disabled = false;
                        document.getElementById("Active" + i).style.display = "none";
                        document.getElementById("free" + i).style.display = "block";
                    }
                    else {
                        document.getElementById("chktbl" + i).checked = false;
                        document.getElementById("Active" + i).style.display = "none";
                        document.getElementById("free" + i).style.display = "block";
                    }
                }
            }
        });
    });


    $('#close').click(function () {
        $('#popupdiv').hide();
        Refresh();
        Defaultfocus();
    });

    function Defaultfocus() {
        $('#txtJobSearch').focus();
    }

    $('#btnnew').click(function () {
        $('#CopyRowCount').val('');
        $('#CopyJobName').val('');
        $('#CopyJobDate').val('');
        $('#btnsubmit').show();
        $("#btnprint").hide();
        $('#tblEmployesInfo tr').remove();
        Refresh();
    });

    $('#btnSalarySettings').click(function () {

    });
    $('#btnsubmit').click(function () {

                var oArray = new Array();
                var Alloted = 1;
                var  DelFlag = 1;
                var relieved = 0;
                    for (var k = 1; k <= $("#TableRowCount").val() ; k++) {
                        if (document.getElementById("chktbl" + k).checked == true) {
                            var JobAssignedBy = $('#dstJobAssignedId' + k).val();
                            var Job = $('#JobId').val();
                            if (JobAssignedBy == 0 || JobAssignedBy == Job) {
                                var EmpID = $('#dstEmpId' + k).val();
                                var JobId = $('#dstJobId' + k).val();
                                var DesignationId = $('#dstDesignationId' + k).val();
                                oArray.push({
                                    'JobId': JobId,
                                    'EmpId': EmpID,
                                    'DesignationId': DesignationId,
                                    'Alloted': Alloted,
                                    'JobAllotedDate': $('#Alloteddate').val(),
                                    'UId': UId,
                                    'DeptId': DeptId,
                                    'DelFlag': DelFlag
                                })
                            }
                        }
                        else {
                            relieved += 1;
                            var JobAssignedBy = $('#dstJobAssignedId' + k).val();
                            var Job = $('#JobId').val();
                            var EmpId = $('#dstEmpId').val();
                            if (JobAssignedBy == Job) {
                                var data = {};
                                data.ProjectJobId = $("#JobId").val();
                                data.EmpId = $('#dstEmpId' + k).val();
                                $.ajax({
                                    type: "POST",
                                    url: "../JobAllotment/Relieving",
                                    data: data,
                                    success: function (result) {
                                        if (result.length != 0) {
                                            ShowInfoDetails(result.oList);
                                        }
                                    }
                                });
                            }
                        }
                    }
                if (oArray != "") {
                    var data = { 'JobAllotment': oArray };
                    $.ajax({
                        type: "POST",
                        url: "../../JobAllotment/JobAllotmentInsertandUpdate",
                        data: data,
                        success: function (result) {
                     
                            for (var i = 0; i < result.oList.length; i++) {
                                var status = result.oList[i].Status;
                                $('#btnsubmit').prop("disabled", false);
                                Showalerts(status);
                            }
                        }
                    });
                }
                if (relieved != 0)
                {
                    swal('JobRelievedSuccessfully',"", "success");
                    $('.swal-button swal-button--confirm').focus();
                }
                Refresh();
                $('#tblEmployesInfo tr').remove();
    });



    function Showalerts(Status) {
        if (Status == 1) {
            swal('JobAllotedSuccessfully', "", "success");
            $('.swal-button swal-button--confirm').focus();
            Refresh();
        }
        else {
            Refresh();
            swal("Sorry Already Alloted");
            $('.swal-button swal-button--info').focus();
        }
    }


    function Refresh() {
        var Alloted = 0;
        var UId = ERPUserId;
        var DeptId = ERPDeptId;
        var Delflag = 0;
        var CopyRowLen = 0;
        $('#txtJobSearch').val('');
        $('#JobId').val('');
        $('#TableRowCount').val('');
        document.getElementById("chckHead").checked = false;
        $("#btnsubmit").html('SAVE');
        $('#DesignationId0').val('');
        $('#JobName').focus();
    }



    $(document).ready(function () {

        $('#DateFrom').daterangepicker({
            minDate: minDate,
          
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        })

        $('#Alloteddate').daterangepicker({
            minDate: minDate,
    
            singleDatePicker: true,
            showDropdowns: true,
            locale:
            {
                format: 'DD/MM/YYYY'
            }
        })
    });



    $(document).ready(function () {

        $('#txtJobSearch').focus();
        $('#btncopy').click(function () {
            Refresh();
            $('#txtJobSearchcopy').val("");
            $('#popupdiv').show();
            $('#txtJobSearchcopy').focus();

        });


        //         Copy area..............

        $("#txtJobSearchcopy").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.Description = $("#txtJobSearchcopy").val();
                $.ajax({
                    url: '../JobAllotment/AllotedJobNameSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'THREE',
                                label: item.Description,
                                label1: item.ProjectJobId,
                                headers: ["Job Name", "Code"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#btnsubmitCopy').focus();
                $('#btnsubmitCopy').select();
                $('#JobIdCopy').val(ui.item.label1);
                $('#Copy').val("1");
            },
        });

        $('#btnsubmitCopy').click(function () {
            $('#CopyRowCount').val('');
            $('#CopyJobName').val('');
            $('#CopyJobDate').val('');
            $("#btnprint").show();
            $("#btnprint").focus();
            $("#btnsubmit").hide();
        $('#CopyJobName').val($('#txtJobSearchcopy').val());
        $('#CopyJobDate').val($('#DateFrom').val());
            var data = {};
            data.JobAllotedDate = $('#DateFrom').val();
            data.JobCode = $("#JobIdCopy").val();
            data.Copy = $("#Copy").val();
            $.ajax({
