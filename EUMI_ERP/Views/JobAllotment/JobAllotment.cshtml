    function handleClick(cb)
    {
        
        if (cb.checked) {
           
            var currentId = $(cb).attr('Id');
            
            var res = currentId.substring(6, currentId.length);
       
            document.getElementById("Active" + res).style.display = "block";
            document.getElementById("free" + res).style.display = "none";
        }
        else {

            var currentId = $(cb).attr('Id');
            var res = currentId.substring(6, currentId.length)
            document.getElementById("Active" + res).style.display = "none";
            document.getElementById("free" + res).style.display = "block";
        }
    }

