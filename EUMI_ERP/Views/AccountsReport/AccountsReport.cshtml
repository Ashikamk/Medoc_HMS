
@{
    ViewBag.Title = "AccountsReport";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>




<div id="Entry">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    
                    <div>
                        <table width="100%">
                            <tr>
                               
                                <td><h4 id="header"></h4></td>
                                <td width="32%"></td>
                                <td align="right"><h3 class="text-right" id="blnce" style="float:right;opacity:0">Balance</h3></td>
                                <td></td><td></td><td></td><td></td><td></td><td></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                               

                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">




                                <div id="divreport" style="display:none; overflow:auto">
                                    <hr />

                                    <table id="Tblreport" class="table table-striped table-bordered dataTable" style="margin: 0 auto 0 0;"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@*</div>
        </div>
    </div>*@





<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Accounts Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:30px">From Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="margin-top:5px;margin-left:45px">To Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">

                        <label style="margin-top:5px;margin-left:5px">Account Code </label>
                        <div class="col-md-4">
                            <input type="text" id="AccountCode" class="form-control" autocomplete="off">
                            <input type="hidden" id="AccountCodeId" class="form-control" />
                        </div>


                        <label style="margin-top:5px;margin-left:30px">Job Code </label>
                        <div class="col-md-4">
                            <input type="text" id="JobCode" class="form-control" autocomplete="off">
                            <input type="hidden" id="JobCodeId" class="form-control" />
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:20px">Department </label>
                        <div class="col-md-4">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>


                        <label style="margin-top:5px;margin-left:68px">Type</label>
                        <div class="col-md-4">
                            <select id="Type" name="priority" class="form-control">

                                <option value="0">Statement</option>
                                <option value="1">Outstanding Statement</option>
                                <option value="2">Outstanding Statement(PDC)</option>
                                <option value="3">Statement(FC)</option>
                                <option value="4">Outstanding Statement(FC)</option>
                                <option value="5">PDC Statement</option>
                                <option value="6">Statement(Job)</option>
                                <option value="7">Outstanding Statement(Job)</option>
                                <option value="8">Statement(Job) Link A/C</option>
                                <option value="9">Ageing Detailed</option>
                                <option value="10">Ageing Statement</option>
                                <option value="11">Ageing with PDC</option>
                                <option value="12">Ageing Salesmanwise</option>
                                <option value="13">Daily SalesOut</option>
                                <option value="14">Address List</option>
                                <option value="15">Bank Statement</option>
                                <option value="16">Day Book</option>
                            </select>
                        </div>

                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">

                        <label style="margin-top:5px;margin-left:32px">Cost Code</label>
                        <div class="col-md-4">
                            <select id="CostCenterCode" name="priority" class="form-control"></select>
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-outline-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>



    $("#JobCode").autocomplete({
        source: function (request, response) {
            var data = {};
            data.JobCode = $("#JobCode").val();
            $.ajax({
                url: '../Master/JobCodeSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.JobCode,
                            label1: item.Description,

                            Description: item.Description,
                            JobcodeId: item.ProjectJobId,
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#JobCodeId').val(ui.item.JobcodeId);
        },

    });

    $("#AccountCode").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountDescription = $("#AccountCode").val();
            $.ajax({
                url: '../Inventory/AccountNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            DebitAccount: item.DebitAccount,
                            AccountDescription: item.AccountDescription,
                            AccountId: item.AccountId
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#AccountCodeId').val(ui.item.AccountId)
            $('#AccountCode').val(ui.item.DebitAccount);

        },
    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }

    function Showreport(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var PrevAmout = 0;
        var total = 0;
        var bal = 0;


        var responseText = "<thead><tr><th>Slno</th><th>VType Prefix</th><th>Voucher No</th><th>Voucher Date</th><th>Account Code</th><th>Account Description</th><th>Voucher Description</th><th>Reference No</th><th>Cheque No</th><th style=text-align:right>Debit</th><th style=text-align:right>Credit</th><th style=text-align:right>Balance</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            bal = result[i].Balance;
            cr = result[i].Credit;
            db = result[i].Debit;
            Balance = parseFloat(parseFloat(parseFloat(PrevAmout) + parseFloat(result[i].Debit - result[i].Credit))).toFixed(2);
            PrevAmout = Balance;
            total = parseFloat(Balance + total);


            if (result[i].VTypePrefix == '') {
                responseText += '<tr style=background-color:#8ee4f1;font-weight:bold><td>' + slno + '</td><td>' + result[i].VTypePrefix + '</td><td>' + result[i].VoucherNo + '</td><td>' + result[i].VoucherDate + '</td><td>' + result[i].Acc_Code + '</td><td>' + result[i].AccDesc + '</td><td>' + result[i].VDesc + '</td><td>' + result[i].ReferenceNo + '</td><td>' + result[i].ChequeNo + '</td><td style=text-align:right>' + result[i].Debit + '</td><td style=text-align:right>' + result[i].Credit + '</td><td id=' + "total" + slno + ' style=text-align:right>' + result[i].Balance + '</td></tr>';
            }
            else {
                responseText += '<tr><td>' + slno + '</td><td>' + result[i].VTypePrefix + '</td><td>' + result[i].VoucherNo + '</td><td>' + result[i].VoucherDate + '</td><td>' + result[i].Acc_Code + '</td><td>' + result[i].AccDesc + '</td><td>' + result[i].VDesc + '</td><td>' + result[i].ReferenceNo + '</td><td>' + result[i].ChequeNo + '</td><td style=text-align:right>' + result[i].Debit + '</td><td style=text-align:right>' + result[i].Credit + '</td><td id=' + "total" + slno + ' style=text-align:right>' + Balance + ' </td></tr>';
            }
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Slno</th><th>VType Prefix</th><th>Voucher No</th><th>Voucher Date</th><th>Account Code</th><th>Account Description</th><th>Voucher Description</th><th>Reference No</th><th>Cheque No</th><th>Debit</th><th>Credit</th><th>Balance</th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Accounts Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);

        $('#blnce').text('Balance : ' + bal);
        $("#blnce").css("opacity", '100');
    }



    function GetDepartment(id) {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#department").empty();
        $("#department").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
        if (a == 0) {
            $('#department').val(0);
        }
        else {
            $('#department').val(a);
        }
    }


    function CostCenterLoad(result) {
        $("#CostCenterCode").empty();
        $("#CostCenterCode").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#CostCenterCode").append("<option value='" + result[i].CostCenterId + "'>" + result[i].CostCenterCode + "</option>");
        }
    }

    function GetCostCenter(id) {
        var data5 = {};
        data5.CostCenterId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CostCenterGetandGets",
            data: data5,
            success: function (result) {
                CostCenterLoad(result.oList, id);

            }
        });
    }



    $(function () {
        GetDepartment(0);

        GetCostCenter(0);




        $("#AccountCode").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 08) {
                e.preventDefault();
                $('#AccountCodeId').val(0);
            }

        });

        $("#JobCode").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 08) {
                e.preventDefault();
                $('#JobCodeId').val(0);
            }

        });

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });



        $("#btnsubmit").click(function (e) {

            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }
            else {

                $('#Loading').show();
                if ($('#AccountCode').val() == '') {
                    $('#AccountCodeId').val(0);
                }

                if ($('#JobCode').val() == '') {
                    $('#JobCodeId').val(0);
                }

                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.AccCode = parseInt($('#AccountCode').val() || 0);
                data.JobCode = parseInt($('#JobCodeId').val() || 0);
                data.Department = parseInt($('#department').val() || 0);
                data.CostCode = parseInt($('#CostCenterCode').val() || 0);
                $.ajax({
                    type: "POST",
                    url: "../AccountsReport/AccntReportGet",
                    data: data,
                    success: function (result) {
                        Showreport(result);
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                    }
                });
            }


        });

    });






</script>