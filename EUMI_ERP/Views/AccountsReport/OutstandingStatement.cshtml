                    <div>

                        <table width="100%">
                            <tr>
                                <td ><h5 id="header"></h5></td>
                                <td style="display:none;"><h5 id="header1"></h5></td>
                                <td style="display:none;"><h5 id="header2"></h5></td>
                                <td width="25%"></td>
                                
                                <td id="td1" style="display:none">

                                    <div class="input-group" style="margin-left:20px">
                                        <div class="custom-control custom-radio custom-control-inline">
                                            <input type="radio" id="customRadioInline1" name="customRadioInline1" onclick="SearchOutStanding(5,0)" class="custom-control-input">
                                            <label class="custom-control-label" for="customRadioInline1">Summary</label>
                                        </div>
                                    </div>


                                </td>
                                <td id="td2"  style="display:none">
                                    <div class="input-group">
                                        <div class="custom-control custom-radio custom-control-inline">
                                            <input type="radio" id="customRadioInline2" name="customRadioInline2" onclick="SearchOutStanding(6,0)" class="custom-control-input">
                                            <label class="custom-control-label" for="customRadioInline2">Detailed</label>
                                        </div>
                                    </div>
                                </td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#AccountGrp').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                @*<td align="right"><button type="button" style="width:100px;margin-left:20px" onclick="SearchOutStanding(5)" id="btnAll" class="btn btn-outline-primary">Detailed</button></td>*@
                                <td id="td3"  style="display:none"><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintOutStanding()" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>

                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">
                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
