            function gotoreport(VNum, VTypeId, VType, BillSeriesId, DeptId) {

                if (VType == 'SI')
                {
                    if ((usermenu1.indexOf("M54") != -1)) {
                        window.open('../inventory/SalesInvoice?slno=' + VNum + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                    }
                    else if ((usermenu1.indexOf("M227") != -1)) {
                        window.open('../inventory/SalesInvoiceNew?slno=' + VNum + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
                }


                else if (VType == 'PI')
                {
                    if ((usermenu1.indexOf("M31") != -1)) {
                        window.open('../inventory/PurchaseInvoice?slno=' + VNum + '&dept=' + DeptId);
                    }
                    else if ((usermenu1.indexOf("M233") != -1)) {
                        window.open('../Purchase/PurchaseInvoiceNew?slno=' + VNum + '&dept=' + DeptId);

                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
                }


                else if (VType == 'SR')
                {
                    if ((usermenu1.indexOf("M56") != -1)) {
                        window.open('../SalesInvoice/SalesReturn?billseries=' + BillSeriesId + '&slno=' + VNum + '&dept=' + DeptId);

                    }
                    else if ((usermenu1.indexOf("M241") != -1)) {
                        window.open('../SalesInvoice/SalesReturnNew?billseries=' + BillSeriesId + '&slno=' + VNum + '&dept=' + DeptId);
                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
                }


                else if (VType == 'PR')
                {

                    if ((usermenu1.indexOf("M32") != -1)) {
                        window.open('../Purchase/PurchaseReturn?slno=' + VNum + '&dept=' + DeptId);
                    }
                    else if ((usermenu1.indexOf("M239") != -1)) {
                        window.open('../Purchase/PurchaseReturnNew?slno=' + VNum + '&dept=' + DeptId);

                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
                }
                else
                {
                    window.open('../AccountsErp/VoucherEntryModify?vno=' + VNum + '&vtypeid=' + VTypeId);

                }

            }

