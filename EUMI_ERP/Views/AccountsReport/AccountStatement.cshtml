<script>
    $(function () {
        AccountStmt(0, 0);
        hidepopup(0);
        GetDepartment(0);
        GetCostCode(0);
        $("#AccountCode").focus();

        
        //$('#DateFrom,#FromDate').val(FinanceStartDate)
        $('#DateFrom,#FromDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo,#ToDate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 20, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $(document).keydown(function (e) {
            if (e.keyCode == 27) { //ESC       :   Popup Close
                hidepopup(1);
            }

        });
        if (getQueryString('AccId') != null) {
            $('#AccountCode').val(getQueryString('AccountCode'))
            $("#AccountCodeId").val(getQueryString('AccId'));
            AccountStmt(0, $('#AccountCodeId').val());
            $('#Entry').show();

        }

        $('#btnsummary,#btndetail').click(function () {
            if ($('#AccountCodeId').val() == 0 && $('#AccountGrpId').val() == 0) {
                warningshow('Please Select Account');
                return false;
            };

        });
       
       
    });

    function GetCostCode(id) {
        var data5 = {};
        data5.CostCenterId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CostCenterGetandGets",
            data: data5,
            success: function (result) {
                CostCenterLoad(result.oList);

            }
        });
    }
    function CostCenterLoad(result) {
        $("#CostCode").empty();
        $("#CostCode").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#CostCode").append("<option value='" + result[i].CostCenterId + "'>" + result[i].CostCenterCode + "</option>");
        }
    }
    function calloutStanding()
    {

        if (($('#btnsummary').is(":checked")))
        {
            SearchOutStanding(1);
        }
        else {
            SearchOutStanding(0);
        }
    }
    

    const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

    function hidepopup(flg) {

        if (flg == 0)                 //Show Popup
        {
            if ($('#toggle').prop("checked") == false)
                $('#toggle').click();
        }
        else if (flg == 1)           //Hide Popup
        {
            if ($('#toggle').prop("checked") == true)
            {
                $('#toggle').click();
                $(document).mousedown();
                $('#Type,#Dept').blur();
            }
        }
    }

    function PrintOutStanding() {
        if (VoucherBillType == 'LOCAL') {
            if (SummaryFlag == 0)
                PrintthisReportWindows('OUTSTANDINGREPORT', $('#ResultLength').val())
            else
                PrintthisReportWindows('OUTSTANDINGREPORTSummary', $('#ResultLength').val())
        }
        else if (VoucherBillType == 'DEFAULT') {
            if (SummaryFlag == 0)
                PrintthisReportWindows('OUTSTANDINGREPORTNew', $('#ResultLength').val())
            else
                PrintthisReportWindows('OUTSTANDINGREPORTSummaryNew', $('#ResultLength').val())

        }
    }
        function PrintAccountStatement() {
            if (VoucherBillType == 'LOCAL') {
                PrintthisReportWindows('ACCOUNTSREPORT', $('#ResultLength').val())
            }
            else  if (VoucherBillType == 'DEFAULT')
            {
                PrintthisReportWindows('ACCOUNTSREPORTNew', $('#ResultLength').val())
            }
        }

            var SummaryFlag = 0;


            function SearchOutStanding(Flag) {
                $('#header3').text("Outstanding Statement - from ");

                if (Flag == 0) {
                    SummaryFlag = 0;
                }
                else {
                    SummaryFlag = 1;
                }
                if ($('#AccountCodeId').val() == 0 && $('#AccountGrpId').val() == 0) {
                    warningshow('Please Select Account');
                    return false;
                }
                $('#Entry').show();
                $('#divdetail,#divsummary').show();



                if ($('#AccountCode').val() == '') {
                    $('#AccountCodeId').val('');
                }
                if ($('#AccountGrp').val() == '') {
                    $('#AccountGrpId').val('');
                }

                if (usermenu1.indexOf("M83") != -1) {

                    var status = 0;
                    if ($('#opening').prop("checked"))
                        status = 1;

                    var Curr = 0;
                    if ($('#FC').prop("checked")) {
                        Curr = 1;
                    }
                    var Linked = 0;
                    

                    $('#Loading').show();

                    var data = {};
                    data.DateFrom = $('#FromDate').val();
                    data.DateTo = $('#ToDate').val();
                    data.AccountCode = $('#AccountCodeId').val();
                    data.AccountGroup = $('#AccountGrpId').val();
                    data.Opening = status;
                    data.DeptId = $('#Dept').val();
                    data.CostCode = $('#CostCode').val();
                    data.UserId = ERPUserId;
                    data.Condition = Flag;
                    data.Currency = Curr;
                    data.Var1 = Linked;
                    data.Var2 = 0;

                    $.ajax({
                        type: "POST",
                        url: "../AccountsReport/OutstandingStatement",
                        data: data,
                        success: function (result) {
                            $('#divreport').show();
                            hidepopup(1);
                            $('#btnprint1').hide();
                            $('#btnprint2').show();
                            $('#btnprint3').hide();

                            disable_datatable('Tblreport', 'buttonPlace');

                            $('#Loading').hide();
                            $('#Address1').val(result[0].VDesc);
                            $('#Address2').val(result[1].VDesc);
                            $('#Address3').val(result[2].VDesc);
                            $('#Address4').val(result[3].VDesc);

                            var RunningBalance = 0;
                            var RunningBalanceVar = 0, GrandBalance = 0;

                            var FromDate = []; var ToDate = [];
                            FromDate = ($("#FromDate").val()).split('/');
                            ToDate = ($("#ToDate").val()).split('/');

                            var FromDatePrint = FromDate[0] + '-' + monthNames[parseInt(FromDate[1] - 1)] + '-' + FromDate[2];
                            var ToDatePrint = ToDate[0] + '-' + monthNames[parseInt(ToDate[1] - 1)] + '-' + ToDate[2];



                            if (data.Condition == 0) {

                                if ($('#FC').prop("checked")) {

                                    var PrevAmout = 0;
                                    var total = 0;
                                    var balnc = 0;
                                    var HideAmount = 0;
                                    var responseText = "<thead><tr><th style='width:1%'>Sl#</th><th style='width:6%'>Date</th><th style='width:6%'>Voucher#</th><th style='width:6%'>Reference#</th><th style='width:6%'>Account#</th><th style='width:10%'>Account Name</th><th style='width:15%'>Description</th><th style='width:8%'>Fx.</th><th style='width:3%'>Fx.Rate</th><th style='width:3%'>Debit</th><th style='width:3%'>Credit</th><th style='width:8%'>Balance</th><th style=display:none>Amount</th></thead><tbody>";


                                    for (var i = 4; i < result.length; i++) {


                                        var slno;


                                        slno = parseInt(i - 3);

                                        var Balance = parseFloat(result[i].Amount || 0);



                                        Amount = result[i].Amount;

                                        if (result[i].VDesc != 'Total' && result[i].VDesc != 'GrandTotal') {


                                            RunningBalance = RunningBalance + parseFloat(result[i].Amount || 0);

                                            if (RunningBalance < 0) {

                                                RunningBalanceVar = RunningBalance * -1;
                                                RunningBalanceVar = parseFloat(RunningBalanceVar).toFixed(Decimal) + ' Cr';
                                            }
                                            else {

                                                RunningBalanceVar = parseFloat(RunningBalance).toFixed(Decimal) + ' Dr';
                                            }
                                        }

                                        balnc = parseFloat(GrandBalance || 0).toFixed(Decimal)

                                        if (balnc < 0) {

                                            balnc = balnc * -1;
                                            balnc = parseFloat(balnc).toFixed(Decimal) + ' Cr';
                                        }
                                        else {

                                            balnc = parseFloat(balnc).toFixed(Decimal) + ' Dr';
                                        }


                                        var CreditAmt = parseFloat(result[i].Credit || 0).toFixed(Decimal)
                                        if (CreditAmt == 0)
                                            CreditAmt = '';
                                        var DebitAmt = parseFloat(result[i].Debit || 0).toFixed(Decimal)
                                        if (DebitAmt == 0)
                                            DebitAmt = '';

                                        HideAmount = parseFloat(result[i].Amount || 0).toFixed(Decimal)
                                        if (HideAmount < 0) {

                                            HideAmount = HideAmount * -1;
                                            HideAmount = parseFloat(HideAmount).toFixed(Decimal) + ' Cr';
                                        }
                                        else {

                                            HideAmount = parseFloat(HideAmount).toFixed(Decimal) + ' Dr';
                                        }



                                        if (result[i].VDesc == 'Total') {

                                            GrandBalance = GrandBalance + RunningBalance;
                                            responseText += '<tr style=background-color:#cfd8dc><td style=text-align:center>' + slno + '</td><td   id="Col1_' + slno + '" >' + result[i].VDate + '</td><td   id="Col2_' + slno + '" >' + result[i].ReferenceNo + '</td><td   id="Col3_' + slno + '" >' + result[i].VNum + '</td><td   id="Col4_' + slno + '" ></td><td id="Col5_' + slno + '">' + result[i].AccDesc + '</td><td  id="Col6_' + slno + '" ><b>' + result[i].VDesc + '</b></td><td>' + result[i].Currency + '</td><td style=text-align:right></td><td id="Col7_' + slno + '" style=text-align:right   ><b>' + DebitAmt + '</b></td><td id="Col8_' + slno + '" style=text-align:right><b>' + CreditAmt + '</b></td><td id="Col9_' + slno + '" style=text-align:right   ><b>' + RunningBalanceVar + ' </b></td><td id="Col12_' + slno + '" style=display:none>' + HideAmount + '</td></tr>';
                                            RunningBalance = 0;
                                        }
