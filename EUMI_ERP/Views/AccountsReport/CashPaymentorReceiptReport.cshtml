                            <input type="hidden" class="form-control" id="AccountCodeId" />
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:-1.5%">Fx.</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select id="Currency" name="priority" class="form-control"></select>
                        </div>
                    </div>
                    <div class="row">
                        <label style="margin-top:2%;font-weight:bold;margin-left:5%">Department</label>
                        <div class="col-md-4" style="margin-top:2%;">
                            <select type="text" class="form-control" id="Dept"></select>
                        </div>

                    </div>

                    
                </div>
                <hr />
                <div class="text-center">
                    <button type="button" style="width:100px" id="btnGo" class="btn btn-primary">Go</button>
                    <input type="hidden" id="ResultLength" class="form-control" />
                    <input type="hidden" class="form-control" id="x" />
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    $("#AccountCode").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountDescription = $("#AccountCode").val();
            $.ajax({
                url: '../Inventory/AccountNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            DebitAccount: item.DebitAccount,
                            AccountDescription: item.AccountDescription,
                            AccountId: item.AccountId,
                            headers: ["Code", "Decription"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $("#AccountCodeId").val(ui.item.AccountId);
            $("#AccountCode").val(ui.item.AccountDescription);
         //   $('#btnsubmit').focus();
        },
    });
</script>



