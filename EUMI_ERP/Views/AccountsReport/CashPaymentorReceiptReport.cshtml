            }
        });
    }
    function CurrencyLoad(result) {

        $("#Currency").empty();
        $("#Currency").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Currency").append("<option value='" + result[i].Id + "' name='" + result[i].CurrencyRate + "'>" + result[i].CurrencyName + "</option>");

        }
    }

