
@{
    ViewBag.Title = "LogReport";
}



<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }

    #btnsubmit:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnback:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }

    #btnprint:hover {
        -ms-transform: scale(1.1);
        transform: scale(1.1);
    }
</style>

<div class="myData" data-x="M210" />
<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <div>


                        <table width="100%">
                            <tr>
                                <td><h6 id="header"></h6></td>
                                <td width="45%"></td>
                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#User').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>


                                <td align="right">

                                    <div class="btn-group" id="buttonPlace">




                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">

                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        </table>


                        <div align="right">

                            <div class="heading-elements">




                                <div id="divreport" style="display:none; overflow:auto">
                                    <hr style="margin-top:.1%;" />

                                    <table id="Tblreport" class="table table-striped table-bordered dataTable" style="width:100%;margin: 0 auto 0 0;"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>



                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>


<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h5 class="modal-title" id="myheader">UPI COLLECTION Report</h5>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                @*<div class="modal-body">
                        <fieldset class="form-group floating-label-form-group">
                            <label for="DateFrom">From Date<span class="danger">*</span></label>
                            <input type="text" id="DateFrom" class="form-control">
                        </fieldset>
                        <fieldset class="form-group floating-label-form-group">
                            <label for="DateTo">To Date<span class="danger">*</span></label>
                            <input type="text" id="DateTo" maxlength="100" class="form-control">
                        </fieldset>
                        <fieldset class="form-group floating-label-form-group">
                            <label for="User">User</label>
                            <input type="text" id="User" maxlength="100" class="form-control">
                            <input type="hidden" id="UserId" maxlength="100" class="form-control">
                        </fieldset>
                        <fieldset class="form-group floating-label-form-group">
                            <label for="Dept">Department</label>
                            <select type="text" id="Dept" maxlength="100" class="form-control"></select>
                        </fieldset>
                    </div>*@
                <div class="modal-body">
                    <div class="row">
                        <label style="font-weight:bold;margin-left:11%">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="font-weight:bold;margin-left:4%">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>
                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>
                    <div class="row" style="margin-top:2%;display:none">
                        <label style="margin-top:2%;font-weight:bold;margin-left:12%">User</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <input type="text" id="User" maxlength="100" class="form-control">
                            <input type="hidden" id="UserId" maxlength="100" class="form-control">
                        </div>


                        <label style="margin-top:2%;font-weight:bold;margin-left:-1.5%">Dept.</label>
                        <div class="col-md-4" style="margin-top:2%">
                            <select type="text" id="Dept" maxlength="100" class="form-control"></select>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:40%" id="btnsubmit" class="btn btn-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>


    $("#User").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#UserId').val(0);

            var data = {};
            data.UserName = $("#User").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        console.log(data)
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#UserId').val(ui.item.UserId);
        },
    });

    function popuprefresh() {
        $('#popupdiv').hide();
    }



    function Showreport(result) {

       
        disable_datatable('Tblreport', 'buttonPlace');
        var Xyx = "";
        var responseText = "<thead><tr><th>Sl#</th><th>Date</th><th>Bill Type</th><th>Bill No</th><th>Reg No</th><th>Description</th><th>Amount</th></tr></thead><tbody>";
       
       
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            Xyx = (result[i].Area).split('##');
            console.log(Xyx)
            responseText += '<tr><td>' + slno + '</td><td>' + Xyx[1] + '</td><td align="center">' + Xyx[2] + '</td><td>' + Xyx[0] + '</td><td>' + result[i].TaxAmount + '</td><td>' + Xyx[4] + '</td><td align=right>' + result[i].BaseAmount + '</td></tr>';
        }
        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Entry Date</th><th>Entry Date</th><th>User</th><th>Operation</th><th>Description</th><th>Dept.Code</th></tr> </tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "UPI COLLECTION Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');

        $('#header').text(title);


    }



    function GetDepartment(id) {
        var data = {};
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserDepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result, a) {
        $("#Dept").empty();
        $("#Dept").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Dept").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
    }
    $(function () {
        GetDepartment(0);
        $('#User').focus();
        $('#Dept').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth() + 1, new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $("#User").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;

            if (key == 13) {
                e.preventDefault();
                $('#Dept').focus();
            }

        });


        $("#btnsubmit").click(function (e) {

            if ($('#User').val() == '') {
                $('#UserId').val(0);
            }



            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {
                $('#Loading').show();

                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.User = parseInt($('#UserId').val() || 0);
                data.Dept = parseInt($('#Dept').val() || 0);
                data.Userid = ERPUserId;

                $.ajax({
                    type: "POST",
                    url: "../AccountsReport/VATReport",
                    data: data,
                    success: function (result) {
                        $('#Loading').hide();
                        $('#divreport').show();
                        $('#popupdiv').hide();
                        Showreport(result);


                    }
                });
            }
        });

    });

    function datatableWithsearch(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            if (title == 'Entry Date')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Dept.Code')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'User')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%;" />');
            if (title == 'Description')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:900px" />');
            if (title == 'Opertion')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:400px" />');

        });
        var table = null;
        if (download) {
            if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                    {
                        extend: 'collection',
                        text: 'Export',
                        className: 'excelexport',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'print',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            }
                        ]
                    },
                    'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
            $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

        } else {
            table = $('#' + tablename).DataTable();
        }
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
        if (ExcelExport == 0) {
            $('.excelexport').hide();
        }
    }

</script>






