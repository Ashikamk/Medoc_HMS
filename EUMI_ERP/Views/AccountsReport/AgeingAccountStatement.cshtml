                responseText += '<tr ><td align= center id = Col1_' + slno + '>' + slno + '</td> <td  id = Col1_' + slno + '>' + result[i].CurrencyRate + '</td> <td id= Col5_' + slno + '></td>            <td id= Col5_' + slno + '></td><td id= Col6_' + slno + '></td><td  id= Col7_' + slno + '></td><td  style="background-color: #bbbb77;font-weight: bold" id= Col2_' + slno + '>' + result[i].VDate + '</td><td  style="background-color:#bbbb77;font-weight: bold" id= Col3_' + slno + '>' + result[i].AccDesc + '</td><td style="background-color: #bbbb77;font-weight: bold" align=right id= Col4_' + slno + '>' + result[i].BaseAmount + '</td><td style="background-color: #bbbb77;font-weight: bold" align=right id= Col8_' + slno + '>' + result[i].RecAmount + '</td><td style="background-color: #bbbb77;font-weight: bold" align=right id= Col8_' + slno + '>' + result[i].Amount + '</td></tr>';

            }
            else if (result[i].AccDesc == 'GRAND TOTAL') {
                responseText += '<tr ><td align= center id = Col1_' + slno + '>' + slno + '</td><td  id = Col1_' + slno + '>' + result[i].CurrencyRate + '</td> <td id= Col5_' + slno + '></td>            <td id= Col5_' + slno + '></td><td id= Col6_' + slno + '></td><td  id= Col7_' + slno + '></td><td  style="background-color: #aaff80;font-weight: bold" id= Col2_' + slno + '>' + result[i].VDate + '</td><td  style="background-color:#aaff80;font-weight: bold" id= Col3_' + slno + '>' + result[i].AccDesc + '</td><td style="background-color: #aaff80;font-weight: bold" align=right id= Col4_' + slno + '>' + result[i].BaseAmount + '</td><td style="background-color: #aaff80;font-weight: bold" align=right id= Col8_' + slno + '>' + result[i].RecAmount + '</td><td style="background-color: #aaff80;font-weight: bold" align=right id= Col8_' + slno + '>' + result[i].Amount + '</td></tr>';

            }
            else {

                var CashType = '';
                if (result[i].VDesc == 'CASH') CashType = '<span class="badge badge-success">&#160;&#160;CASH&#160;&#160;</span>';
                else if (result[i].VDesc == 'CREDIT') CashType = '<span class="badge badge-danger">&#160;&#160;CREDIT&#160;&#160;&#160;</span>';
                else {
                    CashType = '<span class="badge badge-success">UPI/BANK</span>';
                }

                switch (result[i].Currency) {
                    case 'CONSULTATION FEE': day = "RG"; break;
                    case "IP BILL":          day = "IP"; break;
                    case "OP BILL":          day = "PB"; break;
                    case "LAB BILL":         day = "LB"; break;
                    case "PHARMA": day = "SI"; break;



                    case "PHARMA RETURN": day = "SR"; break;
                }
               
                responseText += '<tr onClick="Billinfogets(' + result[i].VType+ "," + slno + "," + result[i].ReferenceNo + "," + result[i].BillSeriesId +  "," + result[i].DeptId + ')" ><td align= center id = Col1_' + slno + '> <input id="BillFlg' + slno + '"  type=hidden value=' + day + '>  ' + slno + '</td>     <td  id = Col1_' + slno + '>' + result[i].CurrencyRate + '</td>        <td id= Col5_' + slno + '>' + result[i].ReferenceNo + '</td><td id= Col6_' + slno + '>' + result[i].VNum + '</td><td  id= Col7_' + slno + '>' + result[i].Days + '</td><td id= Col5_' + slno + '>' + CashType + '</td><td id= Col2_' + slno + '>' + result[i].VDate + '</td><td id= Col3_' + slno + '>' + result[i].AccDesc + '</td><td align=right id= Col4_' + slno + '>' + result[i].BaseAmount + '</td><td align=right id= Col8_' + slno + '>' + result[i].RecAmount + '</td><td align=right id= Col8_' + slno + '>' + result[i].Amount + '</td></tr>';

            }
        }
        $('#Tblreport').html(responseText + '</tbody>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var title = "Collection  Report - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch2('Tblreport', true, title, 'buttonPlace');       
        $('#header').text(title);

    }



    function Billinfogets(Billyr, BID, Billno, Series, depId) {
        debugger;
        console.log(Series)
        $('#Tblreportdetails').html('');
        $('#Tblreporthdrdetails').html('');

        var BFlag = $('#BillFlg' + BID).val();
        $("#myModaltransfer").modal("show");
        $("#myModaltransfer").appendTo("body");
        if (BFlag != 'SI' && BFlag != 'SR') {
            Series = Billyr;
        }

        var data = {};
        data.BillType = BID + '##' + depId;
        data.BillNo = Billno;
        data.Billseries = Series
        data.BFlag = BFlag
        $.ajax({
            type: "POST",
            url: "../Master/BillInfoGdetandGets",
            data: data,
            success: function (result) {
                showbilldet(result.oList);
            }
        });



    }


    

    function showbilldet(result) {
       // disable_datatable('Tblreportdetails', 'buttonPlace');

