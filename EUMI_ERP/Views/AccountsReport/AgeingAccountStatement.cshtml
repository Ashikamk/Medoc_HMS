    $(function () {

        //$('#User').focus();
        $('#Dept').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear() + 1, new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
        $('#DateFrom,#DateTo').val(CurDate);

        $("#btnsubmit").click(function (e) {



            var Allpending = 0;
            if ($("#grpbyall").prop("checked")) {
                Allpending = 1;
            }
            var Groupby = 0;
            if ($("#detailed").prop("checked")) {
                Groupby = 1;
            }
            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {

                $('#Loading').show();
                var data = {};
                data.DateFrom = $('#DateFrom').val();
                data.DateTo = $('#DateTo').val();
                data.AccountCode = $('#Doctor').val();
                data.AccountGroup = $('#UserId').val();
                data.Opening = $('#branch').val();
                data.DeptId = $('#Dept').val();
                data.UserId = $('#Pid').val();;
                data.Condition = Groupby;
