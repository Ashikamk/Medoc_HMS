<script>

    GetDepartment(0);
    //UserList()




    

    function GetDepartment(id) {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList, id);


            }
        });
    }

    function DepartmentLoad(result) {
        $("#branch").empty();
        $("#branch").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#branch").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }

    }


    function popuprefresh() {
        $('#popupdiv').hide();
    }


    function UserList() {

        var data = {};
        data.UserId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/UsersGetandGets",
            data: data,
            success: function (result) {
                ShowUserslist(result.oList);
            }
        });

    }


    function ShowUserslist(result) {
        $("#UserId").append("<option value='0'>All</option>");
        for (var i = 0; i < result.length; i++) {
            $("#UserId").append("<option value='" + result[i].UserId + "'>" + result[i].UserName + "</option>");
        }

    }


    

       function Showreportall(result) {
           let day;


           console.log(result)
        disable_datatable('Tblreport', 'buttonPlace');
           var responseText = "<thead><tr><th>Sl#</th><th align= center>Dept</th><th>BNo#</th><th>Reg#</th><th>IP#</th><th>Type</th><th>Date</th><th>Patient</th><th>Bill Amount</th><th>Rec Amt</th> <th>Balance</th> </tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            if (result[i].AccDesc == '580REG FEE' || result[i].AccDesc == 'REVISIT FEE' || result[i].AccDesc == 'PHARMA RETURN' ||     result[i].AccDesc == 'PENDING COLLECTION' || result[i].AccDesc == 'LAB BILL' || result[i].AccDesc == 'PHARMA RETURN' ||result[i].AccDesc == 'PHARMA' || result[i].AccDesc == 'OP BILL' || result[i].AccDesc == 'ADVANCE' || result[i].AccDesc == 'IP BILL' || result[i].AccDesc == 'CONSULTATION FEE') {
                responseText += '<tr ><td align= center  id = Col1_' + slno + '>' + slno + '</td><td align= center id = Col1_' + slno + '></td> <td id= Col5_' + slno + '></td>            <td id= Col5_' + slno + '></td><td id= Col6_' + slno + '></td><td  id= Col7_' + slno + '></td><td  style="background-color: #bb99ff;font-weight: bold" id= Col2_' + slno + '>' + result[i].VDate + '</td><td  style="background-color: #bb99ff;font-weight: bold" id= Col3_' + slno + '>' + result[i].AccDesc + '</td><td align=right id= Col4_' + slno + '></td><td align=right id= Col8_' + slno + '></td><td align=right id= Col8_' + slno + '></td></tr>';

            }
            else if (result[i].AccDesc == 'TOTAL') {
                responseText += '<tr ><td align= center id = Col1_' + slno + '>' + slno + '</td><td  id = Col1_' + slno + '>' + result[i].CurrencyRate + '</td> <td id= Col5_' + slno + '></td>            <td id= Col5_' + slno + '></td><td id= Col6_' + slno + '></td><td  id= Col7_' + slno + '></td><td  style="background-color: #ff99ff;font-weight: bold" id= Col2_' + slno + '>' + result[i].VDate + '</td><td  style="background-color: #ff99ff;font-weight: bold" id= Col3_' + slno + '>' + result[i].AccDesc + '</td><td style="background-color: #ff99ff;font-weight: bold" align=right id= Col4_' + slno + '>' + result[i].BaseAmount + '</td><td style="background-color: #ff99ff;font-weight: bold" align=right id= Col8_' + slno + '>' + result[i].RecAmount + '</td><td style="background-color: #ff99ff;font-weight: bold" align=right id= Col8_' + slno + '>' + result[i].Amount + '</td></tr>';
                
