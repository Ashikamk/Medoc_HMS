<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1">
    <div class="modal-dialog" role="document" style="top:10%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h6 class="modal-title" id="myheader">Pending Bill Report</h6>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">

                    <table style="border-spacing: 0 15px; ">
                        <tr>
                            <td><b>From</b></td>
                            <td> <input type="text" id="DateFrom" class="form-control" autocomplete="off"></td>
                            <td><b>To</b></td>
                            <td><input type="text" id="DateTo" class="form-control" autocomplete="off"></td>
                        </tr>

                        <tr>
                            <td><b>Type</b></td>
                            <td>
                                <select type="text" id="billtype" class="form-control">
                                    <option value="0">All</option>
                                    <option value="OP">OP</option>
                                    <option value="IP">IP</option>
                                    <option value="OT">OTHERS</option>
                                </select>
                            </td>
                            <td><b>Dept</b></td>
                            <td>
                                <select type="text" id="Doctor" class="form-control">
                                    <option value="0">All</option>
                                    <option value="OP BILL">GENERAL BILL</option>
                                    <option value="LAB BILL">LAB</option>
                                    <option value="PHARMA">PHARMA</option>
                                    <option value="CONSULTATION FEE">REG FEE</option>
                                    <option value="ADV">ADVANCE</option>
                                </select>
                            </td>
                        </tr>

                        <tr>
                            <td><b>Paytype</b></td>
                            <td colspan="3">
                                <select type="text" id="UserId" class="form-control">
                                    <option value="0">All</option>
                                    <option value="1">CASH</option>
                                    <option value="3">CARD/UPI</option>
                                    <option value="2">CREDIT</option>
                                </select>
                            </td>
                        </tr>

                        <tr>
                            <td><b>Branch</b></td>
                            <td colspan="3">
                                <select type="text" id="branch" class="form-control">                                   
                                </select>
                            </td>
                        </tr>

                        <tr>
                            <td><b>Patient</b></td>
                            <td colspan="3"><table width="100%"><tr><td width="30%"><input type="text" id="patient" class="form-control" autocomplete="off"></td><td><input type="text" id="patientname" readonly class="form-control" autocomplete="off"><input type="hidden" id="Pid" />  </td></tr></table> </td>
                        </tr>
                        <tr>
                            <td></td>
                            <td colspan="2">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" name="customCheck" id="detailed" autocomplete="off">
                                    <label class="custom-control-label" for="detailed">
                                        Grouping(Dept)
                                    </label>
                                </div>
                            </td>
                        </tr>
                    </table>


                </div>

                <div class="modal-footer">

                    <table style="padding:15px;" width="100%">
                        <tr>
                            <td align="left">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input" name="customCheck" id="grpbyall" autocomplete="off">
                                    <label class="custom-control-label" for="grpbyall" >All pending Bills</label>
                                </div>
                            </td>
                            <td align="right">
                                <button type="button" style="width:100px;margin-right:6%" id="btnsubmit" class="btn btn-primary">Go</button>
                                <input type="hidden" id="LabBillLength" class="form-control" />
                            </td>
                        </tr>
                    </table>
                    @*<button type="button" style="width:100px;margin-right:6%" id="btnsubmit" class="btn btn-primary">Go</button>
                        <input type="hidden" id="LabBillLength" class="form-control" />*@
                </div>
            </form>

        </div>
    </div>
</div>




