@model EUMI_ERP.Models.AWWorkItemListModel
@{
    ViewBag.Title = "Users by Division";
}
<style type="text/css">
    .main-panel {
        height: auto;
        width: auto;
        max-height: none;
        min-height: 100%;
        margin: 0;
        padding-top: 85px;
        float: none;
    }

    .eumi-search-box {
        box-sizing: border-box;
        width: 100%;
    }

    body.eumi-loader::before {
        content: '';
        display: block;
        position: fixed;
        z-index: 31000;
        height: 4px;
        background-color: rgba(0, 157, 160, 0.2);
        top: 0;
        left: 0;
        right: 0;
    }

    body.eumi-loader::after {
        content: '';
        display: block;
        position: fixed;
        z-index: 31001;
        height: 4px;
        background-color: rgba(0, 157, 160, 1);
        top: 0;
        width: 50px;
        animation: eumiloader 4s infinite linear;
    }

    .eumi-search-table, .eumi-shadow {
        border-spacing: 0 0px;
        box-shadow: 0px 0px 0px 2px #fff, 0 0 2px 2px #999;
    }
    /* .eumi-search-table tbody td { border:none; } */
    @@keyframes eumiloader {
        from {
            right: 100%;
        }

        to {
            right: 0;
        }
    }
</style>
@if (Model != null)
{
    <script>
        window.ListPageParams = @Html.Raw(EUMI_ERP.Common.ToJson(Model));
    </script>
}
else
{
    <script>
        window.ListPageParams = { };
    </script>
}
<div class="row m-1">
    <div class="col-md-8">
        <h2>Work Items</h2>
    </div>
    <div class="col-md-4 eumi-button-area" id="divDownload" data-download-url="@Url.Action("ListItemsDownload", "WorkItem")">
        <div class="btn-group" role="group">
            <button id="btnColVisibility" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                Columns
            </button>
            <div class="dropdown-menu eumi-col-show" aria-labelledby="btnColVisibility">
            </div>
        </div>

        <div class="btn-group" role="group">
            <button id="btnGroupDropDownload" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                Export
            </button>
            <div class="dropdown-menu" aria-labelledby="btnGroupDropDownload">
                <a class="dropdown-item buttons-excel" data-eumi-download="excel" href="#">Excel</a>
                <a class="dropdown-item buttons-pdf" data-eumi-download="pdf" href="#">PDF</a>
                <a class="dropdown-item buttons-csv" data-eumi-download="csv" href="#">CSV</a>
                <a class="dropdown-item buttons-print" data-eumi-download="print" href="#">Print</a>
            </div>
        </div>
        <button class="btn btn-outline-primary" data-eumi-clear="1" type="button">Clear Search</button>
        <div class="clearfix"></div>
    </div>
</div>
<table id="listitems" class="table table-condensed table-light table-striped table-bordered eumi-search-table" style="width:100%; margin: 0 auto 0 0;">
    <tfoot>
        <tr class="eumi-search-row">
            <th></th>
            <th>Title</th>
            <th>AssignedOn</th>
            <th>Assigned By</th>
            <th>Assigned To</th>
            <th>Department</th>
            <th>Division</th>
            <th>Status</th>
            <th></th>
        </tr>
    </tfoot>
</table>
<div style="height:100px;clear: both">
    &nbsp;
</div>
<script type="text/javascript">
    $(document).ready(function () {
        //$("body").addClass("eumi-loader");
        var table = $("#listitems").EumiDataTable({
            "processing": true,
            "serverSide": true,
            "ajax": {
                "url": "../WorkItem/ListItemsJson",
                "type": "POST",
                "data": function (data) {
                    data.addData = window.ListPageParams;
                }
            },
            "columnDefs": [{
                "targets": 8,
                "render": function (data, type, row, meta) {
                    return '<a href="' + "@Url.Action("ItemView", "WorkItem")" + "?wid=" + row.WorkItemId + '"><i class="ft-eye"></i></a> ' + '&nbsp'
                        + '<a href="' + "@Url.Action("ItemData", "WorkItem")" + "?wid=" + row.WorkItemId + '"><i class="ft-edit"></i></a> '
                }
            }],
            "columns": [
                { data: "slno", title: "Slno", searchable: false, sortable: false },
                { data: "Title", title: "Title" },
                { data: "AssignedOn", title: "Assigned On" },
                { data: "AssignedByUser", title: "Assigned By" },
                { data: "AssignedToUser", title: "Assigned To" },
                { data: "Dept", title: "Department" },
                { data: "Div", title: "Division" },
                { data: "Status", title: "Status" },
                { data: "WorkItemId", title: "Edit", searchable: false, sortable: false }
            ],
        });
    });
</script>
@section bottomscripts {
    <script type="text/javascript" src="~/Scripts/EumiDataTable/eumi-datatable.js"></script>
}
