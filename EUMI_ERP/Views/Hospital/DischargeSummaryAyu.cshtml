<script>
    function GetPatientData(result) {
        $('#Weight').val(result[0].Weight);
    }

    function GetLastRevisitDetails(PatientId) {
        var data = {};                                       //dropdownbind
        data.PatientId = PatientId;
        data.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_LAstRevisitGets",
            data: data,
            success: function (result) {
                if (result.oList.length > 0) {
                    GetPatientData(result.oList, 0);

                }
            }
        });
    }


    $("#RegNo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {

            formrefresh(1);

            var data = {};
            data.PatientName = $("#RegNo").val();
            data.Flag = 10;
            data.DeptId = ERPDeptId;
            $.ajax({
                url: '../Revisit/HMS_IPPatientSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'GR3',
                            label: item.OPSerName + ' - ' + item.OPNumber,
                            label1: item.PatientName,
                            label2: item.AadharNo,            //IP NUMBER
                            PatientId: item.PatientId,
                            DOB: item.DOB,
                            Contact: item.Contact,
                            OPNumber: item.OPNumber,
                            OPSerId: item.OPSerId,
                            PatientName: item.PatientName,
                            IpNo: item.AadharNo,
                            IPYear: item.Status,
                            AdmitDate: item.FromDate,
                            AdmitTime: item.ToDate,
                            DoctorName:item.DoctorName,
                            headers: ["RegNo", "Patient", "IP No"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $("#RegNoSave").val(ui.item.OPNumber);
            $("#RegSeries").val(ui.item.OPSerId);
            $("#RegSer").val(ui.item.OPSerId);

            $("#PatientId").val(ui.item.PatientId);
            $("#IP_Year").val(ui.item.IPYear);
            $("#IP_Number").val(ui.item.IpNo);
            $("#PName").val(ui.item.PatientName);
            $("#AdmittedDate").val(ui.item.AdmitDate + ' - ' + ui.item.AdmitTime);
            $("#SIP_Number").val(ui.item.IPYear + '/' + ui.item.IpNo);
            $("#OPVisitId").val(ui.item.OPNumber);

            GetPatient(ui.item.PatientId);
            GetLabDetails(ui.item.OPNumber, ui.item.OPSerId);
            DocGet(ui.item.IpNo, ui.item.IPYear);
            GetLastRevisitDetails(ui.item.PatientId);

            GetIPDetailsRoom(ui.item.IpNo, ui.item.IPYear, ui.item.PatientName);

           // casesheetdetailsget(ui.item.IpNo, ui.item.IPYear, ui.item.OPNumber)
        },
    }).on('keydown', function (e) {
        if ((e.which == 13) && (($('#RegNo').val() == '') || (($('#PatientId').val() || 0) != 0))) {
            $('#PresentComplaints').focus().select();
        }

    });


    function GetIPDetailsRoom(IPNo, IPYear) {
        var data = {};
        data.IPNumber = IPNo;
        data.IPYear = IPYear;
        data.DeptId = ERPDeptId;

        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_IPStatementRoom",
            data: data,
            success: function (result) {
                LoadIPStatementRoom(result.oList)
            }
        });
    }

    function LoadIPStatementRoom(result) {


        $('#PatAadhar').text(result[0].Remarks)

    }


    $("#Medicine0").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#Medicine0").val();
            data.SlNumber = 0;
            data.DeptId = ERPDeptId;
            data.UserId = ERPUserId;
            $.ajax({
                url: '../Pharmacy/HMS_PurchaseProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '4',
                            label: item.Description,
                            label1: item.ItemCode,
                            label2: item.Group,
                            label3: item.Category,

                            ItemId: item.ItemId,
                            headers: ["Name", "Code", "Company", "Type"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $("#MedicineId0").val(ui.item.ItemId);
            $('#Daily0').focus().select();
        },
    }).on('keydown', function (e) {
        if ((e.which == 13)) {
            $('#Daily0').focus().select();
