                                            <table class="jsgrid-table" id="TblLabBill"></table>
                                        </div>
                                    </div>

                                </div>
                                <div class="form-actions" style="padding-top:5px">
                                    <div class="row">
                                        <div class="col-md-7 row">

                                            <div class="col-md-12" style="padding-left:3%">
                                                <table class="headertable" id="" style="background-color:white;width:100%;">
                                                    <tbody>
                                                        <tr>
                                                            <td class="text-center" width="25%" style="border-left:1px solid #BABFC7;"><b>Total Amount</b></td>
                                                            <td class="text-center" width="25%" style="border-left:1px solid #BABFC7;"><b>Discount%</b></td>
                                                            <td class="text-center" width="25%" style="border-left:1px solid #BABFC7;"><b>Discount Amount</b></td>
                                                            <td class="text-center" width="25%" style="border-left:1px solid #BABFC7;"><b>Net Amount</b></td>
                                                        </tr>
                                                        <tr>
