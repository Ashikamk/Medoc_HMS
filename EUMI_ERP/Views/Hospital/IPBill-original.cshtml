                                                <input type="text" id="BillNo" class="form-control avdclr disb" disabled style="background-color:white">

                                            </div>
                                            <div class="col-md-1 text-right">
                                                <label class="label-control">IP#</label>
                                            </div>
                                            <div class="col-md-2">
                                                <input type="text" id="IpNo" class="form-control rdonl patdet">
                                            </div>
                                            <div class="col-md-1 text-right">
                                                <label class="label-control">OP#</label>
                                            </div>
                                            <div class="col-md-2">
                                                <input type="text" id="OpNo" class="form-control rdonl patdet">
