                                                                <label class="totlbl" style="font-weight:bold;" id="TotalAmt"></label>
                                                            </td>
                                                            <td style="border-left:1px solid #BABFC7;text-align:center;" class="pt-1">
                                                                <input type="text" class="form-control text-center" style="font-weight:bold;border:none" onclick="this.select()" id="DiscPercent" onkeypress='isNumber(event,this)' onkeyup="CalcGrandTotal(0)" onblur="$('#DiscPercent').val(parseFloat($('#DiscPercent').val()).toFixed(Decimal));">
                                                            </td>
                                                            <td style="border-left:1px solid #BABFC7;text-align:center;" class="pt-1">
                                                                <input type="text" class="form-control text-center" style="font-weight:bold;border:none" onclick="this.select()" id="DiscAmt" onkeypress='isNumber(event,this)' onkeyup="CalcGrandTotal(2)" onblur="$('#DiscAmt').val(parseFloat($('#DiscAmt').val()).toFixed(Decimal));">
                                                                @*<label class="totlbl" style="font-weight:bold;" id="DiscAmt"></label>*@
                                                            </td>
                                                            <td style="border-left:1px solid #BABFC7;text-align:center;" class="pt-1">
                                                                <label class="totlbl" style="font-weight:bold;" id="NetAmt"></label>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                        </div>
                                        <div class="col-md-5 text-right">
                                            <button type="button" style="width:120px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                            <button type="button" style="width:120px" id="btnview" onclick="GetRows(1)" class="btn btn-primary btn-min-width mr-1 mb-1" autocomplete="off">View <i class="ft-eye"></i></button>
                                            <button type="button" style="width:120px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">Copy <i class="ft-align-justify"></i></button>
                                            <button type="button" style="width:120px" id="btnnew" onclick="formrefreshconfirm()" class="btn btn-primary btn-min-width mr-1 mb-1">New <i class="ft-refresh-cw position-right"></i></button>
                                            <button style="display:none" type="button" id="btnprint" onclick="PrintthisBill(1)" class="btn btn-primary btn-min-width mr-1 mb-1">Print <i class="ft-printer"></i></button>
                                            <button style="display:none;width:120px" type="button" id="btnedit" onclick="$('#otptype').val(0), $('#OTPDiv').show(), $('#txtotp,#otpremarks').prop('disabled', false), $('#txtotp').focus()" class="btn btn-secondary btn-min-width mr-1 mb-1">Edit<i class="fa fa-check-square-o"></i></button>
                                            <button style="display:none;width:120px" type="button" id="btnupdate" class="btn btn-secondary btn-min-width mr-1 mb-1">Update<i class="fa fa-check-square-o"></i></button>
                                            <button style="display:none;width:120px" type="button" id="btndelete" onclick="$('#otptype').val(1), $('#OTPDiv').show(), $('#txtotp,#otpremarks').prop('disabled', false), $('#txtotp').focus()" class="btn btn-danger btn-min-width mr-1 mb-1">Delete<i class="fa fa-times"></i></button>
                                            <button style="display:none" type="button" id="btnacctran" onclick="GetTrans()" class="btn btn-info white btn-min-width mr-1 mb-1">Accounts Details <i class="fa ft-info"></i></button>
                                        </div>
                                    </div>

                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

