                                                <label class="label-control">Surgery Date</label>
                                            </div>
                                            <div class="col-md-2">
                                                <input type="text" id="SurgeryDate" class="form-control denull">
                                            </div>

                                            <div class="col-md-1  text-right">
                                                <label class="label-control">Remarks</label>
                                            </div>
