                                                    <option value="0">Normal Rate</option>
                                                    <option value="1">Special Rate</option>
                                                    <option value="2">Very Special Rate</option>
                                                    <option value="3">Outside Rate</option>
                                                </select>*@
                                            </div>
                                            <div class="col-md-1 text-right">
                                                <label class="label-control" style="width: 130%;margin-left:-30%">Discharge Date</label>
                                            </div>
                                            <div class="col-md-2">
                                                <input type="text" id="DischargeDate" class="form-control rdonl patdet">
                                                @*<select id="Hospital" class="form-control">
                                                    <option value="0">Kims HosPital</option>
                                                    <option value="1">LakeShore HosPital</option>
                                                </select>*@
                                            </div>
                                        </div>
