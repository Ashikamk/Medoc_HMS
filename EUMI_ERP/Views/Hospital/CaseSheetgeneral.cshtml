<script>

    GetItemGroup()
    function GetItemGroup() {
        var data = {};
        data.GroupId = 0;
        $.ajax({
            type: "POST",
            url: "../ItemMapping/ItemGroupGetandGets",
            data: data,
            success: function (result) {
                Loadgroup(result.oList);
            }
        });
    }

    function Loadgroup(result) {
        $("#Itemgroup1").empty();
        var group = "<option value=0> -template- </option>";
        for (var i = 0; i < result.length; i++) {
            group += "<option value='" + result[i].GroupId + "'>" + result[i].GroupName + "</option>";
        }
        $("#Itemgroup1").append(group);
    }

    function GetItemGroupload() {
        var data = {};
        data.GroupId = $("#Itemgroup1").val()
        $.ajax({
            type: "POST",
            url: "../ItemMapping/ItemGroupGetandGets",
            data: data,
            success: function (result) {
                Loadgrouplist(result.oList);
            }
        });
    }


    function Loadgrouplist(result) {
        MedCount = 1;
        var DD = result[0].GroupName.split("#");
        $('#Medicine1').val(DD[2]);
        $('#MedicineId1').val(DD[0]);
        $('#Daily1').val(DD[3]);
        $('#Dosage1').val(DD[4]);
        $('#Days1').val(DD[5]);

        for (var i = 1; i < result.length; i++) {
            DD = result[i].GroupName.split("#");

            var Id = parseInt(i) + 1; var SlNo = $('.Mrow').length + 1;
            var MedRow =
                '<tr  class="jsgrid-header-row Mrow NtAd" id="MdRow' + Id + '">' +
                '<td class="jsgrid-control-field jsgrid-align-center" id="editheader" style="width: 3%;" onclick="DelTableRowConfirm(0,' + Id + ')"><i class="icon-trash"></i></td>' +
                '<td class="jsgrid-align-center" style="width: 4%;" id="Mslno' + Id + '">' + SlNo + '</td>' +
                '<td class="" style="width: 30%;">' +
                '<input type="text" class="form-control mdclass brdles" name="medname" id="Medicine' + Id + '"  value="' + DD[2] + '" onfocus="LoadMedicine(' + Id + ')" onfocusout=UpdateMedicineRow(' + Id + ',0) />' +
                '<input type="text" style="display:none" class="form-control"  value="' + DD[0] + '" id="MedicineId' + Id + '"  />' +
                '</td>' +
                '<td class="" style="width: 20%;"><input type="text" class="form-control mdclass brdles"  onfocus="mednoteload3(' + Id + ')"  name="Notes" id="mednote' + Id + '" /></td>' +
                '<td class="" style="width: 10%;"><input type="text" class="form-control mdclass brdles"  onfocus="mednoteload1(' + Id + ')" onfocusout=UpdateMedicineRow(' + Id + ',1) name="Daily" value="' + DD[3] + '" id="Daily' + Id + '"  /></td>' +
                '<td class="" style="width: 10%;"><input type="text" class="form-control mdclass brdles" onfocus="mednoteload(' + Id + ')" onfocusout=UpdateMedicineRow(' + Id + ',2) name="Dosage" value="' + DD[4] + '" id="Dosage' + Id + '" /></td>' +
                '<td class="" style="width: 10%;"><input type="text" class="form-control mdclass brdles" onfocusout=UpdateMedicineRow(' + Id + ',3) name="Days" id="Days' + Id + '" value="' + DD[5] + '" onkeydown=AddMedicineRowConfirm(event,' + Id + ') /></td>' +
                '</tr>';
            $('#TblMedicine').append(MedRow);
            $('.brdles').css('border', 'none');
            MedCount++;


        }

    }




</script>

