<script>


    function PrintPrevVisit() {
        var myWindow = window.open("", "", "width=1500,height=1500");

        var ComapnydivToPrintLab = document.getElementById("ComapnyImage");








        $(ComapnydivToPrintLab).css('height', 130); $(ComapnydivToPrintLab).css('width', 700);
        myWindow.document.write('<table width=100% ><tr ><td width=100% align=center  style=color:#008000;font-weight:bold>' + (ComapnydivToPrintLab.outerHTML) + '</td></tr>');
        myWindow.document.write('</table>');

        var text = document.getElementById('PDiagnosis');
        var val = text.value;
        var arr = val.split("\n");

        arr = arr.slice(0, arr.length - 1);

        var newText = arr.join("<br>");

        myWindow.document.write('<table width=100% ><tr ><td width=30px>Reg No</td><td width=400px>' + $('#PRegNo').val() + '</td><td width=30px>OP No</td><td>' + $('#PatientOP').text() + '</td></tr>' +
            '<tr ><td>Name</td><td>' + $('#PatientName').val() + '</td><td>Age</td><td>' + $('#PatientAge').text() + '</td></tr>' +
            '<tr ><td>Doctor</td><td>' + $('#consdoctor').text() + '</td><td>Date</td><td>' + $('#PrevCaseDate').text() + '</td></tr>' +

           // '<tr ><td>Doctor</td><td>' + $('#DocName').val() + '</td><td>Date</td><td>' + $('#CaseDate').val() + '</td></tr>' +
            '<tr ><td colspan=4><hr></td></tr></table>');

        var row = '<table width=100% >';
        if ($('#PPatComplaint').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>Progress Notes</b></td></tr><tr ><td>' + $('#PPatComplaint').val() + '</td></tr>'
        }
        if ($('#PDiagnosis').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>Examination</b></td></tr><tr ><td>' + newText + '</td></tr>'
        }
        if ($('#PAdvice').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>Treatment</b></td></tr><tr ><td>' + $('#PAdvice').val() + '</td></tr>'
        }
        if ($('#PMedAdvice').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>Diagnosis</b></td></tr><tr ><td>' + $('#PMedAdvice').val() + '</td></tr>'
        }
        if ($('#PDetails').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>H/O Other Medical Illness</b></td></tr><tr ><td>' + $('#PDetails').val() + '</td></tr>'
        }
        if ($('#PNotes').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>Own Medicine</b></td></tr><tr ><td>' + $('#PNotes').val() + '</td></tr>'
        }
        if ($('#PAllergies').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>H/O Allergy</b></td></tr><tr ><td>' + $('#PAllergies').val() + '</td></tr>'
        }
        if ($('#PRemarks').val() != '') {
            row += '<tr style="background-color:#D3D3D3"><td><b>Advice</b></td></tr><tr ><td>' + $('#PRemarks').val() + '</td></tr>'
        }

        row += '<tr style="background-color:#D3D3D3"><td><b>Medicine Details</b></td></tr>'

        myWindow.document.write(row);

        for (var i = 0; i <= 15; i++) {
            var Id = parseInt(i + 1);
            if ($('#PMedicine_' + Id).length && $.trim($('#PMedicine_' + Id).val()) != '') {

                var medname = Id + ".  " + $('#PMedicine_' + Id).val();
                var Dosage = $('#PDosage_' + Id).val();
                // var Daily = $('#PrintDaily_' + Id).val();
                // var Days = $('#PrintDays_' + Id).val();
                //var Notes = $('#mednote' + Id).val();

                myWindow.document.write('<tr><td>' + medname + '  ' + Dosage + '</td></tr>');
            }

        }


        myWindow.document.write('</table>')
        myWindow.document.write('</tr>')
        myWindow.document.write('<tr ><td colspan=4><hr></td></tr></table>');
        myWindow.print();

    }


    function Paientinformationedit()
