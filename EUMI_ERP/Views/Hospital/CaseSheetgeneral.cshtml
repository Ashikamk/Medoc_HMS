    function LoadMedicine(Id) {

        $("#Medicine" + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                $("#MedicineId" + Id).val('0');
                var data = {};
                data.ItemCode = $("#Medicine" + Id).val();
                data.SlNumber = 0;
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                $.ajax({
                    url: '../Pharmacy/HMS_PurchaseProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                           // if (item.Model1 > 0) {
                                return ({
                                    ColCount: '-20ph',
                                    label: item.Description,
                                    //label1: item.ItemCode,
                                    label1: item.Model1,
                                    label2: item.Category,

                                    ItemId: item.ItemId,
                                    headers: ["Name", "Stock", "Type"]
                                })
                            //}
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {

                $("#MedicineId" + Id).val(ui.item.ItemId);
                $('#mednote' + Id).focus();
            },
        }).on('keydown', function (e) {
            //if ((e.which == 13) && (($('#MedicineId' + Id).val() || 0) != 0)) {
            //    $('#mednote' + Id).focus().select();
            //}
            //else
                if ((e.which == 13) && (($('#MedicineId' + Id).val() || 0) != 0)) {
                    $('#mednote' + Id).focus().select();
            }
            else if ((e.which == 39) && (($('#Medicine' + Id).val()) == '')) {
                $('#Daily' + Id).focus().select();
            }
            else if ((e.which == 37) && (($('#Medicine' + Id).val()) == '')) {
                $('#Days' + Id).focus().select();
            }
        });
    }


