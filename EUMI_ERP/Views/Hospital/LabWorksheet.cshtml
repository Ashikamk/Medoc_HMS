        function OpenLabResult(Id) {

            var status = $("#RowStatus_" + Id).val();

            if (!status || status === "PENDING") {
                swal("Lab result is pending", "", "warning");
                return;
            }

            if (status !== "RESULT") {
                swal("Lab result is not available", "", "warning");
                return;
            }


            var patientName = $("#PatientName_" + Id).val();
            var opSerName = $("#OPSerName_" + Id).val();
            var opNumber = $("#OPNumber_" + Id).val();
            var opVisitId = $("#OPVisitId_" + Id).val();
            var revisitDate = $("#RevisitDate_" + Id).text();
            var doctorName = $("#ddname" + Id).text();
            var bloodGroup = ($("#BloodGroup_" + Id).val()).split("##")[0];
            var gender = $("#Gender_" + Id).val();
            var patientId = $("#PatientId_" + Id).val();
            var tokenNo = $("#TokenNo_" + Id).val() || '';

            window._currentPatientId = patientId;
            window._currentRegNo = opNumber;

            $("#LRD_PatientName").text(patientName);
            $("#LRD_RegNo").text(opSerName + '-' + opNumber);
            $("#LRD_Age").text(gender + ' / ' + bloodGroup);
            $("#LRD_Doctor").text(doctorName);
            $("#LRD_Contact").text('');
            $("#LRD_SampleId").text(opVisitId);
            $("#LRD_BillNo").text(tokenNo);
            $("#LRD_CollDate").text('');
            $("#LRD_RecvDate").text('');

            var now = new Date();
            var day = String(now.getDate()).padStart(2, '0');
            var month = String(now.getMonth() + 1).padStart(2, '0');
            var year = now.getFullYear();
            var hours = String(now.getHours()).padStart(2, '0');
            var minutes = String(now.getMinutes()).padStart(2, '0');
            var reportDateTime = day + "/" + month + "/" + year + " " + hours + ":" + minutes;

            $("#LRD_ReportDate").text(reportDateTime);
            $("#LRD_Notes").html('');
            $("#LRD_TestBody").html(
                '<tr><td colspan="4" class="text-center text-muted p-3">Loading...</td></tr>'
            );

            $("#LabResultDetailModal").modal("show");
            $("#LabResultDetailModal").appendTo("body");
            //LoadUserDropdowns();

            var data = {};
            data.OPNumber = opVisitId;
            data.PatientId = patientId;
            data.DeptId = ERPDeptId;
            data.Flag = 0;

            $.ajax({
                type: "POST",
                url: "../Revisit/HMS_LabBillGets",
                data: data,
                success: function (result) {
                    var bills = (result.oList && result.oList.length > 0) ? result.oList : [];
                    if (bills.length === 0) {
                        var data2 = {
                            OPNumber: '', PatientId: patientId,
                            DeptId: ERPDeptId, Flag: 1
                        };
                        $.ajax({
                            type: "POST",
                            url: "../Revisit/HMS_LabBillGets",
                            data: data2,
                            success: function (r2) {
                                _pickBestBill(r2.oList || [], tokenNo, opVisitId, opNumber);
                            }
                        });
                    } else {
                        _pickBestBill(bills, tokenNo, opVisitId, opNumber);
                    }
                },
                error: function () {
                    $("#LRD_TestBody").html(
                        '<tr><td colspan="4" class="text-center text-danger">Error loading bills.</td></tr>'
                    );
                }
            });
        }

        function _pickBestBill(bills, tokenNo, opVisitId, opNumber) {
            if (!bills || bills.length === 0) {
                $("#LRD_TestBody").html(
                    '<tr><td colspan="4" class="text-center text-danger p-2">No lab bills found.</td></tr>'
                );
                return;
            }

            var best = null;
            for (var b = 0; b < bills.length; b++) {
                if (String(bills[b].BillNo) === String(tokenNo)) { best = bills[b]; break; }
            }
            if (!best) {
                for (var b = 0; b < bills.length; b++) {
                    if (String(bills[b].OPNumber) === String(opVisitId)) { best = bills[b]; break; }
                }
            }
            if (!best) {
                for (var b = 0; b < bills.length; b++) {
                    if (String(bills[b].OPNumber) === String(opNumber)) { best = bills[b]; break; }
                }
            }
            if (!best) {
                bills.sort(function (a, b) { return b.Flag - a.Flag; });
                best = bills[0];
            }

            var docParts = (best.Doctor || '').split('#');
            var contactNo = (docParts[6] || '').trim();
            if (/\d{6,}/.test(contactNo)) {
                $("#LRD_Contact").text(contactNo.substring(0, 10));
            }

            $("#LRD_CollDate").text(best.Date);
            $("#LRD_RecvDate").text(best.Date);
            $("#LRD_BillNo").text(best.BillNo);

            window._currentBill = best;



            var resultData = {};
            resultData.ResultId = 1;
            resultData.DeptId = ERPDeptId;
            resultData.BillNo = best.BillNo;
            resultData.BillYear = best.BillYear;
            resultData.Flag = 1;
            resultData.FromDate = '';
            resultData.ToDate = '';
            resultData.DoctorId = 0;
            resultData.PatientId = 0;

            $.ajax({
                type: "POST",
                url: "../Revisit/HMS_ResultGetandGets",
                data: resultData,
                success: function (resultRes) {
                    var resultList = resultRes.oList || [];


                    if (resultList.length > 0) {

                    }

                    if (resultList.length > 0) {

                        var savedDate = (resultList[0].Date || '').toString().trim();
                        var savedTime = (resultList[0].ToDate || '').toString().trim();

                        if (savedDate !== '' && savedDate !== '0' && savedDate !== 'null') {
                            best.TrueResultDate = savedDate + (savedTime !== '' && savedTime !== '0' && savedTime !== 'null' ? ' ' + savedTime : '');
                        } else {
                            best.TrueResultDate = '';
                        }


                        var allNotes = '';
                        for (var n = 0; n < resultList.length; n++) {

                            var rn = (resultList[n].Notes || '').toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                            if (rn !== '' && allNotes.indexOf(rn) === -1) {
                                allNotes += rn + ' ';
                            }

                            var rr = (resultList[n].Remarks || '').toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                            if (rr !== '' && rr.indexOf('##') === -1 && allNotes.indexOf(rr) === -1) {
                                allNotes += rr + ' ';
                            }

                            var tr = (resultList[n].TestRemarks || '').toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                            if (tr !== '' && allNotes.indexOf(tr) === -1) {
                                allNotes += tr + ' ';
                            }

                            var nt = (resultList[n].NoteText || '').toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                            if (nt !== '' && allNotes.indexOf(nt) === -1) {
                                allNotes += nt + ' ';
                            }
                        }
                        best.TrueNotes = allNotes.trim();

                    } else {
                        best.TrueResultDate = '';
                        best.TrueNotes = '';
                    }


                    var d2 = { BillNo: best.BillNo, BillYear: best.BillYear, Flag: 0, DeptId: ERPDeptId };
                    $.ajax({
                        type: "POST",
                        url: "../Revisit/HMS_LabBillTestGets",
                        data: d2,
                        success: function (res) {
                            LoadUserDropdowns(best.BillNo);          // ← pass BillNo here
                            LoadLabResultPopup(res.oList || [], best);
                        },
                        error: function () {
                            $("#LRD_TestBody").html(
                                '<tr><td colspan="4" class="text-center text-danger">Error loading tests.</td></tr>'
                            );
                        }
                    });
                },
                error: function () {
                    best.TrueResultDate = '';
                    best.TrueNotes = '';
                    var d2 = { BillNo: best.BillNo, BillYear: best.BillYear, Flag: 0, DeptId: ERPDeptId };
                    $.ajax({
                        type: "POST",
                        url: "../Revisit/HMS_LabBillTestGets",
                        data: d2,
                        success: function (res) {
                            LoadLabResultPopup(res.oList || [], best);
                        }
                    });
                }
            });
        }
        function LoadLabResultPopup(tests, bill) {
            $("#LRD_TestBody").html('');
            $("#LRD_Notes").html('');

            if (!tests || tests.length === 0) {
                $("#LRD_TestBody").html(
                    '<tr><td colspan="4" class="text-center text-muted p-3">No test details available.</td></tr>'
                );
                return;
            }

            var html = '';
            var finalNotes = '';
            var currentDeptId = '';

            for (var i = 0; i < tests.length; i++) {
                var t = tests[i];

                var noteVal = '';
                if (t.Notes && t.Notes.toString().replace(/undefined/g, '').replace(/null/g, '').trim() !== '') {
                    noteVal = t.Notes.toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                } else if (t.Remarks && t.Remarks.toString().replace(/undefined/g, '').replace(/null/g, '').trim() !== '') {
                    var tempR = t.Remarks.toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                    if (tempR.indexOf('##') === -1) { noteVal = tempR; }
                } else if (t.TestRemarks && t.TestRemarks.toString().replace(/undefined/g, '').replace(/null/g, '').trim() !== '') {
                    noteVal = t.TestRemarks.toString().replace(/undefined/g, '').replace(/null/g, '').trim();
                }
                if (noteVal !== '' && finalNotes.indexOf(noteVal) === -1) {
                    finalNotes += noteVal + ' ';
                }

                if (t.Flag == 1) {

                    currentDeptId = (t.MedDeptId || '').toString();
                    html += '<tr class="lab-dept-header" style="background-color:#f2f2f2;">' +
                        '<td colspan="4" style="font-weight:bold;text-align:center;padding:4px 8px;' +
                        'font-size:11px;letter-spacing:1px;">' + (t.TestName || '') + '</td></tr>';
                } else {


                    var thisDeptId = (t.MedDeptId || '').toString();
                    if (thisDeptId !== '' && thisDeptId !== currentDeptId) {
                        currentDeptId = thisDeptId;
                        var deptName = (t.MedDeptName || '').split('#')[0].trim();
                        if (deptName !== '') {
                            html += '<tr class="lab-dept-header" style="background-color:#f2f2f2;">' +
                                '<td colspan="4" style="font-weight:bold;text-align:center;padding:4px 8px;' +
                                'font-size:11px;letter-spacing:1px;">' + deptName + '</td></tr>';
                        }
                    }

                    var resultVal = (t.Result || '').trim();
                    var genderSymbol = '';
                    if ($("#LRD_Age").text().indexOf('Female') !== -1 || $("#LRD_Age").text().indexOf('F') !== -1) {
                        if (resultVal !== '' && !isNaN(parseFloat(resultVal))) {
                            genderSymbol = ' ♀';
                        }
                    }

                    var normalVal = (t.NormalValue || '').replace(/##/g, '<br>');
                    var stdUnit = t.StdUnit || '';

                    var isWBC = (t.TestName || '').toUpperCase().indexOf('TOTAL WBC COUNT') !== -1 ||
                        (t.TestName || '').toUpperCase().indexOf('TOTAL WBC') !== -1;

                    if (isWBC && (!normalVal || normalVal === '')) {
                        normalVal = 'Mean: -0.000 - 0.000<br>' +
                            'Minimum: -4.000 - 0.000<br>' +
                            'Maximum: 4.000 - 10.000<br>' +
                            'Child: &lt;500 - 14.600<br>' +
                            'Infants: 8,100 - 14.500';
                    }

                    var maxV = parseFloat((t.MaxValue + '').replace(/,/g, '') || 0);
                    var minV = parseFloat((t.MinValue + '').replace(/,/g, '') || 0);

                    var isAbnorm = false;
                    var arrow = '';

                    if (resultVal !== '') {
                        var resNum = parseFloat(resultVal.replace(/,/g, ''));
                        if (!isNaN(resNum)) {
                            if (maxV > 0 && resNum > maxV) {
                                isAbnorm = true;
                                arrow = ' <span style="color:#c0392b;font-size:10px;">&#9650;</span>';
                            } else if (minV > 0 && resNum < minV) {
                                isAbnorm = true;
                                arrow = ' <span style="color:#c0392b;font-size:10px;">&#9660;</span>';
                            }
                        }
                        var up = resultVal.toUpperCase();
                        if (up.indexOf('RECH') !== -1 || up.indexOf('REACT') !== -1 || up.indexOf('POSITIVE') !== -1) {
                            isAbnorm = true;
                        }
                    }

                    var resultCellStyle = 'padding:4px 8px;width:18%;' +
                        (isAbnorm ? 'font-weight:bold;color:#c0392b;' : '');

                    var testDisplay = t.TestName || '';
                    var indented = false;
                    if (testDisplay.indexOf('##') !== -1) {
                        testDisplay = testDisplay.replace('##', '');
                        indented = true;
                    }

                    html += '<tr style="border-bottom:0.5px solid #eee;">' +
                        '<td style="padding:4px 8px;width:38%;font-weight:bold;' +
                        (indented ? 'padding-left:24px;' : '') + '">' + testDisplay + '</td>' +
                        '<td style="' + resultCellStyle + '">' +
                        (resultVal !== '' ? resultVal + genderSymbol + arrow : '&mdash;') + '</td>' +
                        '<td style="padding:4px 8px;color:#555;width:12%;">' + stdUnit + '</td>' +
                        '<td style="padding:4px 8px;color:#555;width:32%;font-size:11px;">' + normalVal + '</td>' +
                        '</tr>';
                }
            }

            $("#LRD_TestBody").html(html);

            var cleaned = finalNotes.replace(/undefined/g, '').replace(/null/g, '').trim();
            if (bill && bill.TrueNotes && bill.TrueNotes.trim() !== '') {
                cleaned = bill.TrueNotes.trim();
            }
            if (cleaned !== '') {
                $("#LRD_Notes").html('<strong>' + cleaned + '</strong>');
            }


        }

