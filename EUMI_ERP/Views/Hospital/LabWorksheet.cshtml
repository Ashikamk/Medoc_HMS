        function GetImmunizationDetails(OPVisit, Type, Flag) {

            $("#TblImmunization").html('');

            var ImFlag = 1;
            if (Flag == 0) { ImFlag = 0; }
            var data = {};
            data.OPVisit = OPVisit;
            data.IPNumber = 0;
            data.IPYear = 0;
            data.PRegSer = 1;
            data.PRegNo = $('#GOPNumber').val();
            data.DeptId = ERPDeptId;
            data.UserId = ERPUserId;
            data.Flag = ImFlag;

            $.ajax(
                {
                    type: "POST",
                    url: "../Hospital/HMS_ImmunizationGets",
                    data: data,
                    success: function (result) {
                        if (Type == 0) {
                            RowRemove(2);
                            LoadImmunizationDetails(result.oList);
                        }
                        else if (Type == 1) {
                            LoadImmunizationDetails(result.oList);
                        }
                    }
                });
        }

