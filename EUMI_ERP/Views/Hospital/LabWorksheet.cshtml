            $("#LRD_VerifiedIcon").html('');
            $("#LRD_ApprovedIcon").html('');

            // No BillNo → show -- Select -- + ❌
            if (!billNo || billNo == 0) {
                $("#LRD_VerifiedBy").val('');
                $("#LRD_LabIncharge").val('');
                $("#LRD_VerifiedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                $("#LRD_ApprovedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                return;
            }

            // BillNo exists → check DB
            $.ajax({
                type: "POST",
                url: '@Url.Action("HMS_LabResultVerificationGet", "Revisit")',
                data: { SampleId: billNo },
                success: function (res) {
                    if (res.oList && res.oList.length > 0) {
                        var saved = res.oList[0];
                        var vUser = parseInt(saved.VerifiedUser || 0);
                        var aUser = parseInt(saved.ApprovedUser || 0);

                        if (vUser > 0) {
                            $("#LRD_VerifiedBy").val(vUser);
                            $("#LRD_VerifiedIcon").html('<span style="color:green;font-size:22px;">&#10004;</span>');
                        } else {
                            $("#LRD_VerifiedBy").val('');
                            $("#LRD_VerifiedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                        }

                        if (aUser > 0) {
                            $("#LRD_LabIncharge").val(aUser);
                            $("#LRD_ApprovedIcon").html('<span style="color:green;font-size:22px;">&#10004;</span>');
                        } else {
                            $("#LRD_LabIncharge").val('');
                            $("#LRD_ApprovedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                        }

                    } else {
                        // No DB record
                        $("#LRD_VerifiedBy").val('');
                        $("#LRD_LabIncharge").val('');
                        $("#LRD_VerifiedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                        $("#LRD_ApprovedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                    }
                },
                error: function () {
                    $("#LRD_VerifiedBy").val('');
                    $("#LRD_LabIncharge").val('');
                    $("#LRD_VerifiedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                    $("#LRD_ApprovedIcon").html('<span style="color:red;font-size:22px;">&#10006;</span>');
                }
            });
        }
    });
}
