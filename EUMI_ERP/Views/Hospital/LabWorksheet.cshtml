    function SaveApprovedBy() {
    var billNo = window._currentBill ? window._currentBill.BillNo : 0;
    var patientId = window._currentPatientId || 0;
    var regNo = window._currentRegNo || 0;
    var approvedUser = $("#LRD_LabIncharge").val();  // ✅ Only check approved
    var verifiedUser = $("#LRD_VerifiedBy").val();
    var sampleDate = $("#LRD_CollDate").text();

    if (!billNo || billNo == 0) { swal("Please open a lab result first.", "", "warning"); return; }

    // ✅ Block if approved not selected
    if (!approvedUser || approvedUser === '') {
        swal("Please select a user to approve.", "", "warning");
        return;   // ← MUST return here, do not fall through
    }

    var data = {};
    data.SampleId     = billNo;
    data.Pid          = patientId;
    data.RegNo        = regNo;
    data.VerifiedUser = verifiedUser;
    data.ApprovedUser = approvedUser;
    data.userid       = ERPUserId;
    data.SampleDate   = sampleDate;

    $.ajax({
        type: "POST",
        url: '@Url.Action("HMS_LabResultVerificationInsert", "Revisit")',
        data: data,
        success: function (result) {
            if (result.oList && result.oList.length > 0) {
                if (result.oList[0].Status == "1") {
                    // ✅ Update icon immediately on success
                    $("#LRD_ApprovedIcon").html('<span style="color:green;font-size:22px;">&#10004;</span>');
                    swal("Approved By saved successfully.", "", "success");
                } else {
                    swal("Failed to save.", "", "error");
                }
            }
        },
        error: function () {
            swal("Error saving. Please try again.", "", "error");
        }
    });
}

function SaveVerifiedBy() {
    var billNo = window._currentBill ? window._currentBill.BillNo : 0;
    var patientId = window._currentPatientId || 0;
