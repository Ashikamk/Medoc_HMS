@{
    ViewBag.Title = "LabWorksheet";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<style>
    .label-control {
        font-weight: bold;
    }

    .bgcolor {
        background-color: #daeff1;
    }

    #divContainerNew {
        border: solid 1px black;
        min-width: 200px;
        min-height: 40px;
        width: auto;
        height: auto;
        background-color: white;
        cursor: pointer !important;
        font-weight: bold;
    }

    .divpop {
        position: absolute;
        text-align: left;
        display: none;
        color: black;
        border-radius: 3px;
    }

    .pointer:hover {
        background-color: #acd6f5;
        text-decoration: underline;
    }

    /* Increase all label text inside modal */
    #SimpleLabModal p:first-child {
        font-size: 16px !important;
        font-weight: 600 !important;
        letter-spacing: 0.3px;
    }

    .btn-close-custom {
        padding: 8px 20px;
        border: 1px solid #cbd5e0;
        background: #fff;
        border-radius: 6px;
        font-size: 13px;
        transition: all 0.3s ease;
    }

        /* 🔥 HOVER EFFECT */
        .btn-close-custom:hover {
            background: #0F6E56;
            color: #fff;
            border-color: #0F6E56;
        }

    
</style>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<div class="myData" data-x="M361" />

<div class="modal fade" id="SimpleLabModal">
    <div class="modal-dialog" style="max-width:720px;">
        <div class="modal-content" style="border-radius:12px; overflow:hidden; border:none; font-family:'Segoe UI',sans-serif;">

            <!-- HEADER -->
            <div style="background:#0F6E56; padding:18px 24px; display:flex; justify-content:space-between; align-items:center;">

                <div style="display:flex; align-items:center; gap:12px;">
                    
                    <div>
                        <p style="margin:0; font-size:20px; font-weight:700; color:#fff;">LAB ADVICE DETAILS</p>
                        
                    </div>
                </div>

                <div style="display:flex; align-items:center; gap:8px;">
                    <button type="button" class="close" data-dismiss="modal"
                            style="color:#fff; font-size:22px; background:rgba(255,255,255,0.2); border-radius:50%; width:28px; height:28px; border:none;">
                        &times;
                    </button>
                </div>
            </div>

            <!-- PATIENT INFO -->
            <div style="padding:20px 24px; background:#E1F5EE; border-bottom:0.5px solid #9FE1CB;">

                <!-- ✅ PATIENT BOXES -->
                <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:10px; margin-bottom:10px;">

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Name</p>
                        <p id="M_Patient" style="margin:5px 0 0; font-size:16px; font-weight:700;"></p>
                    </div>

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Age / Sex</p>
                        <p id="M_AgeSex" style="margin:5px 0 0; font-size:16px; font-weight:700;"></p>
                    </div>

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Phone</p>
                        <p id="M_Phone" style="margin:5px 0 0; font-size:16px; font-weight:700;"></p>
                    </div>

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Reg#</p>
                        <p id="M_RegNo" style="margin:5px 0 0; font-size:16px; font-weight:700;"></p>
                    </div>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:10px;">

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Date</p>
                        <p id="M_Date" style="margin:5px 0 0; font-size:15px; font-weight:600;"></p>
                    </div>

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Time</p>
                        <p id="M_Time" style="margin:5px 0 0; font-size:15px; font-weight:600;"></p>
                    </div>

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">OP#</p>
                        <p id="M_OPNo" style="margin:5px 0 0; font-size:15px; font-weight:600;"></p>
                    </div>

                    <div style="background:#fff; border:1px solid #9FE1CB; border-radius:8px; padding:12px;">
                        <p style="margin:0; font-size:13px; color:#085041;">Doctor</p>
                        <p id="M_Doctor" style="margin:5px 0 0; font-size:15px; font-weight:700;"></p>
                    </div>

                </div>
            </div>

            <!-- LAB TESTS -->
            <div style="padding:20px 24px;">
                <div style="display:flex; justify-content:space-between; margin-bottom:14px;">
                    <p style="margin:0; font-size:18px; font-weight:700;">Lab Tests Advised</p>
                </div>

                <ul id="M_LabAdviceList" style="list-style:none; padding:0; margin:0;"></ul>
            </div>

            <!-- FOOTER -->
            <div style="padding:14px 24px; border-top:1px solid #9FE1CB; background:#E1F5EE; display:flex; justify-content:flex-end; align-items:center;">

                <button type="button" data-dismiss="modal" class="btn-close-custom">
                    Close
                </button>

            </div>

        </div>
    </div>
</div><!-- CSS for enhanced styling -->
<style>
    /* Table row styling */
    #LRD_TestBody tr {
        border-bottom: 0.5px solid #eee;
    }

    #LRD_TestBody td {
        padding: 10px 12px !important;
        font-size: 16px !important;
        line-height: 1.5 !important;
    }

        /* Test name column - bold */
        #LRD_TestBody td:first-child {
            font-weight: bold !important;
        }

        /* Unit and Reference Range columns - black color */
        #LRD_TestBody td:nth-child(3),
        #LRD_TestBody td:nth-child(4) {
            color: #000000 !important;
            font-weight: normal !important;
        }

        /* Result column styling */
        #LRD_TestBody td:nth-child(2) {
            font-weight: 600 !important;
        }

    /* Department header styling */
    #LRD_TestBody .lab-dept-header td {
        background-color: #e8e8e8 !important;
        font-weight: bold !important;
        font-size: 17px !important;
        letter-spacing: 1px !important;
        padding: 10px 12px !important;
        color: #000 !important;
    }

    /* Abnormal result highlighting - keep color but maintain size */
    #LRD_TestBody td[style*="color:#c0392b"],
    #LRD_TestBody td:has(> span[style*="color:#c0392b"]) {
        font-weight: bold !important;
        font-size: 16px !important;
    }

    /* Notes section styling */
    #LRD_Notes strong {
        font-size: 15px !important;
    }

    /* Scrollbar styling */
    #LRD_TestTable ~ div::-webkit-scrollbar,
    .modal-body div[style*="max-height"]::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    #LRD_TestTable ~ div::-webkit-scrollbar-track,
    .modal-body div[style*="max-height"]::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 4px;
    }

    #LRD_TestTable ~ div::-webkit-scrollbar-thumb,
    .modal-body div[style*="max-height"]::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 4px;
    }

        #LRD_TestTable ~ div::-webkit-scrollbar-thumb:hover,
        .modal-body div[style*="max-height"]::-webkit-scrollbar-thumb:hover {
            background: #555;
        }



    #LRD_TestTable,
    #LRD_TestBody td {
        font-size: 17px !important;
    }





    .modal-body > div:first-child {
        flex-direction: column !important;
    }

    #LRD_TestBody td {
        font-size: 13px !important;
        padding: 6px 8px !important;
    }
</style>

