<!-- Lab Result Detail Popup -->
<div class="container">
    <div class="modal fade" id="LabResultDetailModal" role="dialog">
        <!-- Slightly reduced popup size -->
        <div class="modal-dialog modal-xl" style="max-width: 85%; width: 1100px;">
            <div class="modal-content" style="border-radius:8px; border:none; font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">

                <!-- Header -->
                <div class="modal-header" style="background-color:#fff; border-bottom:none; padding:20px 30px 0 30px; flex-direction:column; align-items:center; position:relative;">
                    <button type="button" class="close" style="position:absolute;top:15px;right:20px;font-size:28px;" data-dismiss="modal">&times;</button>
                    <div style="text-align:center; border-bottom:3px solid #333; width:100%; padding-bottom:10px;">
                        <h4 style="font-weight:bold; letter-spacing:3px; margin:0; font-size:24px;" id="LRD_HospitalName">LABORATORY</h4>
                        <p style="font-size:15px; letter-spacing:4px; margin:5px 0 0 0; color:#333;">LABORATORY REPORT</p>
                    </div>
                </div>

                <div class="modal-body" style="padding:0 30px 20px 30px; background:#fff;">

                    <!-- Patient Info Box - Labels BOLD, Values normal -->
                    <!-- Patient Info Box -->
                    <div style="border:1.5px solid #ccc; display:flex; margin:15px 0 0 0; font-size:16px; border-radius:4px;">

                        <!-- LEFT SIDE -->
                        <div style="flex:1.4; padding:12px 15px; border-right:1.5px solid #ccc;">
                            <table style="width:100%; border-collapse:collapse; line-height:2.3;">

                                <tr>
                                    <td style="color:#555; width:120px; font-weight:bold;">Patient ID</td>
                                    <td>:</td>
                                    <td><span id="LRD_RegNo"></span></td>
                                </tr>

                                <tr>
                                    <td colspan="3">
                                        <table style="width:100%;">
                                            <tr>
                                                <td style="color:#555; font-weight:bold; width:120px;">Name</td>
                                                <td>:</td>
                                                <td>
                                                    <table style="width:100%; border-collapse:collapse;">
                                                        <tr>
                                                            <td style="width:50%; text-align:left; font-weight:normal;">
                                                                <span id="LRD_PatientName"></span>
                                                            </td>
                                                            <td style="width:50%; text-align:right;">
                                                                <span style="color:#555; font-weight:bold;">Age-Gender</span> :
                                                                <span id="LRD_Age"></span>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="color:#555; font-weight:bold;">Contact No</td>
                                    <td>:</td>
                                    <td><span id="LRD_Contact"></span></td>
                                </tr>

                            </table>
                        </div>

                        <!-- RIGHT SIDE -->
                        <div style="flex:1; padding:12px 15px;">
                            <table style="width:100%; border-collapse:collapse; line-height:2.3;">
                                <tr>
                                    <td style="color:#555; width:140px; font-weight:bold;">Sample Id</td>
                                    <td>:</td>
                                    <td><span id="LRD_SampleId"></span></td>
                                </tr>
                                <tr>
                                    <td style="color:#555; font-weight:bold;">Collection Date</td>
                                    <td>:</td>
                                    <td><span id="LRD_CollDate"></span></td>
                                </tr>
                                <tr>
                                    <td style="color:#555; font-weight:bold;">Referred By</td>
                                    <td>:</td>
                                    <td><span id="LRD_Doctor"></span></td>
                                </tr>
                                @*<tr>
                                        <td style="color:#555; font-weight:bold;">Receiving Date</td>
                                        <td>:</td>
                                        <td><span id="LRD_RecvDate"></span></td>
                                    </tr>
                                    <tr>
                                        <td style="color:#555; font-weight:bold;">Reporting Date</td>
                                        <td>:</td>
                                        <td><span id="LRD_ReportDate"></span></td>
                                    </tr>*@
                            </table>
                        </div>

                    </div>

                    <!-- Report Label -->
                    <div style="text-align:center; border-top:1.5px solid #999; border-bottom:1.5px solid #999; padding:10px 0; font-weight:bold; letter-spacing:3px; font-size:17px; margin-top:10px;">
                        LABORATORY REPORT
                    </div>

                    <!-- Test Results Table - Increased font size, black color for Unit/Ref Range -->
                    <div style="max-height:450px; overflow-y:auto; margin-top:10px;">
                        <table style="width:100%; border-collapse:collapse; font-size:16px;" id="LRD_TestTable">
                            <thead>
                                <tr style="border-bottom:2px solid #ccc; background-color:#f8f8f8;">
                                    <th style="padding:12px 12px; text-align:left; font-weight:bold; width:38%; font-size:16px;">Test</th>
                                    <th style="padding:12px 12px; text-align:left; font-weight:bold; width:18%; font-size:16px;">Result</th>
                                    <th style="padding:12px 12px; text-align:left; font-weight:bold; width:12%; font-size:16px; color:#000;">Unit</th>
                                    <th style="padding:12px 12px; text-align:left; font-weight:bold; width:32%; font-size:16px; color:#000;">Reference Range</th>
                                </tr>
                            </thead>
                            <tbody id="LRD_TestBody">
                            </tbody>
                        </table>
                    </div>

                    <!-- Notes -->
                    <div id="LRD_Notes" style="font-size:15px; color:#333; padding:10px 0; font-weight:bold; min-height:30px; background-color:#f9f9f9; margin-top:10px; border-radius:4px;"></div>



                    <!-- Signature Row -->
                    <div style="display:flex; justify-content:space-between; padding:15px 40px 8px 40px; font-size:15px; font-weight:600; text-align:center; color:#333; gap:20px;">

                        <div style="flex:1; text-align:center;">
                            <div style="margin-bottom:6px; letter-spacing:1px; display:flex; align-items:center; justify-content:center; gap:8px;">
                                VERIFIED BY
                                <span id="LRD_VerifiedIcon"></span>  <!-- ✅ icon here -->
                            </div>
                            <div style="display:flex; gap:6px; justify-content:center; align-items:center;">
                                <select id="LRD_VerifiedBy" style="width:200px; height:38px; font-size:13px; font-weight:normal; padding:6px 8px; border:1px solid #ced4da; border-radius:4px;">
                                </select>
                                <button type="button" onclick="SaveVerifiedBy()" style="width:38px; height:38px; font-size:13px; font-weight:normal; padding:0; border:1px solid #007bff; border-radius:4px; background-color:#fff; color:#007bff; cursor:pointer;">OK</button>
                            </div>
                        </div>

                        <div style="flex:1; text-align:center;">
                            <div style="margin-bottom:6px; letter-spacing:1px; display:flex; align-items:center; justify-content:center; gap:8px;">
                                APPROVED BY
                                <span id="LRD_ApprovedIcon"></span>  <!-- ✅ icon here -->
                            </div>
                            <div style="display:flex; gap:6px; justify-content:center; align-items:center;">
                                <select id="LRD_LabIncharge" style="width:200px; height:38px; font-size:13px; font-weight:normal; padding:6px 8px; border:1px solid #ced4da; border-radius:4px;">
                                </select>
                                <button type="button" onclick="SaveApprovedBy()" style="width:38px; height:38px; font-size:13px; font-weight:normal; padding:0; border:1px solid #007bff; border-radius:4px; background-color:#fff; color:#007bff; cursor:pointer;">OK</button>
                            </div>
                        </div>

                    </div>
                </div>




            </div>
        </div>
    </div>
</div>

<!-- CSS for enhanced styling -->
<style>
    /* Table row styling */
    #LRD_TestBody tr {
        border-bottom: 0.5px solid #eee;
    }

    #LRD_TestBody td {
        padding: 10px 12px !important;
        font-size: 16px !important;
        line-height: 1.5 !important;
    }

        /* Test name column - bold */
        #LRD_TestBody td:first-child {
            font-weight: bold !important;
        }

        /* Unit and Reference Range columns - black color */
        #LRD_TestBody td:nth-child(3),
        #LRD_TestBody td:nth-child(4) {
            color: #000000 !important;
            font-weight: normal !important;
        }

        /* Result column styling */
        #LRD_TestBody td:nth-child(2) {
            font-weight: 600 !important;
        }

    /* Department header styling */
    #LRD_TestBody .lab-dept-header td {
        background-color: #e8e8e8 !important;
        font-weight: bold !important;
        font-size: 17px !important;
        letter-spacing: 1px !important;
        padding: 10px 12px !important;
        color: #000 !important;
    }

    /* Abnormal result highlighting - keep color but maintain size */
    #LRD_TestBody td[style*="color:#c0392b"],
    #LRD_TestBody td:has(> span[style*="color:#c0392b"]) {
        font-weight: bold !important;
        font-size: 16px !important;
    }

    /* Notes section styling */
    #LRD_Notes strong {
        font-size: 15px !important;
    }

    /* Scrollbar styling */
    #LRD_TestTable ~ div::-webkit-scrollbar,
    .modal-body div[style*="max-height"]::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    #LRD_TestTable ~ div::-webkit-scrollbar-track,
    .modal-body div[style*="max-height"]::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 4px;
    }

    #LRD_TestTable ~ div::-webkit-scrollbar-thumb,
    .modal-body div[style*="max-height"]::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 4px;
    }

        #LRD_TestTable ~ div::-webkit-scrollbar-thumb:hover,
        .modal-body div[style*="max-height"]::-webkit-scrollbar-thumb:hover {
            background: #555;
        }



    #LRD_TestTable,
    #LRD_TestBody td {
        font-size: 17px !important;
    }





    .modal-body > div:first-child {
        flex-direction: column !important;
    }

    #LRD_TestBody td {
        font-size: 13px !important;
        padding: 6px 8px !important;
    }
</style>
