<script>
    $(document).ready(function () {
        document.onkeydown = function (evt) {
            evt = evt || window.event;
            var isEscape = false;
            if ("key" in evt) {
                isEscape = (evt.key === "Escape" || evt.key === "Esc");
            } else {
                isEscape = (evt.keyCode === 27);
            }
            if (isEscape) {
                $('#HPatient').select()
                $('#HPatient').focus()

            }
        };
    });

</script>


<script>

    //function drchange() {
    //    var Dname = $("#HDoctor option:selected").text();
    //    $('#Doctorname').val(Dname)
    //}


    var doctorMode = 'dropdown'; 

    function drchange() {
        var Dname = $("#HDoctor option:selected").text();
        $('#Doctorname').val(Dname === '--Select--' ? '' : Dname);
    }

    function toggleDoctorMode() {
        if (doctorMode === 'dropdown') {
            // switch to manual
            doctorMode = 'manual';
            $('#HDoctor').hide();
            $('#HDoctorManual').show().focus();
            $('#iconDoctorMode').removeClass('fa-pencil').addClass('fa-list');
            $('#btnDoctorMode').attr('title', 'Switch to dropdown');
            $('#Doctorname').val(''); // clear hidden field
        } else {
            // switch back to dropdown
            doctorMode = 'dropdown';
            $('#HDoctorManual').hide().val('');
            $('#HDoctor').show();
            $('#iconDoctorMode').removeClass('fa-list').addClass('fa-pencil');
            $('#btnDoctorMode').attr('title', 'Switch to manual entry');
            // sync hidden field with current dropdown selection
            drchange();
        }
    }


    if ("@Request.QueryString["flag"]" == "bill") {
        debugger;
         setTimeout(function () {
             GetRows(0)
             SalesGetCall("@Request.QueryString["billser"]", "@Request.QueryString["billno"]", 1, 0);

        }, 1000);
    }

    function SpceialAmountCalc(Id) {

        var Cash = parseFloat($("#BAmount").val() || 0);
        var Upi = parseFloat($("#UPISpecialFeeAmt").val() || 0);
        var Card = parseFloat($("#SpecialFeeAmt").val() || 0);
        var Result = (Cash + Upi + Card);

        if (Result > parseFloat($('#TAmount').val())) {
            warningshow('Please Check payment amount', Result);
            $("#" + Id).val(0).select()

        }

    }



    function okamount() {
        var Cash = parseFloat($("#BAmount").val() || 0);
        var Upi = parseFloat($("#UPISpecialFeeAmt").val() || 0);
        var Card = parseFloat($("#SpecialFeeAmt").val() || 0);
        var Result = (Cash + Upi + Card);

        if (Result > parseFloat($('#TAmount').val())) {

            warningshow('Payment amount is not correct', Result);
            $('#SpecialFeeDiv').on('shown.bs.modal', function () {
                $('#SpecialFeeAmt').focus();

            })

        }
        else {
            $('#SpecialFeeDiv').modal('hide');
        }

    }


    function paymethodechange() {


        var Id = $('#PayType').val();

        $('#UPISpecialFeeAmt').val(0);
        $('#SpecialFeeAmt').val(0);
        $('#BAmount').val(0);
        if (Id == 2) {
            $('#TAmount').focus();
        }
        else {
            if (Id == 1) {
                $('#BAmount').val($("#BaseTextTotalProc").text());
                $('#BAmount').focus();

            }

            else if (Id == 3) {
                $('#UPISpecialFeeAmt').val($("#BaseTextTotalProc").text());
                $('#UPISpecialFeeAmt').focus();
            }
            else {
                $('#SpecialFeeAmt').val($("#BaseTextTotalProc").text());
                $('#SpecialFeeAmt').focus();

            }
        }

    }

    function ShowCreditBillGets() {
        if (!($('#PrescriptionModal1').is(':visible'))) {
            $("#PrescriptionModal1").modal("show");
            $("#PrescriptionModal1").appendTo("body");
            $('.tool_tip').tooltip({ trigger: 'manual' }).tooltip('hide');
        }
    }

    function CloseCreditBillGets() {
        $("#PrescriptionModal1").modal("hide");
    }


    function CreditBillGets() {

        var data = {};
        data.Patient = $('#HPatientId').val();
        data.RegNo = $("#HRegNo").val();
        data.OPVisit = $("#HOpNo").val();
        data.DeptId = $("#IPNumber").val();

        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_CreditBillGets",
            data: data,
            success: function (result) {
                LoadCreditBill(result.oList)
            }
        });
    }


    var creditbillllenths = 0
    function LoadCreditBill(result) {
        $('#tbl_IPGrid tr').remove();
        $("#GridLength").val(0);
        var balamount = result[0].Days;
        var Adamount = result[0].Status;


        if (balamount>0) {
            $('#btncreditbill').show();
            $('#ShowCreditBillPopUp').show();
        }
        else {
            $('#btncreditbill').hide();
            $('#ShowCreditBillPopUp').hide();
        }

        var totalpending = 0;
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

            var CashType = '';
            if (result[i].Status == '1') CashType = '<span class="badge badge-danger">Cash</span>';
            else if (result[i].Status == '2') CashType = '<span class="badge badge-success">Credit</span>';

            var BillNo = '';
            //  if (result[i].BillYear != 0) BillNo = result[i].BillYear;
            BillNo = result[i].BillNo;

            var id = slno;

            var ProdEditRow = "<tr class='jsgrid-row Billtr TotalBill' id='Brow_" + id + "'>" +
                '<td class= "jsgrid-cell jsgrid-align-center" style="width:2%"><input type="checkbox"  id="BillId_' + id + '"       onclick="SumChange(' + id + ')" data-toggle="tooltip" ></td>' +
                "<td id='BillSlNo_" + id + "' class='jsgrid-cell p-1 GridBRow'  style= 'width:30px;text-align:center' >" + id + "</td>" +
                "<td class='jsgrid-cell p-1 GridBRow' id='BillDate_" + id + "'  style= 'width:50px;' ><b>" + result[i].Date + "</b></td>" +
                "<td class='jsgrid-cell p-1 GridBRow' id='BillNo_" + id + "' style= 'width:15%;text-align:center;' ><b>" + BillNo + "</b></td>" +
                "<td id='Dept_" + id + "' class='jsgrid-cell p-1 GridBRow'  style= 'width:15%;text-align:center' ><b>" + result[i].Department + "</b></td>" +
                "<td class='jsgrid-cell p-1 GridBRow' id='CashType_" + id + "'  style= 'width:50px;' align=center>" + CashType + "</td>" +
                "<td class='jsgrid-cell p-1 GridBRow' id='AmountTr_" + id + "'  style= 'width:50px;' align=center ><b>" + parseFloat(result[i].Amount || 0).toFixed(Decimal) + "</b></td>" +
                //"<td class='jsgrid-cell p-1 GridBRow' id='AmountCTr1_" + id + "'  style= 'width:50px;' align=right >" +
                //"<input type='text' id='cash_" + id + "' class='form-control GridTextBox' onkeypress='isNumber(event,this)' onkeyup='CalcAmount(this.id," + id + ")' value='' /></td>" +
                //"<td class='jsgrid-cell p-1 GridBRow' id='AmountCTr2_" + id + "'  style= 'width:50px;' align=right >" +
                //"<input type='text' id='Upi_" + id + "' class='form-control GridTextBox' onkeypress='isNumber(event,this)' onkeyup='CalcAmount(this.id," + id + ")' value='' /></td>" +
                //"<td class='jsgrid-cell p-1 GridBRow' id='AmountCTr3_" + id + "'  style= 'width:50px;' align=right >" +
                //"<input type='text' id='Card_" + id + "' class='form-control GridTextBox' onkeypress='isNumber(event,this)' onkeyup='CalcAmount(this.id," + id + ")' value='' />" +
                "</td>" +
                "</tr>";

            totalpending = totalpending + parseFloat(result[i].Amount || 0)
            $('#tbl_IPGrid').append(ProdEditRow);


        }

        creditbillllenths = result.length;


        $('#cctotal').html('');;
        $('#cctotal').append('<span style=color:red>Total Bill Amount :&#160;&#160;&#160;' + totalpending.toFixed(Decimal) + '&#160;&#160;&#160;  Total Advance :&#160;&#160;&#160;' + Adamount + ' &#160;&#160;&#160; Total Pending :&#160;&#160;&#160;' + (balamount).toFixed(2) + '</span>');
        $("#GridLength").val(id);
        $('#proddiv').animate({ scrollTop: 5000 }, 900);
    }

    var Selectamt = 0;
    function SumChange(Id) {
        if ($('#BillId_' + Id).prop('checked') == true) {
            Selectamt = Selectamt + parseFloat($('#AmountTr_' + Id).text() || 0);
            $('#cash_' + Id).val(parseFloat($('#AmountTr_' + Id).text() || 0))
        }
        else {
            Selectamt = Selectamt - parseFloat($('#AmountTr_' + Id).text() || 0);
            $('#cash_' + Id).val(0)
        }

        if (Selectamt == 0) {
            $('#cctotalselect').text('');
        }
        else {
            $('#cctotalselect').text('Selected Bill Amount  :' + Selectamt)
        }

    }

    function SelectAllcbills() {

        if ($('#SlNoHeadCheck').prop('checked') == true) {
            for (var a = 1; a <= creditbillllenths; a++) {
                $('#BillId_' + a).prop('checked') == true
                SumChange(a)
            }
        }
        else {
            for (var a = 1; a <= creditbillllenths; a++) {
                $('#BillId_' + a).prop('checked') == false
                SumChange(a)
            }

        }

    }



    function AddCreditBill(id) {
        window.open('../AccountsErp/PDCReceived?pid=' + $('#HPatientId').val() + '&Preg=' + $('#HRegNowithseries').val());
    }



    function AddCreditBill1(id) {

        var oArray = new Array();

        for (var i = 1; i <= creditbillllenths; i++) {
            if ($("#BillId_" + i).is(":checked")) {
                oArray.push({
                    'BillId': $("#BillSlNo_" + i).text(),
                    'BillNo': $("#BillNo_" + i).text(),
                    'BillType': $("#Dept_" + i).text(),
                    'PatientId': $("#HPatientId").val(),
                    'Cash': $("#cash_" + i).val(),
                    'UPI': $("#Upi_" + i).val(),
                    'Card': $("#Card_" + i).val()
                })
            }
            else {
                warningshow('Please Check Payment Amount');
            }
        }


        if (oArray != "") {
            var data = { 'IPStatement': oArray };

            $.ajax({
                type: "POST",
                url: "../Revisit/CreditBillInsertandUpdate",
                data: data,
                success: function (result) {
                    var status = result.oList[0].Status;
                    var BillNo = result.oList[0].BillNo;
                    Alerts(status, BillNo);
                    $("#PrescriptionModal1").modal("hide");
                    $('#btncreditbill').hide();
                    $('#ShowCreditBillPopUp').hide();
                }
            });
        }

    }

    function CalcAmount(id, u) {

        var Cash = parseFloat($("#cash_" + u).val() || 0);
        var Upi = parseFloat($("#Upi_" + u).val() || 0);
        var Card = parseFloat($("#Card_" + u).val() || 0);
        var Result = (Cash + Upi + Card);

        if (Result > parseFloat($('#AmountTr_' + u).text())) {
            warningshow('Please Check payment amount', Result);
            $("#" + id).val(0).select();

        }

    }

    function Alerts(Status) {

        if (Status == 1) {
            swal('', 'Credit Bill Paid Successfully', "success");
            $('.swal-button swal-button--confirm').focus();
        }

    }


</script>

<script>


    GetItemGroup()
    function GetItemGroup() {
        var data = {};
        data.GroupId = 0;
        $.ajax({
            type: "POST",
            url: "../ItemMapping/ItemGroupGetandGets",
            data: data,
            success: function (result) {
                Loadgroup(result.oList);
            }
        });
    }

    function Loadgroup(result) {
        $("#Itemgroup1").empty();
        var group = "<option value=0> -template- </option>";
        for (var i = 0; i < result.length; i++) {
            group += "<option value='" + result[i].GroupId + "'>" + result[i].GroupName + "</option>";
        }
        $("#Itemgroup1").append(group);
    }


    function GetItemGroupload() {

        if (parseInt($("#HLocation").val() || 0) != 0) {
            var data = {};
            data.Status = 0;
            data.HLocation = $("#HLocation").val();
            data.DeptId = $('#Itemgroup1').val();
            $.ajax({
                type: "POST",
                url: "../Hospital/HMS_SalesPrescriptionGets",
                data: data,
                success: function (result) {
                    if (result.oList.length > 0) {
                        PopUpClose(2)
                        PrescriptionLoad(result.oList);
                    }
                }
            });
        }
        else {
            warningshow('Please Select Location', 'HLocation');
        }



    }



</script>

<script>

    function adjust(color, amount) {
        return '#' + color.replace(/^#/, '').replace(/../g, color => ('0' + Math.min(255, Math.max(0, parseInt(color, 16) + amount)).toString(16)).substr(-2));
    }

    function DynamicColor() {
        var BGmainclr = '#009da0';  //#9d05a4   #008184
        var Txmainclr = 'white';
        var Sbmainclr = '#E0F3F4'; //#9d05a436    #00818429
        var SbTextclr = 'black';

        var Shadowclr = 'lightgrey';
        try {
            Shadowclr = adjust(BGmainclr, 80);
        }
        catch (err) {
            Shadowclr = 'lightgrey';
        }

        var sheet = document.createElement('style')
        sheet.innerHTML = ".FormHeadClr,.bg-primary {background-color: " + BGmainclr +
            " !important; color:" + Txmainclr + "} .btn-primary {background-color: " + BGmainclr +
            " !important;border-color: " + BGmainclr + " !important; color: " + Txmainclr + " !important;}  " +
            " .btn-primary:not(:disabled):not(.disabled):active:focus, .btn-primary:not(:disabled):not(.disabled).active:focus, " +
            " .show > .btn-primary.dropdown-toggle:focus { box-shadow: 0 0 0 0.2rem " + BGmainclr + " !important;} " +
            " .btn-outline-primary {border-color: " + BGmainclr + " !important; color:" + BGmainclr + " !important; } " +
            ".btn-outline-primary:hover { background-color: " + BGmainclr + " !important; border-color: " + BGmainclr + " !important;} .btn-outline-primary:not(:disabled):not(.disabled):active," +
            " .btn-outline-primary:not(:disabled):not(.disabled).active, .show > .btn-outline-primary.dropdown-toggle { background-color: " + BGmainclr + " !important; }" +
            ".btn-outline-primary:focus {  color: " + BGmainclr + " !important; }" +
            ".btn-primary.disabled, .btn-primary:disabled {background-color: " + BGmainclr + " !important ;border-color: " + BGmainclr + " !important; }" +
            ".SubDivClr{background-color: " + Sbmainclr + "!important; color:" + SbTextclr + "!important;}.SubDivClr label{color:" + SbTextclr + "!important;}" +
            " .btn-primary:focus, .btn-primary.focus { box-shadow: 0 0 0 0.1rem " + Shadowclr + " !important } " +
            "";

        console.log(sheet)
        document.body.appendChild(sheet);

    }

    function Showprescription() {

        var data = {};
        data.RegSeries = 1//$("#HBillSeries").val();
        data.PRegNo = $('#HRegNo').val();
        data.RevisitId = $('#HOpNo').val();
        data.DelFlag = 1;
        data.Status = 'OP';
        $.ajax({
            type: "POST",
            url: "../Hospital/HMS_CaseSheetMedicineGets",
            data: data,
            success: function (result) {

                AddMedicineList(result.oList)

            }
        });
    }

    var medadv = 0
    function AddMedicineList(result)      //flg-0 : Add Medicine during List
    {

        $('#TblMedicineadv').html('');
        var MedRow = '<tr class="jsgrid-header-row"><th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 4%;">SL#</th><th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 30%;">Medicine</th><th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 15%;">Notes</th><th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 15%;">Qty</th><th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 10%;">Dosage</th><th class="jsgrid-header-cell jsgrid-align-right jsgrid-header-sortable" style="width: 10%;">Days</th></tr>';
        medadv = result.length;
        for (var i = 0; i < result.length; i++) {

            MedRow += '<tr  class="jsgrid-header-row Mrow">' +
                '<td class="jsgrid-align-center" style="width: 5%;">' + parseInt(i + 1) + '</td>' +
                '<td id="PMedicine_' + parseInt(i + 1) + '" class="" style="width: 30%;">' + result[i].Medicine + '</td>' +
                '<td id="PMedicinenote_' + parseInt(i + 1) + '" class="" style="width: 20%;">' + result[i].Mednotes + '</td>' +
                '<td id="PMedicinedaily_' + parseInt(i + 1) + '" class="" align=center style="width: 10%;">' + result[i].Daily + '</td>' +
                '<td id="PDosage_' + parseInt(i + 1) + '" class="" align=center style="width: 10%;">' + result[i].Dosage + '</td>' +
                '<td id="PDays_' + parseInt(i + 1) + '" class="" align=center style="width: 10%;">' + result[i].Days + ' </td>' +
                /* '<td id="PMedicinetot_' + parseInt(i + 1) + '" class="" align=center style="width: 10%;">' + parseInt(result[i].Days || 0) * parseInt(result[i].Daily || 0) + ' </td>' +*/
                '</tr>';
        }
        $('#TblMedicineadv').append(MedRow);
        $("#medSpliPopup").modal("show");
        $("#medSpliPopup").appendTo("body");
    }




</script>


