    function adddoctor(A) {
        $('#doctorentrydiv').modal('show');
        $('#doctorentrydiv').appendTo('body');
        $('#Doctorname').focus();
    }


    function doctorsave() {

        if ($('#Doctorname').val() == '') {
            warningshow('Please Enter Doctor Name');
        }
        else {
            $('#doctorentrydiv').modal('hide')

            var data = {};   //array
            data.Active = 1;
            data.Name = $.trim($('#Doctorname').val());
            data.MobileNumber = $.trim($('#doctormobile').val());
            data.Address1 = $('#doctoraddress').val();
            data.Doctor_UserId = ERPUserId
            data.DelFlag = 1;
            data.MainDept = ERPDeptId;

            $.ajax({
                type: "POST",
                url: "../Master/DoctorInsertandUpdate",
                data: data,
                success: function (result) {

                    $('#Doctorname').val('');
                    $('#doctormobile').val('');
                    $('#doctormobile').val('');


                    var DoctorId = result.oList[0].DoctorsId
                    DoctorLoad(DoctorId)

                }
            });
        }
    }


</script>