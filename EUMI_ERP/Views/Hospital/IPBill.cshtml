<script>

    SelectPayType()
    function SelectPayType() {
        if (SalesPayType == 'Credit') {
            $('#PayType').val(2);
        }
        else if (SalesPayType == 'UPI Pay') {
            $('#PayType').val(3);
        }
        else if (SalesPayType == 'Card Pay') {
            $('#PayType').val(4);
        }
        else {
            $('#PayType').val(1);
        }
    }

    function paytypechange() {
      
        var py = $('#PayType').val();
        var Amt = parseFloat($('#GrandTotal').text()).toFixed(2)
        $('#paycash').val(0); $('#payupi').val(0); $('#paycard').val(0)
        if (py == 1) { $('#paycash').val(Amt)    }
        else if (py == 3) { $('#payupi').val(Amt)     }
        else if (py == 4) { $('#paycard').val(Amt)    }
    }


    function partpayenable() {

        let checkbox = document.getElementById("paydis");      
        if (checkbox.checked) {
            $("#paycash").removeAttr("disabled");
            $("#payupi").removeAttr("disabled");
            $("#paycard").removeAttr("disabled");
        }
        else {
            $("#paycash").attr("disabled", "disabled");
            $("#payupi").attr("disabled", "disabled");
            $("#paycard").attr("disabled", "disabled");
        }
    }


    function paymentamountcalcul(ID) {
        var a=  parseFloat($('#paycash').val() ||0)
        var b = parseFloat($('#payupi').val()||0)
        var c = parseFloat($('#paycard').val() || 0)
        var Amt = parseFloat($('#GrandTotal').text()).toFixed(2)
        var Tot = parseFloat(a + b + c)
        if (Tot > Amt) {
            warningshow('Received Amount must be Equal Bill Amount', 'paycash' + ID);
            $('#' + ID).val(0).select();
        }
    }

   
    function ShowcasualityPrescription() {

        $('#casualityInfoPopUp').hide();
        var data = {};
        data.OpNo = $('#OpNo').val();;
        data.RegNo = $('#RegNo').val();
        data.RegSeries = 1;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_CasualityAdviceGets",
            data: data,
            success: function (result) {
                debugger;
                console.log(result.oList)
                if (result.oList.length > 0) {
                    $('.TsRw').remove();var Qr=""
                    for (var i = 0; i <= result.oList.length; i++) {

                        Qr = (result.oList[i].TestName).split("##")
                        $('#TestName0').val(Qr[0])
                        $('#TestCode0').val(Qr[1])

                        $('#TestId0').val(result.oList[i].TestId);
                        $('#PQty0').val(parseInt(result.oList[i].Department || 1));
                        $('#PRate0').val(result.oList[i].PRate);
                        AmountCalc(0)
                        AddTestConfirmtransfer();
                    }

                }
                $('#proddiv').animate({ scrollTop: 1000 }, 900);

            }
        });
    }




    function Gettestadviceget(OPNumber, OPSerId, RevisitId) {

        $('#casualityInfoPopUp').hide();
        var data = {};
        data.OpNo = RevisitId;
        data.RegNo = OPNumber;
        data.RegSeries = OPSerId;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_CasualityAdviceGets",
            data: data,
            success: function (result) {
                if (result.oList.length > 0) {
                   // $('#casualityInfoPopUp').show();
                }
            }
        });
    }

    function AddTestConfirmtransfer() {
        var Amt = parseFloat($('#PRate0').val());
        Amt = isNaN(Amt) ? 0 : Amt;

        if ($('.TsRw').length == 0) { Count = 0; }

        Count++; SlNum = $('.TsRw').length + 1;

        var id = parseInt(Count);
        var slno = parseInt(SlNum);

        var ProdRow1 = "<tr id=" + 'Row' + id + " class='jsgrid-row TsRw' onclick='EditRow(" + id + ")' onfocusout=updaterow(" + id + ")>" +
            "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' style='width:5%'><input class='jsgrid-button jsgrid-delete-button jsgrid-align-center' type='button' onclick='rowdelete(" + id + ")' title='Delete'></td>" +
            "<td class='jsgrid-cell' style='width:5%;text-align:center' id='slrow" + id + "'>" + slno + "</td>" +
            "<td class='jsgrid-cell jsgrid-align-left' style='width:20%'><input type='text' id='TestName" + id + "' value='" + $('#TestName0').val() + "'  class='form-control TestName' style='height:30px' ></td>" +
            "<td class='jsgrid-cell jsgrid-align-left' style='width:40%'><input type='text' readonly id='TestCode" + id + "' value='" + $('#TestCode0').val() + "' class='form-control' style='height:30px;background-color:white' ></td>" +
            "<td class='jsgrid-cell jsgrid-align-center' style='width:5%'><input id='PQty" + id + "' class='form-control text-center PQty cmdts' value='" + $('#PQty0').val() + "' style='height:30px' onkeydown=FocusManual('PQty','TestName'," + id + ",event) onkeyup=AmountCalc(" + id + ") onkeypress=isNumberInt(event,this)></td>" +
            "<td class='jsgrid-cell jsgrid-align-center' style='width:12%'><input id='PRate" + id + "' value=" + parseFloat(Amt).toFixed(Decimal) + " class='form-control text-center PRate cmdts' style='height:30px' onkeyup=AmountCalc(" + id + ") onkeypress=isNumber(event,this) onkeydown=FocusManual('PRate','TestName'," + id + ",event)></td>" +
            "<td class='jsgrid-cell jsgrid-align-center' style='width:12%'><input type='text' readonly id='TestAmount" + id + "'  value='" + $('#TestAmount0').val() + "'  onkeydown=FocusManual('TestAmount','TestName'," + id + ",event)   class='form-control text-center TestAmount cmdts' style='height:30px;background-color:white' onkeypress='isNumber(event,this)'></td>" +
            "<td style=display:none><input type='text' id='TestId" + id + "' value=" + $('#TestId0').val() + " class='form-control prmkey'></td>" +
            "</tr>";
        $('#TblLabBill').append(ProdRow1);
        $('.jsgrid-cell> input,.jsgrid-cell >select').css('border', 'none').css('border', 'none');
        $('#Department' + id).val($('#Department0').val());
        ClearData(1, 0);
        $('#TestName0').val('').focus();
        CalcGrandTotal(1);
    }


