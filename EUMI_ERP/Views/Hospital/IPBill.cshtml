<script>


    function addautobill() {
        var rowCount = $('#tblautobillList tr').length;       
        var tname = '', procid = 0, days = 0, rate = 0, bdate = ''    

        var B = ddhiabc;
      
        for (var a = B; a <= rowCount-2; a++) {
            bdate = $('#BillDate').val();
            tname = $('#Ippname' + a).text(), procid = $('#IppId' + a).val(), days = parseInt($('#Ippdays' + a).val() || 1), rate = parseFloat(($('#Ippprate' + a).text() || 0) / days)
           
            $('#TestName0').val(bdate)
            $('#TestCode0').val(tname.split("*")[0])
            $('#TestId0').val(procid);
            $('#PQty0').val(parseInt(days || 1));
            $('#PRate0').val(rate);
            AmountCalc(0)
            AddTestConfirmtransfer();

        }
        ngOnDestroyad()
       
    }


    function ngOnDestroyad() {
        $("#myModaladvance").modal("hide");
    }

    function advanceandotherinfoshow() {
        var adamount = parseFloat($('#Advamount').val() || 0)
        if (adamount == 0) {
           // warningshow('No Advance paid', '');
            $("#myModaladvance").modal("show");
            $("#myModaladvance").appendTo("body");
        }
        else {
            $("#myModaladvance").modal("show");
            $("#myModaladvance").appendTo("body");

        }
    }


</script>

