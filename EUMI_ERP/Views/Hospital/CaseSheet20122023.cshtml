<script>


    function transfertootherdoctor() {
        $("#myModaltransfer").modal("show");
        $("#myModaltransfer").appendTo("body");
        DoctorLoad();
        $('#tRegNumber').val($('#PRegNo').val())
        $('#tPatName').val($('#PatientName').val())
    }



    function DoctorLoad() {
        var Feeduration = 0;
        var data = {};                                       //dropdownbind
        data.DoctorId = 0;
        data.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_RevistDoctorGets",
            data: data,
            success: function (result) {
                if (result.oList.length > 0) {
                    $("#tDocName").empty()
                    $("#tDocName").append("<option value='0' Fee='0'>--Select--</option>");
                    for (var i = 0; i < result.oList.length; i++) {
                        Feeduration = parseInt(result.oList[i].Status || 0);
                        $("#tDocName").append("<option value='" + result.oList[i].DoctorId + "'  Feedur='" + Feeduration + "'   Fee='" + result.oList[i].ConsultFees + "'>" + result.oList[i].DoctorName + "</option>");
                    }

                }
            }
        });
    }


    function ChangeFee() {
        var data = {};
        data.DoctorId = $("#tDocName").val();
        data.PatientId = $("#PatientId").val();
        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_DoctorFeegets",
            data: data,
            success: function (result) {
                $("#tConsultationFees").val(result.oList[0].ConsultFees)
                //$('#PatLastVisitdayes').text(result.oList[0].FromDate + '-' + result.oList[0].ToDate)

            }
        });
    }


    function Transferaptient() {
        if ($("#tDocName").val() == 0) {

            warningshow('Please Select Doctor', 'tDocName');
        }
        else {

            var data = {};
            data.RegSeries = $('#RegSeries').val();
            data.PRegNo = $('#PRegNo').val();
            data.PatientId = $("#PatientId").val();
            data.DoctorId = $("#tDocName").val();
            data.VisitFees = parseFloat($("#tConsultationFees").val() || 0);
            data.RevisitDate = $('#CaseDate').val();
            data.RevisitId = $('#PatientOP').text();
            data.UserId = ERPUserId;
            data.DeptId = ERPDeptId;


            $.ajax({
                type: "POST",
                url: "../Revisit/Refertootherdoctor",
                data: data,
                success: function (result) {

