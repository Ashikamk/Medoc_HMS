<script>



    function LoadMedicine(Id) {
        $("#Medicine" + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                $("#MedicineId" + Id).val('');
                var data = {};
                data.ItemCode = $("#Medicine" + Id).val();
                data.SlNumber = 0;
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                $.ajax({
                    url: '../Pharmacy/HMS_PurchaseProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2ph',
                                label: item.Description,
                                //label1: item.ItemCode,
                                label1: item.Group,
                                label2: item.Category,

                                ItemId: item.ItemId,
                                headers: ["Name", "Company", "Type"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $("#MedicineId" + Id).val(ui.item.ItemId);
                $('#Daily' + Id).focus().select();
            },
        }).on('keydown', function (e) {
            if ((e.which == 13) && (($('#MedicineId' + Id).val() || 0) != 0)) {
                $('#Daily' + Id).focus().select();
            }
            else if ((e.which == 39) && (($('#Medicine' + Id).val()) == '')) {
                $('#Daily' + Id).focus().select();
            }
            else if ((e.which == 37) && (($('#Medicine' + Id).val()) == '')) {
                $('#Days' + Id).focus().select();
            }
        });
    }


    function LoadMedicinePrev(Id) {
        $("#PMedicine_" + Id).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                $("#PMedicineId_" + Id).val(0);
                var data = {};
                data.ItemCode = $("#PMedicine_" + Id).val();
                data.SlNumber = 0;
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                $.ajax({
                    url: '../Pharmacy/HMS_PurchaseProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2ph',
                                label: item.Description,
                                //label1: item.ItemCode,
                                label1: item.Group,
                                label2: item.Category,

                                ItemId: item.ItemId,
                                headers: ["Name", "Company", "Type"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $("#PMedicineId_" + Id).val(ui.item.ItemId);
                $('#PDaily_' + Id).focus().select();
            },
        }).on('keydown', function (e) {
            if ((e.which == 13) && (($('#PMedicine_' + Id).val() || 0) != 0)) {
                $('#PDaily_' + Id).focus().select();
            }
            else if ((e.which == 39) && (($('#PMedicine_' + Id).val()) == '')) {
                $('#PDaily_' + Id).focus().select();
            }
            else if ((e.which == 37) && (($('#PMedicine_' + Id).val()) == '')) {
                $('#PDays_' + Id).focus().select();
            }
        });
    }

    function LoadVaccine(Medicine,MedicineId,CompanyId)
    {
        $("#" + Medicine).autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                $("#" + MedicineId).val(0);
                $("#" + CompanyId).val(0);
                var data = {};
                data.ItemCode = $("#" + Medicine).val();
                data.SlNumber = 0;
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                $.ajax({
                    url: '../Pharmacy/HMS_PurchaseProductSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-2ph',
                                label: item.Description,
                                //label1: item.ItemCode,
                                label1: item.Group,
                                label2: item.Category,
                                GrpId:item.GrpId,
                                ItemId: item.ItemId,
                                headers: ["Name", "Company", "Type"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $("#" + MedicineId).val(ui.item.ItemId);
                $("#" + CompanyId).val(ui.item.GrpId);
                $('#' + CompanyId).focus().select();
            },
        }).on('keydown', function (e) {
            if ((e.which == 13 || e.which == 39) && (($('#' + MedicineId).val() || 0) != 0)) {
                e.preventDefault();
                $('#' + CompanyId).focus().select();
            }

        });
    }


    if (("@Request.QueryString["from"]" == "OPWorkSheet_D")) {

        var PatientId = sessionStorage.getItem("PatientId");

        $('#PatientId').val(PatientId);

        sessionStorage.removeItem("PatientId");

        GetLastRevisitDetails(PatientId);
        window.setTimeout(function () {
            $("#Complaint").focus().select();
        }, 1000);
    }
</script>

