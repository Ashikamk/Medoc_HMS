<script>

    function billtorerturn() {
        console.log(globalResult);
        var result = globalResult;
        '<table class="jsgrid-table"><thead><tr class="jsgrid-header-row">' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:2%"><i class="icon-trash"></i></th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:3%">SL#</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:13%">Name</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Batch</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%; display:none;">Company</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Expiry</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Qty</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%; display:none;">Free</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Sell. Rate</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:4%">MRP</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:8%">Disc % / Disc Amt.</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:6%">Tax/Tax%</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Taxable Amt</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Tax Amt</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Cess</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Amount</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Drug Sch.</th>' +
            '<th class="jsgrid-header-cell jsgrid-align-center" style="display:none">None</th>' +
            '</tr></thead><tbody>';

        for (var l = 0; l < result.length; l++) {
            var checkboxId = 'SlNoCheckSImainItem' + (l + 1);
            if ($('#' + checkboxId).is(':checked')) {
                $('#Product0').val(result[l].ProductCode);
                $('#ProductDesc0').val(result[l].Batch);
                $('#Company0').val('');
                $('#Expiry0').val(result[l].Expiry);
                $('#Quantity0').val(parseInt(result[l].ProdQty));
                $('#Free0').val('');
                $('#SellPrice0').val(parseFloat(result[l].ProdRate).toFixed(Decimal));
                $('#PurPrice0').val(parseFloat(result[l].mrp).toFixed(Decimal));
                $('#DiscountPerc0').val(result[l].ProdDiscPercent);
                $('#Discount0').val(parseFloat(result[l].ProdDisc).toFixed(Decimal));
                $('#TaxableAmt0').val(result[l].TaxableAmount);
                $('#TaxAmt0').val(result[l].TaxAmount);
                $('#CessAmount0').val(result[l].CessAmount);
                $('#Amount0').val(result[l].Amount);
                $('#DrugSchedule0').val(result[l].DrugSchedule);
                $('#ProductId0').val(result[l].ProductId);
                $('#BatchSlNo0').val(result[l].BatchSlNo);
                $('#Cess0').val(result[l].Cess);
                $('#PHSNCode0').val(result[l].PHSNCode);
                $('#Tax0').val(result[l].TaxId);
                AddProduct();
            }

        }
        $('#Enquirypopup').hide()

    }

    function Close() {
        $('#Enquirypopup').hide()
    }

    //Close Enquiry PopUP
    function CloseEnquiry() {
        disabletables();
        $('#SalesInvdiv').hide();
        $('#SalesInvdivcust').hide();
        $('#SalesInvdivsub').hide();
        $('#Enquirypopup').hide();
        $('#Qtndiv').hide();
        $('#RowGet7').val(0);
        $('#RowGet8').val(0);
        $('#RowGet9').val(0);
        $('#rowcnt').val(0);
        $('#Warningpopup').fadeOut();
        Location = ''; Location1 = '';
        sino = ''; sisno = '';

        $('#SearchCustsi').val('')
        $('#hiddencustIdsi').val(0);
        $('#SearchFromdatesi').val(CurDate);
        $('#SearchToDatesi').val(CurDate);

        $('#SearchFromdatesi1').val(CurDate);
        $('#SearchToDatesi1').val(CurDate);

        $('#SearchProdsi').val('')
        $('#hiddenProdIdsi').val('');


        if (($('#txtcrncyrate').val() == 1 || $('#GrandTotal').val() <= 0)) {
            $("#fc").css("opacity", '0');
        }
        else {
            $("#fc").css("opacity", '100');
        }

    }

</script>












