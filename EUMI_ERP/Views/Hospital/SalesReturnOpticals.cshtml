<script>
    $(document).ready(function () {
        document.onkeydown = function (evt) {
            evt = evt || window.event;
            var isEscape = false;
            if ("key" in evt) {
                isEscape = (evt.key === "Escape" || evt.key === "Esc");
            } else {
                isEscape = (evt.keyCode === 27);
            }
            if (isEscape) {
                $('#HPatient').select()
                $('#HPatient').focus()

            }
        };



        $('#HPatient').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                if ($('#HPatient').val() != '') {
                    if ($('#HRegNo').val() == '') {
                        $('#HDoctor').val(1);
                    }
                    $('#HDoctor').focus();
                }
            }
        });


        $('#HDoctor').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Remarks').focus();

            }
        });


        $('#select_salesman').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#Remarks').focus().select();
            }
        });



        $('#Remarks').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus().select();
            }
        });




        $("#select_transfer").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                var data = {};
                data.BillSlNo = $("#select_transfer").val();
                data.BillSeriesId = 0;
                data.LocId = $("#HLocation").val();
                data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../SalesInvoice/SerialNoSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'sl4',
                                label: item.BillSlNo,
                                label1: item.CustName,
                                label2: item.DepartmentName + '-' + item.BillDescription,
                                label3: item.InvDate,
                                billsl: item.BillSlNo,
                                billseries: item.BillSeriesId,
                                DepartmentCode: item.DepartmentName,
                                DeptId: item.DeptId,
                                headers: ["Bill No", "Customer Name", "Department-Billseries"]
                            })
                        }));
                    }
                })

            },
            autoFocus: true,
            select: function (event, ui) {
                $('#Transferdeptid').val(ui.item.DeptId);
                $('#Transferbillseries').val(ui.item.billseries);
                $('#select_transfer').val(ui.item.billsl);
                Transfer();
            },

        });




    });


    function Transfer() {
        //disabletables();
