    function GetPrintTypes(BillType,PrintType,SelectBox) {
       
        var data = {};
        data.BillType = BillType;
        data.PrintType = PrintType;
        data.Id = 0;
        data.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../Company/PrintTypeGets",
            data: data,
            success: function (result) {
                PrintTypeGets(result.oList, SelectBox);


            }
        });
    }

    function PrintTypeGets(result, SelectBox) {
        $("#" + SelectBox).empty();
        var PrintType = "";
        for (var i = 0; i < result.length; i++) {
            PrintType += "<option value='" + result[i].PrintId + "'>" + result[i].PrintFormat + "</option>";
        }
        $("#" + SelectBox).append(PrintType);

    }

    function SaveAndUpdatePrint() {
        
        if ($("#SalesPrint").val() == 0 || $("#SalesPrint").val() == '' || $("#SalesPrint").val() == null || $("#SalesPrint").val() == undefined)
        {
            warningshow('Select Sales Print', 'SalesPrint');
            return false;
        }
        else if ($("#SalesReturnPrint").val() == 0 || $("#SalesReturnPrint").val() == '' || $("#SalesReturnPrint").val() == null || $("#SalesReturnPrint").val() == undefined) {
            warningshow('Select Sales Return Print', 'SalesReturnPrint');
            return false;
        }
        else if ($("#VoucherPrint").val() == 0 || $("#VoucherPrint").val() == '' || $("#VoucherPrint").val() == null || $("#VoucherPrint").val() == undefined) {
            warningshow('Select Voucher Print', 'VoucherPrint');
            return false;
        }
        else if ($("#QuotationPrint").val() == 0 || $("#QuotationPrint").val() == '' || $("#QuotationPrint").val() == null || $("#QuotationPrint").val() == undefined) {
            warningshow('Select Quotation Print', 'QuotationPrint');
            return false;
        }
        else if ($("#LabBillPrint").val() == 0 || $("#LabBillPrint").val() == '' || $("#LabBillPrint").val() == null || $("#LabBillPrint").val() == undefined) {
            warningshow('Select Lab Bill Print', 'LabBillPrint');
            return false;
        }
        else if ($("#IPBillPrint").val() == 0 || $("#IPBillPrint").val() == '' || $("#IPBillPrint").val() == null || $("#IPBillPrint").val() == undefined) {
            warningshow('Select IP Bill Print', 'IPBillPrint');
            return false;
        }
        else if ($("#DischargePrint").val() == 0 || $("#DischargePrint").val() == '' || $("#DischargePrint").val() == null || $("#DischargePrint").val() == undefined) {
            warningshow('Select Discharge Print', 'DischargePrint');
            return false;
        }
        else if ($("#PrintColor").val() == 0 || $("#PrintColor").val() == '' || $("#PrintColor").val() == null || $("#PrintColor").val() == undefined) {
            warningshow('Select Print Color', 'PrintColor');
            return false;
        }
        else {

            var data = {};
            data.SalesPrintId = $("#SalesPrint").val();
            data.SalesReturnPrintId = $("#SalesReturnPrint").val();
            data.VoucherPrintId = $("#VoucherPrint").val();
            data.QuotationPrintId = $("#QuotationPrint").val();
            data.PrintColor = '#' + $('#PrintColor').val();
            data.DeptId = $('#dept').val();
            data.LabBillId = $("#LabBillPrint").val();
            data.IPBillId = $("#IPBillPrint").val();
            data.DischargePrintId = $("#DischargePrint").val();
            $.ajax({
                type: "POST",
                url: "../Company/CompanyPrintInsertandUpdate",
                data: data,
                success: function (result) {
                    var status = result.oList[0].Status;                 
                    //Showalerts(status);
                    swal('Data Updated Successfully', "", "success");
                    $('.swal-button swal-button--confirm').focus();

                }
            });
        }
    }

    function PrintDefaultTypeGets(result, SelectBox) {

        $("#" + SelectBox).empty();
        var PrintType = "";
        var DefaultPrint = 0;
        for (var i = 0; i < result.length; i++) {
            DefaultPrint = result[i].SalesPrintId;
            PrintType += "<option value='" + result[i].PrintId + "'>" + result[i].PrintFormat + "</option>";
        }
        $("#" + SelectBox).append(PrintType);
        $("#" + SelectBox).val(DefaultPrint);

        if(SelectBox=='SalesPrint'){
            if(result[0].PrintType=='Lazor')
            {
                $("#saleslazor").prop("checked", true);
                $("#salesdotmatrix").prop("checked", false);
            }
            else{
                $("#salesdotmatrix").prop("checked", true);
                $("#saleslazor").prop("checked", false);
            }
        }
        else if(SelectBox=='SalesReturnPrint'){
            if(result[0].PrintType=='Lazor')
            {
                $("#salesreturnlazor").prop("checked", true);
                $("#salesreturndotmatrix").prop("checked", false);
            }
            else{
                $("#salesreturndotmatrix").prop("checked", true);
                $("#salesreturnlazor").prop("checked", false);
            }
        }
        else if (SelectBox == 'LabBillPrint') {
            if (result[0].PrintType == 'Lazor') {
                $("#LabBilllazor").prop("checked", true);
                $("#LabBilldotmatrix").prop("checked", false);
            }
            else {
                $("#LabBilldotmatrix").prop("checked", true);
                $("#LabBilllazor").prop("checked", false);
            }
        }
        else if (SelectBox == 'IPBillPrint') {
            if (result[0].PrintType == 'Lazor') {
                $("#IPBilllazor").prop("checked", true);
                $("#IPBilldotmatrix").prop("checked", false);
            }
            else {
                $("#IPBilldotmatrix").prop("checked", true);
                $("#IPBilllazor").prop("checked", false);
            }
        }
        else if (SelectBox == 'VoucherPrint') {
            if (result[0].PrintType == 'Lazor') {
                $("#voucherlazor").prop("checked", true);
                $("#voucherdotmatrix").prop("checked", false);
            }
            else {
                $("#voucherdotmatrix").prop("checked", true);
                $("#voucherlazor").prop("checked", false);
            }
        }
        else if (SelectBox == 'QuotationPrint') {
            if (result[0].PrintType == 'Lazor') {
                $("#quotationlazor").prop("checked", true);
                $("#quotationdotmatrix").prop("checked", false);
            }
            else {
                $("#quotationdotmatrix").prop("checked", true);
                $("#quotationlazor").prop("checked", false);
            }
        }
        else if (SelectBox == 'DischargePrint') {
            if (result[0].PrintType == 'Lazor') {
                $("#Dischargelazor").prop("checked", true);
                $("#Dischargedotmatrix").prop("checked", false);
            }
            else {
                $("#Dischargedotmatrix").prop("checked", true);
                $("#Dischargelazor").prop("checked", false);
            }
        }
    }

</script>