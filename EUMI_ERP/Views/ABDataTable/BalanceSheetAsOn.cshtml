        var CrAmount = 0; var DrAmount = 0; var PandLResultcr = 0; var PandLResultdr = 0; var slno = 1; var pandldiff = 0;
        for (var i = 0; i < result.length; i++) {

            if (result[i].AccDesc == 'STOCKVAL') { var OP = i; }
             var Accode = parseFloat(result[i].AccCode.substring(0, 4) || 0)
             if (Accode != 0 ) {
                if (Accode < 4000 && Accode != 1 ) {

                    if (result[i].AccCode.length > 5) {

                        if ((result[i].Balance).toFixed(decimal) > 0) {
                            responseText += '<tr onclick="GetSummary(' + result[i].AccCode + ')" ><td  style="width:10px">' + slno + '</td><td style="width:70px"  id="Col1_' + slno + '">' + result[i].AccCode + '</td><td id="Col2_' + slno + '">' + result[i].AccDesc + '</td><td  style=text-align:right;width:150px  id="Col3_' + slno + '"></td><td  style=text-align:right;width:150px  id="Col4_' + slno + '">' + (result[i].Balance).toFixed(decimal) + '</td></tr>';
                            CrAmount += parseFloat(result[i].Balance)
