                                responseText += '<tr style=background-color:#cfd8dc onclick="GetSummary(' + result[i].AccCode + ')" ><td  style="width:10px">' + slno + '</td><td style="width:70px" id="Col1_' + slno + '"><b>' + result[i].AccCode + '</b></td><td id="Col2_' + slno + '"><b>' + result[i].AccDesc + '</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"></td><td  style=text-align:right;width:150px  id="Col4_' + slno + '"><b></b></td></tr>';
                                slno += 1

