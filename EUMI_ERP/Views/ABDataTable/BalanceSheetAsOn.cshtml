                                    responseText += '<tr style=background-color:#e6e6e6><td  style="width:10px" style="cursor:pointer"  onclick="GetSummary(' + result[i].AccCode + ')" >' + slno + '</td><td style="width:70px" id="Col1_' + slno + '"><b></b></td><td id="Col2_' + slno + '"><b>' + result[i].AccDesc + '</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"></td><td  style=text-align:right;width:150px  id="Col4_' + slno + '"><b>' + (result[i].Balance).toFixed(decimal) + '</b></td></tr>';
                                    slno += 1
                                }

