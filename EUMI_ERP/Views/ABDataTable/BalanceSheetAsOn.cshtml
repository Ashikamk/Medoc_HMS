<script type="text/javascript">
    var decimal = Decimal;
    $("#Account").autocomplete({
        source: function (request, response) {

            var data = {};
            data.AccountCode = $("#Account").val();
            $.ajax({
                url: '../Master/AccountScheduleSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.AccountCode,
                            label1: item.AcntDescription,
                            AcntId: item.AcntId,
                            headers: ["Code", "Decription"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#AccountId').val(ui.item.AcntId)
        },

    });
    function popuprefresh() {
        $('#popupdiv').hide();
    }




    function ShowListSummery(result) {

        const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        var FromDate = []; var ToDate = [];
        FromDate = ($("#DateFrom").val()).split('/');
        ToDate = ($("#DateTo").val()).split('/');

        var FromDatePrint = FromDate[0] + '-' + monthNames[parseInt(FromDate[1] - 1)] + '-' + FromDate[2];
        var ToDatePrint = ToDate[0] + '-' + monthNames[parseInt(ToDate[1] - 1)] + '-' + ToDate[2];

        disable_datatable('Tblreport', 'buttonPlace');
        var responseText = "<thead><tr><th  style='width:10px'>Sl#</th><th style='width:70px'>Account Code</th><th style='width:1000px'>Account Name</th><th  style=text-align:right;width:150px>Liabilities</th><th  style=text-align:right;width:150px>Assets</th></tr></thead><tbody>";
        var CrAmount = 0; var DrAmount = 0; var PandLResultcr = 0; var PandLResultdr = 0; var slno = 1; var pandldiff = 0;
        for (var i = 0; i < result.length; i++) {
            if (result[i].AccDesc == 'STOCKVAL') { var OP = i; }
            var Accode = parseFloat(result[i].AccCode.substring(0, 4) || 0)

            if (Accode < 4000 && Accode != 0) {
                if ((result[i].Balance).toFixed(decimal) > 0) {
                    responseText += '<tr  style="cursor:pointer"  onclick="GetSummary(' + result[i].AccCode + ')"><td  style="width:10px">' + slno + '</td><td style="width:70px" id="Col1_' + slno + '">' + result[i].AccCode + '</td><td id="Col2_' + slno + '">' + result[i].AccDesc + '</td><td  style=text-align:right;width:150px id="Col3_' + slno + '"></td><td  style=text-align:right;width:150px id="Col4_' + slno + '">' + (result[i].Balance).toFixed(decimal) + '</td></tr>';
                    CrAmount += parseFloat(result[i].Balance)
                    slno += 1;
                }
                else if ((result[i].Balance).toFixed(decimal) < 0) {
                    responseText += '<tr ><td  style="width:10px">' + slno + '</td><td style="width:70px" id="Col1_' + slno + '">' + result[i].AccCode + '</td><td id="Col2_' + slno + '">' + result[i].AccDesc + '</td><td  style=text-align:right;width:150px id="Col3_' + slno + '">' + (-1 * result[i].Balance).toFixed(decimal) + '</td><td  style=text-align:right;width:150px id="Col4_' + slno + '"></td></tr>';
                    DrAmount += parseFloat(-1 * result[i].Balance)
                    slno += 1;

                }
                pandldiff += parseFloat(result[i].Balance)
            }
            else
            {
                if (result[i].AccCode != 0) {
                    PandLResultcr += parseFloat(result[i].Balance);
                    pandldiff += parseFloat(result[i].Balance);
                }
            
               }
        }


        
        if (PandLResultcr < 0)
        {
            responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td id="Col1_' + slno + '"></td><td id="Col2_' + slno + '"><b>P/L RESULT</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"><b>' + -1 * PandLResultcr.toFixed(decimal) + '</b></td><td  style=text-align:right;width:150px id="Col4_' + slno + '"></td></tr>';
            DrAmount += -1 * PandLResultcr
            slno += 1;
        }
        else
        {
            responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td id="Col1_' + slno + '"></td><td id="Col2_' + slno + '"><b>P/L RESULT</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"></td><td  style=text-align:right;width:150px id="Col4_' + slno + '"><b>' + PandLResultcr.toFixed(decimal) + '</b></td></tr>';
            CrAmount += PandLResultcr
            slno += 1;
        }

        if (pandldiff > 0) {
            responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td id="Col1_' + slno + '"></td><td id="Col2_' + slno + '"><b>Trial Balance Difference</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"><b>' + -1 * pandldiff.toFixed(decimal) + '</b></td><td  style=text-align:right;width:150px id="Col4_' + slno + '"></td></tr>';
            DrAmount += -1 * pandldiff
            slno += 1;
        }
        else {
            responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td id="Col1_' + slno + '"></td><td id="Col2_' + slno + '"><b>Trial Balance Difference</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"></td><td  style=text-align:right;width:150px id="Col4_' + slno + '"><b>' + -1 * pandldiff.toFixed(decimal) + '</b></td></tr>';
            CrAmount += -1 * pandldiff
            slno += 1;
        }


        
         responseText += '<tr style=background-color:#cfd8dc><td>' + slno + '</td><td id="Col1_' + slno + '"></td><td id="Col2_' + slno + '"><b>TOTAL</b></td><td  style=text-align:right;width:150px id="Col3_' + slno + '"><b>' + DrAmount.toFixed(decimal) + '</b></td><td  style=text-align:right;width:150px id="Col4_' + slno + '"><b>' + CrAmount.toFixed(decimal) + '</b></td></tr>';
         slno += 1;
    

        $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th style="width:10px">Sl#</th><th style="width:70px">Account Code</th><th>Account Name</th><th> </th><th> </th></tr></tfoot>');
        $('#Tblreportprint').html(responseText + '</tbody>');
        var status = $("#seltype option:selected").text();
        var title = "BALANCE SHEET   " + status + "  - FROM " + $("#DateFrom").val() + " TO " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
        $('#header2').text("From " + FromDatePrint + " to " + ToDatePrint + "");
        $('#ResultLength').val($("#Tblreportprint tbody tr").length);
    }





    function GetSummary(Acccode) {

        var data = {};
        data.DateFrom = $('#DateFrom').val();
        data.DateTo = $('#DateTo').val();
        data.AccountCode = Acccode;
        data.UserId = 1;


        $.ajax({
            type: "POST",
            url: "../AccountsReport/TrialsBalanceSummeryGets",
            data: data,
            success: function (result) {
                ShowSummery(result)
            }
        });
    }


    function ShowSummery(result) {
        disable_datatable('Tblsummaryreport');
        var responseText = "<thead><tr><th style='width:1%'>Sl#</th><th style='width:2%'>Date</th><th style='width:77%'>Description</th><th style='width:10%' class='text-right'>Debit</th><th style='width:10%' class='text-right'>Credit</th></tr></thead><tbody>";

        for (var i = 0; i < result.length; i++) {
            var slno;
            slno = parseInt(i + 1);
            var DebitAmt = parseFloat(result[i].Debit || 0).toFixed(Decimal);
            var CreditAmt = parseFloat(result[i].Credit || 0).toFixed(Decimal);
            if (DebitAmt == 0)
                DebitAmt = '';
            if (CreditAmt == 0)
                CreditAmt = '';

            if (result[i].BillSeriesId == 1) {
                responseText += '<tr style="background-color:#cfd8dc"><td align=center  id="Colsl_' + slno + '"><b>' + slno + '</b></td><td   id="Col1_' + slno + '" ><b>' + result[i].VDate + '</b></td><td   id="Col2_' + slno + '" ><b>' + result[i].VDesc + '</b></td><td   id="Col3_' + slno + '" style="text-align:right"><b>' + DebitAmt + '</b></td><td id="Colc_' + slno + '" style="text-align:right"><b>' + CreditAmt + '</sb></td></td></tr>';
            }
            else if (result[i].AccDesc != '') {
                responseText += '<tr><td align=center id="Colsl_' + slno + '">' + slno + '</td><td   id="Col1_' + slno + '" >' + result[i].VDate + '</td><td   id="Col2_' + slno + '" >' + result[i].VDesc + '</td><td   id="Col3_' + slno + '" style="text-align:right">' + DebitAmt + '</td><td id="Colc_' + slno + '"  style="text-align:right">' + CreditAmt + '</td></td></tr>';
            }

        }

        $('#Tblsummaryreport').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Date#</th><th>Description</th><th> </th><th> </th></tr></tfoot>');
        datatableWithsearch('Tblsummaryreport');
        $('#popupdiv1').show();

    }


    function ShowList(result) {

        const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
        var FromDate = []; var ToDate = [];
