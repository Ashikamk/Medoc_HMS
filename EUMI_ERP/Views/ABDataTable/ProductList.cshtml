
@{
    ViewBag.Title = "ProductList";
}
<style type="text/css">
    .main-panel { height: auto; width: auto; max-height: none; min-height: 100%; margin:0; padding-top: 85px; float:none; }
    .eumi-search-box { box-sizing: border-box; width: 100%; }
    body.eumi-loader::before { content: ''; display:block; position: fixed; z-index:31000; height: 4px; background-color: rgba(0, 157, 160, 0.2); top:0; left:0; right:0; }
    body.eumi-loader::after { content: ''; display:block; position: fixed; z-index:31001; height: 4px; background-color: rgba(0, 157, 160, 1); top:0; width:50px; animation:eumiloader 4s infinite linear;  }
    .eumi-search-table, .eumi-shadow { border-spacing: 0 0px; box-shadow: 0px 0px 0px 2px #fff, 0 0 2px 2px #999; }
    /* .eumi-search-table tbody td { border:none; } */
    @@keyframes eumiloader {
        from {
            right: 100%;
        }

        to {
            right: 0;
        }
    }
</style>


<div id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr style="border-bottom:1px solid gray">
                                <td><h4 class="card-title"> Product List</h4></td>
                                <td align="right">
                                    <div class="col-md-4 eumi-button-area" id="divDownload" data-download-url="@Url.Action("ProductlistDownload", "ABDataTable")">
                                        <div class="btn-group" role="group">
                                            <button id="btnColVisibility" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                Columns
                                            </button>
                                            <div class="dropdown-menu eumi-col-show" aria-labelledby="btnColVisibility">
                                            </div>
                                        </div>
                                        <div class="btn-group" role="group">
                                            <button id="btnGroupDropDownload" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                Export
                                            </button>
                                            <div class="dropdown-menu" aria-labelledby="btnGroupDropDownload">
                                                <a class="dropdown-item buttons-excel" data-eumi-download="excel" href="#">Excel</a>
                                                <a class="dropdown-item buttons-pdf" data-eumi-download="pdf" href="#">PDF</a>
                                                <a class="dropdown-item buttons-csv" data-eumi-download="csv" href="#">CSV</a>
                                                <a class="dropdown-item buttons-print" data-eumi-download="print" href="#">Print</a>
                                            </div>
                                        </div>
                                        <button class="btn btn-outline-primary" data-eumi-clear="1" type="button">Clear Search</button>
                                        <div class="clearfix"></div>
                                    </div>
                                  
                                </td>
                            </tr>
                           
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard">
                            <table id="productlist" class="table table-condensed table-light table-striped table-bordered eumi-search-table" style="width:100%; margin: 0 auto 0 0;">
                                <tfoot>
                                    <tr class="eumi-search-row">
                                        <th></th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th>Unit</th>
                                        <th>Group</th>
                                        <th>Sub Group</th>
                                        <th>Category</th>
                                        <th>Sub Category</th>
                                        <th>Selling Price</th>
                                        <th>Average Cost</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </tfoot>
                            </table>

                            <div style="height:100px;clear: both">
                                &nbsp;
                            </div>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        //$("body").addClass("eumi-loader");
        var table = $("#productlist").EumiDataTable({
            "processing": true,
            "serverSide": true,
            "ajax": {
                "url": "../ABDataTable/ProductListJson",
                "type": "POST",
            },
           
            "columns": [
                { data: "slno", title: "Slno", searchable: false, sortable: false },
                { data: "ItemCode", title: "Item Code" },
                { data: "Description", title: "Description" },
                { data: "UnitName", title: "Unit" },
                { data: "GrpName", title: "Group" },
                { data: "SbgrpName", title: "Sub Group" },
                { data: "CategoryName", title: "Category" },
                { data: "SubCategoryName", title: "Sub Category" },
                { data: "SellingPrice", title: "Selling Price" },
                { data: "AvgCost", title: "Average Cost" },
                { data: "Status", title: "Status" },
                { data: "ItemId", data: "GroupId", data: "SubGroupId", data: "CategoryId", title: "Edit", searchable: false, sortable: false }
            ],

            "createdRow": function (row, data, index) {
                row.getElementsByTagName("td")[11].innerHTML = '<a  onclick="GetItem(' + data.ItemId + ',' + data.GroupId + ',' + data.SubGroupId + ',' + data.CategoryId + ');"><i class="ft-edit"></a>';

            },
        });
    });
   
    function GetItem(ItemId, GroupId, SubGroupId, CategoryId) {
        window.open('../Master/UsedCarsItemMaster?itemid=' + ItemId + '&grpid=' + GroupId + '&subgrpid=1&cati=' + CategoryId);
    }


</script>
@section bottomscripts {
    <script type="text/javascript" src="~/Scripts/EumiDataTable/eumi-datatable.js"></script>
}