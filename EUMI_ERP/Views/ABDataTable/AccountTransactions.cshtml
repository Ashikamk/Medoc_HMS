
@{
    ViewBag.Title = "Accoun Transactions Report";
}
<style type="text/css">
    .main-panel {
        height: auto;
        width: auto;
        max-height: none;
        min-height: 100%;
        margin: 0;
        padding-top: 85px;
        float: none;
    }

    .eumi-search-box {
        box-sizing: border-box;
        width: 100%;
    }

    body.eumi-loader::before {
        content: '';
        display: block;
        position: fixed;
        z-index: 31000;
        height: 4px;
        background-color: rgba(0, 157, 160, 0.2);
        top: 0;
        left: 0;
        right: 0;
    }

    body.eumi-loader::after {
        content: '';
        display: block;
        position: fixed;
        z-index: 31001;
        height: 4px;
        background-color: rgba(0, 157, 160, 1);
        top: 0;
        width: 50px;
        animation: eumiloader 4s infinite linear;
    }

    .eumi-search-table, .eumi-shadow {
        border-spacing: 0 0px;
        box-shadow: 0px 0px 0px 2px #fff, 0 0 2px 2px #999;
    }
    /* .eumi-search-table tbody td { border:none; } */
    @@keyframes eumiloader {
        from {
            right: 100%;
        }

        to {
            right: 0;
        }
    }
</style>
<div class="myData" data-x="M82" />
<div class="card">
   
        <div class="row m-1">
            <div class="col-md-6">
                <h2>Account Statement</h2>
            </div>
            <div class="col-md-6 eumi-button-area" id="divReportOptions" data-download-url="@Url.Action("AccountTransactDownload", "ABDataTable")">
                <div class="btn-group" role="group">
                    <button class="btn btn-outline-primary" id="btnGo" onclick="window.open('../AccountsReport/AccountStatement')" type="button">Account Statement</button>
                </div>
                
                <div class="btn-group" role="group">
                    <button id="btnColVisibility" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        Columns
                    </button>
                    <div class="dropdown-menu eumi-col-show" aria-labelledby="btnColVisibility">
                    </div>
                </div>

                <button type="button" id="btnchgp" class="btn btn-primary" data-toggle="modal" data-target="#paramModal" onclick="$('#AccountGroup').focus()">Change Parameters</button>

                <div class="btn-group" role="group">
                    <button id="btnGroupDropDownload" type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                        Export
                    </button>
                    <div class="dropdown-menu" aria-labelledby="btnGroupDropDownload">
                        <a class="dropdown-item buttons-excel" data-eumi-download="excel" href="#">Excel</a>
                        <a class="dropdown-item buttons-pdf" data-eumi-download="pdf" href="#">PDF</a>
                        <a class="dropdown-item buttons-csv" data-eumi-download="csv" href="#">CSV</a>
                        <a class="dropdown-item buttons-print" data-eumi-download="print" href="#">Print</a>
                    </div>
                </div>
                <button class="btn btn-outline-primary" data-eumi-clear="1" type="button">Clear Search</button>
            </div>
        </div>
    <div id="ddddd" style="display:none;">
        <div class="row m-1">
            <div id="paramOfReport" class="row m-1"></div>
        </div>
        <table id="accounttranrpt" class="table table-condensed table-light table-striped table-bordered eumi-search-table" style="width:100%; margin: 0 auto 0 0;">
            <tfoot>
                <tr class="eumi-search-row">
                    <th></th>
                    <th>Prefix</th>
                    <th>Voucher No.</th>
                    <th>Voucher Date</th>
                    <th>Account Code</th>
                    <th>Account Description</th>
                    <th>Voucher Description</th>
                    <th>Reference No.</th>
                    <th>Cheque No.</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th><div style="width:100px">&nbsp;</div></th>
                </tr>
                <tr>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th>Grand Total</th>
                    <th></th>
                    <th></th>
                    <th></th>
                    <th id="eumiDebitTotal" class="text-right">Debit</th>
                    <th id="eumiCreditTotal" class="text-right">Credit</th>
                    <th id="eumiGrandBalance" class="text-right">Balance</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
<div style="height:100px;clear: both">
    &nbsp;
</div>
<script type="text/javascript">
    $(document).ready(function () {
      

        $('#btnchgp').click();
      
            var decimal = (window.Decimal || 1);
            window.EumiLastSelectedInAccRpt = null;
            var table = $('#accounttranrpt').EumiDataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "../ABDataTable/AccountTransJson",
                    "type": "POST",
                    "data": function (data, settings) {
                        var addData = (window.EumiLastSelectedInAccRpt || {});
                        addData.dateFrom = moment(addData.dateFrom || new Date()).format("YYYY-MM-DD");
                        addData.dateTo = moment(addData.dateTo || new Date()).format("YYYY-MM-DD");
                        addData.accountId = (addData.accountId || 0);
                        addData.jobId = (addData.jobId || 0);
                        addData.departmentId = (addData.departmentId || 0);
                        addData.costCenterId = (addData.costCenterId || 0);
                        addData.AccountGroup = (addData.AccountGroup || 0);
                        if (!addData.title) {
                            addData.title = "Parameters - " + "From: " + moment(new Date()).format("DD-MM-YYYY") + " To: " + moment(new Date()).format("DD-MM-YYYY")
                            $("#paramOfReport").text(addData.title);
                        }
                        data.addData = addData;
                    }
                },
                "columnDefs": [{
                    "targets": 9,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                {
                    "targets": 10,
                    "className": "text-right",
                    "render": function (data) {
                        return (data || 0).toFixed(decimal);
                    }
                },
                {
                    "targets": 11,
                    "className": "text-right",
                    "render": function (data) {
                        return (Math.abs(data) || 0).toFixed(decimal) + " " + (data < 0 ? "CR" : "DR");
                    }
                }],
                "columns": [
                    { data: "rowNum", title: "Sl No.", searchable: false, sortable: false },
                    { data: "VoucherPrefix", title: "Prefix", sortable: false },
                    { data: "VoucherNo", title: "Voucher No.", sortable: false },
                    { data: "VoucherDate", title: "Voucher Date", sortable: false },
                    { data: "AccountCode", title: "Account Code", sortable: false },
                    { data: "AccountDesc", title: "Account Description", sortable: false },
                    { data: "VoucherDesc", title: "Voucher Description", sortable: false },
                    { data: "ReferenceNo", title: "Reference No.", sortable: false },
                    { data: "ChequeNo", title: "Cheque No.", sortable: false },
                    { data: "DebitAmount", title: "Debit", sortable: false },
                    { data: "CreditAmount", title: "Credit", sortable: false },
                    { data: "Balance", title: "Balance", searchable: false, sortable: false },
                ],
                "createdRow": function (row, data, index) {
                    if (index == 0) {
                        $("#eumiGrandBalance").text(Math.abs(data._grandbalance).toFixed(decimal) + " " + (data._grandbalance < 0 ? "CR" : "DR"));
                        $("#eumiDebitTotal").text(data._debittotal.toFixed(decimal));
                        $("#eumiCreditTotal").text(data._credittotal.toFixed(decimal));
                        console.log(index);
                    }
                },
            });

            $('#accounttranrpt tbody').on('click', 'tr', function () {
                console.log($("#accounttranrpt").DataTable().row(this).data().VEntryId);
            });

    });
    
   
</script>

@section popups {
    <div class="modal" id="paramModal">
        <div class="modal-dialog">
            <div class="modal-content">

                <!-- Modal Header -->
                <div class="modal-header">
                    <h4 class="modal-title">Report Parameters</h4>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>

                <!-- Modal body -->
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="dateFrom">From Date:</label>
                                <input type="text" class="form-control" id="dateFrom">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="dateTo">
                                <label for="email">To Date:</label>
                                <input type="text" class="form-control" id="dateTo">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="AccountGroup">Account Group:</label>
                                <input type="text" class="form-control" id="AccountGroup" onkeyup="CodeClear()">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="accountCode">Account Code:</label>
                                <input type="text" class="form-control" id="accountCode" onkeyup="GroupClear()">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="jobCode">Job Code:</label>
                                <input type="text" class="form-control" id="jobCode">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="costCenterCode">Cost Center Code:</label>
                                <select id="costCenterCode" class="form-control">
                                    <option value="0">- All -</option>
                                </select>
                            </div>
                        </div>
                    </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="vDept">Department:</label>
                                    <select id="vDept" class="form-control">
                                        <option value="0">- All -</option>
                                    </select>
                                </div>
                            </div>

                        </div>
                    </div>

                <!-- Modal footer -->
                <div class="modal-footer">
                    <button type="button" id="btnsubmit" class="btn btn-primary" data-dismiss="modal" onclick="redrawTable();">Apply</button>
                    <button type="button" class="btn btn-primary" data-dismiss="modal">Close</button>
                </div>

            </div>
        </div>
    </div>
}

@section bottomscripts {
    <script type="text/javascript" src="~/Scripts/EumiDataTable/eumi-datatable.js"></script>
    <script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
    <script type="text/javascript">
            $(document).ready(function () {
                $("#accountCode").autocomplete({
                    source: function (request, response) {
                        var data = {};
                        data.AccountDescription = request.term;
                        $.ajax({
                            url: '../Inventory/AccountNumberSearch',
                            type: "POST",
                            data: data,
                            dataType: "json",
                            success: function (resultData) {
                                var resultData = $.map(resultData, function (ele) {
                                    return {
                                        label: ele.AccountDescription,
                                        value2: ele.AccountId,
                                        value: ele.DebitAccount,
                                    }
                                });
                                response(resultData);
                            }
                        });
                    },
                    autoFocus: true,
                    select: function (event, ui) {
                        $("#accountCode").data("eumi-val", ui.item.value2);
                    },
                }).autocomplete("instance")._renderItem = function (ul, item) {
                    var jqLi = $("<li>")
                    var jqRow = getTableRow(item, ["value", "label"], ["50%", "50%"], ["Code", "Desc"]);
                    return jqLi.append($('<table class="tblautocomplete">').css("width", "300px").append(jqRow)).appendTo(ul);
                };

                $("#AccountGroup").autocomplete({
                    source: function (request, response) {

                        var data = {};
                        data.AccountCode = $("#AccountGroup").val();
                        $.ajax({
                            url: '../Master/AccountScheduleSearch',
                            type: "POST",
                            data: data,
                            dataType: "json",
                            success: function (data) {
                                console.log(data);
                                response($.map(data, function (item) {
                                    return ({
                                        ColCount: 'TWOEnq',
                                        label: item.AccountCode,
                                        label1: item.AcntDescription,
                                        AcntId: item.AcntId,
                                        headers: ["Code", "Decription"]
                                    })
                                }));
                            }

                        })

                    },
                    autoFocus: true,
                    select: function (event, ui) {
                        $('#AccountGroup').data("eumi-val", ui.item.AcntId);
                    },

                });

                $("#jobCode").autocomplete({
                    source: function (request, response) {
                        var data = {};
                        data.JobCode = request.term;
                        $.ajax({
                            url: '../Master/JobCodeSearch',
                            type: "POST",
                            data: data,
                            dataType: "json",
                            success: function (resultData) {
                                var resultData = $.map(resultData, function (item) {
                                    return {
                                        value: item.JobCode,
                                        label: item.Description,
                                        value2: item.ProjectJobId,
                                    }
                                });
                                response(resultData);
                            }
                        });
                    },
                    autoFocus: true,
                    select: function (event, ui) {
                        $("#jobCode").data("eumi-val", ui.item.value2);
                    },
                }).autocomplete("instance")._renderItem = function (ul, item) {
                    var jqLi = $("<li>")
                    var jqRow = getTableRow(item, ["value", "label"], ["50%", "50%"], ["Code", "Desc"]);
                    return jqLi.append($('<table class="tblautocomplete">').css("width", "300px").append(jqRow)).appendTo(ul);
                };

                $('#dateFrom').val(FinanceStartDate)
                $('#dateFrom, #dateTo').daterangepicker({
                    minDate: minDate,
                    maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
                    singleDatePicker: true,
                    showDropdowns: true,
                    locale: {
                        format: 'DD/MM/YYYY'
                    }
                });

                GetCostCenter(0);
                GetDept(0);
                $('#AccountGroup').focus();

                $('#AccountGroup').keypress(function (e) {
                    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                    if (key == 13) {
                        $('#accountCode').focus();
                        e.preventDefault();
                    }
                });
                $('#accountCode').keypress(function (e) {
                    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                    if (key == 13) {
                        $('#jobCode').focus();
                        e.preventDefault();
                    }
                });
                $('#jobCode').keypress(function (e) {
                    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                    if (key == 13) {
                        $('#costCenterCode').focus();
                        e.preventDefault();
                    }
                });
                $('#costCenterCode').keypress(function (e) {
                    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                    if (key == 13) {
                        $('#vDept').focus();
                        e.preventDefault();
                    }
                });
                $('#vDept').keypress(function (e) {
                    var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
                    if (key == 13) {
                        $('#btnsubmit').focus();
                        e.preventDefault();
                    }
                });
            });


            function getTableRow(item, keyArray, widthArray, headersArray) {
                var jqRow = $("<tr>")
                for (var x = 0; x < keyArray.length; x++) {
                    $("<td>").css({ "border": "1px solid #d6d9db", "width": widthArray[x] })
                        .html(item[keyArray[x]])
                        .attr("data-em-header", (headersArray[x] || ""))
                        .appendTo(jqRow)
                }
                return jqRow;
            }

            function GetCostCenter(id) {
                var data = {};
                data.CostCenterId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/CostCenterGetandGets",
                    data: data,
                    success: function (result) {
                        console.log(result)
                        $.each(result.oList, function (index, ele) {
                            $("#costCenterCode").append($("<option>").attr("value", ele.CostCenterId).text(ele.CostCenterCode));
                        });
                    }
                });
            }

            function GetDept(id) {
                var data = {};
                data.DeptId = 0;
                $.ajax({
                    type: "POST",
                    url: "../Master/DepartmentGetandGets",
                    data: data,
                    success: function (result) {
                        console.log(result)
                        $.each(result.oList, function (index, ele) {
                            $("#vDept").append($("<option>").attr("value", ele.DepartmentId).text(ele.DepartmentName));
                        });
                    }
                });
            }
            function GroupClear() {
                $("#AccountGroup").val('');
            }
            function CodeClear() {
                $("#accountCode").val('');
            }
            function redrawTable() {
                $('#ddddd').show();
                var data = {};
                data.dateFrom = moment($('#dateFrom').val(), "DD-MM-YYYY").toDate();
                data.dateTo = moment($('#dateTo').val(), "DD-MM-YYYY").toDate();
                data.accountId = ($('#accountCode').val().match(/^\s*$/) ? 0 : parseInt($('#accountCode').data("eumi-val") || 0));
                data.jobId = ($('#jobCode').val().match(/^\s*$/) ? 0 : parseInt($('#jobCode').data("eumi-val") || 0));
                data.departmentId = parseInt($('#vDept').val() || 0);
                data.costCenterId = parseInt($('#costCenterCode').val() || 0);
                data.AccountGroup = ($('#AccountGroup').val().match(/^\s*$/) ? 0 : parseInt($('#AccountGroup').data("eumi-val") || 0));
                data.title = "Parameters - " + "From: " + $('#dateFrom').val()
                    + " To: " + $('#dateTo').val() + " Account: " + ($('#accountCode').val() || "(All)")
                    + " Job: " + ($('#jobCode').val() || "(All)") + " Dept: " + $("#vDept").find("option:selected").text()
                    + " Cost Center: " + $('#costCenterCode').find("option:selected").text()
                  + " Account Group: " + ($('#AccountGroup').val() || "(All)");
                if ($.fn.DataTable.isDataTable('#accounttranrpt')) {
                    window.EumiLastSelectedInAccRpt = data;
                    $("#accounttranrpt").DataTable().ajax.reload();
                    $("#paramOfReport").text(data.title);
                }
            }
    </script>
}
