    function ShowList(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th style='width:10px'>Slno</th><th style='width:70px'>Account Code</th><th>Account Name</th><th style=text-align:right;width:200px>Debit</th><th style=text-align:right;width:200px>Credit</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            len = (result[i].AccCode).length;

            if (len == 4 && result[i].AccDesc != 'TOTAL') {
                ResponseEntity += '<tr style=background-color:#cfd8dc><td style="width:10px" >' + slno + '</td><td  style="width:70px"><b>' + result[i].AccCode + '</b></td><td><b>' + result[i].AccDesc + '</b></td><td style="width:200px"></td><td style="width:200px"></td></tr>';
            }
            else if (result[i].AccDesc == 'TOTAL') {
                ResponseEntity += '<tr><td style="width:10px">' + slno + '</td><td style="width:70px">' + result[i].AccCode + '</td><td><b>' + result[i].AccDesc + '</b></td><td style=text-align:right;width:200px><b>' + parseFloat(result[i].DR || 0).toFixed(Decimal) + '</b></td><td style=text-align:right;width:200px><b>' + parseFloat(result[i].CR || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else if (result[i].AccCode == '' && result[i].AccDesc != 'TOTAL') {
                ResponseEntity += '<tr style=background-color:#cfd8dc><td style="width:70px" >' + slno + '</td><td style="width:50px"><b>' + result[i].AccCode + '</b></td><td><b>' + result[i].AccDesc + '</b></td><td  style=text-align:right;width:200px><b>' + parseFloat(result[i].DR || 0).toFixed(Decimal) + '</b></td><td  style=text-align:right;width:200px><b>' + parseFloat(result[i].CR || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else {
                ResponseEntity += '<tr><td style="width:10px" >' + slno + '</td><td style="width:70px">' + result[i].AccCode + '</td><td>' + result[i].AccDesc + '</td><td  style=text-align:right;width:200px>' + parseFloat(result[i].DR || 0).toFixed(Decimal) + '</td><td  style=text-align:right;width:200px>' + parseFloat(result[i].CR || 0).toFixed(Decimal) + '</td></tr>';
            }
        }

        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th style="width:10px">Slno</th><th style="width:70px">Account Code</th><th>Account Name</th><th style=width:200px> </th><th style=width:200px> </th></tr> </tfoot>');

        var title = "Trial Balance Groupwise Report- from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }


    function ShowListSummary(result) {
        disable_datatable('Tblreport', 'buttonPlace');
        var ResponseEntity = "<thead><tr><th style='width:10px'>Slno</th><th style='width:70px'>Account Code</th><th>Account Name</th><th style=text-align:right;width:200px>Debit</th><th style=text-align:right;width:200px>Credit</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);

           if (result[i].AccCode == '') {
                ResponseEntity += '<tr style=background-color:#cfd8dc><td style="width:70px" >' + slno + '</td><td style="width:50px"><b>' + result[i].AccCode + '</b></td><td><b>' + result[i].AccDesc + '</b></td><td  style=text-align:right;width:200px><b>' + parseFloat(result[i].Debit || 0).toFixed(Decimal) + '</b></td><td  style=text-align:right;width:200px><b>' + parseFloat(result[i].Credit || 0).toFixed(Decimal) + '</b></td></tr>';
            }
            else {
                ResponseEntity += '<tr><td style="width:10px" >' + slno + '</td><td style="width:70px">' + result[i].AccCode + '</td><td>' + result[i].AccDesc + '</td><td  style=text-align:right;width:200px>' + parseFloat(result[i].Debit || 0).toFixed(Decimal) + '</td><td  style=text-align:right;width:200px>' + parseFloat(result[i].Credit || 0).toFixed(Decimal) + '</td></tr>';
            }
        }

        $('#Tblreport').html(ResponseEntity + '</tbody><tfoot><tr><th style="width:10px">Slno</th><th style="width:70px">Account Code</th><th>Account Name</th><th style=width:200px> </th><th style=width:200px> </th></tr> </tfoot>');

        var title = "Trial Balance Summary- from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
        datatableWithsearch('Tblreport', true, title, 'buttonPlace');
        $('#header').text(title);
    }

    $(document).ready(function () {
        GetCostCode(0);
        GetDepartment(0);
        $('#Account').focus();


        $('#CostCode').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#department').focus();
                e.preventDefault();
            }
        });
        $('#department').keypress(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $("#Account").keyup(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 08 || key == 13) {
                $('#AccountId').val(0);
                $('#CostCode').focus();
                e.preventDefault();
            }

        });

        $('#DateFrom').val(FinanceStartDate)

        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });

        $("#btnsubmit").click(function (e) {
            var Condition = '';
            var FromDate = $('#DateFrom').val();
            var ToDate = $('#DateTo').val();
            var account = '', costcode = '', dept = '', Condition = 'CONVERT(datetime,VDate,103) >= CONVERT(datetime,' + "'" + FromDate + "'" + ',103) and CONVERT(datetime,VDate,103) <= CONVERT(datetime,' + "'" + ToDate + "'" + ',103)'

            var Account = parseInt($('#AccountId').val() || 0);
            var CostCode = parseInt($('#CostCode').val() || 0);
            var Department = parseInt($('#department').val() || 0);

            if ($('#Account').val() == '') {
                $('#AccountId').val(0);
            }


            if ($('#DateFrom').val() == '') {
                alert('Please Select From Date');
                $('#DateFrom').focus();

            }
            else if ($('#DateTo').val() == '') {
                alert('Please Select To Date');
                $('#DateTo').focus();

            }

            else {
                $('#Loading').show();
                if ($("#trialabalsummary").prop("checked")) {

                    if (Account != 0) { Condition += ' and AcntId=' + Account; }
                    if (CostCode != 0) { Condition += ' and CostCenterId=' + CostCode; }
                    if (Department != 0) { Condition += ' and at.DeptId=' + Department; }


                    var data = {};
                    data.Condition = Condition;
                    $.ajax({
                        type: "POST",
                        url: "../AccountsErp/TrialsBalanceSummary",
                        data: data,
                        success: function (result) {
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            ShowListSummary(result.oList);
                        }
                    });

                }
                else {
                    if (Account != 0) { Condition += ' and AcntId=' + Account; }
                    if (CostCode != 0) { Condition += ' and CostCenterId=' + CostCode; }
                    if (Department != 0) { Condition += ' and at.DeptId=' + Department; }


                    var data = {};
                    data.Condition = Condition;
                    $.ajax({
                        type: "POST",
                        url: "../AccountsErp/TrailsBalanceGroupwiseGetandGets",
                        data: data,
                        success: function (result) {
                            $('#Loading').hide();
                            $('#divreport').show();
                            $('#popupdiv').hide();
                            ShowList(result.oList);
                        }
                    });
                }

            }
        });
    });
        function GetDepartment(id) {
            var data = {};
            data.DeptId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/DepartmentGetandGets",
                data: data,
                success: function (result) {
                    DepartmentLoad(result.oList, id);


                }
            });
        }

        function DepartmentLoad(result) {
            $("#department").empty();
            $("#department").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
            }

        }
        function GetCostCode(id) {
            var data5 = {};
            data5.CostCenterId = 0;
            $.ajax({
                type: "POST",
                url: "../Master/CostCenterGetandGets",
                data: data5,
                success: function (result) {
                    CostCenterLoad(result.oList);

                }
            });
        }
        function CostCenterLoad(result) {
            $("#CostCode").empty();
            $("#CostCode").append("<option value='0'>-All-</option>");
            for (var i = 0; i < result.length; i++) {
                $("#CostCode").append("<option value='" + result[i].CostCenterId + "'>" + result[i].CostCenterCode + "</option>");
            }
        }
</script>

