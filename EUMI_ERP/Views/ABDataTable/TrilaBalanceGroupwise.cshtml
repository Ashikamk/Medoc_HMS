</div>
<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h3 class="modal-title" id="myheader">Trial Balance Groupwise Report</h3>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:30px">From Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label style="margin-top:5px;margin-left:70px">To Date </label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">

                        <label style="margin-top:5px;margin-left:45px">Account </label>
                        <div class="col-md-4">
                            <input type="text" id="Account" class="form-control">
                            <input type="hidden" id="AccountId" class="form-control" />
                        </div>


                        <label style="margin-top:5px;margin-left:50px">Cost Code </label>
                        <div class="col-md-4">
                            <select id="CostCode" name="priority" class="form-control"></select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;margin-left:-10px">
                        <label style="margin-top:5px;margin-left:20px">Department </label>
                        <div class="col-md-4">
                            <select id="department" name="priority" class="form-control"></select>
                        </div>
                      
                            <div class="custom-control custom-checkbox" style="margin-left:150px">
                                <input type="checkbox" class="custom-control-input" name="customCheck" id="trialabalsummary">
                                <label class="custom-control-label" style="margin-left:10px" for="trialabalsummary">Trial Balance Summary</label>
                            </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-outline-primary">Go</button>
                </div>

            </form>
        </div>
    </div>
</div>
