<div style="display:none">
    <input type="text" value="0" id="AgreementId" />
    <input type="text" id="VehicleDesc" />
    <input type="text" id="DailyPrice" />
    <input type="text" id="WeeklyPrice" />
    <input type="text" id="MonthlyPrice" />
    <input type="text" id="AnnualPrice" />
    <input type="text" id="SalesFlag" />
    <input type="text" id="Address" />
    <input type="text" id="PhoneNo" />
    <input type="text" id="Email" />
    <input type="text" id="ItemId" />
</div>

<script>
    function SIDetails(AgreementNo) {
        var AgreementNo = AgreementNo;
        var CustomerId = '', Customer = '', VechicleNo = '', ItemId = '', VehicleDesc = '', StartDate = '', EndDate = '';
        var DailyPrice = '', WeeklyPrice = '', MonthlyPrice = '', AnnualPrice = '';
        var Address = '', PhoneNo = '', Email = '';

        if ($("#CustomerId").val() != '') CustomerId = CustomerId + $("#CustomerId").val();
        if ($("#Customer").val() != '') Customer = Customer + $("#Customer").val();
        if ($("#VechicleNo").val() != '') VechicleNo = VechicleNo + $("#VechicleNo").val();
        if ($("#ItemId").val() != '') ItemId = ItemId + $("#ItemId").val();
        if ($("#VehicleDesc").val() != '') VehicleDesc = VehicleDesc + $("#VehicleDesc").val();
        if ($("#StartDate").val() != '') StartDate = StartDate + $("#StartDate").val();
        if ($("#EndDate").val() != '') EndDate = EndDate + $("#EndDate").val();

        if ($("#DailyPrice").val() != '') DailyPrice = DailyPrice + $("#DailyPrice").val();
        if ($("#WeeklyPrice").val() != '') WeeklyPrice = WeeklyPrice + $("#WeeklyPrice").val();
        if ($("#MonthlyPrice").val() != '') MonthlyPrice = MonthlyPrice + $("#MonthlyPrice").val();
        if ($("#AnnualPrice").val() != '') AnnualPrice = AnnualPrice + $("#AnnualPrice").val();

        if ($("#Address").val() != '') Address = Address + $("#Address").val();
        if ($("#PhoneNo").val() != '') PhoneNo = PhoneNo + $("#PhoneNo").val();
        if ($("#Email").val() != '') Email = Email + $("#Email").val();

        sessionStorage.setItem("AgreementNo", AgreementNo);
        sessionStorage.setItem("CustomerId", CustomerId);
        sessionStorage.setItem("Customer", Customer);
        sessionStorage.setItem("VechicleNo", VechicleNo);
        sessionStorage.setItem("ItemId", ItemId);
        sessionStorage.setItem("VehicleDesc", VehicleDesc);
        sessionStorage.setItem("StartDate", StartDate);
        sessionStorage.setItem("EndDate", EndDate);

        sessionStorage.setItem("DailyPrice", DailyPrice);
        sessionStorage.setItem("WeeklyPrice", WeeklyPrice);
        sessionStorage.setItem("MonthlyPrice", MonthlyPrice);
        sessionStorage.setItem("AnnualPrice", AnnualPrice);

        sessionStorage.setItem("Address", Address);
        sessionStorage.setItem("PhoneNo", PhoneNo);
        sessionStorage.setItem("Email", Email);
        window.location = "@Url.Action("SalesInvoiceRentCar", "SalesInvoice", new { from = "CarAgreement" })";
    }

    $("#Customer").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#CustomerId').val('');
            $('#LicenseNo').val('');
            $('#Phone').val('');
            var data = {};
            data.CustName = $("#Customer").val();
            data.CustType = 'C';
            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '-2ph',
                            label: item.CustName,
                            label1: item.CustAccount,
                            label2: item.PhoneNumber,
                            CustName: item.CustName,
                            Address: item.CustStreet1 + '\n' + item.CustCity1,
                            CustId: item.CustId,
                            SalesmanId: item.SalesmanId,
                            CurncyId: item.CurrencyId,
                            CustTermsId: item.CustTermsId,
                            AreaId: item.AreaId,
                            PhoneNumber: item.PhoneNumber,
                            PriceGroupId: item.PriceGroupId,
                            licenseNo:item.licenseNo,
                            headers: ["Customer Name", "Account Code", "Phone No"]
                        })
                    }));
                }
            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CustomerId').val(ui.item.CustId);
            $('#LicenseNo').val(ui.item.licenseNo);
            $('#Phone').val(ui.item.PhoneNumber);
            $('#AgreementNo').focus();
        },

    });

    $("#VechicleNo").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#VechicleId').val('');
            $('#Model').val('');
            $('#Make').val('');
            var data = {};
            data.VechicleNo = $("#VechicleNo").val();
            $.ajax({
                url: '../CarAgreement/CarSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.VechicleNo,
                            label1: item.VechicleDesc,
                            VechicleId:item.VechicleId,
                            Model:item.Model,
                            Make:item.Make,
                            headers: ["Vechicle Code", "Vechicle Description"]
                        })
                    }));
                }
            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#VechicleId').val(ui.item.VechicleId);
            $('#Model').val(ui.item.Model);
            $('#Make').val(ui.item.Make);
            $('#Phone').focus();
        },

    });

    $("#CreatedBy").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#CreatedById').val('');
            var data = {};
            data.UserName = $("#CreatedBy").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CreatedById').val(ui.item.UserId);
            $('#btnsubmit').focus();
        },
    });

    if (("@Request.QueryString["from"]" == "DailyPlannerRent") || ("@Request.QueryString["from"]" == "RCDashBoard")) {

        var CarId = sessionStorage.getItem("CarId");
        var CarCode = sessionStorage.getItem("CarCode");
        var AgrDate = sessionStorage.getItem("AgrDate");

        $('#VechicleNo').val(CarCode);
        $('#VechicleId').val(CarId);
        $('#StartDate,#EndDate').val(AgrDate);

        sessionStorage.removeItem("CarId");
        sessionStorage.removeItem("CarCode");
        sessionStorage.removeItem("AgrDate");

        var data = {};
        data.CarId = CarId;
        $.ajax({
            type: "POST",
            url: "../RentCar/CarGetandGets",
            data: data,
            success: function (result) {
               // $('#Make').val(result[0].CarMake);
                $('#Model').val(result[0].IYear);
            }
        });

    }

</script>


