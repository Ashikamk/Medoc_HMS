    <script>

        function CheckLocationselected() {
           if($('#ToLocation').val()==0){
                warningshow('Please Select To Location', 'ToLocation');
            }
        }

        //product

        $("#txtproduct0").autocomplete({
            delay: 0,
            minLength: 0,
            source: function (request, response) {
                if ($('#Location').val() == 0) {
                    warningshow('Please Select Location', 'Location');
                    $("#txtproduct0").val('');
                    return false;
                }
                else if ($('#Location').val() == ($('#ToLocation').val())) {
                    warningshow('From Location and To Location Cannot be same', 'ToLocationIn');
                    $('#txtproduct0').val('');
                    return false;
                }
                else {
                    var data = {};
                    data.ItemCode = $("#txtproduct0").val();
                    data.LocId = $("#Location").val();
                    data.DeptId = ERPDeptId;
                    data.UserId = ERPUserId;
                    data.CustId = 0;
                    data.ProductMultiPriceId = 0;
                    $.ajax({
                        url: '../SalesInvoice/ProductSearchSales',
                        type: "POST",
                        data: data,
                        dataType: "json",
                        success: function (data) {

                            response($.map(data, function (item) {
                                return ({
                                    ColCount: '-9s',
                                    label: item.ItemCode,
                                    label1: item.Description,
                                    //label2: item.UnitName,
                                    label3: item.stocktotloseqty,
                                    label4: item.SellingPrice.toFixed(Decimal),
                                    label5: item.GrpName.substring(0, 15),
                                    label6: item.SbgrpName.substring(0, 15),
                                    label7: item.CategoryName.substring(0, 15),
                                    label8: item.SubCategoryName.substring(0, 15),
                                    Unit: item.UnitId,
                                    Description: item.Description,
                                    Rates: item.SellingPrice,
                                    UnitName: item.UnitName,
                                    ProductId: item.ItemId,
                                    Product: item.ItemCode,
                                    Qty: item.stocktotloseqty,
                                    headers: ["Product Code", "Product Description", "Quantity", "Price", "Group", "Sub Group", "Category", "Sub Ctegory"]
                                })
                            }));
                        }
                    })
                }
            },
            autoFocus: true,
            select: function (event, ui) {
                LOcQty = ui.item.Qty;
                if (ui.item.Qty == 0) {
                    var data = {};
                    data.ProductId = ui.item.ProductId;
                    data.CustId = 0;
                    data.DeptId = ERPDeptId;
                    $.ajax({
                        type: "POST",
                        url: '../SalesInvoice/CustomerProductDetailsSearch',
                        data: data,
                        success: function (result) {
                            CustPrdctLoad(result.oList);
                        }
                    });
                    $('#txtproduct0').val(ui.item.Product);
                    warningshow('Not enough stock!', 'txtproduct0');
                    $('#ProductId0').val(ui.item.ProductId);
                    $('#txtproduct0').select();
                    qtyflag = 1;
                    return false;
                }
                else {
                    $('#ProductId0').val(ui.item.ProductId);
                    $('#select_unit0').val(ui.item.Unit);
                    $('#Description').val(ui.item.Description);
                    $('#txtrate').val(ui.item.Rates);
                    $('#hiddenquantitycheck').val(ui.item.Qty);
                    $('#txtquantity').focus();
                    qtyflag = 0;
                    var data = {};
                    data.ProductId = ui.item.ProductId;
                    data.CustId = 0;
                    data.DeptId = ERPDeptId;
                    $.ajax({
                        type: "POST",
                        url: '../SalesInvoice/CustomerProductDetailsSearch',
                        data: data,
                        success: function (result) {
                            CustPrdctLoad(result.oList);
                        }
                    });
                }
            },
        });
        $("#DebitAccount").autocomplete({
            source: function (request, response) {
                var data = {};
                data.AccountDescription = $("#DebitAccount").val();
                data.DeptId = ERPDeptId;
                $.ajax({
                    url: '../Inventory/AccountNumberSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-3',
                                label: item.DebitAccount,
                                label1: item.AccountDescription,
                                DebitAccount: item.DebitAccount,
                                AccountDescription: item.AccountDescription,
                                AccountId: item.AccountId,
                                headers: ["Account Code", "Account Name"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#hiddendebit').val(ui.item.AccountId)
                $('#DebitAccount').val(ui.item.DebitAccount);
                $('#txtdacnt').val(ui.item.AccountDescription);
                $("#CreditAccount").focus();
            },
        });
        //Credit Account

        $("#CreditAccount").autocomplete({
            source: function (request, response) {
                var data = {};
                data.AccountDescription = $("#CreditAccount").val();
                $.ajax({
                    url: '../Inventory/AccountNumberSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-3',
                                label: item.DebitAccount,
                                label1: item.AccountDescription,
                                DebitAccount: item.DebitAccount,
                                AccountDescription: item.AccountDescription,
                                AccountId: item.AccountId,
                                headers: ["Account Code", "Account Name"]
                            })
                        }));
                    }
                })
            },
            autoFocus: true,
            select: function (event, ui) {
                $('#hiddenCredit').val(ui.item.AccountId)
                $('#CreditAccount').val(ui.item.DebitAccount);
                $('#txtcacnt').val(ui.item.AccountDescription);
                $('#Comments').focus();
            },
        });

        //L Tr No#
        $("#TRNo").autocomplete({
            source: function (request, response) {
                var data = {};
                data.trNo = $("#TRNo").val();
                data.FromLocation = UserLocationId;
                data.DeptId = ERPDeptId;
                data.UnitId = ERPUserId; //UserId
                data.flag = 1;
                $.ajax({
                    url: '../Inventory/LocationTransfernumbersearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-4',
                                label1: item.LocFrom + '  -->   ' + item.LocTo,
                                label: item.trNo,
                                label2: item.TRDate,
                                label3: item.Description,
                                trNo: item.trNo,
                                TRDate: item.TRDate,
                                FromLocation: item.FromLocation,
                                ToLocation: item.ToLocation,
                                TRDate: item.TRDate,
                                DAccount: item.DAccount,
                                CAccount: item.CAccount,
                                DAccountId: item.DAccountId,
                                CAccountId: item.CAccountId,
                                Comments: item.Comments,
                                DAccountName: item.DAccountName,
                                CAccountName: item.CAccountName,
                                DeptId: item.DeptId,
                                Qty: item.Qty,
                                User: item.User,
                                headers: ["tr No", "Transfer from->To", "Date", "Department"]
                            })
                        }));
                    }
                })
            },

            autoFocus: true,
            select: function (event, ui) {
                LOcQty = ui.item.Qty;
                $("#tblLocationTransfer tr").remove();
                $('#TRNo').val(ui.item.trNo);
                $('#Location').val(ui.item.FromLocation);
                $('#ToLocation').val(ui.item.ToLocation);
                $('#TRDate').val(ui.item.TRDate);
                $('#DebitAccount').val(ui.item.DAccount);
                $('#CreditAccount').val(ui.item.CAccount);
                $('#Comments').val(ui.item.Comments);
                $('#txtdacnt').val(ui.item.DAccountName);
                $('#txtcacnt').val(ui.item.CAccountName);
                $('#hiddendebit').val(ui.item.DAccountId);
                $('#hiddenCredit').val(ui.item.CAccountId);
                $('#User').val(ui.item.User);
                var trNo = ui.item.trNo;
                var dep = ui.item.DeptId;
                var data = {};
                data.trNo = trNo;
                data.DeptId = ui.item.DeptId;
                data.LocId = $("#Location").val();
                $.ajax({
                    type: "POST",
                    url: "../../inventory/LocationTransferGetansGets",
                    data: data,
                    success: function (result) {
                        if (trNo != 0) {
                            JsBarcode("#barcode1", dep + '-' + trNo);
                            LocationTransferGet(result.oList);
                        }


                    }
                });
                $('#TRDate').prop('disabled', true);
                $('#DebitAccountIn').prop('disabled', true);
                $('#CreditAccountIn').prop('disabled', true);
                $('#Comments').prop('disabled', true);

            },
        });


        function GetLocTransferList() {
            var dataPI = {};
            dataPI.FromDate = $('#ViewFromDate').val();
            dataPI.ToDate = $('#ViewToDate').val();
            dataPI.TransferDeptId = $('#UserDepartments').val();
            dataPI.DeptId = ERPDeptId;
            dataPI.UId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Inventory/LocationTransferList",
                data: dataPI,
                success: function (result) {

                    GetLocTransListView(result);


                }
            });
        }


        function GetLocTransListView(result) {

            $('#ViewFromDate,#ViewToDate,#UserDepartments').prop("disabled", false);
            disable_datatable('tbl_PIViewList');
            $('#purchaseViewForm').show();
            var responseText = "<thead><tr></th><th style='width:90px;'>Sl#</th><th>Transfer#</th><th>Date</th><th>From</th><th>To</th><th>DeptCode</th><th>Print</th></tr>" +
                "<tr><th> </th><th>Transfer#</th><th>Date</th><th>From</th><th>To</th><th>DeptCode</th><th> </th></tr></thead><tbody>";
            for (var l = 0; l < result.length; l++) {
                var slno = parseInt(l + 1);

                responseText += "<tr ondblclick=\"CopyFromView('" + result[l].trNo + "','"
                    + result[l].DeptId + "','"
                    + result[l].FromLocation + "','"
                    + result[l].ToLocation + "','"
                    + result[l].TRDate + "','"
                    + result[l].Qty + "','"
                    + result[l].DAccount + "','"
                    + result[l].CAccount + "','"
                    + result[l].DAccountName + "','"
                    + result[l].CAccountName + "','"
                    + result[l].DAccountId + "','"
                    + result[l].CAccountId + "','"
                    + $.trim(result[l].Comments) + "','"
                    + result[l].User + "',0)\">"

                    + "<td style='width:90px;' >" + slno + "</td>"
                    + "<td id=" + "InvoView_" + slno + ">" +
                    result[l].trNo + "</td><td>" +
                    result[l].TRDate + "</td><td>" +
                    result[l].LocFrom + "</td><td>" +
                    result[l].LocTo + "</td><td>" +
                    result[l].Description + "</td>"
                    + "<td><button class='btn white btn-round btn-xs' style='background-color:#009DA0;font-size:smaller;margin:0' " +

                    "onclick=\"CopyFromView('" + result[l].trNo + "','"
                    + result[l].DeptId + "','"
                    + result[l].FromLocation + "','"
                    + result[l].ToLocation + "','"
                    + result[l].TRDate + "','"
                    + result[l].Qty + "','"
                    + result[l].DAccount + "','"
                    + result[l].CAccount + "','"
                    + result[l].DAccountName + "','"
                    + result[l].CAccountName + "','"
                    + result[l].DAccountId + "','"
                    + result[l].CAccountId + "','"
                    + $.trim(result[l].Comments) + "','"
                    + result[l].User + "',1)\" autocomplete='off'>Print <i class='ft-printer'></i></button></td></tr>";
            }
            $('#tbl_PIViewList').html(responseText + '</tbody>');
            datatableWithsearch('tbl_PIViewList', 'Multiple');
        }

        function CopyFromView(trNo, DeptId, FromLocation, ToLocation, TRDate, Qty, DAccount, CAccount, DAccountName, CAccountName, DAccountId, CAccountId, Comments, User, Print) {
            JsBarcode("#barcode1", DeptId + '-' + trNo);
            $('#tblLocationTransfer tr').remove();
            enablecopy(FromLocation, ToLocation);
            $('#purchaseViewForm').hide();
            $("#tblLocationTransfer tr").remove();


            var data = {};
            data.trNo = trNo;
            data.DeptId = DeptId;
            data.LocId = FromLocation;
            $.ajax({
                type: "POST",
                url: "../../inventory/LocationTransferGetansGets",
                data: data,
                success: function (result) {

                    if (trNo != 0)

                        $('#Location').val(FromLocation);
                    $('#LocationHide').val(FromLocation);

                    LocationTransferGet(result.oList);
                    $('#TRNo').val(trNo);

                    $('#ToLocation').val(ToLocation);
                    $('#TRDate').val(TRDate);
                    $('#DebitAccount').val(DAccount);
                    $('#CreditAccount').val(CAccount);
                    $('#Comments').val(Comments);
                    $('#txtdacnt').val(DAccountName);
                    $('#txtcacnt').val(CAccountName);
                    $('#hiddendebit').val(DAccountId);
                    $('#hiddenCredit').val(CAccountId);
                    $('#User').val(User);
                    LOcQty = Qty;
                    if (Print == 1) {
                        $('#btnprint').click();
                    }
                }
            });
            $('#TRDate').prop('disabled', true);
            $('#DebitAccountIn').prop('disabled', true);
            $('#CreditAccountIn').prop('disabled', true);
            $('#Comments').prop('disabled', true);



        }
    </script>
