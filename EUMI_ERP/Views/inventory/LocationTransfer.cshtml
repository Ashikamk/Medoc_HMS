<script>

    //Print After Copy
    //function PrintthisBill() {
    //    PrintthisBillWindows('LOCATIONTRANSFER', i, 'MAIN');
    //}


    //Print After Copy
    function PrintthisBill(flg) {

        if ($('#tblLocationTransfer tr').length > 0) {
            if (flg == 0)            //Save
            { PrintthisBillWindows('LOCATIONTRANSFER', i, 'MAIN'); }
            else if (flg == 1)       //Copy
            { PrintthisBillWindows('LOCATIONTRANSFER', i, 'COPY'); }

        }
        else {
            warningshow('Please select a TR# to print', 'TRNo');
            $('#TRNo').select();
        }

    }
 </script>

