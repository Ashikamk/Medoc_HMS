<script>


    function calProfitpercentage(Id) {
        var vat = parseInt($('#TaxRate_' + Id).val() || 0);
        var Purrate = parseFloat($('#Rate_' + Id).val() || 0);
        var Mrp = parseFloat($('#MRP_' + Id).val() || 0);
        var LandingCost = parseFloat(Purrate + ((Purrate * vat) / 100) || 0);
        var Profit = parseFloat(((Mrp - LandingCost) / Mrp) * 100).toFixed(2);
        $('#marginststus').text('Marg(MRP) :' + Profit + '%')
    }


    function CalcSellingPriceWithMargin(Id) {





        var Margintype = "PLUSPURRATE1";

        if (Margintype == "PLUSPURRATE") {
            var Rate = parseFloat($("#Rate_" + Id).val() || 0).toFixed(Decimal);
            var Margin = parseFloat($("#Margin_" + Id).val() || 0).toFixed(Decimal);
            var SellingRate = parseFloat(Rate * (1 + (Margin / 100))).toFixed(Decimal);
        }
        else {
            var Rate = parseFloat($("#MRP_" + Id).val() || 0).toFixed(Decimal);
            var Margin = parseFloat($("#Margin_" + Id).val() || 0).toFixed(Decimal);
            var SellingRate = parseFloat(Rate - (Rate * (Margin / 100))).toFixed(Decimal);

        }

        $("#SR_" + Id).val(SellingRate);

        var vat = parseInt($('#TaxRate_' + Id).val() || 0);
        var Purrate = parseFloat($('#Rate_' + Id).val() || 0);
        var Mrp = SellingRate;
        var LandingCost = parseFloat(Purrate + ((Purrate * vat) / 100) || 0);
        var Profit = parseFloat(((Mrp - LandingCost) / Mrp) * 100).toFixed(2);
        $('#marginststusN').text('||(SR):' + Profit + '%')
        if (Profit < 0) {
            $('#marginststusN').animate({ color: 'red' }, 100);
        }
        else {
            $('#marginststusN').animate({ color: 'black' }, 100);
        }

    }


