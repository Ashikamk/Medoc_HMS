<style>
    .FormHeaderColour {
        background-color: #009da0 !important;
    }

    .FormHeader {
        height: 70px;
    }

    .MainBodyHead {
        background-color: #E0F3F4;
    }

    .label-control {
        font-weight: bold;
    }

    hr {
        margin-top: 0px;
        margin-bottom: 0px;
    }

    .smallTextbox {
        height: 40px !important;
    }

    .borderno {
        border: hidden !important;
    }

    #Tbl_Purchase tr td, #tblOtherCost tr td, #tbltaxsplit tr td, #tbltaxsplit tr th, #TBL_TempPurchaseList tr td, .taxsplittb tr td, .taxsplittb tr th {
        border: 1px solid #9faec3 !important;
    }


    .modal-xl {
        max-width: 90%;
    }

    .modal-sxl {
        max-width: 80%;
    }

    .modal-slg {
        max-width: 60%;
