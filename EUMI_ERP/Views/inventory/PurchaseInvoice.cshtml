                                                        <div class="toast-message">LPCost : <span id="descpopup"></span></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-12">
                                                <div class="row mb-1 px-2">

                                                    <table border="0" width="100%">
                                                        <tr>
                                                            <td class="pr-1"  width="350">
                                                                <label class="label-control">Product<span class="danger">*</span></label>
                                                                <input type="text" id="Product_0" class="form-control smallTextbox denull" name="NoEnterFlow">
                                                                <input type="hidden" id="Cess_0" class="form-control smallTextbox dezero" value="0">
                                                                <input type="hidden" id="ProductId_0" class="form-control dezero" />
                                                                <input type="hidden" id="ProductDesc_0" class="form-control denull" />
                                                            </td>
                                                            <td class="pr-1" width="90">
                                                                <label class="label-control">Batch<span class="danger">*</span></label>
                                                                <input type="text" id="Batch_0" class="form-control smallTextbox1 denull" onkeydown="FocusNext(event, 'Product_0', 'Batch_0', '', '', '')" name="NoEnterFlow">
                                                            </td>
                                                            <td class="pr-1" width="90">

                                                                <label class="label-control">Expiry<span class="danger">*</span></label>
                                                                <input type="text" id="Expiry_0" class="form-control smallTextbox1 denull" onkeypress="isNumberDate(event, this)" onkeyup="ExpiryDate('Expiry_0')" onkeydown="FocusNext(event, 'Batch_0', 'Expiry_0', 'Pack_0', '', '')" name="NoEnterFlow">

                                                            </td>

                                                            @*stephy*@




                                                            <td class="pr-1" width="90" style="">


                                                                <label class="label-control">Color</label>
                                                                <input type="text" id="Batch_color" class="form-control smallTextbox1 denull">

                                                            </td>
                                                            <td class="pr-1" width="90" style="">


                                                                <label class="label-control">Size</label>
                                                                <input type="text" id="Batch_size" class="form-control smallTextbox1 denull">

                                                            </td>
                                                            <td class="pr-1" width="90" style="">


                                                                <label class="label-control">Material</label>
                                                                <input type="text" id="Batch_material" class="form-control smallTextbox1 denull">

                                                            </td>

                                                            @*stephyend*@

                                                            <td class="pr-1" width="90" style="display:none;">


                                                                <label class="label-control">Pack<span class="danger">*</span></label>
                                                                <input type="text" id="Pack_0" class="form-control smallTextbox1 denull" onkeypress="isNumberInt(event, this)" onkeyup="CalcDiscRow(0, 0,0)" onkeydown="FocusNext(event, 'Expiry_0', 'Pack_0', 'Qty_0', '', '')" name="NoEnterFlow">

                                                            </td>
                                                            <td class="pr-1" width="90">

                                                                <label class="label-control">Quantity<span class="danger">*</span></label>
                                                                <input type="text" id="Qty_0" class="form-control smallTextbox1 denull" onkeypress="isNumberInt(event, this)" onkeyup="CalcDiscRow(0, 0,0)" onkeydown="FocusNext(event, 'Pack_0', 'Qty_0', 'Rate_0', '', '')" name="NoEnterFlow">

                                                            </td>
                                                            <td class="pr-1" width="90">

                                                                <label class="label-control">Free<span class="danger"></span></label>
                                                                <input type="text" id="Free_0" class="form-control smallTextbox1 denull" onkeypress="isNumberInt(event, this)" onkeyup="CalcDiscRow(0, 0,0)" onkeydown="FocusNext(event, 'Qty_0', 'Free_0', 'Loose_0', '', '')">

                                                            </td>
                                                            <td class="pr-1" width="90">

                                                                <label class="label-control">Loose<span class="danger"></span></label>
                                                                <input type="text" id="Loose_0" class="form-control smallTextbox1 denull" onkeypress="isNumberInt(event, this)" onkeyup="CalcDiscRow(0, 0,0)" onkeydown="FocusNext(event, 'Free_0', 'Loose_0', 'Rate_0', '', '')">

                                                            </td>
                                                            <td class="pr-1" width="90">

                                                                <label class="label-control">Pur. Rate<span class="danger">*</span></label>
                                                                <input type="text" id="Rate_0" class="form-control smallTextbox1 denull" onkeypress="isNumber(event, this)" onkeyup="CalcAmount(0),CalcDiscRow(0, 0, 0)" onkeydown="FocusNext(event, 'Qty_0', 'Rate_0', 'Discount_0', '', '')">

                                                            </td>

                                                            <td class="pr-1" width="90">


                                                                <label class="label-control">MRP<span class="danger">*</span></label>
                                                                <input type="text" id="MRP_0" class="form-control smallTextbox1 denull" onkeyup="mrpandsllingrate()" onkeypress="isNumber(event, this)" onkeydown="FocusNext(event, 'Discount_0', 'MRP_0', 'SR_0', '', '')">

                                                            </td>

                                                            <td class="pr-1" width="100">

                                                                <label class="label-control">Tax<span class="danger">*</span></label>
                                                                <select type="text" id="TaxId_0" class="form-control smallTextbox1 dezero" onkeydown="FocusNext(event, 'Rate_0', 'TaxId_0', 'DiscountPer_0', '', '')"></select>
                                                                <input type="hidden" id="TaxRate_0" value="0" />
                                                            </td>
                                                            <td class="pr-1" width="100">

                                                                <label class="label-control">Disc (%)<span class="danger"></span></label>
                                                                <input type="text" id="DiscountPer_0" class="form-control smallTextbox1 denull" onkeypress="isNumber(event, this)" onkeyup="CalcDiscRow(0, 1,0)" onkeydown="FocusNext(event, 'TaxId_0', 'DiscountPer_0', 'MRP_0', '', '')">

                                                            </td>
                                                            <td class="pr-1" width="100">

                                                                <label class="label-control">Disc Amt<span class="danger"></span></label>
                                                                <input type="text" id="Discount_0" class="form-control smallTextbox1 denull" onkeypress="isNumber(event, this)" onkeyup="CalcDiscRow(0, 0,0)" onkeydown="FocusNext(event, 'DiscountPer_0', 'Discount_0', 'MRP_0', '', '')">

                                                            </td>


                                                            <td class="pr-1" width="100">

                                                                <label class="label-control">Margin(%)</label>
                                                                <input type="text" id="Margin_0" class="form-control smallTextbox1 denull" onkeypress="isNumber(event, this)" onkeyup="CalcSellingPriceWithMargin(0)" keydown="FocusNext(event, 'Rate_0', 'Margin_0', 'SR_0', '', '')" name="NoEnterFlow">

                                                            </td>
                                                            <td class="pr-1" width="100">

                                                                <label class="label-control">Sell. Rate<span class="danger">*</span></label>
                                                                <input type="text" id="SR_0" class="form-control smallTextbox1 denull" onkeyup="ChangeSellRate(event)" onkeypress="isNumber(event, this)" onkeydown="CalcAmount(0),FocusNext(event, 'MRP_0', 'SR_0', 'MRP_0', '', '')" name="NoEnterFlow">

                                                            </td>

                                                            <td width="50">
                                                                <label class="label-control">ADD</label>
                                                                <button type="button" class="btn smallTextbox btn-warning m-0 btndis" id="btnadd" onkeydown="FocusNext(event, 'MRP_0', 'btnadd', '', '', '')"><i class="fa fa-1x fa-plus"></i></button>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                    <div class="col-md-1" style="display:none">

                                                        <label class="label-control">Distributer Rate<span class="danger">*</span></label>
                                                        <input type="text" id="DR_0" class="form-control smallTextbox denull">
                                                        <label class="label-control">Location<span class="danger">*</span></label>
                                                        <select id="Locn_0" class="form-control smallTextbox dezero"></select>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="px-2">
                                    <div id="customView" class="jsgrid" style="position: relative; height: 426px; width: 100%;overflow-x: auto;overflow-y:hidden ">
                                        <div class="jsgrid-grid-header" style="width:200%;">
                                            <table class="jsgrid-table" style="width:100%;">
                                                <tr class="jsgrid-header-row">
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:2%"><i class="icon-trash"></i></th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:3%">SL#</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:13%">Name</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%;">Batch</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:4%">Expiry</th>


                                                    @*stephy*@
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:3%">Color</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:3%">Size</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:3%">Material</th>

                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:4%;display:none;">Pack</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:4%">Qty</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:4%">Free</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Rate</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Tax</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Amount</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%;">Dis (%)</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%;">Discount</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Sell. Rate</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">MRP</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">TQty</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">TLQty</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Taxable</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Tax Amt</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Amount</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Margin %</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Cess</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%">Other Cost</th>
                                                    <th class="jsgrid-header-cell jsgrid-align-center" style="width:5%;display:none">None</th>
                                                </tr>
                                            </table>
                                        </div>
                                        <div id="proddiv" class="" style="position: relative; overflow-x: auto;overflow-y:scroll; height: 360px; width:200%;">
                                            <table class="jsgrid-table" id="Tbl_Purchase"></table>
                                        </div>
                                    </div>
                                </div>
                                <div class="p-2">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-9">
                                                <table style="width:100%">
                                                    <tr>
                                                        <td class="p-0" width="20%" valign="top">
                                                            <textarea id="txtnotes" style="height:100%;border:none;resize:none;" rows="1" class="form-control denull" placeholder="Remarks"></textarea>

                                                        </td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;">
                                                            <b>Dis</b>
                                                            <div class="custom-control custom-checkbox" style="float:right;">
