                                                                <label class="custom-control-label" for="DiscFromGrandTotal"></label>
                                                            </div>
                                                        </td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>Dis%</b></td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>Tot.Dis</b></td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>Taxable</b></td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>Tax</b></td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;display:none">
