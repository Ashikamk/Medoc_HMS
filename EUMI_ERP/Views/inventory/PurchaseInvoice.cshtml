                                                                <label class="custom-control-label" for="CessCheck"></label>
                                                            </div>
                                                        </td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>Less</b></td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>Add</b></td>
                                                        <td class="bordertable" width="5%" valign="middle" style="text-align:center;font-weight:500;"><b>TCS</b></td>
