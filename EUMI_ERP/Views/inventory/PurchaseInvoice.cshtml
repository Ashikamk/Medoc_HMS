                            <div class="col-md-2 text-right">
                                <div class="row  text-right">
                                    <span class="btn p-0" onclick="$('#ShortCutDiv').toggle('slow','linear')">
                                        <span id="CrntMode" class="badge badge-primary">Mode : New</span>
                                    </span>
                                    @*<i class="ft-calendar" style="font-weight:normal;font-size:xx-large;color:white;"></i>*@
                                    @*<input type="text" id="PharmaPIDate" style="width:150%;background-color:#009da0;border:none;color:white;font-size:xx-large" onfocus="FocusDate(this)" onkeydown="DateKeyDown(event,this)" class="form-control FormHeaderColour input-lg col-md-10 dedisa" disabled>*@
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="card-content collapse show">
                        <div class="card-body">
                            <form action="#">
                                <div class="form-body">
                                    <hr />
                                    <div class="MainBodyHead">

                                        <div class="col-md-12 pt-1">
                                            <div class="row">
                                                <div class="col-md-10">
                                                    <div class="row mb-1">
                                                        <label class="label-control col-lg-1">Invoice#<span class="danger">*</span></label>
                                                        <div class="col-md-1">
                                                            <input type="text" class="form-control smallTextbox dedisa" id="PINo_A" disabled>
                                                        </div>
                                                        @*=====div for page load======*@
                                                        <div class="col-md-3" id="purchaseinv">
                                                            <div class="input-group m-0">
                                                                <input type="text" class="form-control smallTextbox denull" id="PINo_S" onkeyup="SearchSupplierInvoice()">
                                                                <div class="input-group-append">
                                                                    <button type="button" id="btnlist" class="btn btn-outline-primary smallTextbox"><i class="ft-search"></i></button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        @*============================*@

                                                        @*===div for copy===*@
                                                        <div class="col-md-3" id="copypurchase" style="display:none;position:inherit;">
                                                            <div class="input-group m-0">
                                                                <div class="input-group-prepend">
                                                                    <span class="input-group-btn" title="Previous">
                                                                        <button type="button" id="btnprvs" onclick="GetBillPrevousornext(-1)" class="btn smallTextbox btn-outline-primary"><i class="ft-chevron-left"></i></button>
                                                                    </span>
                                                                </div>
                                                                <input type="text" class="form-control smallTextbox denull" id="PINo_C" placeholder="Search Invoice">
                                                                <div class="input-group-append">
                                                                    <span class="input-group-btn" title="Next">
                                                                        <button type="button" id="btnnxt" onclick="GetBillPrevousornext(1)" class="btn smallTextbox btn-outline-primary"> <i class="ft-chevron-right"></i></button>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        @*=================*@
                                                        <label class="label-control col-lg-1 text-lg-right" style="font-weight:bold">Location<span class="danger">*</span></label>
                                                        <div class="col-md-2 ">
                                                            <select id="Location" class="form-control smallTextbox"></select>
                                                        </div>
                                                        <label class="label-control col-lg-1 text-lg-right">Inv.Dt<span class="danger">*</span></label>
                                                        <div class="col-md-2">

                                                            <input type="text" id="PharmaPIDate" class="form-control smallTextbox" />
                                                            <select style="display:none" id="PRType" name="priority" class="form-control smallTextbox" onchange="CalcAmt(), ResetBillDiscount();">

                                                                <option value="Local">Local</option>
                                                                <option value="Import">Import</option>

                                                            </select>
                                                            <input type="hidden" id="ImpTax" />
                                                        </div>

                                                    </div>
                                                    <div class="row mb-1">
                                                        <label class="label-control col-lg-1" style="font-weight:bold">Supplier<span class="danger">*</span></label>

                                                        <div class="col-md-4 ">
                                                            <input type="text" id="Supplier" class="form-control smallTextbox denull">

                                                        </div>
                                                        <input type="hidden" id="SupplierId" class="form-control dezero" value="0" />

                                                        <label class="label-control col-lg-1 text-lg-right">Pay Type<span class="danger">*</span></label>
                                                        <div class="col-md-2">
                                                            <select id="PayType" name="priority" class="form-control smallTextbox">

                                                                <option value="2">Credit</option>
                                                                <option value="1">Cash</option>

                                                            </select>
                                                        </div>

                                                        <label class="col-lg-1 text-lg-right" style="font-weight:bold">Inv. Total<span class="danger">*</span></label>
                                                        <div class="col-md-2">

                                                            <table width="100%">
                                                                <tr>
                                                                    <td>
                                                                        <input type="text" id="FCInvoiceTotal" value="0.00" class="form-control smallTextbox dediszero" onkeypress="isNumber(event, this)" onkeyup="CalcInvoice()">
                                                                    </td>
                                                                    <td>
                                                                        <input type="text" id="FCdiff" readonly value="0.00" class="form-control smallTextbox dediszero" onkeypress="isNumber(event, this)" onkeyup="CalcInvoice()">

                                                                    </td>
                                                                </tr>
                                                            </table>

                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-2">
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            <h1 class="text-center m-0 p-1 detextdiszero" id="FCTextTotal" style="color:red;font-weight:500">0.00</h1>



                                                        </div>
                                                    </div>
                                                    <div class="row" style="display:none1;">
                                                        <h2 class="text-right m-0 detextnull" id="BaseTextTotal" style="color:red;font-weight:500;display:none">dsdsd</h2>
                                                        <div style="margin-left:-100px;position:fixed" class="col-md-12">

                                                            <table>
                                                                <tr><td> <span style="font-weight:bold" id="marginststus"></span></td><td> <span style="font-weight:bold" id="marginststusN"></span></td></tr>
                                                            </table>



                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <hr />
                                    <div class="px-2">
