<script>


    $(document).ready(function () {
        document.onkeydown = function (evt) {
            evt = evt || window.event;
            var isEscape = false;
            if ("key" in evt) {
                isEscape = (evt.key === "Escape" || evt.key === "Esc");
            } else {
                isEscape = (evt.keyCode === 27);
            }
            if (isEscape) {
                $('#Discountpercent').select()
                $('#Discountpercent').focus()

            }
        };



        $('#Discountpercent').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                e.preventDefault();
                $("#btnsubmit").focus();

            }
        });


    });




    function othercostchange() {

        var taxable = parseFloat($('#tottaxable').val() || 0);
        var tax = parseFloat($('#tottax').val() || 0)
        var Add1 = parseFloat($('#otrcost').val() || 0);
        var Add2 = parseFloat($('#otrcost1').val() || 0);
        var less1 = parseFloat($('#otrcost2').val() || 0);

        var Total = parseFloat((taxable + tax + Add1 + Add2) - less1).toFixed(2);
        $('#FCTextTotal').text(Total || 0)
        //$('#BaseTotalCess').val(Other);
        $("#BaseAmount").val(Total || 0);

        debugger;
        var txtinvototal = parseFloat($('#FCInvoiceTotal').val() || 0);
        var LDiff = parseFloat(txtinvototal - Total);
        $('#FCdiff').val((LDiff).toFixed(2));
    }




</script>

