        border: 1px solid #CCD6E6;
    }

    .bordertable {
        border: 2px solid #CCD6E6;
    }

    .modalProduct {
        position: absolute;
        top: 55px;
    }

    .txtbl {
        color: royalblue !important;
        font-weight: 500 !important;
        /*font-size:x-large!important;*/
    }
</style>
<div class="myData" data-x="M347" />

<div style="display:none">

    <input type="text" id="GridLength" value="0" class="dezero">
    <input type="text" id="CostGridLength" value="0" class="dezero">
    <input type="text" id="BInvoiceTotal" class="dezero" value="0">
    <input type="text" id="JobId" class="dezero" value="0">

    <input type="text" id="BaseAmount" class="dezero" value="0">
    <input type="text" id="FCAmount" class="dezero" value="0">
    <input type="text" id="BaseTaxable" class="dezero" value="0">
    <input type="text" id="BaseTax" class="dezero" value="0">

    <input type="text" id="BaseDiscount" class="dezero" value="0">

    <input type="text" id="HiddenGrandTotal" class="dezero" value="0">
    <input type="text" id="HiddenTaxable" class="dezero" value="0">
    <input type="text" id="HiddenTax" class="dezero" value="0">
    <input type="text" id="TempSlNo" class="dezero" value="0">
</div>
<div id="Entry" style="width:100%;">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
