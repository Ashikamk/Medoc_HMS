<script>
    function Upload() {

        //Reference the FileUpload element.
        var fileUpload = document.getElementById("fileUpload");

        //Validate whether File is valid Excel file.
        var regex = /^([a-zA-Z0-9\s_\\.\-:])+(.xls|.xlsx)$/;
        if (regex.test(fileUpload.value.toLowerCase())) {
            if (typeof (FileReader) != "undefined") {
                var reader = new FileReader();

                //For Browsers other than IE.
                if (reader.readAsBinaryString) {
                    reader.onload = function (e) {
                        ProcessExcel(e.target.result);
                    };
                    reader.readAsBinaryString(fileUpload.files[0]);
                } else {
                    //For IE Browser.
                    reader.onload = function (e) {
                        var data = "";
                        var bytes = new Uint8Array(e.target.result);
                        for (var i = 0; i < bytes.byteLength; i++) {
                            data += String.fromCharCode(bytes[i]);
                        }
                        ProcessExcel(data);
                    };
                    reader.readAsArrayBuffer(fileUpload.files[0]);
                }

            } else {
                warningshow("This browser does not support HTML5.");
            }
        } else {
            warningshow("Please upload a valid Excel file.");
        }




    };


    function supplierchecking() {

        var data = {};
        data.CustName = $('#Supplier').val();
        data.CustType = 'S';

        $.ajax({
            url: '../Master/CustomerOrSupplierSearch',
            type: "POST",
            data: data,
            dataType: "json",
            success: function (data) {

                if (data.length == 0) {
                    warningshow("Please Select Valid Supplier or Create Supplier");
                }
                else {
                    $('#Supplier').val(data[0].CustName)
                    $('#SupplierId').val(data[0].CustId)
                }

            }
        })



    }



    function ProcessExcel(data) {
        var a = 0; b = 0; c = 0; d = 0; e = 0;
        //Read the Excel File data.
        var workbook = XLSX.read(data, {
            type: 'binary'
        });

        //Fetch the name of First Sheet.
        var firstSheet = workbook.SheetNames[0];
        var SecondSheet = workbook.SheetNames[1];



        //Read all rows from First Sheet into an JSON array.
        var excelRows = XLSX.utils.sheet_to_row_object_array(workbook.Sheets[firstSheet]);

        var HeaderDetails = XLSX.utils.sheet_to_row_object_array(workbook.Sheets[SecondSheet]);

        console.log(workbook.Sheets[SecondSheet])
        var HD = workbook.Sheets[SecondSheet]
        ///$('#PINo_S').val(HD.D1['v'])
        // $('#Supplier').val(HD.F1['v'])
        //supplierchecking();

        for (var k = 0; k < excelRows.length; k++) {

            if (excelRows[k]["itemcode"] == '' || excelRows[k]["itemcode"] == undefined || excelRows[k]["itemcode"] == '') {
                a = 1;
                break;
            }
            if (excelRows[k]["batchno"] == 0 || excelRows[k]["batchno"] == undefined || excelRows[k]["batchno"] == '') {
                d = 1;
                break;
            }
            if (excelRows[k]["expdate"] == 0 || excelRows[k]["expdate"] == undefined || excelRows[k]["expdate"] == '') {
                e = 1;
                break;
            }
            if (excelRows[k]["invqty"] == 0 || excelRows[k]["invqty"] == undefined || excelRows[k]["invqty"] == '') {
                b = 1;
                break;
            }
            if (excelRows[k]["salerate"] == 0 || excelRows[k]["salerate"] == undefined || excelRows[k]["salerate"] == '') {
                c = 1;
                break;
            }

        }




        if (a != 0) {
            warningshow("Please Enter Code of all Items");
        }
        else if (b != 0) {
            warningshow("Please Enter Quantity for all Items");
        }
        else if (c != 0) {
            warningshow("Please Enter Rate for all Items");
        }
        else if (d != 0) {
            warningshow("Please Enter Batch for all Items");
        }
        else if (e != 0) {
            warningshow("Please Enter Exp Date for all Items");
        }
        else {

            //Add the data rows from Excel file.

            var sl = 0;
            $('#tblAlert tr').remove();
            $('#Tbl_Purchase tr').remove();


            var la = 1;
            var oArray = new Array();
            for (var j = 0; j <= excelRows.length; j++) {


                if (j < excelRows.length) {

                    var Product = ''; Description = ''; Batch = ''; Expiry = ''; Unit = ''; Quantity = ''; Rate = ''; Discount = ''; MRP = ''; TaxRate = '';

                    if (excelRows[j]["itemcode"] == undefined) { Product = '' } else {
                        Product = excelRows[j]["itemcode"]
                    }
                    if (excelRows[j]["itemname"] == undefined) { Description = '' } else {
                        Description = excelRows[j]["itemname"]
                    }
                    if (excelRows[j]["batchno"] == undefined) { Batch = '' } else {
                        Batch = excelRows[j]["batchno"]
                    }
                    if (excelRows[j]["expdate"] == undefined) { Expiry = '' } else {
                        Expiry = excelRows[j]["expmonth"] + "/" + excelRows[j]["expyear"]
                    }
                    if (excelRows[j]["invqty"] == undefined) { Quantity = '0' } else {
                        Quantity = excelRows[j]["invqty"]
                    }
                    if (excelRows[j]["packname"] == undefined) { Unit = '' } else {
                        Unit = excelRows[j]["packname"]
                    }
                    if (excelRows[j]["salerate"] == undefined) { Rate = '0' } else {
                        Rate = excelRows[j]["salerate"]
                    }
                    if (excelRows[j]["Discount"] == undefined) { Discount = '0' } else { Discount = excelRows[j]["Discount"] }
                    if (excelRows[j]["itemmrp"] == undefined) { MRP = '0' } else {
                        MRP = excelRows[j]["itemmrp"]
                    }
                    if (excelRows[j]["cgstper"] == undefined) { TaxRate = '0' } else {
                        TaxRate = excelRows[j]["cgstper"] * 2
                    }


                    oArray.push({
                        'SlNo': parseInt(j + 1),
                        'ItemCode': $.trim(Product),
                        'ItemDescription': $.trim(Description),
                        'Batch': $.trim(Batch),
                        'Expiry': $.trim(Expiry),
                        'Quantity': $.trim(Quantity),
                        'Unit': $.trim(Unit),
                        'Rate': $.trim(Rate),
                        'Discount': $.trim(Discount),
                        'MRP': $.trim(MRP),
                        'TaxRate': $.trim(TaxRate),
                    })

                }
                else if (j == excelRows.length) {
                    console.log(oArray)
                    var data = { 'PharmacyModel': oArray };

                    $.ajax(
                        {
                            type: "POST",
                            url: "../Pharmacy/HMS_ItemExcelImport",
