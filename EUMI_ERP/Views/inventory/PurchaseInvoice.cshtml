                                                            <button type="button" class="btn btn-outline-info mb-0 mr-1 btn-sm" onclick="TempPurchaseShow()">Temp</button>

                                                            <button type="button" class="btn btn-outline-info mb-0 mr-1 btn-sm" onclick="newitemadd()">Item <i class="ft-plus-square"></i></button>
                                                            <button type="button" class="btn btn-outline-info mb-0 mr-1 btn-sm" onclick="newisupplieradd()">Supplier <i class="ft-plus-square"></i></button>



