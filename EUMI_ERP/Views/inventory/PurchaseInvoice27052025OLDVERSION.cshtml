    function GetPIListView(result) {
        $('#ViewFromDate,#ViewToDate,#SelectReports').prop("disabled", false);
        disable_datatable('tbl_PIViewList');
        $('#purchaseViewForm').show();
        var responseText = "<thead><tr><th>Sl#</th><th>PI#</th><th>Invoice#</th><th>Date</th><th width=40%>Supplier</th><th>PType</th><th>TQty</th><th>Grand Total</th><th>User</th><th>Transfer#</th><th>Print</th></tr>" +
            "<tr><th> </th><th>PI#</th><th>Invoice#</th><th>Date</th><th>Supplier</th><th>PType</th><th>TQty</th><th>GrandTotal</th><th>User</th><th>Transfer#</th><th> </th></tr></thead><tbody>";
        for (var l = 0; l < result.length; l++) {
            var slno = parseInt(l + 1);

            var Transfer = '';

            if (parseInt(result[l].Variable1 || 0) != 0) {
                Transfer = 'Performa# - '
            }
            else if (parseInt(result[l].Variable2 || 0) != 0) {
                Transfer = 'MRV# - '
            }
            else if (parseInt(result[l].PONo || 0) != 0) {
                Transfer = 'PO# - '
            }

            responseText += '<tr ondblclick="GetCopyofThisPurchase(\'' + result[l].SlNo + '\',\'' + result[l].DepartmentId + '\',\'0\')"><td style="" align="center">' + slno + '</td><td id=' + 'InvoView_' + slno + '>' +
                result[l].SlNo + '</td><td>' +
                result[l].InvoNo + '</td><td>' +
                result[l].InvoDate + '</td><td>' +
                result[l].SupplierName + '</td><td>' +
                result[l].PurchaseType + '</td><td align="center">' +
                result[l].Quantity + '</td><td align="right">' +
                parseFloat(result[l].GrandTotal).toFixed(Decimal) + '</td><td>' +
                result[l].AccName + '</td><td>' +
                Transfer + result[l].LPO + '</td>' +
                '<td><button class="btn white btn-round btn-xs" style="background-color:#009DA0;font-size:smaller;margin:0" onclick="GetCopyofThisPurchase(\'' + result[l].SlNo + '\',\'' + result[l].DepartmentId + '\',\'1\')" autocomplete="off">Print <i class="ft-printer"></i></button></td></tr>';
        }
        $('#tbl_PIViewList').html(responseText + '</tbody>');
        datatableWithsearch('tbl_PIViewList', 'Multiple');

    }
    function GetCopyofThisPurchase(slno, dept, Print) {
        var data = {};
        data.SlNo = slno;
        data.DepartmentId = dept;
        $.ajax({
            type: "POST",
            url: "../Purchase/PurchaseInvoiceGetandGets",
            data: data,
            success: function (result) {
                formrefresh(1);

                PurchaseGets(result.oList);
                $('#btnnew').focus();
                $('.form-control').prop('disabled', true);
                $('#copypurchaseinvo,#btnprvs,#btnnxt,#SelectReports').prop("disabled", false);
