        row += '<tr><td> </td><td></td><td><b>Purchase Type</b></td><td><b>' + Purchasetype + '</b></td><td></td><td></td><td><b>Total</b></td><td><b>' + Amount + '</b></td><td></td></tr>'
        row += '<tr><td>Item Code</td><td>Name</td><td>Unit</td><td>Qantity</td><td>Rate</td><td>Discount</td><td>Taxable Amount</td><td>Tax Amount</td><td>Amount</td></tr>'

        for (k = 1; k < i; k++) {
            var ProductId = $('#productId_' + k).val();                               var ProductCode = $('#product_' + k).val();
            var ProductDescr = $('#productdesc_' + k).val();                        
            var UnitId = $('#unit_' + k).val();
            var UnitName = $('#unit_' +k+' option:selected').text();
            var ProdQty = $('#quantity_' + k).val();
            var ProdRate = $('#baserate_' + k).val();                                 var FcProdRate = $('#txtrate_' + k).val();
            var ProdDisc = $('#basediscount_' + k).val();                             var FcProdDisc = $('#discount_' + k).val();
            var TaxableAmount = $('#basetaxableamount_' + k).val();                   var FCTaxableAmount = $('#txttaxable_' + k).val();
            var TaxId = $('#tax_' + k).val();                                         var TaxPercent = $('#taxpercentage_' + k).val();
            var TaxAmount = $('#basetaxamount_' + k).val();                           var FCTaxAmount = $('#txttax_' + k).val();
            var Amount = $('#baseamount_' + k).val();                                 var FCAmount = $('#amount_' + k).val();
            var LocnId = $('#select_location' + k).val();
            row += '<tr><td>' + ProductCode + '</td><td>' + ProductDescr + '</td><td>' + UnitName + '</td><td>' + ProdQty + '</td><td>' + ProdRate + '</td><td>' + ProdDisc + '</td><td>' + TaxableAmount + '</td><td>' + TaxAmount + '</td><td>' + Amount + '</td></tr>'
        }
