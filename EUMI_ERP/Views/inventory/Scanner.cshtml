<script>
    $("#txtBillSlNocopy").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.BillSlNo = $("#txtBillSlNocopy").val();
            data.BillSeriesId = $("#txtBillseriesId").val();
            data.LocId = UserLocationId;;
            data.DeptId = ERPDeptId;

                $.ajax({
                    url: '../SalesInvoice/SerialNoSearch',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {

                        if ($.trim($("#txtBillSlNocopy").val()) != '') {
                            response($.map(data, function (item) {
                                return ({
                                    ColCount: '3',
                                    label: item.BillSlNo,
                                    label1: item.CustName,
                                    label2: item.InvDate,
                                    billsl: item.BillSlNo,
                                    billseries: item.BillSeriesId,
                                    headers: ["Bill No", "Customer Name", "Inv Date"]
                                })
                            }));
                        }
                        else {
                            $('.ui-autocomplete').hide();


                        }

                    }
                })

        },
        autoFocus: true,
        select: function (event, ui) {
            var data = {};
            data.BillSeriesId = ui.item.billseries;
            data.BillSlNo = ui.item.billsl;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../SalesInvoice/PackingHistoryGetandGets",
                data: data,
                success: function (result) {
                    PackingGets(result.oList);
                    getdiffrence();
                    $('#txtscancode').focus();
                }
            })
        },

    });


    $("#txtloctrcopy").autocomplete({
