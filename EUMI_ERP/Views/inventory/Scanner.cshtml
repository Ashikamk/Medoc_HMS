    function ExportToExcel() {
        if ($("#PackingList tr").length == 0) {
            warningshow('Please Select the Bill....');
        }
        else {


            $('#tblExport thead tr').remove();
            $('#tblExport tbody tr').remove();

            var Title = "Deliver Order# : " + $("#txtslno").val();

            var responseTextExcel = "<thead><tr><th  colspan=9><b><center>" + Title + "</center></b></th></tr>";

            if ($("#BillType").val() == 0) {
                responseTextExcel += "<tr><th  colspan=5><b>Sales Bill</b></th>" +
                                         "<th  colspan=4><b>BillNo : " + $("#txtBillseriesId option:selected").html() + ' - ' + $("#txtBillSlNocopy").val() + "</b></th></tr>";
                responseTextExcel += "<tr><th  colspan=5><b>Customer : " + $("#txtcustomer").val() + "</b></th>" +
                                        "<th  colspan=4><b>SalesMan : " + $("#txtsalesman").val() + "</b></th></tr>";
            }
            else if ($("#BillType").val() == 1) {

                responseTextExcel += "<tr><th  colspan=5><b>Location Transfer</b></th>" +
                                         "<th  colspan=4><b>BillNo : " + $("#txtloctrcopy").val() + "</b></th></tr>";
                responseTextExcel += "<tr><th  colspan=5><b>From Location : " + $("#txtfromloc").val() + "</b></th>" +
                                        "<th  colspan=4><b>To Location : " + $("#txttoloc").val() + "</b></th></tr>";

            }
            responseTextExcel += "<tr>" +
           "<th><b>Sl#</b></th>" +
           "<th><b>Product</b></th>" +
           "<th><b>Description</b></th>" +
           "<th><b>Unit</b></th>" +
           "<th><b>Location</b></th>" +
           "<th><b>Invoice Qty</b></th>" +
           "<th><b>Scanned Qty</b></th>" +
           "<th><b>Issued Qty</b></th>" +
           "<th><b>Difference</b></th>" +
           "</tr></thead><tbody>"

            var newslno = 1;

            for (var i = 0; i < $('#PackingList tr').length ; i++) {


                var slno = parseInt(i + 1);


                responseTextExcel += '<tr id="RowTrExcel_' + slno + '">' +
                        '<td>' + newslno + '</td>' +
                        '<td>' + $("#itemcode" + slno).text() + '</td>' +
                        '<td>' + $("#Des" + slno).text() + '</td>' +
                        '<td>' + $("#unit" + slno).text() + '</td>' +
                        '<td>' + $("#locn" + slno).text() + '</td>' +
                        '<td>' + $("#invoiceqty" + slno).text() + '</td>' +
                        '<td>' + $("#scanqty" + slno).text() + '</td>' +
                        '<td>' + $("#issuedqty" + slno).text() + '</td>' +
                        '<td>' + $("#diff" + slno).text() + '</td>' +
                        '</tr>';
                newslno++;

            }
            $('#tblExport').html(responseTextExcel + '</tbody>');

            $("#tblExport").table2excel({
                filename: Title+".xls"
            });
        }
    }

    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

</script>
<script>
