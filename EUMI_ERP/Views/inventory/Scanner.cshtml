                   '<tr><td colspan="2">Date&Time</b></td><td colspan="3">: ' + $('#dttime').text() + '</td></tr>' +
                   '<tr><td colspan="2">User</b></td><td colspan="3">: ' + $('#txtuser').val() + '</td></tr>'+
                   '<tr><td colspan="2">Inv.No</td><td colspan="4">: ' + $('#DepatmentCode').val() + ' - ' + $('#txtloctrcopy').val() + '</td></tr>' +
