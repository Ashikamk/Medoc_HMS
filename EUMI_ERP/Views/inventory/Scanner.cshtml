<script>
    $("#Search").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.GarageName = $("#Search").val();

            $.ajax({
                url: '../SalesInvoice/GarageNameSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3',
                            label: item.GarageName,
                            label1: item.CustAddress,
                            label2: item.GaragePhone,
                            garagename: item.GarageName,
                            txtlgrgadr: item.CustAddress,
                            GarageNo: item.GaragePhone,
                            headers: ["Name", "Address", "Phone No"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#Search').val(ui.item.garagename);
            GetSalesSummary(0, 0, 0, 0, 0, $('#Location').val(), $('#Search').val(), 0)
        },

    });


    $(document).ready(function () {
        $('#Search').focus();
        $('#DateFrom').val(CurDate);
        $('#DateTo').val(CurDate);
        GetLocation(0);
        $('#Location').val(UserLocationId);
        GetSalesDetails(0, 0, 0, 0, 0, UserLocationId, $('#Search').val(), 0, 0);

        GetSalesSummary(0, 0, 0, 0, 0, UserLocationId, $('#Search').val(), 0)



        setInterval(function ()
        {
            var rowCount2 = document.getElementById('salesdetails').rows.length;
            $('#Location').val(UserLocationId);
            $('#Search').val('');
            if ($('#btndetail').prop("checked") == true) {
                GetSalesDetails(0, 0, 0, 0, 0, $('#Location').val(), $('#Search').val(), 0, 1)
                var A = 0;
            }
            else {
                GetSalesDetails(0, 0, 0, 0, 0, $('#Location').val(), $('#Search').val(), 0, 0);

                GetSalesSummary(0, 0, 0, 0, 0, $('#Location').val(), $('#Search').val(), 0)


                var A = 0;
            };
            if (A == 0) {
                for (var i = 1; i <= (rowCount2 - 2) ; i++) {
                    if (i == rowCount2 - 2)
                        A = 1;

                    if ($('#btndetail').prop("checked") == true) {
                        if (($('#ColD13_' + i).text() == '0') && ($('#ProductIdD' + i).val() > 0) && ($('#BillnoD' + i).val() > 0)) {
                            printthisoutbill(i, $('#BillSeriesIdD' + i).val(), $('#BillnoD' + i).val(), $('#ProductIdD' + i).val(), $('#ColD14_' + i).text(), $('#ColD15_' + i).text(), $('#ColD12_' + i).text(), $('#UserIdD' + i).val())
                            $('#ColD13_' + i).text('Noprint')
                        }
                    }

