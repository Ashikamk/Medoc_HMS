                    '<tr><td colspan="2">Inv.No</td><td colspan="4">: ' + $('#DepatmentCode').val() + ' - ' + $('#txtBillseriesId option:selected').html() + '-' + $('#txtBillSlNocopy').val() + '</td></tr>' +
