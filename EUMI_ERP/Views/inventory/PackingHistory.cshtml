<script>
    function printthisoutbill() {
      
        var rowCount = document.getElementById('PackingList').rows.length;
        if (rowCount == 0) {
            warningshow('Please Select the Bill....');
            return false;
        }
        else {
            var flgg = 0;
            for (var k = 1; k <= rowCount; k++) {
                
               
                if ($('#scanqty' + k).text() == 0 && flgg != 1) {
                    
                    flgg = 0;
                }
                else if (($('#scanqty' + k).text() != 0)) {
                    
                    flgg = 1;
                   
                }
                
            }

            if (flgg == 0)
            {
                ScanItem();
            }
            else
            {
                var Nof = 0;

                for (var k = 1; k <= rowCount; k++) {

                    if ($('#issuedqty' + k).text() > 0) {
                        Nof = parseFloat(Nof || 0) + parseFloat($('#scanqty' + k).text() || 0);
                    }

                }

                loc = window.LoggedInUserArray[4];
                var myWindow = window.open("", "", "width=400,height=1500");

                myWindow.document.write('<style type="text/css">.printbdy1{font-family:tahoma; font-size: 12px;}.printbdy{ border-collapse: collapse;font-family:tahoma; font-size: 10px;} .printbdy tr td {border:0.5px solid black;border-top:none;}.printbdy th {border:0.5px solid black;}.tbl1{ } </style>');


                if ($("#BillType").val() == 0) {
                    myWindow.document.write('<table  class=printbdy1 width="100%"><tr><td colspan="6"  style="border-bottom:1px solid black;text-align:center"><b>ABDULLA & NASIR</b></td></tr>' +
                    '<tr><td colspan="8" style="border-bottom:1px solid black;text-align:center"><b>PARTS OUT BILL</b></td></tr>' +
                    '<tr><td colspan="2">LOCATION</b></td><td colspan="3">: ' + loc + '</td></tr>' +
                    '<tr><td colspan="2">Out No</td><td colspan="4">: ' + $('#txtslno').val() + '</td></tr>' +
                    '<tr><td colspan="2">Date&Time</b></td><td colspan="3">: ' + $('#dttime').text() + '</td></tr>' +
                    '<tr><td colspan="2">SalesMan</td><td colspan="4">: ' + $('#txtsalesman').val() + '</td></tr>' +
                    '<tr><td colspan="2">User</b></td><td colspan="3">: ' + $('#txtuser').val() + '</td></tr>' +
                    '<tr><td colspan="2">Customer</td><td colspan="4">: ' + $('#txtcustomer').val() + '</td></tr>' +
                    //'<tr><td colspan="2">Driver</b></td><td colspan="3">: ' + $('#txtdriver option:selected').html() + '</td></tr>' +
                    '<tr><td colspan="2">Inv.No</td><td colspan="4">: ' + $('#DepatmentCode').val() + ' - ' + $('#txtBillseriesId option:selected').html() + '-' + $('#txtBillSlNocopy').val() + '</td></tr>' +
                    '<tr><td colspan="2">Quantity</b></td><td colspan="3">: ' + Nof + '</td></tr></table>');
                }
                else {

                    myWindow.document.write('<table  class=printbdy1 width="100%"><tr><td colspan="6"  style="border-bottom:1px solid black;text-align:center"><b>ABDULLA & NASIR</b></td></tr>' +
                   '<tr><td colspan="8" style="border-bottom:1px solid black;text-align:center"><b>PARTS OUT BILL</b></td></tr>' +
                   '<tr><td colspan="2">From Location</b></td><td colspan="3">: ' + $('#txtfromloc').val() + '</td></tr>' +
                   '<tr><td colspan="2">To Location</b></td><td colspan="3">: ' + $('#txttoloc').val() + '</td></tr>' +
                   '<tr><td colspan="2">Out No</td><td colspan="4">: ' + $('#txtslno').val() + '</td></tr>' +
                   '<tr><td colspan="2">Date&Time</b></td><td colspan="3">: ' + $('#dttime').text() + '</td></tr>' +
                   '<tr><td colspan="2">User</b></td><td colspan="3">: ' + $('#txtuser').val() + '</td></tr>'+
                   '<tr><td colspan="2">Inv.No</td><td colspan="4">: ' + $('#DepatmentCode').val() + ' - ' + $('#txtloctrcopy').val() + '</td></tr>' +
                   '<tr><td colspan="2">Quantity</b></td><td colspan="3">: ' + Nof + '</td></tr></table>');
                }

                var RW = '<table width="100%" class="printbdy"><tr><th width=10%>No</th><th>Code & Description</th><th width=20% >Qty</th></tr>'

                //var scan = 0;
                //var pending = 0;
                var slnoprint = 0;
                for (var k = 1; k <= rowCount; k++) {

                    if ($('#scanqty' + k).text() > 0) {
                        slnoprint++;
                        //scan++;
                        var ItemDescription = $('#Des' + k).text();
                        var ItemCode = $('#itemcode' + k).text();
                        var InvoiceQty = $('#invoiceqty' + k).text();
                        var ScannedQty = $('#scanqty' + k).text();
                        var IssuedQty = $('#issuedqty' + k).text();
                        var Diffrence = $('#diff' + k).text();

                        RW += '<tr><td align=center>' + slnoprint + '</td><td>' + ItemCode + ' ' + ItemDescription + '</td><td align=center>' + ScannedQty + '</td></tr>';
                    }
                    //else
                    //{
                    //    pending++;
                    //}

                }

                myWindow.document.write(RW + '<br>');
                //myWindow.document.write('<table style="font-size:85%" width=100%>');
                //myWindow.document.write('<tr><td height="10px"  colspan=11></td></tr>');
                //myWindow.document.write('<tr><td colspan=11 align=right> Total Scanned Items : ' + scan + ' &nbsp;&nbsp;&nbsp; Total Pending : ' + pending + '</td></tr>');

                myWindow.print();
                myWindow.close()
            }
          

        }
       
    }
</script>
