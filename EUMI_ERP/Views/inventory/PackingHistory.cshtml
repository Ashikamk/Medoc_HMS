    function BillScan() {

        var barcodebill = {};
        var billcode=$("#txtBillSlNocopy").val();
        barcodebill = billcode.split('-');

        if (barcodebill[1] != undefined && barcodebill[0] != undefined) {



            $("#txtBillSlNocopy").val(barcodebill[1]);
            $("#txtBillseriesId").val(barcodebill[0]);

            var data = {};
            data.BillSeriesId = $("#txtBillseriesId").val();
            data.BillSlNo = $("#txtBillSlNocopy").val();
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../SalesInvoice/PackingHistoryGetandGets",
                data: data,
                success: function (result) {
                    PackingGets(result.oList);
                    getdiffrence();
                    $('#txtscancode').focus();
                }
            });
        }
    }

    function LocTransferScan() {

        var barcodebill = {};
        var billcode = $("#txtloctrcopy").val();
        barcodebill = billcode.split('-');

        if (barcodebill[1] != undefined && barcodebill[0] != undefined) {



            $("#txtloctrcopy").val(barcodebill[1]);
            $("#Dept").val(barcodebill[0]);

            var data = {};
            data.trNo =  $("#txtloctrcopy").val();
            data.TransferDeptId = $("#Dept").val();
            data.DeptId = ERPDeptId;
