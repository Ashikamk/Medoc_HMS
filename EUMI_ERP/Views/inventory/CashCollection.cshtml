<script>
    $("#txtBillSlNocopy").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.BillSlNo = $("#txtBillSlNocopy").val();
            data.BillSeriesId = $("#txtBillseriesId").val();
            data.LocId = UserLocationId;;
            data.DeptId = ERPDeptId;

                $.ajax({
                    url: '../SalesInvoice/SalesGetandGetsCashCollection',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '3',
                                label: item.BillSlNo,
                                label1: item.CustName,
                                label2: item.InvDate,
                                billsl: item.BillSlNo,
                                billseries: item.BillSeriesId,
                                headers: ["Bill No", "Customer Name", "Inv Date"]
                            })
                        }));
                    }
                })

        },
        autoFocus: true,
        select: function (event, ui) {
            var data = {};
            data.BillSeriesId = ui.item.billseries;
            data.BillSlNo = ui.item.billsl;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../SalesInvoice/SalesGetandGets",
                data: data,
                success: function (result) {
                    GetList(result.oList);
                }
            })
        },

    });



    function GetList(result) {
        if (result.length != 0) {            
            $('#hiddencustId').val(result[0].CustId);
            $('#txtcustomer').val(result[0].CustName);
            $('#txtaddress').val(result[0].CustAddress);
            $('#txtamount').val((parseFloat(result[0].GrandTotal).toFixed(Decimal)));
            $('#txtscancode').val((parseFloat(result[0].GrandTotal).toFixed(Decimal)));
            $('#FC').focus();
        }
    }

    function crncyload() {
        var data2 = {};
        data2.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CurrencyGetandGets",
            data2: data2,
            success: function (result) {
                CurrencyLoad(result.oList);
            }
        });
        function CurrencyLoad(result) {
            $("#FC").empty();
            for (var i = 0; i < result.length; i++) {
                if (result[i].BaseCurrencyId != 0) {
                    var BaseCurrency = result[i].BaseCurrencyId;
                }
            }
            CurrencySelect = "<option value=0>-----Select-------</option>";
            for (var i = 0; i < result.length; i++) {
                CurrencySelect += "<option  name='" + result[i].CurrencyRate + "' value='" + result[i].Id + "'>" + result[i].CurrencyName + "</option>";
                if (result[i].CurrencyName == 'INR')
                { inr = result[i].Id;}
                if (result[i].CurrencyName == 'DIRHAM')
                {  dir = result[i].Id; }
            }            
            $("#FC").append(CurrencySelect);
            $('#FC').val(BaseCurrency);
            $('#txtrate').val($('#FC').find("option:selected").attr("name"));
            if(inr==BaseCurrency)
            {
                $('#inrdiv').show();
                $('#dirdiv').hide();
            }
            else if (dir == BaseCurrency) {
                $('#inrdiv').hide();
                $('#dirdiv').show();
            }
            
        }
    }
    function CurrencyChange(Id) {
        $('#txtrate').val($('#' + Id).find("option:selected").attr("name"));
        if(dir == $('#' + Id).val())
        {
            $('#inrdiv').hide();
            $('#dirdiv').show();
        }
        else if (inr == $('#' + Id).val()) {
            $('#inrdiv').show();
            $('#dirdiv').hide();
        }
    }
    $(document).ready(function () {
        crncyload();
        var Decimal = 3;
         ProductFlag = 0;  i=0;
         editflag = 0;
         $('#txtBillSlNocopy').focus();
         $('#FC').keydown(function (e) {
             var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
             if (key == 13) {
                 e.preventDefault();
                 $('#txtcuramount').focus();
             }
         });
         $('#txtcuramount').keydown(function (e) {
             var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
             if (key == 13) {
                 e.preventDefault();
                 $('#btnadd').focus();
             }
         });

         var data = {};
         data.id = 0;
         data.DeptId = ERPDeptId;
         $.ajax({
             type: "POST",
             url: "../SalesInvoice/BillSeriesGetandGets",
             data: data,
             success: function (result) {
                 Billseriesload(result.oList);
             }
         });
         $("#btnsubmit").click(function (e) {
             if (editflag != 0) {
                 warningshow('You are in Edit Mode');
             }
             else if ($.trim($('#txtBillSlNocopy').val()) == "") {
                 warningshow('Please Select A Bill No', 'txtBillSlNocopy');
                 return false;
             }
             else if ($.trim($('#txtrecieved').val()) == 0) {
                 warningshow('Please Select A Currency', 'txtcuramount');
                 return false;
             }
             else
             {
                 showdeliver();
             }
            
         });

         $('#txtBillSlNocopy').keyup(function (e) {
             e.preventDefault();
             $('#tour1').fadeOut();
             var entrkey = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
             if (entrkey == 8) {
                 checkSTOtextempty();
             }
         });


    });
    //bill no load
    function Billseriesload(result) {
        $("#txtBillseriesId").empty();
        for (var i = 0; i < result.length; i++) {
            $("#txtBillseriesId").append("<option value='" + result[i].id + "' name='" + result[i].CurrentNo + "'>" + result[i].BillDescription + "</option>");
        }
        $('#txtBillSlNo').val(result[0].CurrentNo)
        $('#txtBlSlNo').val(result[0].CurrentNo);
    }


    var editflag;
    var ProductFlag; var i; var dir; var inr;
    i = 1; dir = 0; inr = 0;
    function calcgrandtotal()
    {
       
        var rate = parseFloat($('#txtrate').val()).toFixed(Decimal);
        rate = isNaN(rate) ? 0 : rate;
        var amount = parseFloat($('#txtcuramount').val()).toFixed(Decimal);
        amount = isNaN(amount) ? 0 : amount; 
        var tot = parseFloat(rate * amount).toFixed(Decimal);
        $('#txttotal').val(tot)
    }
   
    function productadd() {
        var rowcount = $('#tblcurrency tr').length;
        var ProductFlag = 0;
        for (p = 1; p <= i; p++) {
            if ($('#txt_currency' + p).val() == $("#FC").val()) {
                ProductFlag = 1;
            }
        }
        var slno = parseInt($('#slnotxt').val())
        if ($.trim($('#txtcuramount').val()) == "") {
            warningshow('Please Enter Amount', 'txtcuramount');
            return false;
        }
        if ($.trim($('#txtBillSlNocopy').val()) == "") {
            warningshow('Please Select A Bill No', 'txtBillSlNocopy');
            return false;
        }
        
        else {
            if (rowcount == 0) {
                i = 1;
            }
            if (ProductFlag == 1) {
                var Res = confirm('Product Already Added! Do You Want to Continue');
