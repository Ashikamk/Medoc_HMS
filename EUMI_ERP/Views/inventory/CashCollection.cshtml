                    ClearProductRow();
                    return false;
                }
                if (Res == true) {
                    addcurrency();
                }
            }
            else
                {
            var slno = parseInt(i)
            var Count = $('#tblcurrency tr').length;
            var serialNo = rowcount + 1;
            var ProdRowEdit = "<tr id=" + 'row' + slno + " class= jsgrid-row ><td  id=" + 'td' + slno + " class= jsgrid-cell  style= width:93px;text-align:center >"
               + serialNo + "<input type='hidden' id='SlNo" + slno + "' value=" + Count + "></td><td class= 'jsgrid-cell jsgrid-align-center'  style='width:300px;text-align:center' > <select id=" + 'txt_currency' + slno + " class='form-control text-center' disabled=disabled style='background-color:white;height:30px;' >"
       + CurrencySelect + "</select> </td><td class= 'jsgrid-cell jsgrid-align-left'  style='width:130px;text-align:center' > <input type='text' class='form-control text-right'  disabled  style='background-color:white;height:30px;' id='txt_rate" + slno + "' value='"
               + parseFloat($('#txtrate').val() || 0).toFixed(Decimal) + "'> <td class= 'jsgrid-cell jsgrid-align-left'  style= 'width:220px;display:none' ><input type='text' class='form-control text-right'  disabled=disabled  style='background-color:white;height:30px;'  onkeyup='tot_row(" + slno + ")' onkeypress='return isNumber1(event)' id='txt_hiddenamnt" + slno + "' value='"
