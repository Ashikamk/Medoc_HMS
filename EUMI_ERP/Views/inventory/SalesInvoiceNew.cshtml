    //Custom Print
    function PrintBill(flg)
    {
      
        $('#CustomPrint').hide();
        $("#custom1").prop("checked", true);

        if ($('#alertpopup').is(':visible')) {
          //Custom Print During Save
            if (flg == 1) {
                PrintthisBillWindows('SALES', i, 'WITHBINSPAREPARTSSAVE');

            }
            else if (flg == 2) {              
                PrintAfterSave()
            }
            else if (flg == 3) {
                PrintthisBillWindowsNew('SALES', i, 'SPAREPARTSCOPY');
            }
            alertpopuprefresh();
            formrefresh();
            Tbldelete();
        }
        else                      //Custom Print During Copy
        {
            if (flg == 1) {
                PrintthisBillWindows('SALES', i, 'WITHBINSPAREPARTSCOPY'); 

            }
            else if (flg == 2) {
                PrintthisBill();
            }
            else if (flg == 3) {
                PrintthisBillWindowsNew('SALES', i, 'SPAREPARTS');
            }
        }
    }

    //Print After Copy
    function PrintAfterSave()
    {
        if (SalesBillType == 'MOBILE')
            PrintthisBillWindows('SALES', i, 'MAINMOBILE');
        else if (SalesBillType == 'LOCAL')
            PrintthisBillWindows('SALES', i, 'MAIN');
        else if (SalesBillType == 'ORYX')
            PrintthisBillWindows('SALES', i, 'MAINORYX');
        else if (SalesBillType == 'AUTOMOBILES')
            PrintthisBillWindows('SALES', i, 'MAINSPAREPARTS');
        else if (SalesBillType == 'DEFAULT')
            PrintthisBillWindowsNew('SALES', i, 'SPAREPARTSCOPY');
        else if (SalesBillType == 'SPAREPARTS')
            PrintthisBillSalesNew(i, 'save');
        else if (SalesBillType == 'FAZAL-AMIN')
            PrintthisBillForFazal(i, 'save');
        else if (SalesBillType == 'FAZAL-AMIN-LAZOR')
            PrintthisBillWindows('FAZAL', i, 'SAVE');

        else if (SalesBillType == 'AUTOGLASS')
            PrintthisBillWindows('SALES', i, 'AUTOGLASSSAVE');
        else if (SalesBillType == 'AUTOPARTS')
            PrintthisBillWindows('SALES', i, 'AUTOPARTSSAVE');
    }


    //Print After Copy
  function PrintthisBill()
    {
      
   
      if ($('#tblsalesinvoice tr').length > 0) {
          if (SalesBillType == 'MOBILE')
              PrintthisBillWindows('SALES', i, 'COPYMOBILE');
          else if (SalesBillType == 'LOCAL')
              PrintthisBillWindows('SALES', i, 'COPY');
          else if (SalesBillType == 'ORYX')
              PrintthisBillWindows('SALES', i, 'COPYORYX');
          else if (SalesBillType == 'AUTOMOBILES')
              PrintthisBillWindows('SALES', i, 'COPYSPAREPARTS');
          else if (SalesBillType == 'DEFAULT')
              PrintthisBillWindowsNew('SALES', i, 'SPAREPARTS');
          else if (SalesBillType == 'SPAREPARTS')
              PrintthisBillSalesNew(i);
          else if (SalesBillType == 'FAZAL-AMIN')
              PrintthisBillForFazal(i, 'copy');
          else if (SalesBillType == 'FAZAL-AMIN-LAZOR')
              PrintthisBillWindows('FAZAL', i, 'COPY');

          else if (SalesBillType == 'AUTOGLASS')
              PrintthisBillWindows('SALES', i, 'AUTOGLASSCOPY');
          else if (SalesBillType == 'AUTOPARTS')
              PrintthisBillWindows('SALES', i, 'AUTOPARTSCOPY');
      }
      else {
          warningshow('Please select a bill to print', 'txtBillSlNocopy');
          $('#txtBillSlNocopy').select();
      }

  }

    function getdate() {
        var terms = $($('#select_terms')).find("option:selected").attr("name");
        if ($('#select_terms').val() != 0) {
            var Dt = $('#txtivdate').val();
            var someDate = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));
            someDate.setDate(parseInt(someDate.getDate()) + parseInt(terms));
            var month = +someDate.getMonth() + 1;
            var day = someDate.getDate();

            if (day < 10) {
                day = '0' + day;
            }
            if (month < 10) {
                month = '0' + month;
            }

            newdate = day + "/" + month + "/" + someDate.getFullYear();
            $('#txtduedate').val(newdate);
        }
        else {
            $('#txtduedate').val(CurDate);
        }

    }

