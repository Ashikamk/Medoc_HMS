            type: "POST",
            url: "../SalesInvoice/SalesInvoiceFolderCreate",
            data: data,
            success: function (result) {
                FileUploadDB(0);
            }
        });
    }

    function FileUploadDB(Flag) {
        // Database Save

        var data = {};
        data.BillSlNo = $("#txtBillSlNocopy").val();
        data.BillSeriesId = $("#txtBillseriesId").val();
        data.FileName = $("#SalesfileUpload").get(0).files[Flag].name;
        data.Extension = $("#SalesfileUpload").get(0).files[Flag].name.split('.').pop();
        data.DelFlag = Flag; 
        data.DeptId = $('#SalesDepartmentId').val(); 
        data.UserId = ERPUserId;

        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesInvoceFileInsert", 
            data: data,
            success: function (result) {
                var DBFlag = result.dList[0].DelFlag; 
                var status = result.dList[0].Status;

                if (status == 1) {
                    FileUploadFolder(Flag, DBFlag, status);
                }

            }
        });




    }
    function FileUploadFolder(Flag, DBFlag, status) {
        // Folder Save

        var formData = new FormData();
        var imageName = DBFlag
        var browsedFile = document.getElementById("SalesfileUpload").files[Flag];
        var Extension = $("#SalesfileUpload").get(0).files[Flag].name.split('.').pop();
        var BillSeriesId = $("#txtBillseriesId").val();
        var BillSlNo = $("#txtBillSlNocopy").val();

        formData.append("FileUpload", browsedFile);
        formData.append("FileName", imageName);
        formData.append("BillSlNo", BillSlNo); 
        formData.append("BillSeriesId", BillSeriesId);
        formData.append("Extension", Extension);

        $.ajax({
            type: "POST",
            url: '/SalesInvoice/SalesFileUpload',
            data: formData,
            dataType: "html",
            contentType: false,
            processData: false,
            success: function (result) {
                if (Flag < document.getElementById('SalesfileUpload').files.length - 1) {
                    Flag++;
                    FileUploadDB(Flag);
                }
                else {
                    $("#Loadingsave").hide();
                    swal('Documents Uploaded Successfully', "", "success");
                    $('.swal-button swal-button--confirm').focus();
                    $("#SalesfileUpload").val('');
                    ViewSavedFiles();
                }
            }
        });


    }

    function ViewSavedFiles() {
        var data = {};
        data.BillSlNo = $("#txtBillSlNocopy").val();
        data.BillSeriesId = $("#txtBillseriesId").val(); 
        data.DeptId = $('#SalesDepartmentId').val();

        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesInvocieFileGets",
            data: data,
            success: function (result) {
                ShowSavedFiles(result.oList);

            }
        });
    }


    function ShowSavedFiles(result) {

        disable_datatable('tbl_documentlist');
        $("#SalesDocument").show();

        var responseText = "<tbody>";

        if (result.length > 0) {
            for (var l = 0; l < result.length; l++) {
                var slno = parseInt(l + 1);

                var Icon = '<img src="../app-assets/Project_Icons/DOC_ICON.png" style="width:50px;height:40px" />';

                var Extension = (result[l].Extension).toLowerCase();

                if (Extension == 'pdf') {
                    Icon = '<img src="../app-assets/Project_Icons/PDF_ICON.jpg" style="width:50px;height:40px" />';
                }
                else if (Extension == 'jpeg' || Extension == 'jpg' || Extension == 'png' || Extension == 'gif' || Extension == 'tif') {
                    Icon = '<img src="../app-assets/Project_Icons/IMG_ICON.jpg" style="width:50px;height:40px" />';
                }
                else if (Extension == 'xlsx' || Extension == 'xls' || Extension == 'xlsm' || Extension == 'xlm' || Extension == 'xltx' || Extension == 'xltm' || Extension == 'xlt') {
                    Icon = '<img src="../app-assets/Project_Icons/EXCEL_ICON.png" style="width:50px;height:40px" />';
                }


                responseText += "<tr id='doctr_" + result[l].PFileId + "'>" +
                    "<td align='center'>" + Icon + "</td>" +
                    "<td>" + result[l].FileName + "</td>" +

                    "<td  align='center'>" +
                    "<a onclick=\"ViewDocuments(\'" + result[l].DelFlag + "'\,\'" + result[l].Extension + "'\)\"><i class='fa fa-download' style='color:darkorange'></i><a>" + 
                    "</td>" +

                    "<td align='center' class='hideedit'>" +
                    "<a onclick=\"DeleteDocument(\'" + result[l].PFileId + "'\,\'" + slno + "'\)\">" + DeleteButton + "</a>" +
                    "</td>" +

                    "</tr>";


            }
        }
        else {
            responseText = "<tr><td style='text-align:center;color:red;font-weight:500'>NO DOCUMENTS</td></tr>"
        }

        $('#tbl_documentlist').html(responseText + '</tbody>');

        if (updateflag != 1) { 
            $('.hideedit').hide();
        }

    }

    function ViewDocuments(DocumentId, Extension) {
        var flname = '../ProjectImages/SalesInvoiceDocs/' + $("#txtBillseriesId").val() + '/' + $("#txtBillSlNocopy").val() + '/' + DocumentId + '.' + Extension;
        window.open(flname);
    }

    function DeleteDocument(FileId, slno) {

        $('#Confirmflag').val('Filedelete'), $('#ConfirmRowId').val(FileId)
        $('#confirmmessage').text('Do You Want To Delete This File?')
        $('#confirm').show();
        $('#confirmOk').prop("disabled", false);
        $('#confirmOk').focus();
    }
    function OKDeleteDocument(FileId) {
        var data = {};
        data.PFileId = FileId;
        data.DepartmentId = $('#SalesDepartmentId').val();
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesInvoceFileDelete",
            data: data,
            success: function (result) {
                $("#doctr_" + FileId).remove();
                swal('Documents Deleted Successfully', "", "error");
                $('.swal-button swal-button--confirm').focus();
            }
        });
    }

    //-------------------------------------------------------File Upload---------------------------------------
    // CustEnable     
    function EnableCust() {
        if (copyflag == 1) {
            cleargridids();
            Tbldelete();
            copyrefresh();
            TaxClear();
            $('#txtBillSlNocopy').val('');
            $('#txtBillSlNocopy').select();
            $('#btnsubmit').prop("disabled", true);
            $('#btnlist').prop("disabled", true);
            $('#btnadd').prop("disabled", true);

            $('#btnedit,#SalesViewFiles').hide();
            $("#btndelete").hide();

            $("#txtcustomer").hide();
            $('#txtcustomernew').prop('disabled', false).show().focus();
        }
    }
