<script>
    function ClearWork()
    {
        $('#DueDate').val(CurDate);
        $('#TurnTime').prop('checked', true);
        $('#Department').val(ERPDeptId);
        $('#WorkItemId,#UserId,#StoreKeeperId,#DriverId,#IPUserId').val(0);
        $('#Time').val($('#Time option:first').val());
        $('#Division').val($('#Division option:first').val());
        $('#WorkItemId,#User,#Title,#Description,#RefType,#RefId,#StoreKeeper,#Remarksdisplay,#Driver,#IPUser,#NewRemarks').val('');
        $('#Status').val('Created');
        ShowDate();
    }

    function ShowDate() {
        if ($('#TurnTime').prop('checked'))
        { $('#DueDate').hide(); $('#Time').show().focus(); }
        else if ($('#DueDatebtn').prop('checked'))
        { $('#DueDate').show().focus(); $('#Time').hide(); }

    }

    function checkhold() {

        if ($('#Status').val() == 'On Hold') {
            //$('#panel1').show();
            $('#panelp1').delay(100).slideDown(400);
            $('#reasondisplay').text('Reason For Hold:');
            $('#Remarksdisplay').prop("disabled", false);
            $('#Remarksdisplay').focus();
            if ($("#DriverId").val() == 0) {
                $('#panel2').delay(100).slideUp(400);
            }
            if ($("#IPUserId").val() == 0) {
                $('#panel3').delay(100).slideUp(400);
            }
        }
        else if ($('#Status').val() == 'On The Way') {
            $('#panelp1').delay(100).slideUp(400);
            $('#panel3').delay(100).slideUp(400);
            $('#panel2').delay(100).slideDown(400);

            $("#Driver").prop("disabled", false);
        }
        else if ($('#Status').val() == 'In Progress') {
            $('#panelp1').delay(100).slideUp(400);
            $('#panel2').delay(100).slideUp(400);
            $('#panel3').delay(100).slideDown(400);
            $("#IPUser").prop("disabled", false);
        }

        else {
            //$('#panel1').hide();
            $('#panelp1').delay(100).slideUp(400);
            if ($("#DriverId").val() == 0) {
                $('#panel2').delay(100).slideUp(400);
            }
            if ($("#IPUserId").val() == 0) {
                $('#panel3').delay(100).slideUp(400);
            }
        }
    }

    $("#IPUser").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#IPUserId').val(0);
            var data = {};
            data.UserName = $("#IPUser").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#IPUserId').val(ui.item.UserId);
        },
    }).on('keydown', function (e) {
        if ((e.which == 13) && (($('#IPUser').val() == '') || (($('#IPUserId').val() || 0) != 0))) {
            $('#Title').focus().select(); 
        }
    });

    $("#User").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {

            $('#UserId').val(0);

            var data1 = {};
            data1.UserName = $("#User").val();
            data1.DepartmentId = $("#Department").val();
            data1.DivisionId = $("#Division").val();

            $.ajax({
                url: '../WorkItemUser/DeptUserGetandGets',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#UserId').val(ui.item.UserId);            
        },
    }).on('keydown', function (e) {
        if ((e.which == 13) && (($('#User').val() == '') || (($('#UserId').val() || 0) != 0))) {
            $('#Title').focus().select();
        }
    });

    $("#StoreKeeper").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $('#StoreKeeperId').val(0);
            var data = {};
            data.UserName = $("#StoreKeeper").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName: item.UserName,
                            headers: ["User"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#StoreKeeperId').val(ui.item.UserId);
        },
    }).on('keydown', function (e) {
        if ((e.which == 13) && (($('#StoreKeeper').val() == '') || (($('#StoreKeeperId').val() || 0) != 0))) {
            $('#NewRemarks').focus().select();
        }
    });


    $("#Department").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#Division').focus();
        }

    });
    $("#Division").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#User').focus();
        }

    });
    $("#DueDate").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#Status').focus();
        }

    });
    $("#Title").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#Description').focus();
        }

    });
    $("#Description").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#RefType').focus();
        }

    });
    $("#RefType").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#RefId').focus();
        }

    });
    $("#RefId").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            if ($('#Time').is(':visible'))
            { $('#Time').focus(); }
            else if ($('#DueDate').is(':visible'))
            { $('#DueDate').focus(); }
        }

    });
    $("#Time").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#Status').focus();
        }

    });
    $("#Status").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#NewRemarks').focus();
        }

    });
    $("#NewRemarks,#Remarksdisplay,#Driver").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            e.preventDefault();
            $('#btnassign').focus();
        }

    });

    function WorkTaskTime() {
        var data = {};
        data.DivisionId = $('#Division').val();
        $.ajax({
            type: "POST",
            url: "../WorkItemUser/WorkingTaskTimeGetandGets",
            data: data,
            success: function (result) {
                WorkTimeGets(result.bList);


            }
        });
    }

    function WorkTimeGets(result) {
        $("#Time").empty();
        for (var i = 0; i < result.length; i++) {
            var Hr = 0; var Min = 0; var realmin = 0;

            if (result[i].TurnAroundTimes >= 60) {
                Min = parseInt(result[i].TurnAroundTimes);
                realmin = Min % 60;
                Hr = Math.floor(Min / 60);
                $("#Time").append("<option value='" + result[i].TurnAroundTimes + "'>" + result[i].TurnAroundTimesName + " - " + Hr + " HR(s) " + realmin + " Min(s)</option>");
            }
            else {
                Hr = 0;
                realmin = parseInt(result[i].TurnAroundTimes)
                $("#Time").append("<option value='" + result[i].TurnAroundTimes + "'>" + result[i].TurnAroundTimesName + " - " + Hr + " HR(s) " + realmin + " Min(s)</option>");
            }

        }
    }

    function GetWorkDepartment() {
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                WorkDepartmentLoad(result.oList);
            }
        });
    }

    function WorkDepartmentLoad(result) { 
        $("#Department").empty();
        for (var i = 0; i < result.length; i++) {
            $("#Department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
        $('#Department').val(ERPDeptId);
    }
   
    function CloseAssign() {
        $('#popupdivWork').hide();
        ClearWork();
        Showprint($('#savedbillno').val(), $('#txtBillseriesId').val());
    }

    function SaveAndUpdateWork() {
        if ($('#Department').val() == "") {
            warningshow('Please Select Department', 'Department');
        }
        else if ($('#Division').val() == "") {
            warningshow('Please Select Division', 'Division');
        }
        else if ($('#User').val() != "" && $('#UserId').val() == 0) {
            warningshow('Please Enter Valid User', 'User');
        }
        else if ($.trim($('#Title').val()) == '') {
            warningshow('Please Enter Title', 'Title');
        }
        else if ($.trim($('#Description').val()) == '') {
            warningshow('Please Enter Description', 'Description');
        }
        else if ($.trim($('#RefType').val()) == '') {
            warningshow('Please Enter Reference Type', 'RefType');
        }
        else if ($.trim($('#RefId').val()) == '') {
            warningshow('Please Enter Reference Id', 'RefId');
        }
        else if ($('#Time').val() == "") {
            warningshow('Please Select Turn Around Time', 'Time');
        }
        else if ($('#Status').val() == "") {
            warningshow('Please Select Status', 'Status');
        }
        else if ($.trim($('#Remarksdisplay').val()) == '' && $('#Status').val() == 'On Hold') {
            warningshow('Please Enter Reason For Hold', 'Remarksdisplay');
        }
        else {
            var DueDate = '';

         if ($('#DueDatebtn').prop('checked'))
            { DueDate = $('#DueDate').val(); }
           

            $("#btnassign").prop("disabled", true);
            var data = {};
            data.WorkItemId = $('#WorkItemId').val();
            data.DepartmentId = $('#Department').val();
            data.DivisionId = $('#Division').val();
            data.AssignedTo = $('#UserId').val();
            data.Title = $('#Title').val();
            data.Description = $('#Description').val();
            data.RefType = $('#RefType').val();
            data.RefId = $('#RefId').val();
            data.TurnAroundTimes = $('#Time').val();
            data.WorkStatus = $('#Status').val();
            data.UserId = ERPUserId;
            data.Flag = 1;
            data.Remarks = $('#Remarksdisplay').val();
            data.NewWorkRemarks = $('#NewRemarks').val();
            data.BillSlNo = $('#txtBillseriesId').val();
            data.BillNo = $('#savedbillno').val();
            data.Driver = $('#DriverId').val();
            data.IPUserId = $('#IPUserId').val();
            data.Reference = $('#ReferenceNo').val();
            data.StoreKeeperId = $('#StoreKeeperId').val();
            data.DueDate = DueDate;
            $.ajax({
                type: "POST",
                url: "../WorkItemUser/WorkItemInsertandUpdate",
                data: data,
                success: function (result) {
                    //var status = result.cList[0].Status;
                    //Showalerts(status);
                    CloseAssign();
                    $("#btnassign").prop("disabled", false);
                    Showprint($('#savedbillno').val(), $('#txtBillseriesId').val()) 
                }
            });
        }
    }

    function CreateNew(Status, billsrs, billsrlno) {
        $('#Title').val('Sales Invoice : ' + billsrlno);
        $('#RefType').val('INVOICE');
        $('#RefId').val(billsrlno);

        $("#BillSerId").val(billsrs);
        $("#BillNo").val(billsrlno);
        $("#Description").val($('#txtcustomer').val()+' : '+$('#txtBillseriesId :selected').text()+ '-' + billsrlno);

        $('#popupdivWork').show(); 
        $('#User').focus(); 
        $('#panel1,#panel2,#panel3').hide();
    }

</script>



