<style>
    .message {
        /*background: #181818;
        color: #FFF;*/
        position: fixed;
        top: -550px;
        left: 0;
        width: 100%;
        height: 250px;
        padding: 20px;
        transition: top 1000ms cubic-bezier(0.17, 0.04, 0.03, 0.94);
        overflow: hidden;
        box-sizing: border-box;
    }

        .message h1 {
            /*color: #FFF;*/
        }

    #toggle:checked ~ .message {
        top: 0;
        z-index: 1001;
    }

    #toggle {
        position: absolute;
        appearance: none;
        cursor: pointer;
        left: -100%;
        top: -100%;
    }

        #toggle + label {
            position: absolute;
            cursor: pointer;
            padding: 10px;
            background: #26ae90;
            width: 100px;
            border-radius: 3px;
            padding: 8px 10px;
            color: #FFF;
            line-height: 20px;
            font-size: 12px;
            text-align: center;
            -webkit-font-smoothing: antialiased;
            cursor: pointer;
            margin: 20px 50px;
            transition: all 3000ms ease;
        }

            #toggle + label:after {
                content: "Open";
            }

    .container {
        transition: margin 1000ms cubic-bezier(0.17, 0.04, 0.03, 0.94);
        padding: 5em 3em;
    }



    #toggle:checked ~ .container {
        margin-top: 250px;
    }

    #toggle:checked + label {
        background: #dd6149;
    }

        #toggle:checked + label:after {
            content: "Close";
        }

         .overlay1 { 
        position: fixed;
        width: 100%;
        height: 100%;
        /*top:40%;
        left: 50%;*/
        right: 0;
        bottom: 0;      
        z-index: 2000;
        cursor: pointer;    
           
    }

 .rowactive {
            background: rgb(255, 198, 176) !important;
            color:black !important;
        }

</style>

