    function SalesGetCall(BillSeriesId, BillSlNo, DeptId,type)
    {
        var data = {};
        data.BillSeriesId = BillSeriesId; 
        data.BillSlNo = BillSlNo;
        data.DeptId = DeptId;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesGetandGets",
            data: data,
            success: function (result) {
                TaxClear();
                Tbldelete();
                $('#btnsubmit').prop("disabled", true);
                $('#btnlist').prop("disabled", true);
                $('#btnadd').prop("disabled", true);
               
                $('#roundoffstatus').prop("checked", false);
                $('#roundoffstatus').prop("disabled", true);

                JsBarcode("#barcode1", $('#txtBillseriesId').val() + '-' + result.oList[0].BillSlNo);

                if (type != 2) {
                    $('#salesviewpopup').hide();
                }

                $('#btnedit').hide();
                $("#btndelete").hide();
                 SalesUpload(1); 

                if (result.oList.length > 0) {
                    $('#SalesDepartmentId').val(result.oList[0].DeptId);
                    $('#SalesDepartment').val(result.oList[0].DepartmentName);
                    if (DeptArray.includes(result.oList[0].DeptId)) {
                        if (result.oList.length >0) { 
                            $('#btnedit').show();
                            $("#btndelete").show();
                        }
                      
                        SalesGets(result.oList);
                        SalesUpload(0);
                        //$('#txtBillSlNo').focus();
                        //$('#txtBillSlNocopy').select();
                        if (type == 1) {
                            confirmprint();
                        }
                        else if (type == 2) {                            
                            $('.arrow,.tooltip-inner').hide();
                            PreviewGet()
                        }
                    }

                    else {
                        $('#btnedit').hide();
                        $("#btndelete").hide();
                        $('#btndept').prop('disabled', false);
                        $('#deptmsg').text('')
                        $('#deptmsg').append('Bill NO : ' + $('#txtBillseriesId').find("option:selected").text() + ' - ' + result.oList[0].BillSlNo + ' is From </br> Department - ' + result.oList[0].DepartmentName);
                        $('#deptdiv').show();
                        $('#btndept').focus();
                    }
                }
                else {
                    swal('Bill No : ' + BillSeriesId + '-' + BillSlNo, "Cancelled", "error");
                    $('.swal-button swal-button--confirm').focus();
                }
                CustBillArray = []; CurnId = 0;                                       // CustEnable  
            }
        });
    }

