    //Next-Prev Button For Copy
    function GetBillPrevousornext(Value)
    {
        BillLoad(1);

        window.setTimeout(function () {
            $('#Warningpopup').fadeOut();
            $('#txtBillSlNocopy').prop("disabled", false);
            $('#Warningpopup').fadeOut();

            if ($('#txtBillSlNocopy').val() == '' && Value == -1) {
                $('#txtBillSlNocopy').focus();
                $('#txtBillSlNocopy').val(($('#txtBlSlNo').val()));
            }
            else if ($('#txtBillSlNocopy').val() == '' && Value == 1) {
                $('#txtBillSlNocopy').focus();
                $('#txtBillSlNocopy').val(0);
            }

            if (CustBillArray.length > 0) {
                

                if (Value == -1) {
                    if (CurnId == 0) {
                        warningshow('Bill Number Not Valid', 'txtBillSlNocopy');
                    }
                    if (CurnId > 0) { CurnId--; }
                }
                else if (Value == 1) {
                    if (CurnId == CustBillArray.length - 1) {
                        warningshow('Bill Number Not Valid', 'txtBillSlNocopy');
                    }
                    if (CurnId < CustBillArray.length - 1) { CurnId++; }
                }

                if (CurnId >= 0 && CurnId <= CustBillArray.length) {
                    $('#txtBillSlNocopy').val(CustBillArray[CurnId].BillSlNo);
                    GetSales(CustBillArray[CurnId].BillSlNo, ERPDeptId);
                }

            }

            else
            {
                var Billno = parseInt($('#txtBillSlNocopy').val() || 0);
                Billno = Billno + Value;

                if (((currentbillno == 1) && (Billno == 0))) {

                    warningshow('Bill Number Not Valid', 'txtBillSlNocopy');
                    return false;

                }
                else if ((Billno < 0) || (Billno >= $('#txtBlSlNo').val())) {

                    warningshow('Bill Number Not Valid', 'txtBillSlNocopy');
                    $('#txtBillSlNocopy').select();
                    return false;

                }
                else if (Billno == 0) {

                    warningshow('Bill Number Not Valid', 'txtBillSlNocopy');
                    $('#txtBillSlNocopy').select();
                    return false;

                }
                else {

                    $('#txtBillSlNocopy').val(Billno);
                    GetSales(Billno, ERPDeptId);
                }
            }

          
        } ,100);
        
    }

    // CustEnable     
    function GetSales(Billno, DeptId) {
        var data = {};
        data.BillSeriesId = $('#txtBillseriesId').val();
        data.BillSlNo = Billno;
        data.DeptId = DeptId;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesGetandGets",
            data: data,
            success: function (result) {
                cleargridids();
                Tbldelete();
                copyrefresh();
                $('#txtBillSlNocopy').focus();
                $('#txtBillSlNocopy').select();
                $('#btnsubmit').prop("disabled", true);
                $('#btnlist').prop("disabled", true);
                $('#btnadd').prop("disabled", true);
                $('#btnedit').show();
                JsBarcode("#barcode1", $('#txtBillseriesId').val() + '-' + Billno);
                TaxClear();
                $('#btnedit').hide();
                $("#btndelete").hide();
                SalesUpload(1);
                if (result.oList.length > 0) {
                    $('#SalesDepartmentId').val(result.oList[0].DeptId);
                    $('#SalesDepartment').val(result.oList[0].DepartmentName);
                    if (DeptArray.includes(result.oList[0].DeptId)) {
                        if (result.oList.length > 0) {
                            $('#btnedit').show();
                            $("#btndelete").show();
                        }
                        SalesGets(result.oList);
                        SalesUpload(0);
                    }
                    else {
                        warningshow('Bill NO : ' + $('#txtBillseriesId').find("option:selected").text() + ' - ' + result.oList[0].BillSlNo + ' is From Department - ' + result.oList[0].DepartmentName);
                        $('#btnedit').hide();
                        $("#btndelete").hide();
                    }
                }
                else
                {
                    swal('Bill No : ' + $('#txtBillseriesId :selected').text() + '-' + Billno, "Cancelled", "error");
                    $('.swal-button swal-button--confirm').focus();
                }
            }
        });
    }

