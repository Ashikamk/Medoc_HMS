<script>       
    //product autocomplete
    $("#txtproduct0").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            if ($('#ProdLocation').val() == 0) {
                warningshow('Please Select Location', 'ProdLocation');
                $("#txtproduct0").val('');
                return false;
            }
            else if ($('#ProductionQty').val() == 0) {
                warningshow('Please Enter Production Quantity', 'ProductionQty');
                $("#txtproduct0").val('');
                return false;
            }
            else {
                var data = {};
                data.ItemCode = $("#txtproduct0").val();
                data.LocId = $("#ProdLocation").val();
                data.DeptId = ERPDeptId;
                data.UserId = ERPUserId;
                data.CustId = 0;
                data.PriceGroupId = 0;
                $.ajax({
                    url: '../SalesInvoice/ProductSearchSales',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {
                        response($.map(data, function (item) {
                            return ({
                                ColCount: '-9',
                                label: item.ItemCode,
                                label1: item.Description,
                                label2: item.UnitName,
                                label3: item.stocktotloseqty,
                                label4: item.AvgCost.toFixed(Decimal),
                                label5: item.GrpName.substring(0, 15),
                                label6: item.SbgrpName.substring(0, 15),
                                label7: item.CategoryName.substring(0, 15),
                                label8: item.SubCategoryName.substring(0, 15),
                                Unit: item.UnitId,
                                Description: item.Description,
                                Rates: item.AvgCost,
                                UnitName: item.UnitName,
                                ProductId: item.ItemId,
                                Product: item.ItemCode,
                                Qty: item.stocktotloseqty,
                                headers: ["Product Code", "Product Description", "UnitName", "Quantity", "Price", "Group", "Sub Group", "Category", "Sub Ctegory"]
                            })
                        }));
                    }
                })
            }
        },
        autoFocus: true,
        select: function (event, ui) {
            if (ui.item.Qty == 0) {

                var data = {};
                data.ProductId = ui.item.ProductId;
                data.CustId = 0;
                data.DeptId = ERPDeptId;
                $.ajax({
                    type: "POST",
                    url: '../SalesInvoice/CustomerProductDetailsSearch',
                    data: data,
                    success: function (result) {
                        CustPrdctLoad(result.oList);
                    }
                });
                $('#txtproduct0').val(ui.item.Product);
                warningshow('Not stock!', 'txtproduct0');
                $('#PrdtId0').val(ui.item.ProductId);
                $('#txtproduct0').select();
                qtyflag = 1;
                return false;
            }                 
            else if (($('#hiddenitemId').val()) == ui.item.ProductId) {
                warningshow('Production Item and Purchase Item Cannot be same', 'txtproduct0');
                $("#txtproduct0").val('');
                return false;
            }
            else {
                $('#ProductId0').val(ui.item.ProductId);
                $('#select_unitProd').val(ui.item.Unit);
                $('#Description').val(ui.item.Description);
                $('#hiddenquantitycheck').val(ui.item.Qty);
                $('#txtrate').val(ui.item.Rates);
                $('#txtquantity').focus();
                qtyflag = 0;

                var data = {};
                data.ProductId = ui.item.ProductId;
                data.CustId = 0;
                data.DeptId = ERPDeptId;
                $.ajax({
                    type: "POST",
                    url: '../SalesInvoice/CustomerProductDetailsSearch',
                    data: data,
                    success: function (result) {
                        CustPrdctLoad(result.oList);
                    }
                });
            }
        },
    });
                         
    //Debit Account

    $("#DebitAccount").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountDescription = $("#DebitAccount").val();
            $.ajax({
                url: '../Inventory/AccountNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '-3',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            DebitAccount: item.DebitAccount,
                            AccountDescription: item.AccountDescription,
                            AccountId: item.AccountId,
                            headers: ["Account Code", "Account Name"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#DebitAccount').val(ui.item.DebitAccount);
            $('#hiddendebit').val(ui.item.AccountId);
            $('#txtDacnt').val(ui.item.AccountDescription);
        },
    });

    //Credit Account

    $("#CreditAccount").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountDescription = $("#CreditAccount").val();
            $.ajax({
                url: '../Inventory/AccountNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '-3',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            DebitAccount: item.DebitAccount,
                            AccountDescription: item.AccountDescription,
                            AccountId: item.AccountId,
                            headers: ["Account Code", "Account Name"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#CreditAccount').val(ui.item.DebitAccount);
            $('#hiddencredit').val(ui.item.AccountId);
            $('#txtCacnt').val(ui.item.AccountDescription);
        },
    });

    //Other Cost Account Auto Complete
    
    $("#account").autocomplete({
        source: function (request, response) {
            var data = {};
            data.AccountDescription = $("#account").val();
            $.ajax({
                url: '../Inventory/AccountNumberSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '-3',
                            label: item.DebitAccount,
                            label1: item.AccountDescription,
                            DebitAccount: item.DebitAccount,
                            AccountDescription: item.AccountDescription,
                            AccountId: item.AccountId,
                            headers: ["Account Code", "Account Name"]                           
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#account').val(ui.item.DebitAccount);
            $('#hiddenAcountId').val(ui.item.AccountId);                       
        },
    });
    //Item autocomplete

    $("#ProductionItem").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#ProductionItem").val();
            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '4',
                            label: item.ItemCode,
                            label1: item.Description,
                            label2: item.UnitName,
                            label3: item.SellingPrice.toFixed(Decimal),
                            label4: '0',
                            label5: '0',
                            ItemId: item.ItemId,
                            Description: item.Description,
                            Unit: item.UnitId,
                            UnitName: item.UnitName,
                            Tax: item.VatId,
                            Taxper: item.VatPer,
                            Rate: (item.SellingPrice).toFixed(Decimal),
                            headers: ["Item Code", "Description", "Unit Name", "Average Cost"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $('#hiddenitemId').val(ui.item.ItemId);
            $('#ProdLocation').focus();
        },
    });

    // Prod Number#-copy

    $("#ProNo").autocomplete({
        source: function (request, response) {
            var data = {};
            data.DeptId = ERPDeptId;
            data.ProEntryNo = $("#ProNo").val();
            $.ajax({                
                url: '../ProductionEntry/CopyProdEntry',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '3',                           
                            label: item.ProEntryNo,
                            label1: item.ProEntryDate,
                            label2: item.ItemCode,
                            ProEntryNo: item.ProEntryNo,
                            ProEntryDate: item.ProEntryDate,
                            DAccount: item.DAccount,
                            ProductionQuantity: item.ProductionQuantity,
                            CostPerItem: item.CostPerItem,
                            MaterialTotal: item.MaterialTotal,
                            TotalOtherCost: item.TotalOtherCost,
                            TotalCostFC: item.TotalCostFC,
                            TotalProdCost: item.TotalProdCost,
                            MaterialTotal: item.MaterialTotal,
                            CAccount: item.CAccount,
                            location: item.location,
                            ItemCode: item.ItemCode,
                            Rate: item.Rate,
                            Currency: item.Currency,
                            JobCode: item.JobCode,
                            DAccountName: item.DAccountName,
                            CAccountName: item.CAccountName,
                            headers: ["No", "Date", "Item Code"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,
        select: function (event, ui) {
            $("#tblProductionEntry tr").remove();
            $('#ProNo').val(ui.item.ProEntryNo);
            $('#date').val(ui.item.ProEntryDate);
            $('#DebitAccount').val(ui.item.DAccount);
            $('#ProductionQty').val(ui.item.ProductionQuantity);
            $('#costperitem').val((ui.item.CostPerItem).toFixed(Decimal));
            $('#grandtotal').val((ui.item.MaterialTotal).toFixed(Decimal));
            $('#totothercost').val((ui.item.TotalOtherCost).toFixed(Decimal));
            $('#totalcostFC').val((ui.item.TotalCostFC).toFixed(Decimal));
            $('#totprodcost').val((ui.item.TotalProdCost).toFixed(Decimal));
            $('#totothercost').val((ui.item.TotalOtherCost).toFixed(Decimal));
            $('#CreditAccount').val(ui.item.CAccount);
            $('#ProdLocation').val(ui.item.location);
            $('#ProductionItem').val(ui.item.ItemCode);
            $('#CreditAccount').val(ui.item.CAccount);
            $('#Rate').val(ui.item.Rate);
            $('#FC').val(ui.item.Currency);
            $('#txtDacnt').val(ui.item.DAccountName);
            $('#txtCacnt').val(ui.item.CAccountName);
            $('#select_jobno').val(ui.item.JobCode);
            var ProEntryNo = ui.item.ProEntryNo;
            var data = {};
            data.ProEntryNo = ProEntryNo;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../../ProductionEntry/ProductionEntryGetandGets",
                data: data,
                success: function (result) {
                    if (ProEntryNo != 0)
                        ProductionEntryGet(result.oList);
                }
            });
            var ProEntryNo = ui.item.ProEntryNo;
            var data = {};
            data.ProEntryNo = ProEntryNo;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: "../../ProductionEntry/OtherCostGetandGets",
                data: data,
                success: function (result) {
                    if (ProEntryNo != 0)
                        OtherCostGet(result.oList);
                }
            });         
        },            
    });
    //job code
    $("#select_jobno").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.JobCode = $("#select_jobno").val();

            $.ajax({
                url: '../SalesInvoice/JobSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.JobCode,
                            label1: item.Description,
                            ProjectJobId: item.ProjectJobId,
                            headers: ["Job Code", "Description"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,

        select: function (event, ui) {
            $('#ProjectJobId').val(ui.item.ProjectJobId);
        },

    });
</script>





