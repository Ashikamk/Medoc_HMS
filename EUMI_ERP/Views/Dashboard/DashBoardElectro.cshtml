function GetPurchaseorderItems() {

    var Condition = 'CONVERT(datetime,InvDate,103) >= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) and CONVERT(datetime,InvDate,103) <= CONVERT(datetime,' + "'" + CurDate + "'" + ',103) group by ProductCode,ProductDescr,GrpCode,SbgrpName,CategoryCode,SubCategoryName,Inv_SalesSub.DeptId,avgcost order by Quantity desc'
    var data = {};
    data.Number = 5;
    data.Condition = Condition;



    $.ajax({
        type: "POST",
        url: "../Purchaseandsalesreports/PurchaseOrderReminder",
        data: data,
        success: function (result) {
            ShowTopSalesreport(result);
        }
    });
}
function GetFastMovingItems(Num) {
    $('#LoadingFastmoving').show();
    var data = {};
    data.Number = Num;
    data.Qty = parseInt($('#fastQty').val() || 0);

    $.ajax({
        type: "POST",
        url: "../Purchaseandsalesreports/FastMovingItemsDashboard",
        data: data,
        success: function (result) {
            ShowFastMovingreport(result);
        }
    });
}

function ShowFastMovingreport(result) {
    var responseText = "<thead><tr><th class='text-center'>Sl#</th><th style=text-align:left>Item Code</th><th style=text-align:left>Item Name</th><th style=text-align:right>Qty.Sold</th><th style=text-align:right>Stock</th><th style=text-align:right>Cost</th></tr></thead>  <tbody>";
    for (var i = 0; i < result.length; i++) {

        if (result[i].ItemDesc != 'Grand Total')
            responseText += '<tr><td class="text-center">' + (i + 1) + '</td><td style=text-align:left>' + result[i].ItemCode + ' </td><td style=text-align:left> ' + result[i].ItemDesc + '</td><td style=text-align:right>' + result[i].Qty + '</td><td style=text-align:right>' + result[i].Stock + '</td><td style=text-align:right>' + ReplaceNumberWithCommas(parseFloat(result[i].AvgCost || 0).toFixed(Decimal)) + '</td></tr>';
    }
    $('#fastmovingsales').html(responseText + '</tbody>');
    $('#LoadingFastmoving').hide();
}


function GetNonMovingItems(Num) {
    $('#LoadingNonmoving').show();
    var data1 = {};
    data1.Qty = parseInt($('#nonQty').val() || 0);
    data1.DateFrom = $('#DateFrom').val();
    data1.DateTo = $('#DateTo').val();
    data1.Number = Num;
    $.ajax({
        type: "POST",
        url: "../Purchaseandsalesreports/NonMovingItemsDashboard",
        data: data1,
        success: function (result) {
            ShowNonMovingreport(result);
        }
    });
}


function ShowNonMovingreport(result) {


    
    var responseText = "<thead><tr><th class='text-center'>Sl#</th><th class='text-left' style='width=100px'>Item Code</th><th width=200px class='text-left'>Item Name</th><th class='text-right'>Qty.Sold</th><th class='text-right'>Stock</th><th class='text-right'>Cost</th></tr></thead>  <tbody>";
    for (var i = 0; i < result.length; i++) {

        if (result[i].ItemDesc != 'Grand Total')
            responseText += '<tr><td  class="text-center" width=20px>' + (i + 1) + '</td><td  class="text-left" width=100px>' + result[i].ItemCode.substring(1,15) + ' </td><td class="text-left" width="200px" > ' + result[i].ItemDesc.substring(1,30) + '</td><td width=50px class="text-right">' + result[i].Qty + '</td><td width=50px class="text-right">' + result[i].Stock + '</td><td width=100px class="text-right">' + ReplaceNumberWithCommas(parseFloat(result[i].AvgCost || 0).toFixed(Decimal)) + '</td></tr>';
    }
    $('#nonmovingsales').html(responseText + '</tbody>');
    $('#LoadingNonmoving').hide();
}




