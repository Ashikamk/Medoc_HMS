<script type="text/javascript">


 
    var RemarkFlag=0;
    $("#User").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data1 = {};
            data1.UserName = $("#User").val();
            data1.DepartmentId = $("#Department").val();
            data1.DivisionId = $("#Division").val();

            $.ajax({
                url: '../WorkItemUser/DeptUserGetandGets',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName:item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#UserId').val(ui.item.UserId);
            $('#UserLength').val((ui.item.UserName).length);
        },
    });

    $("#transuser").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data1 = {};
            data1.UserName = $("#transuser").val();
            data1.DepartmentId = $("#Department").val();
            data1.DivisionId = $("#Division").val();

            $.ajax({
                url: '../WorkItemUser/DeptUserGetandGets',
                type: "POST",
                data: data1,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'ONE',
                            label: item.UserName,
                            UserId: item.UserId,
                            UserName:item.UserName,
                            headers: ["User"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#transuserId').val(ui.item.UserId);
            $('#transuserLength').val((ui.item.UserName).length);
        },
    });

    $(document).ready(function () {

        GetDepartment();
        GetDivision();
        GetList();

        $("#btnassign").click(function (e) {
            SaveAndUpdate()
        });
        $("#btncancel").click(function (e) {
            $('#TransferDiv').hide();
            $('#Remarks').prop("disabled",false)
            $('#ReasonDiv').show();
            $('#reason').text('Reason For Cancel:')
            $('#Remarks').focus();
        });
        $("#btntransfer").click(function (e) {
            $('#ReasonDiv').hide();
            $('#rsntransfer').prop("disabled",false);
            $('#transuser').prop("disabled",false);
            $('#TransferDiv').show();
            $('#rsntransfer').focus();

        });
        Defaultfocus();

      

    });

    function GetDepartment(){
        var data = {};
        data.DeptId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/DepartmentGetandGets",
            data: data,
            success: function (result) {
                DepartmentLoad(result.oList);


            }
        });
    }


    function GetDivision(){

        var data1 = {};
        $.ajax({
            type: "POST",
            url: "../WorkItemUser/WorkDivisionGetandGets",
            data: data1,
            success: function (result) {
                DivisionLoad(result.oList);


            }
        });
    }

    function GetList() {
        var table = $("#listitems").EumiDataTable({
            "processing": true,
            "serverSide": true,
            "ajax": {
                "url": "../WorkItemUser/ListWorkItemsJsonDashBoard",
                "type": "POST",
                "data": function (data) {
                    data.addData = window.ListPageParams;
                }
            },
            "autoWidth": false,
            "columnDefs": [
                            {
                                "width": "5px",
                                "targets": 0,
                                "className": "text-center"
                            },
                            {
                                "width": "90px",
                                "targets": 1,
                            },
                            {
                                "width": "120px",
                                "targets": 2,
                            },
                            {
                                "width": "30px",
                                "targets": 3,
                            },
                            {
                                "width": "40px",
                                "targets": 4,

                            },
                            {
                                "width": "5px",
                                "targets": 5,
                            },
                            {
                                "width": "5px",
                                "targets": 6,
                            },
                            {
                                "width": "40px",
                                "targets": 7,
                            },
                            {
                                "width": "60px",
                                "targets": 8,
                            },
                            {
                                "width": "30px",
                                "targets": 9,
                            },
                            {
                                "targets": 10,
                                "visible": false
                            },
            ],
            "columns": [
                { data: "slno", title: "No", searchable: false, sortable: false },
                { data: "Title", title: "Category" },
                { data: "AssignedOn", title: " Date/Time" },
                { data: "AssignedByUser", title: "Assigned By" },
                { data: "AssignedToUser", title: "Assigned To" },
                { data: "Dept", title: "Location" },
                { data: "Div", title: "Division" },
                { data: "Status", title: "Status" },
                { data: "Reason", title: "Remarks" },
                { data: "WorkItemId", title: "Edit", searchable: false, sortable: false },
                { data: "EXCEDDEDTIME", title: "EXCEDDEDTIME" },
            ],
            "createdRow": function (row, data, index) {
                row.getElementsByTagName("td")[9].innerHTML = '<a  onclick="GetItem(' + data.WorkItemId + ');">' + Editbutton + '</a>';

                if (data.EXCEDDEDTIME <= 0 && row.getElementsByTagName("td")[7].innerHTML != 'Completed' && row.getElementsByTagName("td")[7].innerHTML != 'Canceled' && row.getElementsByTagName("td")[7].innerHTML != 'Reassign') {

                    $('td', row).css('background-color', '#FF8F00');
                    $(row).addClass('white');
                }
                else
                    if (row.getElementsByTagName("td")[7].innerHTML == 'On Hold') {
                        $(row.getElementsByTagName("td")[7]).addClass('deep orange');
                        //$(row).addClass('orange');
                        // $('td', row).css('background-color', 'Orange');
                    }
                    else if (row.getElementsByTagName("td")[7].innerHTML == 'Completed') {
                        $(row.getElementsByTagName("td")[7]).addClass('green');
                    }
                    else if (row.getElementsByTagName("td")[7].innerHTML == 'Canceled') {
                        $(row.getElementsByTagName("td")[7]).addClass('danger');
                    }
                    else if (row.getElementsByTagName("td")[7].innerHTML == 'Created') {
                        $(row.getElementsByTagName("td")[7]).addClass('info');
                    }
                    else if (row.getElementsByTagName("td")[7].innerHTML == 'Started') {
                        $(row.getElementsByTagName("td")[7]).addClass('primary');
                    }
                    else if (row.getElementsByTagName("td")[7].innerHTML == 'Reassign') {
                        $(row.getElementsByTagName("td")[7]).addClass('brown');
                    }
                    else if (row.getElementsByTagName("td")[7].innerHTML == 'In Progress') {
                        $(row.getElementsByTagName("td")[7]).addClass('blue');
                    }

            },
            "order": [[9, 'desc']]
        });
    }





    function DepartmentLoad(result) {
        $("#Department").empty();
        for (var i = 0; i < result.length; i++) {
            $("#Department").append("<option value='" + result[i].DepartmentId + "'>" + result[i].DepartmentName + "</option>");
        }
        $('#Department').val(ERPDeptId);
    }

    function DivisionLoad(result) {
        $("#Division,#Division1,#Division2").empty();
        $("#Division1,#Division2").append("<option value='0'>--Select Division--</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Division,#Division1,#Division2").append("<option value='" + result[i].DivisionId + "'>" + result[i].DivisionName + "</option>");
        }
        WorkTaskTime();
    }

    function WorkTaskTime() {
        var data = {};
        data.DivisionId = $('#Division').val();
        $.ajax({
            type: "POST",
            url: "../WorkItemUser/WorkingTaskTimeGetandGets",
            data: data,
            success: function (result) {
                WorkTimeGets(result.bList);


            }
        });
    }

    function WorkTimeGets(result){
        $("#Time").empty();
        for (var i = 0; i < result.length; i++) {
            var Hr=0;   var Min=0;  var realmin=0;

            if(result[i].TurnAroundTimes>=60){
                Min = parseInt(result[i].TurnAroundTimes);
                realmin = Min % 60;
                Hr = Math.floor(Min / 60);
                $("#Time").append("<option value='" + result[i].TurnAroundTimes + "'>" + result[i].TurnAroundTimesName +" - " + Hr + " HR(s) "+ realmin +" Min(s)</option>");
            }
            else{
                Hr=0;
                realmin=parseInt(result[i].TurnAroundTimes)
                $("#Time").append("<option value='" + result[i].TurnAroundTimes + "'>" + result[i].TurnAroundTimesName +" - " + Hr + " HR(s) "+ realmin +" Min(s)</option>");
            }

        }
    }




    $(document).keydown(function (e) {
        if (e.keyCode == 27) {                           //esc
            if ($('#detailForm').is(":visible")) {
                $('#detailForm').hide();
            }
            else {
                $('#iconForm').hide();
            }
        }
    });





    function Getaccountstament() {
        $('#LoadingSmallRound').show();
        $('#salesdetails').hide();
        $('#pcol0').text(''); $('#pcol1').text(''); $('#pcol2').text(''); $('#pcol3').text('');
      
                              
        var data = {};
        data.Fromdate = $('#fromdate').val(); //'01/01/2019';
        data.Todate = $('#todate').val();   //CurDate;
        data.DeptId = ERPDeptId;
        data.UserId = ERPUserId;




        $.ajax({
            type: "POST",
            url: "../Purchaseandsalesreports/CustOutstandingDashboard",
            data: data,
            success: function (result) {
                showaccountstament(result);
            }
        });

    }





    function showaccountstament(result) {


        disable_datatable('Stocklist');
        $('#Stocklist tr').remove();
        var responseText = "";
        if (result.length != 0) {


            var responseText = "<thead><tr><th style='text-align:center;'>Sl#</th><th style='width:150px'>Account Code</th><th style='width:300px'>Account Name</th><th class=text-right style='width:100px'>Debit</th><th style='width:100px' class=text-right>Credit</th><th style='display:none'></th></tr>" +
                "<tr><th style='text-align:center;'>Sl#</th><th>Account Code</th><th>Account Name</th><th class=text-right>Debit</th><th class=text-right>Credit</th><th style='display:none'></th></tr>" +
                "</thead><tbody>";

            for (var i = 0; i < result.length; i++) {


                var slno;
                slno = parseInt(i + 1);

                var DebitAmt = parseFloat(result[i].Debit || 0).toFixed(Decimal);
                var CreditAmt = parseFloat(result[i].Credit || 0).toFixed(Decimal);
                if (DebitAmt == 0)
                    DebitAmt = '';

                if (CreditAmt == 0)
                    CreditAmt = '';

                if (result[i].AccDesc == 'Balance') {

                    responseText += '<tr style="background-color:#cfd8dc"><td style="width:70px;text-align:center;"><b>' + slno + '</b></td><td style="width:150px"  id="Col1_' + slno + '" ><b>' + result[i].AccCode + '</b></td><td style="width:500px;"   id="Col2_' + slno + '" ><b>' + result[i].AccDesc + '</b></td><td   id="Col3_' + slno + '" style="text-align:right;width:120px"><b>' + ReplaceNumberWithCommas(DebitAmt) + '</b></td><td id="Col4_' + slno + '" style="text-align:right;width:120px" ><b>' + ReplaceNumberWithCommas(CreditAmt) + '</b></td><td id="Col5_' + slno + '" style="text-align:right;display:none"><b>1</b></td></tr>';
                }
                else if (CreditAmt == '' && DebitAmt == '') {

                    responseText += '<tr style="background-color:#cfd8dc"><td style="width:70px;text-align:center;"><b>' + slno + '</b></td><td style="width:150px"  id="Col1_' + slno + '" ><b>' + result[i].AccCode + '</b></td><td style="width:500px;"   id="Col2_' + slno + '" ><b>' + result[i].AccDesc + '</b></td><td   id="Col3_' + slno + '" style="text-align:right;width:120px"><b>' + ReplaceNumberWithCommas(DebitAmt) + '</b></td><td id="Col4_' + slno + '" style="text-align:right;width:120px" ><b>' + ReplaceNumberWithCommas(CreditAmt) + '</b></td><td id="Col5_' + slno + '" style="text-align:right;display:none"><b>1</b></td></tr>';
