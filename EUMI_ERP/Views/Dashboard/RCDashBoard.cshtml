    function SalesmanwiseGraphReport(Grtype) {
        if ($('#Datetype').val() == 0) {

            var datamnt = {};
            datamnt.Fromdate = $('#fromdate').val(); // CurDate;
            datamnt.Todate = $('#todate').val(); //CurDate;
            datamnt.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/SalesmanwisePeriodReport",
                data: datamnt,
                success: function (result) {
                    DepartmentWiseSalesDashboard('column');
                    SalesmanwiseSalesGraphPeriod(result, Grtype);
                }
            });
        }
        else if ($('#Datetype').val() == 1) {
            var datamnt = {};
            datamnt.Fromdate = $('#fromdate').val();  //CurDate;
            datamnt.Todate = $('#todate').val();//CurDate;
            datamnt.DeptId = 0;
            datamnt.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/SalesmanDashboard",
                data: datamnt,
                success: function (result) {
                    DepartmentWiseSalesDashboard('column');
                    SalesmanwiseSalesGraph(result, Grtype);
                }
            });
        }
        else if ($('#Datetype').val() == 2) {

            var XFromDate=CurDate.split('/');
            var XXFromDate=XFromDate[2]+'-'+XFromDate[1]+'-'+XFromDate[0];


            var prevSat = new Date(XXFromDate);
            prevSat.setDate(prevSat.getDate() - (prevSat.getDay() + 8) % 7);
            var FormatedDate=GetFormattedDate(prevSat);


            var datamnt = {};
            datamnt.Fromdate =  FormatedDate;                                    //'01/' + mmmonth + '/' + hhh.getFullYear();
            datamnt.Todate = CurDate;                               //'31/12/' + hhh.getFullYear();
            datamnt.DeptId = 0;
            datamnt.UserId = ERPUserId;
            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/SalesmanWeeklyDashboard",
                data: datamnt,
                success: function (result) {
                    $('#fromdate').val(datamnt.Fromdate);
                    $('#todate').val(datamnt.Todate);
                    DepartmentWiseSalesDashboard('column');
                    SalesmanwiseSalesGraphWeek(result, Grtype);
                }
            });
        }
        else if ($('#Datetype').val() == 3) {

            var XFromDate=CurDate.split('/');

            var datamnt = {};
            datamnt.Fromdate = '01/' +XFromDate[1] +'/'+ +XFromDate[2];           //'01/01/' + hhh.getFullYear();
            datamnt.Todate = CurDate;                                             //'31/12/' + hhh.getFullYear();
            datamnt.DeptId = 0;
            datamnt.UserId = ERPUserId;

            $.ajax({
                type: "POST",
                url: "../Purchaseandsalesreports/SalesmanMonthlyDashboard",
                data: datamnt,
                success: function (result) {
                    $('#fromdate').val(datamnt.Fromdate);
                    $('#todate').val(datamnt.Todate);
