<style type="text/css">
    .modal-slg {
        max-width: 700px;
    }

    .main-panel {
        height: auto;
        width: auto;
        max-height: none;
        min-height: 100%;
        margin: 0;
        padding-top: 85px;
        float: none;
    }

    .eumi-search-box {
        box-sizing: border-box;
        width: 100%;
    }

    body.eumi-loader::before {
        content: '';
        display: block;
        position: fixed;
        z-index: 31000;
        height: 4px;
        background-color: rgba(0, 157, 160, 0.2);
        top: 0;
        left: 0;
        right: 0;
    }

    body.eumi-loader::after {
        content: '';
        display: block;
        position: fixed;
        z-index: 31001;
        height: 4px;
        background-color: rgba(0, 157, 160, 1);
        top: 0;
        width: 50px;
        animation: eumiloader 4s infinite linear;
    }

    .eumi-search-table, .eumi-shadow {
        border-spacing: 0 0px;
        box-shadow: 0px 0px 0px 2px #fff, 0 0 2px 2px #999;
    }

    @@keyframes eumiloader {
        from {
            right: 100%;
        }

        to {
            right: 0;
        }
    }

    #topnsales tr {
        border-bottom: 1px solid #e6e6e6;
    }

    #draggable {
        width: 150px;
        height: 150px;
        padding: 0.5em;
    }
    /*.card-block:hover {
        box-shadow: 20px 20px 10px rgba(0, 0, 0, 0.7);
        -webkit-transition: box-shadow 0.1s;
        transform: scale(1.0);
        transition: transform 0.1s;
        cursor: pointer;
    }*/
    .dihover :hover {
        background-color: transparent;
    }
     .jsgrid-cell {
    border: 1px solid lightblue!important;
}
      .notbookd:hover {   
   background-image:  linear-gradient(45deg, #cfd8dc, #546e7a);
}

    .tdhov {   
   background-image:  linear-gradient(45deg, #cfd8dc, #546e7a);
}
</style>

