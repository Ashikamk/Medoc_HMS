<div class="myData" data-x="M261" />
<div class="content-wrapper">
    <div class="row">
        <div class="col-xl-12 col-lg-12 col-12">
            <div class="card">
                <div class="card-body">
                    <div class="card-header">
                        <h4 class="card-title" style="font-weight:bold;">Dashboard</h4>
                    </div>

                    <div class="row" style="margin-left:170px;margin-top:-40px">
                        <div class="col-md-2">
                            <label>Search: </label>
                        </div>
                        <div class="col-md-4" style="margin-top:-0.5%;margin-left:-12%">
                            <input type="text" class="form-control" id="Search" onkeyup="$('#btndetail').prop('btnsummary', true)" onchange="GetSalesSummary(0, 0, 0, 0, 0, $('#Location').val(), $('#Search').val(), 0)" />
                        </div>

                        <div class="col-md-1" style="margin-top:-10px;margin-left:-1%">
                            <input type="text" style="width:125px;border-radius:10px" id="DateFrom" onchange="GetSalesSummary(0, 0, 0, 0, 0, $('#Location').val(), '', 0), $('#btnsummary').prop('checked', true)" class="form-control"/>
                        </div>
                        <div style="margin-left:1.5%">
                            -
                        </div>
                        <div class="col-md-3" style="margin-top:-10px;">
                            <input type="text" style="width:125px;border-radius:10px" id="DateTo" onchange="GetSalesSummary(0, 0, 0, 0, 0, $('#Location').val(), '', 0), $('#btnsummary').prop('checked', true)" class="form-control" />
                        </div>

                        <div class="col-md-2" style="margin-left:-15%">
                            <label>Location</label>
                        </div>
                        <div class="col-md-2" style="margin-top:-0.5%;margin-left:-12%">
                            <select type="text" class="form-control" id="Location" onchange="GetSalesSummary(0, 0, 0, 0, 0, $('#Location').val(), $('#Search').val(), 0)"></select>
                        </div>
                        <div style="margin-left:2%" id="divsummary" class="d-inline-block custom-control custom-radio mr-1">
