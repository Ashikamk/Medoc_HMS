    function GetSalesDetails(slno, bilsrs, billno, ItemId, dept, LocId,GarageName, UserId,flag) {
        var data = {};
        data.FromDate = $('#DateFrom').val();
        data.ToDate = $('#DateTo').val();
        data.BillSeriesId = bilsrs;
        data.BillSlNo = billno;
        data.ProductId = ItemId;
        data.DeptId = dept;
        data.UserId = ERPUserId;
        data.LocId = LocId;
        data.GarageName = GarageName;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/ItemwiseDashboard",
            data: data,
            success: function (result) {

                ShowSalesreport(result, flag);
               
            }
        });
    }
