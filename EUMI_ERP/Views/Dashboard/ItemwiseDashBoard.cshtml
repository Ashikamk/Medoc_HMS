    function GetLocation(id) {
        var data = {};
        data.LocationId = 0;
        data.UserId = ERPUserId;
        $.ajax({
            type: "POST",
            url: "../Master/UserLocationGetandGets",
            data: data,
            success: function (result) {
                LocationLoad(result.oList, id);
            }
        });
    }

    function LocationLoad(result, a) {
        $("#Location").empty();
        $("#Location").append("<option value='0'>-All-</option>");
        for (var i = 0; i < result.length; i++) {
            $("#Location").append("<option value='" + result[i].LocationId + "'>" + result[i].LocationName + "</option>");
        }
        $("#Location").val(UserLocationId)
    }

    function GetSalesSummary(slno, bilsrs, billno, ItemId, dept, LocId, GarageName, UserId) {
        var data = {};
        data.FromDate = $('#DateFrom').val();
        data.ToDate = $('#DateTo').val();
        data.BillSeriesId = bilsrs;
        data.BillSlNo = billno;
        data.DeptId = dept;
        data.UserId = ERPUserId;
        data.LocId = LocId;
        data.GarageName = GarageName;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SummaryDashboard",
            data: data,
            success: function (result) {
                ShowSalesreportSummary(result);
            }
        });
    }

