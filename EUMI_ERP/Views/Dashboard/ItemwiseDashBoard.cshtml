                            printthisoutbill(i, $('#BillSeriesIdsub' + i).val(), $('#Billnosub' + i).val(), $('#ProductId' + i).val(), $('#Col14_' + i).text(), $('#Col15_' + i).text(), $('#Col12_' + i).text(), $('#UserId' + i).val())
