<script type="text/javascript" src="~/app-assets/FromStack/dist/JsBarcode.all.js"></script>
<script type="text/javascript" src="~/app-assets/FromStack/dist/jquery-2.0.3.js"></script>
<script type="text/javascript" src="~/app-assets/FromStack/dist/QRCODE.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script>
    var createQRCode = function () {
        var data = $('#MCode').val();
        $('#QRCode').empty();
        $('#QRCode').qrcode(data);
        //$('#qrcode').append('</br><strong>' + data + '</strong>');
    };

    function generatebarcode() {
        var Code = $('#MCode').val(); if ($('#MCode').val() == '') { Code = 0; } JsBarcode("#barcode1", Code);
    }

    $('#MCode').keyup(function () { createQRCode(); generatebarcode(); });
    $('#MCode').change(function () { createQRCode(); generatebarcode(); });
    createQRCode();
    generatebarcode();

    $("#MCodeSearch").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#MCodeSearch").val();

            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.ItemCode,
                            label1: item.Description,
                            ItemId: item.ItemId,
                            Product: item.Description,
                            productcode: item.ItemCode,
                            GrpId: item.GrpId,
                            CategoryId: item.CategoryId,
                            headers: ["Code", "Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#Loading').show();


            GetItem(ui.item.ItemId, ui.item.GrpId, ui.item.CategoryId);
            $('#MCode').show();
            $('#MCodeSearch').hide();
            $('#btnsubmit').prop("disabled", false);
            $('#btnsubmit').show();
            $('#btnsearch').removeClass();
            $('#btnsearch').addClass('btn btn-outline-info');
        },
    });


    $("#MName").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#MName").val();

            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.ItemCode,
                            label1: item.Description,
                            ItemId: item.ItemId,
                            Product: item.Description,
                            productcode: item.ItemCode,
                            GrpId: item.GrpId,
                            CategoryId: item.CategoryId,
                            headers: ["Code", "Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {


        },
    });









    $("#MHSN").autocomplete({
        source: function (request, response) {
            $("#HSNId").val(0);
            var data = {};
            data.ItemCode = $("#MHSN").val();

            $.ajax({
                url: '../Master/HMS_HSNSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {

                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label: item.Hsncode,
                            label1: item.Name,
                            HsnId: item.DivId,
                            Hsncode: item.Hsncode,
                            Name: item.Name,
                            headers: ["HSN Code", "HSN Name"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $("#HSNId").val(ui.item.HsnId);
        },
    });
</script>


