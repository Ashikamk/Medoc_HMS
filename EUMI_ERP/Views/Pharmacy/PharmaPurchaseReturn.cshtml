    function SearchInvoiceSup1() {

        var data = {};
        data.ProductId = -99;
        data.OrdNo = $('#ExpinvDate').val();
        data.DeptId = ERPDeptId;
        $.ajax({
            type: "POST",
            url: "../SalesInvoice/SalesOrderGetProductsSalesInv",
