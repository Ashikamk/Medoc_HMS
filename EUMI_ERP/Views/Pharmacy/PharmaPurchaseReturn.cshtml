<script>

    function SearchInvoiceSup(A) {
        Search()
    }
    function Search() {

        if ($('#Expsupplier').val() == '') {

            var SupplierId = 0
        }
        else {
            var SupplierId = parseInt($('#EXPSupplierId').val() || 0);
        }

        $("#LoadingSmall").show();
        var data = {};
        data.Param1 = '';
        data.Param10 = $('#ExpinvDate').val();
        data.Param2 = 0;
        data.Param3 = 0;
        data.Param4 = 0;
        data.Param5 = 0;
        data.Param6 =0;
        data.DeptId = ERPDeptId;
        data.UserId = SupplierId;

        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_Rpt_ItemExpiry",
            data: data,
            success: function (result) {

                LoadReport(result);
            }
        });
    }


    function LoadReport(result)
    {

        console.log(result)
        $("#LoadingSmall").hide();

        for (var i = 0; i < 300; i++) {

            debugger;
            if (result[i].ItemId != 0) {
                var taxrate = 0;
                if (result[i].CompanyId == 1) {
                    taxrate = 0;
                }
                else if (result[i].CompanyId == 2) {
                    taxrate = 5;
                }
                else if (result[i].CompanyId == 3) {
                    taxrate = 12;
                }
                else if (result[i].CompanyId == 4) {
                    taxrate = 18;
                }
                else {
                    taxrate = 28;
                }
                var Id = 0;
                $('#Product_0').val(result[i].ItemDesc);
                $("#ProductId_" + Id).val(result[i].ItemId),
                $("#BatchSlNo_" + Id).val(result[i].BatchSlNo),
                $("#PurSlNo_" + Id).val(0),
                $("#InvId_" + Id).val(0),
                $("#TaxId_" + Id).val(result[i].CompanyId);
                $("#TaxRate_" + Id).val(taxrate),
                $("#Cess_" + Id).val(0);
                $("#Batch_" + Id).val(result[i].Batch),
                $("#Expiry_" + Id).val(result[i].Expiry),
                $("#Pack_" + Id).val(1),
                $("#Lqtty_0").val(result[i].Quantity)
                $("#Qty_" + Id).val(result[i].Quantity),
                $("#Loose_" + Id).val(0),
                $("#Free_" + Id).val(0);
                $("#Rate_" + Id).val(result[i].MedType),
                $("#SR_" + Id).val(result[i].MedType),
                $("#Discount_" + Id).val(0),
                $("#DiscountPer_" + Id).val(0),
                $("#MRP_" + Id).val(result[i].MedType);
                ProductAdd();
            }
        }
    }



</script>



