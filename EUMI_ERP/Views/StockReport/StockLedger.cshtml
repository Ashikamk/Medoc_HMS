
@{
    ViewBag.Title = "StockLedger";
}


<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>

<style>
    .form-control {
        font-weight: bold;
    }
</style>

<div class="myData" data-x="M250" />

<div id="Entry">

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">


                    <div>
                        <table width="100%">
                            <tr>
                                <td><h4 id="header"></h4></td>

                                <td align="right"><button type="button" style="width:100px" onclick="$('#popupdiv').show(), $('#placeofsupply').focus()" id="btnback" class="btn btn-outline-primary">Back</button></td>
                                @* <td><button type="button" style="width:100px;margin-left:20px" id="btnprint" onclick="PrintthisReportWindows('PURCHASEREPORT', $('#ResultLength').val())" class="btn btn-primary">Print <i class="ft-printer"></i></button></td>*@

                                <td align="right">
                                    <div class="btn-group" id="buttonPlace">

                                        <div align="right">
                                            <div class="heading-elements">
                                                <div class="btn-group" id="buttonPlace">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <tr><td colspan="3"><span id="header1" style="font-weight:bold"></span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                <span id="header2" style="font-weight:bold"></span></td></tr>

</table>


                        <div align="">
                            <div class="">
                                <hr style="margin-top:0;" />
                                <div id="divreport" style="overflow:auto;display:none1">
                                    <table id="Tblreport" class="table table-striped table-bordered base-style dataTable" style="width:100%"></table><br />
                                </div>
                                <div style="display:none">
                                    <table id="Tblreportprint"></table>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%;width:110%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content" style="width:66%">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Stock Ledger</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row">
                        <label class="col-md-2 text-right" style="font-weight:bold;">From</label>
                        <div class="col-md-4">
                            <input type="text" id="DateFrom" class="form-control" autocomplete="off">
                        </div>


                        <label class="col-md-2 text-right"  style="font-weight:bold;">To</label>
                        <div class="col-md-4">
                            <input type="text" id="DateTo" class="form-control" autocomplete="off">
                        </div>
                    </div>

                    <div class="row" style="border-bottom:1px solid #cfd8dc;margin-top:3%;"></div>

                    <div class="row">
                        <label class="col-md-2 text-right" style="margin-top:2%;font-weight:bold;">Product </label>
                        <div class="col-md-10" style="margin-top:2%;">
                            <input type="text" id="productcode" class="form-control">
                            <input type="hidden" id="productid" value="0" class="form-control" />
                            <input type="hidden" id="productdesc" class="form-control" />
                        </div>


                        
                    </div>

                    
                </div>

                <div class="modal-footer">
                    <button type="button" style="width:100px;margin-right:35%" id="btnsubmit" onclick="GoReport()" class="btn btn-primary">Go</button>
                    <input type="hidden" id="Length" class="form-control" />
                    <input type="hidden" id="ResultLength" class="form-control" />
                </div>


            </form>
        </div>
    </div>
</div>

<script>
    $("#productcode").autocomplete({
        source: function (request, response) {
            var data = {};
            data.ItemCode = $("#productcode").val();

            $.ajax({
                url: '../Purchase/ProductSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                   
                    response($.map(data, function (item) {
                        return ({
                            ColCount: 'TWOEnq',
                            label1: item.ItemCode,
                            label: item.Description,
                            ItemId: item.ItemId,
                            Product: item.Description,
                            headers: ["Product Name", "Product Code",]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#productid').val(ui.item.ItemId)
            $('#productdesc').val(ui.item.Product);
            $('#btnsubmit').focus();
        },
    });


    $(function () {
        $('#productcode').focus();



        $('#productcode').keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $('#btnsubmit').focus();
                e.preventDefault();
            }
        });
        $('#DateFrom').val(FinanceStartDate)
        $('#DateFrom').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
        

        $('#DateTo').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    });


        function popuprefresh() {
            $('#popupdiv').hide();
        }

        function GoReport() {

            if ($('#productcode').val() == '') {
                $('#productid').val(0)
                warningshow('Please Select Product', 'productcode');
            }
           
            else {
                $('#Loading').show();
                var datax = {};
                datax.FromDate = $('#DateFrom').val();
                datax.ToDate = $('#DateTo').val();
                datax.UserId = ERPUserId;
                datax.DeptId = ERPDeptId;
                datax.ProductId = $('#productid').val();


                $.ajax({
                    type: "POST",
                    url: "../StockReport/StockLedger",
                    data: datax,
                    success: function (result) {


                        GetReport(result);

                    }
                });
            }
        }


        function GetReport(result) {

            $('#popupdiv').hide();
            $('#Loading').hide();
            
           

            disable_datatable('Tblreport', 'buttonPlace');
            var responseText = "<thead><tr><th>Sl#</th><th>Date</th><th>Type</th><th>Bill#</th><th>Account</th><th>Description</th><th>Received Qty.</th><th>Rate</th><th>Amount</th><th>Issued Qty.</th><th>Cost</th><th>Amount</th><th>BalQty</th><th>Total Value</th></tr></thead><tbody>";

            for (var i = 0; i < result.length; i++) {
                var slno = parseInt(i + 1);


                if (result[i].Account == 'Opening Balance')
                {
                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold">' +
                                                        '<td>' + slno + '</td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td>' + result[i].Account + '</td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td style="text-align:center">' + result[i].BalanceQty + '</td>' +
                                                        '<td style="text-align:right">' + parseFloat(result[i].AvgCost).toFixed(Decimal) + '</td>' +
                                                        '</tr>';
                }
                else if (result[i].AccCode == 'Total') {
                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold">' +
                                                        '<td>' + slno + '</td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td>' + result[i].AccCode + '</td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td></td>' +
                                                        '<td style="text-align:center">' + result[i].BalanceQty + '</td>' +
                                                        '<td style="text-align:right">' + parseFloat(result[i].AvgCost).toFixed(Decimal) + '</td>' +
                                                        '</tr>';
                }
                else if (result[i].TrType == 1) {

                    responseText += '<tr>' +
                                     '<td>' + slno + '</td>' +
                                     '<td>' + result[i].InvDate + '</td>' +
                                     '<td style="text-align:center">' + result[i].TransType + '</td>' +
                                     '<td>' + result[i].BillNumber + '</td>' +
                                     '<td>' + result[i].AccCode + '</td>' +
                                     '<td>' + result[i].Account + '</td>' +
                                     '<td style="text-align:center">' + result[i].Quantity + '</td>' +
                                     '<td style="text-align:right">' + parseFloat(result[i].Cost).toFixed(Decimal) + '</td>' +
                                     '<td style="text-align:right">' + parseFloat(result[i].Amount).toFixed(Decimal) + '</td>' +
                                     '<td></td>' +
                                     '<td></td>' +
                                     '<td></td>' +
                                     '<td style="text-align:center">' + result[i].BalanceQty + '</td>' +
                                     '<td style="text-align:right">' + parseFloat(result[i].AvgCost).toFixed(Decimal) + '</td>' +
                                     '</tr>';
                }
                else {
                    responseText += '<tr>' +
                                    '<td>' + slno + '</td>' +
                                    '<td>' + result[i].InvDate + '</td>' +
                                    '<td style="text-align:center">' + result[i].TransType + '</td>' +
                                    '<td>' + result[i].BillNumber + '</td>' +
                                    '<td>' + result[i].AccCode + '</td>' +
                                    '<td>' + result[i].Account + '</td>' +
                                    '<td></td>' +
                                    '<td></td>' +
                                    '<td></td>' +
                                    '<td style="text-align:center">' + result[i].Quantity + '</td>' +
                                    '<td style="text-align:right">' + parseFloat(result[i].SellingRate).toFixed(Decimal) + '</td>' +
                                    '<td style="text-align:right">' + parseFloat(result[i].SellingAmount).toFixed(Decimal) + '</td>' +
                                    '<td style="text-align:center">' + result[i].BalanceQty + '</td>' +
                                    '<td style="text-align:right">' + parseFloat(result[i].AvgCost).toFixed(Decimal) + '</td>' +
                                    '</tr>';
                }

                

            }
            
            $('#Tblreport').html(responseText + '</tbody><tfoot><tr><th> </th><th>Date</th><th>Type</th><th>Bill#</th><th>Account</th><th>Description</th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th><th> </th></tr></tfoot>');
            $('#Tblreportprint').html(responseText);
            var title = "Stock Ledger - from " + $("#DateFrom").val() + " to " + $("#DateTo").val() + "";
            datatableWithsearchs('Tblreport', true, title, 'buttonPlace');

            $('#header1').text('Product Code : ' + $('#productcode').val());
            $('#header2').text('Product Name : ' + $('#productdesc').val())


            $('#header').text(title);
            $('#ResultLength').val(result.length);
        }


        function datatableWithsearchs(tablename, download, title, tableButtonContainerId) {

            var a = '#' + tablename + ' tfoot th'
            $(a).each(function () {
                var title = $(this).text();
                if (title != ' ') {
                    $(this).html('<input type="text" placeholder=" ' + title + '" style="width:100%" />');
                }
                

            });
            var table = null;
            if (download) {
                if (!title || !tableButtonContainerId) { console.log("download table need title and button container"); }


                table = $('#' + tablename).DataTable({
                    //dom: 'Blfrtip',
                    dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                   "<'row'<'col-sm-12'tr>>" +
                   "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                    buttons: [],
                    "columnDefs": [
                         { "width": "2%", "targets": 0 },
                         { "width": "10%", "targets": 3 },
                         { "width": "40%", "targets": 5},

                    ]

                });
                new $.fn.dataTable.Buttons(table, {
                    buttons: [
                    {
                        extend: 'collection',
                        text: 'Export',
                        className: 'excelexport',
                        buttons: [
                            {
                                extend: 'excelHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            },
                            {
                                extend: 'print',
                                title: title,
                                messageTop: 'MEDOC HMS',
                                exportOptions: { columns: ":visible" }
                            }
                        ]
                    },
                    'colvis'
                    ]
                });
                table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
                $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");

            } else {
                table = $('#' + tablename).DataTable();
            }
            table.columns().every(function () {
                var that = this;
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that
                            .search(this.value)
                            .draw();

                    }
                });
            });
            if (ExcelExport == 0) {
                $('.excelexport').hide();
            }
        }



</script>