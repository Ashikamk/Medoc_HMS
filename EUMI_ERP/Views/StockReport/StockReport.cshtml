            });

            $('#txtbox').focus();
                $(document).keydown(function (e) {


                    var x = event.keyCode;
                    if ((x > 111 && x < 124)) {
                        //Purchase Popup
                        if (x == 119) {                     // F8 - Pop Up to Show Purchase Transaction Details of Selected Product 
                            if ((usermenu1.indexOf("M31") != -1) || (usermenu1.indexOf("M35") != -1) || (usermenu1.indexOf("M159") != -1) || (usermenu1.indexOf("M233") != -1)) {

                                Purchasespopup($('#ProductId').val());
                                hidepopup(1);
                                $('#productpdiv').hide();
                                $('#salestranspopupdiv').hide();
                                $('#TransactionPopup').hide();
                                $('#MonthwisePurchase').hide();
                                $('#PendingPurchaseTransactionPopup').hide();
