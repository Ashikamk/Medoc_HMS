                                //$('#totalnosales').text('');
                                hidepopup(1);
                                $('#productpdiv').hide();
                                $('#TransactionPopup').hide();
                                $('#PurchaseTransactionPopup').hide();
                                $('#MonthwisePurchase').hide();
                                $('#PendingPurchaseTransactionPopup').hide();
                                $('#DOpopupdiv').hide();
                                $('#salestranspopupdiv').show();
                            }
                            else {
                                $('#salestranspopupdiv').hide();
                                $('#salestransdiv').hide();
                                warningshow('Invalid User Rights')
                            }

                        }
                            //All Transaction Popup
                        else if (x == 120) {                                 // F9 :   All Transaction details Popup  
                            TransactionPopup($('#ProductId').val());
                            hidepopup(1);
                            $('#productpdiv').hide();
                            $('#PurchaseTransactionPopup').hide();
                            $('#salestranspopupdiv').hide();
                            $('#MonthwisePurchase').hide();
                            $('#PendingPurchaseTransactionPopup').hide();
