            var data = {};
            data.ProductId = id;
            data.CustId =0;
            data.DeptId = ERPDeptId;
            $.ajax({
                type: "POST",
                url: '../SalesInvoice/CustomerProductDetailsSearch',
                data: data,
                success: function (result) {
                    LoadProddetails(result.oList, 1);
