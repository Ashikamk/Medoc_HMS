                            $('#TransactionPopup').show();

                            $('#alltranscheckboxdivsales').show();
                            $('#idforlabeltype').text('Previous');
                            $('#status_type').prop("checked", false);
                        }
                        else if (x == 123) {                                 // F12 :   Pending PO Details Popup  
                            PendingPurchasespopup($('#ProductId').val());
                            hidepopup(1);
                            $('#productpdiv').hide();
                            $('#PurchaseTransactionPopup').hide();
                            $('#salestranspopupdiv').hide();
                            $('#MonthwisePurchase').hide();
                            $('#TransactionPopup').hide();
                            $('#DOpopupdiv').hide();
                            $('#PendingPurchaseTransactionPopup').show();
                            
                            $('#alltranscheckboxdivsales').show();
                            $('#idforlabeltype').text('Previous');
                            $('#status_type').prop("checked", false);
                        }
                        else if (x == 122) {                                 // F11 :   DO Details Popup  
                            DeliveryOrderpopup($('#ProductId').val());
                            hidepopup(1);
                            $('#productpdiv').hide();
                            $('#TransactionPopup').hide();
                            $('#PurchaseTransactionPopup').hide();
                            $('#salestranspopupdiv').hide();
                            $('#MonthwisePurchase').hide();
                            $('#PendingPurchaseTransactionPopup').hide();
                            $('#DOpopupdiv').show();
                        }
                        
                            //Monthwise Details Popup
                        else if (x == 121) {                // F10 :   Monthwise details Popup                                                           
                            if (((usermenu1.indexOf("M31") != -1) || (usermenu1.indexOf("M233") != -1) || (usermenu1.indexOf("M35") != -1) || (usermenu1.indexOf("M159") != -1))
                                &&
                                    ((usermenu1.indexOf("M54") != -1) || (usermenu1.indexOf("M227") != -1) || (usermenu1.indexOf("M162") != -1) || (usermenu1.indexOf("M173") != -1) || (usermenu1.indexOf("M192") != -1))) {
                                $('#PurchaseDetails').show();
                                $('#SalesDetails').show();

                                MonthwisePurchasePopup($('#ProductId').val());
                                hidepopup(1);
                                $('#productpdiv').hide();
                                $('#PurchaseTransactionPopup').hide();
                                $('#salestranspopupdiv').hide();
                                $('#TransactionPopup').hide();
                                $('#PendingPurchaseTransactionPopup').hide();
                                $('#DOpopupdiv').hide();
                                $('#MonthwisePurchase').show();
                            }

                            else if (((usermenu1.indexOf("M31") != -1) || (usermenu1.indexOf("M233") != -1) || (usermenu1.indexOf("M35") != -1) || (usermenu1.indexOf("M159") != -1))
                                &&
                                ((usermenu1.indexOf("M54") == -1) || (usermenu1.indexOf("M227") == -1) || (usermenu1.indexOf("M162") == -1) || (usermenu1.indexOf("M173") == -1) || (usermenu1.indexOf("M192") == -1))) {

                                $('#SalesDetails').hide();
                                $('#PurchaseDetails').show();

                                MonthwisePurchasePopup($('#ProductId').val());
                                hidepopup(1);
                                $('#productpdiv').hide();
                                $('#PurchaseTransactionPopup').hide();
                                $('#salestranspopupdiv').hide();
                                $('#TransactionPopup').hide();
                                $('#PendingPurchaseTransactionPopup').hide();
                                $('#MonthwisePurchase').show();
                            }
                            else if (((usermenu1.indexOf("M31") == -1) || (usermenu1.indexOf("M233") == -1) || (usermenu1.indexOf("M35") == -1) || (usermenu1.indexOf("M159") == -1))
                                &&
                                    ((usermenu1.indexOf("M54") != -1) || (usermenu1.indexOf("M227") != -1) || (usermenu1.indexOf("M162") != -1) || (usermenu1.indexOf("M173") != -1) || (usermenu1.indexOf("M192") != -1))) {
                                $('#PurchaseDetails').hide();
                                $('#SalesDetails').show();

                                MonthwisePurchasePopup($('#ProductId').val());
                                hidepopup(1);
                                $('#productpdiv').hide();
                                $('#PurchaseTransactionPopup').hide();
                                $('#salestranspopupdiv').hide();
                                $('#TransactionPopup').hide();
                                $('#PendingPurchaseTransactionPopup').hide();
                                $('#MonthwisePurchase').show();
                            }

                            else {
                                $('#MonthwisePurchase').hide();
                                $('#MonthwisePurchasediv').hide();
                                warningshow('Invalid User Rights')
                            }
                        }
                        event.cancelBubble = true;
                        event.returnValue = false;
                        event.keyCode = false;
                        return false;

                    }
                    else if (e.altKey && e.keyCode == 83) {                   //Alt+S     :   Save
                        $("#txtbox").focus();
                        $("#txtbox").select();
                        hidepopup(1);
                        productpopuprefresh();
                        transpopuprefresh();
                        salestranspopuprefresh();
                        ClosePurTransPopup();
                        ClosePendingPurTransPopup();
                        MonthwisePurchasepopuprefresh();
                        DOpopuprefresh();
                    }
                    else if (e.keyCode == 27) { //ESC       :   Popup Close
                        $('#txtbox').focus();
                        $("#txtbox").select();
                        hidepopup(1);
                        productpopuprefresh();
                        transpopuprefresh();
                        salestranspopuprefresh();
                        ClosePurTransPopup();
                        ClosePendingPurTransPopup();
                        MonthwisePurchasepopuprefresh();
                        DOpopuprefresh();
                    }
                    else if ((e.altKey && e.keyCode == 89) && (($("#salestranspopupdiv").is(":visible")) || ($("#PurchaseTransactionPopup").is(":visible")) || ($("#TransactionPopup").is(":visible")))) {   //ALT+Y : PREVIOUS TRANSACTIONS
                        if ($("#salestranspopupdiv").is(":visible")) {
