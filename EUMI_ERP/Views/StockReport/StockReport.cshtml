            function gotoSales(BillSlNo, BillSeriesId, DeptId) {
                    if ((usermenu1.indexOf("M54") != -1)) {
                        window.open('../inventory/SalesInvoice?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                    }
                    else if ((usermenu1.indexOf("M227") != -1)) {
                        window.open('../inventory/SalesInvoiceNew?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
              
            }
            function gotoPurchase(SlNo, DeptId) {
                if ((usermenu1.indexOf("M31") != -1)) {
                    window.open('../inventory/PurchaseInvoice?slno=' + SlNo + '&dept=' + DeptId);
                }
                else if ((usermenu1.indexOf("M233") != -1)) {
                    window.open('../Purchase/PurchaseInvoiceNew?slno=' + SlNo + '&dept=' + DeptId);

                }
                else {
                    warningshow('Invalid User Rights');
                    return false;
                }

            }
            function gotoTransaction(BillNo, TransType, BillSeriesId, DeptId) {

                if (TransType == 'SI') {
                    if ((usermenu1.indexOf("M54") != -1)) {
                        window.open('../inventory/SalesInvoice?slno=' + BillNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                    }
                    else if ((usermenu1.indexOf("M227") != -1)) {
                        window.open('../inventory/SalesInvoiceNew?slno=' + BillNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
                }


                else if (TransType == 'PI') {
                    if ((usermenu1.indexOf("M31") != -1)) {
                        window.open('../inventory/PurchaseInvoice?slno=' + BillNo + '&dept=' + DeptId);
                    }
                    else if ((usermenu1.indexOf("M233") != -1)) {
                        window.open('../Purchase/PurchaseInvoiceNew?slno=' + BillNo + '&dept=' + DeptId);

                    }
                    else {
                        warningshow('Invalid User Rights');
                        return false;
                    }
                }


                else if (TransType == 'SR') {
                    if ((usermenu1.indexOf("M56") != -1)) {
                        window.open('../SalesInvoice/SalesReturn?billseries=' + BillSeriesId + '&slno=' + BillNo + '&dept=' + DeptId);

                    }
                    else if ((usermenu1.indexOf("M241") != -1)) {
