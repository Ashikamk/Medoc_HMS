<style>
    .checkmark {
        background-color: #eee;
    }

    input[name="Checkimeino"]:not(:checked),
    input[name="Checkimeino"]:checked {
        position: absolute;
        left: -9999px;
    }

        input[name="Checkimeino"]:not(:checked) + label,
        input[name="Checkimeino"]:checked + label {
            position: relative;
            padding-left: 25px;
            padding-top: 8px;
            cursor: pointer;
            border-radius: 4px;
        }

            input[name="Checkimeino"]:not(:checked) + label:before,
            input[name="Checkimeino"]:checked + label:before {
                content: '';
                position: absolute;
                left: 0;
                top: -5px;
                width: 30px;
                height: 30px;
                background: white;
                box-shadow: inset 0 1px 3px rgba(0, 0, 0, .1);
                background-color: white;
                outline: none;
            }

            input[name="Checkimeino"]:not(:checked) + label:after,
            input[name="Checkimeino"]:checked + label:after {
                content: '✔';
                position: absolute;
                top: 3px;
                left: 6px;
                font-size: 24px;
                line-height: 0.8;
                color: #0097a7;
                transition: all .2s;
            }

            input[name="Checkimeino"]:not(:checked) + label:after {
                opacity: 0;
                transform: scale(0);
            }

            input[name="Checkimeino"]:checked + label:after {
                opacity: 1;
                transform: scale(1);
            }

         
        
         input[name="gridheadchk"]:not(:checked),
    input[name="gridheadchk"]:checked {
        position: absolute;
        left: -9999px;
    }

      input[name="gridheadchk"]:not(:checked) + label,
        input[name="gridheadchk"]:checked + label {
            position: relative;
            padding-left: 25px;
            padding-top: 8px;
            cursor: pointer;
            border-radius: 4px;
        }

            input[name="gridheadchk"]:not(:checked) + label:before,
            input[name="gridheadchk"]:checked + label:before {
                content: '';
                position: absolute;
                left: 0;
                top: -5px;
                width: 30px;
                height: 30px;
                background: white;
                box-shadow: inset 0 1px 3px rgba(0, 0, 0, .1);
                background-color: white;
                outline: none;
            }

            input[name="gridheadchk"]:not(:checked) + label:after,
            input[name="gridheadchk"]:checked + label:after {
                content: '✔';
                position: absolute;
                top: 3px;
                left: 6px;
                font-size: 24px;
                line-height: 0.8;
                color: black;
                transition: all .2s;
            }

            input[name="gridheadchk"]:not(:checked) + label:after {
                opacity: 0;
                transform: scale(0);
            }

            input[name="gridheadchk"]:checked + label:after {
                opacity: 1;
                transform: scale(1);
            }
   
         .modal-xl {
        max-width: 100%;
        margin-left: 10%;
        margin-right: 3%;
    }          
</style>
