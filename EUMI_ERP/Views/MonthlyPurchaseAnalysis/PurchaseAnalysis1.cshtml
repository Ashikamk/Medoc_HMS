    $(document).keydown(function (e) {

        var rowCount = document.getElementById('Tblreport').rows.length;
        var x = event.keyCode;

       
        if ((x > 111 && x < 124) && !($('#modal_dialog').is(':visible'))) {
            if (x == 115) {                     // F4
                GetOrder($('#Chkflg').val());
                $('#iconForm').hide();
                $('#PendingPurchaseTransactionPopup').hide();
                $('#salestranspopupdiv').hide();
                $('#OrderPopup').show();
            }
            else if ((x == 118)) {     // F7 - Pop Up to Show Sales Transaction Details of Selected Product      
                $('#OrderPopup').hide();
                $('#iconForm').hide();
                $('#PendingPurchaseTransactionPopup').hide();
                TransactionGet($('#Chkflg').val(), 1);
                e.preventDefault();
            }
            else if ((x == 119)) {                         // F8 - Pop Up to Show Purchase Transaction Details of Selected Product 
                $('#OrderPopup').hide();
                $('#iconForm').hide();
                $('#PendingPurchaseTransactionPopup').hide();
                TransactionGet($('#Chkflg').val(), 2);
            }
            else if ((x == 120)) {  // F9 :   All Transaction details Popup      
                $('#OrderPopup').hide();
                $('#iconForm').hide();
                $('#PendingPurchaseTransactionPopup').hide();
                TransactionGet($('#Chkflg').val(), 3);
                e.preventDefault();
            }
            else if ((x == 121)) {  // F10 :   monthly Popup      
                e.preventDefault();
                $('#PendingPurchaseTransactionPopup').hide();
                TransactionGet($('#Chkflg').val(), 4);

            }
            else if (x == 123) {                                                // F12 :   Pending details Popup      
                $('#OrderPopup').hide();
                $('#iconForm').hide();
                $('#salestranspopupdiv').hide();
                $('#MonthwisePurchase').hide();
                PendingPurchasespopup($('#Chkflg').val());
                $('#PendingPurchaseTransactionPopup').show();
            }

            event.cancelBubble = true;
            event.returnValue = false;
            event.keyCode = false;
            return false;
        }
        else if (e.keyCode == 27) { //ESC       :   Popup Close
            $('#OrderPopup').hide();
            $('#iconForm').hide();
            $('#Chkflg').val('');
            salestranspopuprefresh();
            $('#MonthwisePurchase').hide();
            $('#PendingPurchaseTransactionPopup').hide();
        }

    });


