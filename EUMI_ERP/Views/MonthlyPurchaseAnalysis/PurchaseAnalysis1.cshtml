<div id="popupdiv" class="modal fade text-left show" tabindex="-1" role="dialog" aria-labelledby="myheader" style="padding-right: 17px; background:rgba(0,0,0,0.5); display: block; display:none1;height:200%">
    <div class="modal-dialog modal-lg" role="document" style="top:5%">
        <div class="modal-content">
            <div class="modal-header bg-primary white">
                <h4 class="modal-title" id="myheader">Purchase Analysis</h4>
                <button type="button" class="close" onclick="popuprefresh()" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <form id="monthpopup" style="display:none1">
                <div class="modal-body">
                    <div class="row" style="margin-top:20px;">
                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Purchase Type</label>
                        </div>
                        <div class="col-md-3">
                            <select type="text" class="form-control" id="Type">
                                <option value="0">-All-</option>
                                <option value="Local">Local Purchase</option>
                                <option value="Import">Import Purchase</option>
                            </select>
                        </div>


                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Movement</label>
                        </div>
                        <div class="col-md-3">
                            <select type="text" class="form-control" id="movement" onchange="getcalcmonth()">
                                <option value="1">1 Month</option>
                                <option value="3">3 Month</option>
                                <option value="6">6 Month</option>
                                <option value="9">9 Month</option>
                                <option value="12">12 Month</option>
                            </select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;">
                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Movement From Date </label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" id="DateFrom" class="form-control">
                        </div>


                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Movement To Date </label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" id="DateTo" class="form-control" onchange="getcalcmonth()">
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;">
                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Group </label>
                        </div>
                        <div class="col-md-3">
                            <select id="Group" class="form-control" name="priority" onchange="SubGroupGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Sub Group </label>
                        </div>
                        <div class="col-md-3">
                            <select id="Subgroup" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>

                    <div class="row" style="margin-top:20px;">
                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Category </label>
                        </div>
                        <div class="col-md-3">
                            <select id="Category" class="form-control" name="priority" onchange="SubCategoryGets()">
                                <option value='0'>-All-</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                        <label style="margin-top:5px;">Sub Category</label>
                        </div>
                        <div class="col-md-3">
                            <select id="Subcategory" class="form-control" name="priority">
                                <option value='0'>-All-</option>
                            </select>
                        </div>
                    </div>
                    <div class="row" style="margin-top:20px;">
                        <div class="col-md-3">
                        <label for="Values" style="margin-top:5px;">Supplier</label>
                        </div>
                        <div class="col-md-3">
                            <input type="text" id="suppliername" class="form-control" onkeyup="Checksupempty(event)">
                            <input type="hidden" id="supplierId" class="form-control" />
                        </div>

                        <div class="col-md-3"> 
                        <label style="margin-top:5px;">Order For</label>
                        </div>
                        <div class="col-md-3">
                            <select id="orderfor" class="form-control">
                                <option value="1">1 Month</option>
                                <option value="3">3 Month</option>
                                <option value="6">6 Month</option>
                                <option value="9">9 Month</option>
                                <option value="12">12 Month</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" style="width:100px" id="btnsubmit" class="btn btn-outline-primary">Go</button>
                </div>
            </form>

        </div>
    </div>
</div>

