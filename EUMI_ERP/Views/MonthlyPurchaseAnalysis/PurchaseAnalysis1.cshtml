    function getcalcmonth() {

        if ($('#movement').val() != 0) {
            var Dt = $('#DateTo').val();            
            var x = $('#movement').val(); //or whatever offset
            var CurrentDate = new Date(Dt.slice(6, 10) + '-' + Dt.slice(3, 5) + '-' + Dt.slice(0, 2));;
            //For the very rare cases like the end of a month
            //eg. May 30th - 3 months will give you March instead of February            
            var date = CurrentDate.getDate();
            CurrentDate.setDate(1);
            CurrentDate.setMonth(CurrentDate.getMonth() - x);
            CurrentDate.setDate(date);
            date = new Date(CurrentDate)
            var dd = date.getDate();
            var mm = date.getMonth() + 1;
            var yyyy = date.getFullYear();
            if (dd < 10) { dd = '0' + dd }
            if (mm < 10) { mm = '0' + mm };
            var d = dd + '/' + mm + '/' + yyyy;
            $('#DateFrom').val(d);
        }
    }

