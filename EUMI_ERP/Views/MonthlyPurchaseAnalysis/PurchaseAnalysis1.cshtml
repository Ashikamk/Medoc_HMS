    function GetItem(ItemId)
    {
        var data={};

        data.ItemId = ItemId;
        data.locId = 0;
        $.ajax({
            type:"POST",
            url: "../MonthlyPurchaseAnalysis/PurchaseanalysisPurchaseGet",
            data:data,
            success: function (result) {
                $('#iconForm').show();
                ItemLoad(result.oList);
                
            }

        })

    }

  


    function ItemLoad(result) {

        var Id = $('.rowactive').attr('id').match(/\d+/)[0];
        var ProductDesc = $('#desc' + Id).text();
        var product = $('#itemcode' + Id).text();

        $('#headiddetialls').text(product + '-' + ProductDesc + ' : Purchase Details')
        disable_datatable('Stocklist');
     
        var responseText = "<thead><tr><th>Sl#</th><th>Inv.#</th>" +
              "<th>Inv.Date</th>" +
              "<th>Supplier Name</th>" +
              "<th>Pur.Qty.</th>" +
               "<th>Pur. Cost</th>" +
               "<th>FC Cost</th>" +
               "<th>Currency</th>" +
               "<th>Currency Rate</th>" +
               "<th>Purchase Type</th></tr>" +

              "<tr><th> </th><th>Inv.#</th>" +
              "<th>Inv.Date</th><th>Supplier</th>" +
              "<th>Pur.Qty.</th><th> </th><th> </th><th>Currency</th>" +
              "<th> </th><th>Purchase Type</th></tr></thead><tbody>";
        if (result.length != 0) {
          
            for (var l = 0; l < result.length; l++) {
               

                var slno = parseInt(l + 1);
                responseText += '<tr><td align=center>' + slno + '</td>' +
                                '<td>' + result[l].InvoNo + '</td>' +
                                '<td>' + result[l].Date + '</td>' +
                                '<td>' + result[l].CustName + '</td>' +
                                 '<td align=center>' + result[l].PurchaseQty + '</td>' +
                                '<td align=right>' + parseFloat(result[l].MinCost || 0).toFixed(Decimal) + '</td>' +
                                 '<td align=right>' + parseFloat(result[l].FCCost || 0).toFixed(Decimal) + '</td>' +
                                '<td>' + result[l].Currency + '</td>' +
                                '<td align=right>' + parseFloat(result[l].CurrencyRate || 0).toFixed(Decimal) + '</td>'+
                                '<td>' + result[l].Currency + '</td>' +
                                '</tr>';
            }
            
        }
      
        $('#Stocklist').html(responseText + '</tbody>');       
        datatableWithsearch('Stocklist', 'Multiple');
    }

    function GetOrder(ItemId) {
        var data = {};

        data.ItemId = ItemId;
        $.ajax({
            type: "POST",
            url: "../MonthlyPurchaseAnalysis/PurchaseanalysisPurchaseOrderGet",
            data: data,
            success: function (result) {
                $('#OrderPopup').show();
                OrderLoad(result.oList);

            }

        })

    }

