    function Focusnext(e, Id) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;

        if (key == 40 && Id != 0)          // Down Arrow
        {
            e.preventDefault();
            var Rid;

            try {

                Rid = ($('#RowTr_' + Id).closest('tr').next('tr').attr('id')).match(/\d+/)[0];
                $('#adjstock_' + Rid).focus();
                $('#adjstock_' + Rid).select();
                $('#RowTr_' + Rid).click();
            }
            catch (err) {
                Rid = Id;
            }

        }
        else if (key == 38 && Id != 0) {           // Up Arrow
            e.preventDefault();
            var Rid;

            try {

                Rid = ($('#RowTr_' + Id).closest('tr').prev('tr').attr('id')).match(/\d+/)[0];
                $('#adjstock_' + Rid).focus();
                $('#adjstock_' + Rid).select();
                $('#RowTr_' + Rid).click();
            }
            catch (err) {
                Rid = Id;
            }

        }
    }
   
