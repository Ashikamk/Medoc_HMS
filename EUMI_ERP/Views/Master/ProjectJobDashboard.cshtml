    function ShowProjectJoblist1(result) {

        var responseText = "<thead><tr><th>Slno</th><th>Code</th><th>Description</th><th>Est.Amount</th><th>Status</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            responseText += '<tr><td>' + slno + '</td><td>' + result[i].JobCode + '</td><td>' + result[i].Description + '</td><td>' + result[i].EstAmount + '</td><td>' + result[i].JobStatus + '</td></tr>';
        }
        $('#tblprojectjob1').html(responseText + '</tbody>');

    }


