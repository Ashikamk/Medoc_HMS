    function SalesPerformanceGraph(result, Grtype) {

        var Total = [];
        var MMonth = [];
        var GrData = [];
        var GrDataTest = [];
        var MMonthTest=[];
        for (var i = 0; i < result.length; i++) {
            Total.push(parseFloat(result[i].Total || 0));
