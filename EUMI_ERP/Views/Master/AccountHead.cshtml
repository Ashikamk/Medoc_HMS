                var oArray = new Array();

                var AcntDescription = $('#txtaccname').val();
                var Narration = $('#txtaccnamrration').val();
                var AcntCode = $('#txtacccode').val();
                var Opening = '';
                var ScheduleId = parseFloat($('#scheduleId').val() || 0);
                var AcntId = $('#AccID').val();
                var DelFlag = 0;
                var UserId = ERPUserId;
                var DeptId = ERPDeptId;
                var SCHType = $('#SCHTYPE').val();
                var Type = '';
                var Description = '';
                var Currency = '';
                var Rate = '';
                var Amount = '';
                var Date = '';
                var ReferanceNo = '';
                var NewAccCode = 'x';
                var Variable1 = 'y';
                var Variable2 = 'z';

                oArray.push({

                    'AcntDescription': AcntDescription,
                    'Narration': Narration,
                    'AcntCode': AcntCode,
                    'Opening': Opening,
                    'ScheduleId': ScheduleId,
                    'AcntId': AcntId,
                    'DelFlag': DelFlag,
                    'UserId': UserId,
                    'DeptId': DeptId,
                    'SCHType': SCHType,
                    'Type': Type,
                    'Description': Description,
                    'Currency': Currency,
                    'Rate': Rate,
                    'Amount': Amount,
                    'Date': Date,
                    'ReferanceNo': ReferanceNo,
                    'NewAccCode': NewAccCode,
                    'Variable1': Variable1,
                    'Variable2': Variable2,
                })

                

                var data = { 'AccountSchedule': oArray };
                $.ajax({
                    type: "POST",
                    url: "../Master/AccountHeadInsertandUpdate",
                    data: data,
                    success: function (result) {
                        for (var i = 0; i < result.oList.length; i++) {
                            var status = result.oList[i].Flag;
                            var Accode = result.oList[i].AcntCode;
                            $('#ACCSlno' + $('#scheduleId').val()).val(Accode + 1)
                            Showalerts(status);
                            GetAllaccHead(0);
                            $('#AccID').val(0);

                        }
                    }
                });
            }
        });



        function Accoundheadsave(DelFlag) {
            var NewAccCodeLen = $.trim($('#txtacccodeman').val()).length;

            if ($('#txtaccname').val() == '') {
                warningshow('Press Enter Account Name', 'txtaccname');
            }
            else if ($('#AccID').val() == 0 && NewAccCodeLen != 4) {
                warningshow('Enter 4 Digit Code', 'txtacccodeman');
            }
            else {
                $("#btnsubmit").prop("disabled", true);
                var oArray = new Array();

                //console.log($('#Xvariable').val())
                for (var k = 1; k <= $('#Xvariable').val() ; k++) {

                    var Ob = 0;
                    if (parseFloat($('#txtob').val() || 0) != 0) {
                        var Ob = parseFloat($('#txtob').val() * $('#obtype').val())
                    }

                    var AcntDescription = $.trim($('#txtaccname').val());
                    var Narration = $('#txtaccnamrration').val();
                    var AcntCode = $('#txtacccode').val();
                    var Opening = Ob;
                    var ScheduleId = parseFloat($('#scheduleId').val() || 0);
                    var AcntId = $('#AccID').val();
                    var DelFlag = DelFlag;
                    var UserId = ERPUserId;
                    var DeptId = ERPDeptId;
                    var SCHType = $('#SCHTYPE').val();
