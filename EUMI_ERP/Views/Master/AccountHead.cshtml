    }


    function ShowAccheadList(result) {

        disable_datatable('tblacchead');
        var responseText = "<thead><tr><th align=center>Sl#</th><th>Code</th><th>Name</th><th>Opening</th><th>Schedule</th><th align=center>Edit</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].AcntCode + '</td><td>' + result[i].AcntDescription + '</td><td>' + result[i].Opening + '</td><td>' + result[i].schedul + '</td><td align=center><a onclick="GetRows(' + result[i].AcntId + ')">' + Editbutton + '</a></td></tr>';
        }
        $('#tblacchead').html(responseText + '</tbody><tfoot><tr><th> </th><th>Code</th><th>Name</th><th>Opening</th><th>Schedule</th><th align=center> </th></tr></tfoot>');
        datatableWithsearch1('tblacchead');

    }




    function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ') {
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width:100%" />');
            }           

        });
        var table = null;
        table = $('#' + tablename).DataTable({
           
            dom: "<'row'<'col-sm-2'l><'col-sm-10'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-6'i><'col-sm-6'p>>",
            "columnDefs": [
                                { "width": "1%", "targets": 0 },
                                { "width": "3%", "targets": 1 },
                                { "width": "30%", "targets": 2 },
                                { "width": "2%", "targets": 3 },
                                { "width": "20%", "targets": 4 },
                                { "width": "1%", "targets": 5 },
            ],
            buttons: [],           

        });

        new $.fn.dataTable.Buttons(table, {
            buttons: [
            {
                extend: 'collection',
                text: 'Export',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'pdfHtml5',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    },
                    {
                        extend: 'print',
                        title: title,
                        messageTop: 'MEDOC HMS',
                        exportOptions: { columns: ":visible" }
                    }
                ]
            },
            'colvis'
            ]
        });
        table.buttons(0, null).container().appendTo($("#" + tableButtonContainerId));
        $("#" + tableButtonContainerId).find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
    }


    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }








