        $('#AccID').val(Ac_Id);
        var data = {};
        data.AcntId = Ac_Id;
        data.ScheduleId = 0;
        $.ajax({
            type: "POST",
            url: "../Master/AccountHeadGetandGets",
            data: data,
            success: function (result) {
            
                $('#Xvariable').val(1);
                ShowAccheadheadGets(result);
