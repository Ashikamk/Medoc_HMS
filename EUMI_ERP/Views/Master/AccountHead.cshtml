    }


    $(document).keydown(function (e) {
        if (e.keyCode == 115)     //f4 - add OpenBalance
        {
            calcopnblnc();
            openblncrefresh();
        }
        else if (e.keyCode == 27) {                           //esc
            $('#popup1').hide();
            hidepopup();
            popupclose();
        }
    });

    $(document).ready(function () {

        Gettreeview();
        GetAllaccHead(0);
        CurrencyGets(0);

        $("#opnCurrency").change(function () {
            var selectedValue = $(this).val();
            $("#CurrencyRate").val(parseFloat($(this).find("option:selected").attr("name") || 0).toFixed(Decimal))
        });

        $("#txtob,#txtschedulcode").on("keypress keyup blur", function (event) {
            $(this).val($(this).val().replace(/[^0-9\.]/g, ''));
            if ((event.which != 46 || $(this).val().indexOf('.') != -1) && (event.which < 48 || event.which > 57)) {
                event.preventDefault();
            }
        });

        $("#tblacchead").on('order.dt search.dt', function () {
            var t = $("#tblacchead").DataTable();
            
            t.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                cell.innerHTML = i + 1;
            });
        });


        $("#txtaccname").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $("#txtaccnamrration").focus();
            }
        });
        $("#txtaccnamrration").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $("#btnsubmit").focus();
            }
        });

        $("#txtschedulename").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $("#txtschedulcode").focus();
            }
        });
        $("#txtschedulcode").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $("#acnttype").focus();
            }
        });
        $("#acnttype").keydown(function (e) {
            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13) {
                $("#btnsubmitschedule").focus();
            }
        });
        $('#opnamount').keydown(function (e) {

            var opnamount = parseFloat($('#opnamount').val() || 0);
            opnamount = isNaN(opnamount) ? 0 : opnamount;

            var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
            if (key == 13 && ($('#opnamount').val() == '' || opnamount == 0)) {
                warningshow('Please Enter the Amount', 'opnamount');
                return false;
            }
            else if (key == 13) {
                e.preventDefault();
                $('#opnsave').focus();
            }


        });

        $("#btnsubmitschedule").click(function (e) {

            var data = {};
            if ($('#txtschedulename').val() == '') {
                $('#txtschedulename').focus();
            }
            else if ($('#txtschedulcode').val() == '' || ($('#txtschedulcode').val()).length < 4) {
                $('#txtschedulcode').focus();
            }
            else if ($('#acnttype').val() == '0') {
                $('#acnttype').focus();
            }


            else {
                data.schedul = $('#txtschedulename').val();
                data.AcntCode = $('#txtschedulcode').val();
                data.ScheduleId = $('#scheduleId').val();
                data.SCHType = $('#acnttype').val();


                $.ajax({
                    type: "POST",
                    url: "../Master/AccountScheduleInsertandUpdate",
                    data: data,
                    success: function (result) {
                        for (var i = 0; i < result.oList.length; i++) {
