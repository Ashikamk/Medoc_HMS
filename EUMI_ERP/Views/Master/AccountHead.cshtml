<script>
   
    function Defaultfocus() {

    }

    function Addschedule(Id) {
        var SheduleName = $('#SchName' + Id).val();
        var ScheduleCode = $('#ACCODE' + Id).val();

        $('#scheduleId').val(Id);
        $('#schhead').text(SheduleName);
        $('#popup1').show();
        $('#divschedule').show();
        $('#divachead').hide();
        $('#txtschedulename').focus();
    }


    function AddAccounthead(Id) {
        $('#AccEditDiv').show();
        $('.AccAutoDiv').hide();
        var SheduleName = $('#SchName' + Id).val();
        var ScheduleCode = $('#ACCODE' + Id).val();
        var AccSlno = $('#ACCSlno' + Id).val();
        var ScheduleType = $('#SchType' + Id).val();
        $('#SCHTYPE').val(ScheduleType);
        var Prefix = ["", "0", "00", "000"];
        var i = 4 - AccSlno.length
        if (i < 4) { Pre = Prefix[i] } else { Pre = ''; }
        $('#scheduleId').val(Id);
        $('#txtacccode').val(ScheduleCode + '-' + Pre + AccSlno);
        $('#txtacccodeauto').val(ScheduleCode);
        $('#txtacccodeman').val(Pre + AccSlno);
        $('#myModalLabel1').text(SheduleName);
        $('#popup1').show();
        $('#divschedule,#btnDelete').hide();
        $('#divachead').show();
        $('#txtaccname,#txtaccnamrration,#txtob').val('');
        $('AccID').val(0);
        $('#amttype').text('');
        $("#txtob").prop('readonly', true);
        $('input[name=customRadioInline1]').attr('checked', false);
        $('input[name=customRadioInline1]').prop('disabled', false);
        $('#txtaccname').focus();

    }


    function Showtree(result) {
        $("#tree").empty();
        for (var i = 0; i < result.length; i++) {
            var data = {
                SchName: result[i].description,
                ACCODE: result[i].accountCode,
                ACCSlno: result[i].slno,
                SchType: result[i].Scheduletype
            }
            for (var key in data) {
                $("#tree").append($('<input type="hidden" />').attr("id", key + result[i].accountId).val(data[key]));
            }
        }
        var list = GetScheduleUL(0, result);
        if (list != null && list.length > 0) {
            $('#tree').append(list);
            AddTreeEvents();
        }
    }

    function GetScheduleUL(parentId, result) {
        var arrMainSch = result.filter(function (ele) { return ele.parentId === parentId });
        // if (parentId == 0) {
        //     console.log(arrMainSch);
        // }
        var jqList = null;
        if (arrMainSch.length > 0) {
            jqList = $("<ul>");
        }
        for (var j = 0; j < arrMainSch.length; j++) {
            var jqItem = $("<li>").attr("data-eumi-id-li", arrMainSch[j].accountId).append($("<span>").addClass("eumi-node-span").text(arrMainSch[j].description))
                .append(' ')
                .append($("<span>").addClass("eumi-add ft-plus-circle text-primary").attr("data-eumi-id", arrMainSch[j].accountId));
            jqList.append(jqItem);
            var jqChildList = GetScheduleUL(arrMainSch[j].accountId, result);
            if (jqChildList != null && jqChildList.length > 0) {
                jqItem.append(jqChildList)
            } else {
                jqItem.addClass("eumi-leaf");
            }

        }
        return jqList;
    }

    function AddTreeEvents() {
        $("#tree").off(".eumiTreeEvents").on("click.eumiTreeEvents", ".eumi-add", function () {
            if ($(this).parentsUntil("#tree", "ul").length >= ScheduleLevels) {  //----------------------------------> ScheduleLevels-read from layout set 2 or 3 Depends Customer requirment)
                AddAccounthead($(this).attr("data-eumi-id"));
            } else {
                Addschedule($(this).attr("data-eumi-id"));
                $("#tree").find(".eumi-current-node").removeClass("eumi-current-node");
                $("#tree").find(".eumi-open-list").removeClass("eumi-open-list");
                $(this).closest("li").addClass("eumi-current-node");
                $(this).parentsUntil("#tree", "li").addClass("eumi-open-list");


            }
        }).on("click.eumiTreeEvents", ".eumi-node-span", function () {

            if (!$(this).closest("li").is(".eumi-current-node")) {
                if (!$.fn.DataTable.isDataTable('#example')) {
                    var table = $("#tblacchead").DataTable();
                    //table.column(4).search($(this).text()).draw();
                    table.column(4).search('^' + $.trim($(this).text()) + '$', true, false, true).draw();
                }
            }
            var currentNodeOpen = false;
            if ($(this).closest("li").is(".eumi-open-list")) {
                currentNodeOpen = true;
            }
            $("#tree").find(".eumi-current-node").removeClass("eumi-current-node");
            $("#tree").find(".eumi-open-list").removeClass("eumi-open-list");
            $(this).closest("li").addClass("eumi-current-node");
            $(this).parentsUntil("#tree", "li").addClass("eumi-open-list");
            if (currentNodeOpen) {
                $(this).closest("li").removeClass("eumi-open-list");
            }
            //GetAllaccHead($(this).parentsUntil("#tree", "li.eumi-current-node").attr("data-eumi-id-li"))
        });
    }

