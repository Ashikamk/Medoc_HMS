<script>

    function CurrencyGets(id) {
        var data = {};
        data.Id = 0;
        $.ajax({
            type: "POST",
            url: "../Master/CurrencyGetandGets",
            data: data,
            success: function (result) {
                CurrencyLoad(result.oList, id);
            }
        });
    }
    var BaseCurrency;
    function CurrencyLoad(result, a) {
        $("#opnCurrency").empty();
        for (var i = 0; i < result.length; i++) {
            if (result[i].BaseCurrencyId != 0) {
                BaseCurrency = result[i].BaseCurrencyId;
            }
        }
        $("#opnCurrency").append("<option value='0'>--Select--</option>");

        for (var i = 0; i < result.length; i++) {
            $("#opnCurrency").append("<option value='" + result[i].Id + "' name='" + result[i].CurrencyRate + "'>" + result[i].CurrencyName + "</option>");
        }
        if (a == 0) {
            $('#opnCurrency').val(BaseCurrency);
            $('#CurrencyRate').val(parseFloat($('#opnCurrency').find("option:selected").attr("name") || 0).toFixed(Decimal));

        }
        else {
            $('#opnCurrency').val(a);
            $('#CurrencyRate').val(parseFloat($('#opnCurrency').find("option:selected").attr("name") || 0).toFixed(Decimal));
        }
    }
    $('#opndate').val(CurDate);



    function openblncrefresh() {

        $('#openingentry').hide();
        $('#popupdiv').hide();
        clear();
       
    }

    function addbalance() {

        var opnamount = parseFloat($('#opnamount').val() || 0);
        opnamount = isNaN(opnamount) ? 0 : opnamount;

        if ($('#opndesc').val() == '') {
            warningshow('Please Enter the Description', 'opndesc');
        }
        else if ($('#opnCurrency').val() == 0) {
            warningshow('Please Select Currency', 'opnCurrency');
        }
        else if (($('#CurrencyRate').val() == 0)) {
            warningshow('Please Enter Currency Rate', 'CurrencyRate');
        }
        else if (($('#CurrencyRate').val() == '')) {
            warningshow('Please Enter Currency Rate', 'CurrencyRate');
        }
        else if ($('#opnamount').val() == '') {
            warningshow('Please Enter the Amount', 'opnamount');
            $('#opnamount').select();
        }
        else if (opnamount == 0) {
            warningshow('Please Enter the Amount', 'opnamount');
            $('#opnamount').select();
        }
        else {
            var xvar = $('#Xvariable').val();

            var slno = 1;
            slno = parseInt($('#tblopencost tr').length);
            var balance =
           "<tr id='row" + xvar + "' class='jsgrid-row' style=border:1px solid;height:25px>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='slno_" + xvar + "'>" + slno + "</td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='opndate_" + xvar + "'>" + $('#opndate').val() + "</td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='opntype" + xvar + "'>" + $('#opntype').val() + "</td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='opndesc" + xvar + "'>" + $('#opndesc').val() + "</td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='opnCurrency" + xvar + "'>" + $('#opnCurrency option:selected').html() + " <input type='hidden' id='CurrencyId" + xvar + "' value=" + $('#opnCurrency').val() + "> </td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='CurrencyRate" + xvar + "'>" + parseFloat($('#CurrencyRate').val()).toFixed(Decimal) + "</td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='opnamount" + xvar + "'>" + parseFloat($('#opnamount').val()).toFixed(Decimal) + "</td>" +
            "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' id='opnrefrnc" + xvar + "'>" + ($('#opnrefrncno').val() || 0) + "</td>" +
           "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center' > <button type='button' class='btn mr-1 mb-1 btn-warning btn-sm'  onclick='rowdelet(" + xvar + ")'><i class='ft-x'></i> </button></td>" +
           "</tr>";
            $('#tblopencost').append(balance);
            clear();

            xvar++;
            $('#Xvariable').val(xvar + 1);
            CurrencyGets(0);
        }
        $('#openingdiv').animate({ scrollTop: 5000 }, 900);

    }

    function clear() {
        $('#opndate').val(CurDate)
        $('#opntype').val('C')
        $('#opndesc').val('')
        $('#opnamount').val('')
        $('#opnrefrncno').val('')
        $('#opndesc').focus();
    }

    function isNumber(evt, selectedvalue) {
        var charCode = (evt.which) ? evt.which : event.keyCode
        $(selectedvalue).val($(selectedvalue).val().replace(/[^0-9\.]/g, ''));
        if (charCode != 8 && (charCode != 46 || $(selectedvalue).val().indexOf('.') != -1) && charCode != 13 && (charCode < 48 || charCode > 57)) {
            evt.preventDefault();
            warningshow('Digits Only')
            return false;
        }
        return true;
        $('#Warningpopup').fadeOut();
    }

    //Numeric Only Text Boxes without Decimal Point

    function isNumberInt(evt, selectedvalue) {
        var charCode = (evt.which) ? evt.which : event.keyCode
        $(selectedvalue).val($(selectedvalue).val().replace(/[^0-9\.]/g, ''));
        if (charCode != 8 && charCode != 13 && (charCode < 48 || charCode > 57)) {
            evt.preventDefault();
            warningshow('Digits Only')
            return false;
        }
        return true;

    }


    function CheckCodeLength() {
        var NewLen = $.trim($('#txtacccodeman').val()).length;
        if (NewLen > 4) {
            warningshow('Enter 4 Digit Code', 'txtacccodeman');
            $('#txtacccodeman').val($.trim($('#txtacccodeman').val()).slice(0, 4));          
        }
    }

    function calcopnblnc() {

        var optablelength = $('#Xvariable').val();

        var TotalOpnBalance = 0;
        var CreditRate = 0;
        var DebitRate = 0;
        var CreditAmt = 0;
        var DebitAmt = 0;
        var CurRate = 0;
        var CreditTot = 0;
        var DebitTot = 0;
        console.log("========================================")
        for (var i = 1; i <= optablelength; i++) {
            if ($('#opntype' + i).text() == 'C') {
                CurRate = parseFloat($('#CurrencyRate' + i).text() || 0);
                console.log('CurRate::' + CurRate)
                CreditRate = parseFloat($('#opnamount' + i).text() || 0) * parseFloat(CurRate);
                console.log('CreditRate::' + CreditRate)
                CreditAmt = parseFloat(CreditAmt) + parseFloat(CreditRate);
                console.log('CreditAmt::' + CreditAmt)
            }
            else if ($('#opntype' + i).text() == 'D') {
                CurRate = parseFloat($('#CurrencyRate' + i).text() || 0);
                console.log('CurRate::' + CurRate)
                DebitRate = parseFloat($('#opnamount' + i).text() || 0) * parseFloat(CurRate);
                console.log('DebitRate::' + DebitRate)
                DebitAmt = parseFloat(DebitAmt) + parseFloat(DebitRate);
                console.log('DebitAmt::' + DebitAmt)
            }
        }
      
        TotalOpnBalance = parseFloat(DebitAmt - CreditAmt);
        console.log('TotalOpnBalance::' + TotalOpnBalance)
        console.log("========================================")
        $('#txtob').val(TotalOpnBalance.toFixed(Decimal));
    }

    function rowdelet(RowId) {

        var slno = 1;
        var rowslno = parseInt(slno);
        $('#row' + RowId).remove();
        for (var j = 1; j <= $('#Xvariable').val() ; j++) {
            if ($('#opndesc' + j).val() != undefined) {
                $('#slno_' + j).text(slno);
                slno++;
            }
        }
        $('#opndesc').focus();
    }

    $("#btnadd").focus(function (e) {
        $("#btnadd").removeClass("btn btn-outline-primary");
        $("#btnadd").addClass("btn btn-primary");
    });

    $("#btnadd").focusout(function () {
        $("#btnadd").removeClass("btn btn-primary");
        $("#btnadd").addClass("btn btn-outline-primary");
    });

    $("#btncnclopnblnc").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 39) {
            $("#btnsubmitopnblnc").focus();
        }
    });

    $("#btnsubmitopnblnc").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 37) {
            $("#btncnclopnblnc").focus();
        }
    });

    //Date Picker
    $(function () {
        $('#opndate').daterangepicker({
            minDate: minDate,
            maxDate: new Date(new Date().getFullYear(), new Date().getMonth(), new Date().getDate()),
            singleDatePicker: true,
            showDropdowns: true,
            locale: {
                format: 'DD/MM/YYYY'
            }
        });
    });


    function popupclose() {
        calcopnblnc();
        openblncrefresh();
    }
</script>



