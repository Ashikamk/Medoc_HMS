function previmg(i) {
    var j = i - 1;
    if ($('#slimg-' + j).length) {
        $('#slimg-' + i).hide();
        $('#slimg-' + j).show();
    }
}

function nextimg(i) {
    var j = i + 1;
    if ($('#slimg-' + j).length) {
        $('#slimg-' + i).hide();
        $('#slimg-' + j).show();
    }
}




