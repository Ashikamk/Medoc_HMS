//for SalesmanwiseSales
function SalesmanwiseSalesGraph(result, GrType) {
    var Amount   = [];
    var SalesMan = [];
    var GrData   = [];

    for (var i = 0; i < result.length; i++) {
        Amount.push(parseFloat(result[i].Amount || 0));
        SalesMan.push(result[i].SalesMan);
        GrData.push({ name: result[i].SalesMan, y: parseFloat(result[i].Amount || 0) })
    }


    Highcharts.chart('Sales', {
        chart: { type: GrType },
        title: {
            text: 'Sales Man Wise Sales'
        },
        subtitle: {
            text: 'Source: eumierp.com'
        },
        xAxis: {
            categories:SalesMan
        },
        yAxis: {
            title: {
                text: 'Sales()'
            }
        },
        colors: [
                     '#FF4758',
                     '#08B46B',
                     '#19B6D4',
                      '#FF8558',
                     '#ec407a',
                     '#9c27b0',
                      '#1a237e',
                      '#3e2723'
        ],
        plotOptions: {
            column: {
                colorByPoint: true,
            },
            line: {
                dataLabels: {
                    enabled: true
                },
                enableMouseTracking: false
            }
        },
        series: [
        {
            name: 'Sales',
            data: Amount
        },
        ]
    });


}


//for DepartmentwiseSales
function DepartmentwiseSalesGraph(result, GrType) {
    var Amount = [];
    var GrData = [];
    var Department = [];

    for (var i = 0; i < result.length; i++) {
        Amount.push(parseFloat(result[i].Amount || 0));
        Department.push(result[i].Department);
        GrData.push({ name: result[i].Department, y: parseFloat(result[i].Amount || 0) })
    }
    //PI CHAT
    Highcharts.chart('container', {
        chart: {
            plotBackgroundColor: null,
            plotBorderWidth: null,
            plotShadow: false,
            type: 'pie'
        },
        title: {
            text: 'Department wise Sales'
        },
        tooltip: {
            pointFormat: '{series.name}: <b>(${point.y}) {point.percentage:.1f}%</b>'
        },
        colors: [
                  '#FF4758',
                  '#08B46B',
                  '#19B6D4',
                   '#FF8558',
                  '#ec407a',
                  '#9c27b0',
                   '#1a237e',
                   '#3e2723'
        ],
        plotOptions: {
            pie: {
                allowPointSelect: true,
                cursor: 'pointer',
                dataLabels: {
                    enabled: false
                },
                showInLegend: true
            }
        },
        series: [{
            name: 'Sales',
            colorByPoint: true,
            data: GrData
        }]
    });
}



