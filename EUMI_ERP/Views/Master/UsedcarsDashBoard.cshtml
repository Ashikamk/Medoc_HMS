    }
    function Update(ItemId) {

        if (EditFlag == 0) {
            $('#Cancel' + ItemId).hide();
            $('#Update' + ItemId).hide();
            $('#Edit' + ItemId).show();
        }
        else {
            updatevcc(1, ItemId);
            EditFlag = 0;
            $('#Edit' + ItemId).hide();
            $('#Cancel' + ItemId).hide();
            $('#Update' + ItemId).show();
        }

    }
    function Cancel(ItemId) {

        if (EditFlag == 0) {
            $('#Update' + ItemId).hide();
            $('#Cancel' + ItemId).hide();
            $('#Edit' + ItemId).show();
        } else {
            updatevcc(0, ItemId);
            EditFlag = 0;
            $('#Edit' + ItemId).hide();
            $('#Update' + ItemId).hide();
            $('#Cancel' + ItemId).show();
        }

    }

