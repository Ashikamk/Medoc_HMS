                    '<td>' + result[i].AssignedToUser + '</td>' +
                    '<td>' + result[i].DriverName + '</td>' +
                    '<td><div class="text-center" style="width:100%"><span style="width:100%" class="badge ' + rowclass + '">' + result[i].Status + '</span></div></td>' +
