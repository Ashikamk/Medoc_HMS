    function ShowSales(BillSlNo, BillSeriesId, SType, DeptId) {
        if (SType == 'SI') {
            if ((usermenu1.indexOf("M54") != -1)) {
                window.open('../inventory/SalesInvoice?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);
            }
            else if ((usermenu1.indexOf("M227") != -1)) {
                window.open('../inventory/SalesInvoiceNew?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);
            }
            else if ((usermenu1.indexOf("M301") != -1)) {
                window.open('../SalesInvoice/SalesInvoiceGasTrading?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);
            }
            else if ((usermenu1.indexOf("M314") != -1)) {
                window.open('../SalesInvoice/SalesInvoiceRentCar?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);
            }
            else {
                warningshow('Invalid User Rights');
                return false;
            }
        }
        else {
            if ((usermenu1.indexOf("M56") != -1)) {
                window.open('../SalesInvoice/SalesReturn?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

            }
            else if ((usermenu1.indexOf("M241") != -1)) {
                window.open('../SalesInvoice/SalesReturnNew?slno=' + BillSlNo + '&billseries=' + BillSeriesId + '&dept=' + DeptId);

            }
            else {
                warningshow('Invalid User Rights');
                return false;
            }

        }
    }
