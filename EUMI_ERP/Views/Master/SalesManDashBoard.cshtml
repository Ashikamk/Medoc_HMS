    function ShowReport(result) {


        disable_datatable('CustOutPopup');
        $('#CustOutPopup tr').remove();
        var responseText = "";
        if (result.length != 0) {


            var responseText = "<thead><tr><th style='text-align:center;'>Sl#</th><th style='width:150px'>Account Code</th><th style='width:300px'>Account Name</th><th class=text-right style='width:100px'>Debit</th><th style='width:100px' class=text-right>Credit</th><th style='display:none'></th></tr>" +
                "<tr><th style='text-align:center;'> </th><th>Account Code</th><th>Account Name</th><th class=text-right> </th><th class=text-right> </th><th style='display:none'></th></tr>" +
                "</thead><tbody>";

            for (var i = 0; i < result.length; i++) {


                var slno;
                slno = parseInt(i + 1);

                var DebitAmt = parseFloat(result[i].Debit || 0).toFixed(Decimal);
                var CreditAmt = parseFloat(result[i].Credit || 0).toFixed(Decimal);
                if (DebitAmt == 0)
                    DebitAmt = '';

                if (CreditAmt == 0)
                    CreditAmt = '';

                if (result[i].AccDesc == 'Balance') {

                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold"><td style="width:70px;text-align:center;">' + slno + '</td><td style="width:150px"  id="Col1_' + slno + '" >' + result[i].AccCode + '</td><td style="width:500px;"   id="Col2_' + slno + '" >' + result[i].AccDesc + '</td><td   id="Col3_' + slno + '" style="text-align:right;width:120px">' + ReplaceNumberWithCommas(DebitAmt) + '</td><td id="Col4_' + slno + '" style="text-align:right;width:120px" >' + ReplaceNumberWithCommas(CreditAmt) + '</td><td id="Col5_' + slno + '" style="text-align:right;display:none">1</td></tr>';
                }
                else if (CreditAmt == '' && DebitAmt == '') {

                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold"><td style="width:70px;text-align:center;">' + slno + '</td><td style="width:150px"  id="Col1_' + slno + '" >' + result[i].AccCode + '</td><td style="width:500px;"   id="Col2_' + slno + '" >' + result[i].AccDesc + '</td><td   id="Col3_' + slno + '" style="text-align:right;width:120px">' + ReplaceNumberWithCommas(DebitAmt) + '</td><td id="Col4_' + slno + '" style="text-align:right;width:120px" >' + ReplaceNumberWithCommas(CreditAmt) + '</td><td id="Col5_' + slno + '" style="text-align:right;display:none">1</td></tr>';
                }
                else if (result[i].AccDesc == 'Total') {

                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold"><td style="width:70px;text-align:center;">' + slno + '</td><td style="width:150px"  id="Col1_' + slno + '" >' + result[i].AccCode + '</td><td style="width:500px;"   id="Col2_' + slno + '" >' + result[i].AccDesc + '</td><td   id="Col3_' + slno + '" style="text-align:right;width:120px">' + ReplaceNumberWithCommas(DebitAmt) + '</td><td id="Col4_' + slno + '" style="text-align:right;width:120px" >' + ReplaceNumberWithCommas(CreditAmt) + '</td><td id="Col5_' + slno + '" style="text-align:right;display:none">1</td></tr>';
                }
                else if (result[i].AccDesc == 'Grand Total') {

                    responseText += '<tr style="background-color:#cfd8dc;font-weight:bold"><td style="width:70px;text-align:center;">' + slno + '</td><td style="width:150px"  id="Col1_' + slno + '" >' + result[i].AccCode + '</td><td style="width:500px;"   id="Col2_' + slno + '" >' + result[i].AccDesc + '</td><td   id="Col3_' + slno + '" style="text-align:right;width:120px">' + ReplaceNumberWithCommas(DebitAmt) + '</td><td id="Col4_' + slno + '" style="text-align:right;width:120px" >' + ReplaceNumberWithCommas(CreditAmt) + '</td><td id="Col5_' + slno + '" style="text-align:right;display:none">1</td></tr>';
                }
                else {
                    responseText += '<tr ondblclick="getstatement(\'' + result[i].AccId + '\',\'' + result[i].AccCode + '\')"><td style="text-align:center">' + slno + '</td><td style="width:70px;"   id="Col1_' + slno + '"  style="width:150px" >' + result[i].AccCode + '</td><td   id="Col2_' + slno + '" style="width:500px" >' + result[i].AccDesc + '</td><td   id="Col3_' + slno + '" style="text-align:right;width:120px">' + ReplaceNumberWithCommas(DebitAmt) + '</td><td id="Col4_' + slno + '" style="text-align:right;width:120px">' + ReplaceNumberWithCommas(CreditAmt) + '</td><td id="Col5_' + slno + '" style="text-align:right;display:none"><b>0</b></td></tr>';
                }
            }
        }

        $('#salesdetails').hide();
        $('#CustOutPopup').html(responseText + '</tbody>');
        datatableWithsearchNew('CustOutPopup', 'Multiple');
        
        $('#div1').animate({ scrollTop: 0 });
        $('#LoadingSmallRound').hide();
    }

