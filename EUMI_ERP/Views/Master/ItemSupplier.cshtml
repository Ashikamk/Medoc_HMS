
@{
    ViewBag.Title = "ItemSupplier";
}

<style>

</style>

<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<style>
    .ab {
        margin-top: .5%;
    }

    .abc {
        margin-bottom: 1%;
    }

    .jsgrid-header-row > .jsgrid-header-cell {
        background: #009da0;
        color: white;
        text-align: center;
    }

    .custom-control-label::before {
        margin-left: -50%;
    }

    .custom-control-label::after {
        margin-left: -50%;
    }

    .custom-checkbox .custom-control-input:checked ~ .custom-control-label::before {
        background-color: lightseagreen;
    }
</style>

<div class="myData" data-x="M259" />


<div id="Entry" style="">
    <section class="grid-row-label">
        <div class="row">
            <div class="col-md-2">

            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header" style="border-bottom:1px solid #e6e6e6;height:70px">
                        <h3 style="font-weight:bold;text-align:center;">SUPPLIER ITEMS</h3>
                    </div>


                    <form action="#">
                        <div class="card-body ">

                            <div class="px-3" style="background-color:#E0F3F4;">

                                <div class="row">
                                    <div class="col-md-12 ab">
                                        <div class="row ab">

                                            <div class="col-md-1">
                                                <label class="label">Supplier</label>
                                            </div>
                                            <div class="col-md-3">
                                                <input type="text" id="Supplier" class="form-control" autocomplete="off">
                                                <input type="hidden" class="form-control" id="SupplierId" >
                                            </div>
                                            <div class="col-md-1">
                                                <label class="label">Type</label>
                                            </div>
                                            <div class="col-md-2">
                                                <select id="SearchType" class="form-control" autocomplete="off" onchange="$('#FieldId').val(''), $('#Fieldname').val(''), ItemListGets(0);"> 
                                                    <option value="0">Select</option>
                                                    <option value="2">Group</option>
                                                    <option value="3">Sub Group</option>
                                                    <option value="4">Category</option>
                                                    <option value="5">Sub Category</option>
                                                </select>
                                            </div>
                                            <div class="col-md-3"> 
                                            <input type="text" id="Fieldname" class="form-control" autocomplete="off" onkeyup="CheckFieldempty(event)">  
                                            <input type="hidden" class="form-control" id="FieldId">
                                            </div>
                                          
                                            <button type="button" id="BtnGo" class="btn btn-primary btn-min-width mr-1 mb-1" onclick="ItemListGets(0)">Go <i class="ft-arrow-right"></i></button>
                                        </div>
                                      
                                    </div>                                  
                                </div>
                            </div>


                            <div style="width:95%;margin-left:2.5%;height:565px;overflow:auto;margin-top:.5%;border:1px solid #e9e9e9;">
                                <div id="proddiv" class="" style="overflow: auto;height:auto; width: 100%;">
                                    <table class="table table-bordered jsgrid-table" id="TblItemList" style="table-layout:fixed">
                                        <tr class='jsgrid-header-row'>
                                            <th class='jsgrid-header-cell' style='width:2%'>
                                            <div class='custom-control custom-checkbox' style='margin-left:60%'>
                                                <input type='checkbox' onchange='selectall()' class='custom-control-input' id='select_status'>
                                                <label class='custom-control-label mainc' for='select_status'></label>
                                                </div>
                                            </th>
                                            <th class='jsgrid-header-cell' style='width:7%'>ItemCode</th>
                                            <th class='jsgrid-header-cell' style='width:15%'>Description</th>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <div class="row" style="margin-top:1%">
                                <div class="col-md-10">

                                </div>
                                <div class="col-md-2 text-right">
                                    <button type="button" id="btnsubmit" class="btn btn-primary mr-1 mb-1" onclick="SaveAndUpdate()"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                    <button type="button" id="btnnew" onclick="formrefresh()" class="btn btn-primary mr-1 mb-1">New <i class="ft-refresh-cw position-right"></i></button>
                                </div>
                            </div>
                        </div>
                    </form>




                </div>
            </div>
            <div class="col-md-2">

            </div>
        </div>
    </section>



</div>

<div style="display:none">
    <input type="text" class="form-control" id="DeptId" />
</div>

<script>

    var DeptSelect = '';

    $("#Fieldname").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if ( $("#Fieldname").val()=='' && key == 13 ) {
            $("#BtnGo").focus();
        }
    });
    $("#Supplier").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key == 13) {
            $("#SearchType").focus(); 
        }
    });
    $("#BtnGo").keydown(function (e) {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if ( key == 39) {
            $("#Supplier").focus();
        }
       else if (key == 37) {
            $("#Fieldname").focus();
        }
    });
    function CheckFieldempty(e) 
    {
        var key = e.charCode ? e.charCode : e.keyCode ? e.keyCode : 0;
        if (key != 13)
            $('#FieldId').val(''); 
        if($('#Fieldname').val()=='')
        {
            ItemListGets(0);
        }
    }

    function SaveAndUpdate() {
        var flg = 0;
        var checkboxes = document.getElementsByName('checkb');
        for (var j = 0, n = checkboxes.length; j < n; j++) {
            if (checkboxes[j].checked)
                flg++;
        }

        if ($('#SupplierId').val() =='' || $('#SupplierId').val()== 0)
            warningshow("Please Select Supplier", 'Supplier');
        else if (flg == 0) {
            warningshow("Please Select Items", 'Fieldname');
           
        }
        else {
            $('#btnsubmit').prop('disabled', true);

            var len = $('#TblItemList > tbody > tr:last-child()').attr('id').match(/\d+/)[0];

            var oArray = new Array();
            for (var k = 1; k <= len; k++) {
                if ($('#select_status' + k).is(":checked")) {
                    var SupplierId = $('#SupplierId').val();
                    var ItemId = $('#ItemId' + k).val();

                    if (ItemId != undefined && ItemId != 0 && ItemId != '') {
                        oArray.push({ 'SupplierId': SupplierId, 'ItemId': ItemId })
                    }
                }
            }

            if (oArray != "") {
                var data = { 'ProductMstModel': oArray };
                $.ajax(
                {
                    type: "POST",
                    url: "../Master/SupplierItemInsert",
                    data: data,
                    success: function (result) {
                        Showalerts(1);
                        $('#btnsubmit').prop('disabled', false);
                    }
                });
            }

        }

    }


    $("#Supplier").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var data = {};
            data.CustName = $("#Supplier").val();
            data.CustType = 'S';

            $.ajax({
                url: '../Master/CustomerOrSupplierSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                   
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '-2ph',
                            label: item.CustName,
                            label1: item.CustAccount,
                            label2: item.PhoneNumber,
                            CustId: item.CustId,                          
                            headers: ["Supplier Name", "Account Code", "Phone Number"]
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#SupplierId').val(ui.item.CustId)           
        },

    });


    function formrefresh()
    {
        $('.form-control').val('');
        $('#SearchType').val(0);

        document.getElementById("select_status").checked = false;
       
        Defaultfocus();
        ItemListGets(0); 
        $('#TblItemList tr td').remove(); 
    }

    function Defaultfocus() {
        $('#Supplier').focus(); 
    }


    function ItemListGets(flg)
    {
        var Condition = ' Active=1 ';
        if ($('#FieldId').val()>0) {
            if ($('#SearchType').val() == 0)
                Condition += " and ItemId = " + $('#FieldId').val() + " ";
            else if ($('#SearchType').val() == 2)
                Condition += " and GroupId = " + $('#FieldId').val() + " ";
            else if ($('#SearchType').val() == 3)
                Condition += " and SubGroupId = " + $('#FieldId').val() + " ";
            else if ($('#SearchType').val() == 4)
                Condition += " and CategoryId = " + $('#FieldId').val() + " ";
            else if ($('#SearchType').val() == 5)
                Condition += " and SubCategoryId = " + $('#FieldId').val() + " ";
        }       
        console.log('Condition')
        console.log(Condition)
         var data = {};
         data.Condition = Condition;
         $.ajax({
             type: "POST",
             url: '../inventory/ItemcodeSearchStockAdjustment',
             data: data,
             success: function (result) {
               
                 $('.removeme').remove();
                 var responseText = '';                    
                
                 if (result.length > 0) {
                     var id = 0;
                     try {
                         id = $('#TblItemList > tbody > tr:last-child()').attr('id').match(/\d+/)[0];
                     }
                     catch (err) {
                         console.log(err.message);
                         id = 0;
                     }

                     for (var i = 0; i < result.length; i++) {
                         id++;
                         responseText +=
                             '<tr class="removeme" id="row' + id + '" ><td><div class="custom-control custom-checkbox" style="margin-left:60%"><input type="checkbox" name="checkb" class="custom-control-input" id="select_status' + id + '" onchange="Checkclass(' + id + ')"><label class="custom-control-label" for="select_status' + id + '"></label></div></td>' +
                             '<td style="vertical-align:middle;font-weight:bold;font-size:larger;" align=center  id="Code' + id + '">' + result[i].ItemCode + '</td>' +
                             '<td align=center id="Description' + id + '">' + result[i].Description + ' <input type="hidden" id="ItemId' + id + '" value=' + result[i].ItemId + '> </td>' +
                             '</tr>';
                     }
                 }
                 else {
                     responseText += '<tr><td colspan=7 align=center>No Data Available</td></tr>';

                 }
                 $('#TblItemList').append(responseText);
                 
             }
         });       
    }

    function Checkclass(Id)
    {
        if (document.getElementById("select_status" + Id).checked)
        {
            $("#row" + Id).removeClass("removeme");
            $("#row" + Id).addClass("notremove");
        }
        else
        {
            $("#row" + Id).addClass("removeme");
            $("#row" + Id).removeClass("notremove"); 
        }
       
    }

    $("#Fieldname").autocomplete({                                             
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            var h1 = '';
            var h2 = '';
            if ($('#SearchType').val() == 0) { h1 = 'ItemCode'; h2 = 'Description' }
            else if ($('#SearchType').val() == 2) { h1 = 'Group Code'; h2 = 'Group Name' }
            else if ($('#SearchType').val() == 3) { h1 = 'SubGroup Code'; h2 = 'SubGroup Name' }
            else if ($('#SearchType').val() == 4) { h1 = 'Category Code'; h2 = 'Category Name' }
            else if ($('#SearchType').val() == 5) { h1 = 'SubCategory Code'; h2 = 'SubCategory Name' }

          
            if ($.trim($("#Fieldname").val() != ''))
            {
                var data = {};
                data.Condition = $("#Fieldname").val();
                data.invtype = $('#SearchType').val();
                $.ajax({
                    url: '../SalesInvoice/ItemCodeSearchSales',
                    type: "POST",
                    data: data,
                    dataType: "json",
                    success: function (data) {

                        response($.map(data, function (item) {
                            return ({
                                ColCount: 'Twoserch',
                                label: item.ItemCode,
                                label1: item.Description,
                                ItemCode: item.ItemCode,
                                Description: item.Description,
                                ItemId: item.ItemId,
                                headers: [h1, h2],
                            })
                        }));
                    }
                })
            }
            else if ($("#Fieldname").val() == '') {
                ItemListGets(0);
            }
        },
        autoFocus: true,
        select: function (event, ui) {
            $("#Fieldname").val(ui.item.ItemCode);
            $('#FieldId').val(ui.item.ItemId);
            ItemListGets(1);
        }
    });

    function selectall() {
        var flag = $("#select_status").is(":checked");
        var checkboxes = document.getElementsByName('checkb');
        for (var j = 0, n = checkboxes.length; j < n; j++) {
            checkboxes[j].checked = flag;
        }

        if (flag==true) {          
            $(".removeme").addClass("notremove");
            $(".removeme").removeClass("removeme");
        }
        else {
            $('.notremove').addClass("removeme");
            $('.notremove').removeClass("notremove");
        }
    }

    formrefresh();

</script>

