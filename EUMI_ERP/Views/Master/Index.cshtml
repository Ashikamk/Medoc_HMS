    function ShowOrderBouncinglist(result) {
        disable_datatable('orderbouncing');
        var responseText = "";

        if (result.length == 0) {
            var responseText = "<thead><tr style='text-align:center;color:red'><th>NO TRANSFER REQUEST YET</th></tr></thead>";
            $('#orderbouncing').html(responseText);
        }
        else {
            responseText += "<thead><tr><th style='width:5px;'>Slno</th><th>Approve/Remove</th><th>Date</th><th>Item Code</th><th>Description</th><th>Quantity</th><th>Remarks</th></tr></thead><tbody>";
            for (var i = 0; i < result.length; i++) {
                var slno = i + 1;
                responseText += '<tr ondblclick=PendingPurchasespopup('+result[i].ProductId+ ')>'+
                    '<td style="width:5px">' + slno + '</td>'+
                    '<td id=' + 'Approved' + slno + '  class= "jsgrid-cell jsgrid-control-field jsgrid-align-left"  style="width:3.0%;">&nbsp; '+
                    '<button type="button" onclick="ConfirmApproved(' + result[i].ProductId + ',' + 1 + ',' + result[i].BillSeriesId + ')" title=Approve class="badge badge-default round  btn-success" id="accept" style="font-weight:normal;color:white;border:none;" >Approve</button>&nbsp;'+
                    '<button type="button" onclick="ConfirmApproved(' + result[i].ProductId + ',' + 2 + ',' + result[i].BillSeriesId + ')" title= Reject  class="badge badge-default round  btn-warning" id="delete" style="font-weight:normal;color:white;border:none;"  >Remove</button> </td>'+
                    '<td>' + result[i].CurrentDate + '</td>'+
                    '<td id=' + "Icode" + result[i].ProductId + '>' + result[i].ProductCode + '</td>'+
                    '<td id=' + "IDesc" + result[i].ProductId + '>' + result[i].ProductDescr + '</td>'+
                    '<td>' + result[i].ProdQty + '</td>'+
                    '<td>' + result[i].Remarks + '</td>' +
              '</tr>';

