
@{
    ViewBag.Title = "SubCategory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script type="text/javascript" src="../Projectscript/SubCategoryMaster.js"></script>

<div class="myData" data-x="M02" />
<div id="Entry" style="width:40%;margin-left:30%;height:100%;">

    <div class="row">
        <div class="col-md-12"style="margin-top:30%;">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="font-weight:bold;text-align:center">DRUG SCHEDULE</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>
                                <form action="#">
                                    <div class="form-body" style="margin-left:10%;">

                                        <div class="row">
                                            <div class="col-md-2">

                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Type<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%">
                                                <div class="input-group">

                                                    <select id="CategoryName" class="form-control" aria-describedby="addsbcat"></select>
                                                    <div class="input-group-append" id="addsbcat">
                                                        <button class="btn btn-outline-primary" onclick="window.open('../Master/Category')" type="button" id="addsbcat">+</button>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-3">

                                            </div>
                                        </div>




                                        <div class="row">
                                            <div class="col-md-2">

                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Schedule<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%">
                                                <div class="input-group">

                                                    <input type="text" id="SubCategoryName" onkeyup="changetoupper(this.id)" autocomplete="off" class="form-control" name="Name">
                                                </div>
                                            </div>
                                            <div class="col-md-3">

                                            </div>
                                        </div>





                                        <div class="row">
                                            <div class="col-md-2">

                                            </div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Description</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%">
                                                <div class="form-group">
                                                    <input type="text" id="SubCategoryDescription" autocomplete="off" class="form-control" name="Description">
                                                </div>
                                            </div>
                                            <div class="col-md-3">

                                            </div>
                                        </div>





                                    </div>
                                    <div class="form-actions center">
                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





<div style="margin-left:20%;display:none;width:60%;" id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold">SUBCATEGORY LIST</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>

                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">

                                            </span>
                                        </div>

                                        @*<div class="btn-group">
                                            <button type="button" onclick="closetable(1)" class="btn btn-outline-primary"><i class="ft-edit"></i> Add New</button>
                                            <button type="button" class="btn btn-outline-primary"><i class="ft-edit"></i> Export</button>
                                            <button type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown"
                                                    aria-haspopup="true" aria-expanded="false">
                                                <span class="sr-only">Toggle Dropdown</span>
                                            </button>
                                            <div class="dropdown-menu">
                                                <a class="dropdown-item" href="#">Excel</a>
                                                <a class="dropdown-item" href="#">PDF</a>
                                                <div class="dropdown-divider"></div>
                                                <a class="dropdown-item" href="#">Print</a>
                                            </div>
                                        </div>*@
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto;">
                            <table id="tblsubcategory" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>






<div style="display:none"><input type="text" value="0" id="SubCategoryId" /></div>


