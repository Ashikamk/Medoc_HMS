            function ShowTopSalesreport(result) {
                var responseText = "<thead><tr><th>Image</th><th>Product</th><th>Quantity</th><th>Status</th><th>Amount</th><th></th></tr></thead>  <tbody>";
                for (var i = 0; i < result.length; i++) {

                    if (result[i].ItemDesc != 'Grand Total')
                        responseText += '<tr><td><img class="media-object round-media height-50" src="../app-assets/img/elements/01.png" alt="" /></td><td>' + result[i].ItemCode + ' - ' + result[i].ItemDesc + '</td><td>' + result[i].Qty + '</td><td><a class="btn white btn-round btn-primary">Active</a></td><td>' + ReplaceNumberWithCommas(parseFloat(result[i].Amount||0).toFixed(Decimal) )+ '</td><td><a class="danger" data-original-title="" title=""></a></td></tr>';
                }
                $('#topnsales').html(responseText + '</tbody>');
            }

            function ShowEmployeLogin(result) {
                var responseText = "<thead><tr><th>EmployeeName</th><th>EmployeeCode</th><th>Date</th><th>InTime</th><th>OutTime</th><th>TotalWorkingHours</th></tr></thead>  <tbody>";
                for (var i = 0; i < result.length; i++) {
                    responseText += '<tr><td>' + result[i].EmpName + '</td><td>' + result[i].EmpCode + '</td><td>' + result[i].AtendanceDate + '</td><td>' + result[i].InTime + '</td><td>' + result[i].OutTime + '</td><td>' + result[i].TotalWorkHrs + '</td></tr>';
