                            '#9c27b0',
                            '#03a9f4',
                            '#4caf50',
                            '#795548',
                            '#9e9e9e',
                    ],
                    plotOptions: {
                        column: {
                            colorByPoint: true,
                        },
                        line: {
                            dataLabels: {
                                enabled: true
                            },
                            enableMouseTracking: false
