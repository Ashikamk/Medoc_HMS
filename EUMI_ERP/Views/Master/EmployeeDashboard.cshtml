            //for SalesmanwiseSales

            function SalesmanwiseSalesGraph(result, Grtype) {

                var Amount = [];
                var SalesMan = [];
                var GrData = [];
                var Date = [];
                for (var i = 0; i < result.length; i++) {
                    var shodatesplit = result[i].Fromdate.split("/");
                    var ShowDate = shodatesplit[0] + '/' + shodatesplit[1];
                    Amount.push(parseFloat(result[i].Amount || 0));
                    SalesMan.push(result[i].SalesMan);
                    Date.push(ShowDate)
                    GrData.push({ name: result[i].SalesMan, y: parseFloat(result[i].Amount || 0) })
                }


                Highcharts.chart('Sales', {
                    chart: { type: Grtype },
                    title: {
                        text: 'Salesman Wise Daily - ' + monthNames[hhh.getMonth()] + ',' + hhh.getFullYear()
