@{
    ViewBag.Title = "Edit Person";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model EUMI_ERP.Models.proceduremastercs

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .edit-container {
        padding: 20px 0; /* very small top space */
        background: linear-gradient(to right, #5f6caf, #7f7fd5);
        min-height: 100vh;
    }

    .edit-card {
        width: 650px; /* smaller width */
        margin: 0 auto; /* center horizontally only */
        border-radius: 12px;
    }

    .card-header {
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }
</style>

<div class="edit-container">

    <div class="card shadow edit-card border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Edit Person Details</h5>
        </div>

        <div class="card-body p-3">

            @using (Html.BeginForm("UpdatePerson", "Master", FormMethod.Post))
            {
                @Html.HiddenFor(m => m.PersonId)

                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="form-label small">Full Name</label>
                        @Html.TextBoxFor(m => m.ProcedureName, new { @class = "form-control form-control-sm" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small">Age</label>
                        @Html.TextBoxFor(m => m.ProcedureAge, new { @class = "form-control form-control-sm" })
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="col-md-6">
                        <label class="form-label small">Gender</label>
                        @Html.TextBoxFor(m => m.ProcedureGender, new { @class = "form-control form-control-sm" })
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small">Phone Number</label>
                        @Html.TextBoxFor(m => m.ProcedureNumber, new { @class = "form-control form-control-sm" })
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label small">Address</label>
                    @Html.TextBoxFor(m => m.ProcedureAddress, new { @class = "form-control form-control-sm" })
                </div>

                <div class="text-end mt-3">
                    <a href="@Url.Action("PersonList","Master")" class="btn btn-secondary btn-sm me-2">Cancel</a>
                    <button type="submit" class="btn btn-success btn-sm px-3">Update</button>
                </div>
            }

        </div>
    </div>

</div>