    <section class="taskboard-app-form bg-blue-grey bg-lighten-5">
        <div id="Entry">
          
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                            <h4 class="card-title mb-0">Reminder</h4>
                        </div>
                        <div class="card-body">
                            <div class="px-3">
                                <div class="card-content collapse show">
                                    <div class="card-body">
                                        <div style="height:15px;"></div>
                                        <form action="#">
                                            <div class="form-body">



                                                <div class="row">
                                                    <div class="col-md-5" style="margin-left:70px">
                                                        <div class="form-group row">
                                                            <label>To<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <input type="text" id="UserName" class="form-control" />
                                                                <input type="hidden" id="UserId" class="form-control" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-5" style="margin-left:20px">
                                                        <div class="form-group row">
                                                            <label for="Date">Date<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <input type="text" id="Date" class="form-control" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div style="margin-left:-20px">
                                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1">
                                                            <u>S</u>ave <i class="fa fa-check-square-o"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-5" style="margin-left:50px">
                                                        <div class="form-group row">
                                                            <label>Time<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <input type="Time" id="Time" class="form-control" name="time">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-5" style="margin-left:20px">
                                                        <div class="form-group row">
                                                            <label>Subject<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <input type="text" id="Subject" class="form-control">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">
                                                        List <i class="ft-align-justify"></i></button>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-5" style="margin-left:20px">
                                                        <div class="form-group row">
                                                            <label>Message<span class="danger">*</span></label>
                                                            <div class="col-md-8">
                                                                <textarea id="ReminderMessage" rows="5" class="form-control"></textarea>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div style="margin-left:788px">
                                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                                     @*   <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>*@
                                                    </div>
                                                </div>

                                            </div>
                                        
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    </section>




    <div style="display:none;" id="listing">
        <section>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <table width="100%">
                                <tr>
                                    <td><h4 class="card-title">Reminder List</h4></td>
                                    <td align="right">
                                        <div class="heading-elements">
                                            <div class="btn-group">
                                                <button type="button" onclick="closetable(1)" class="btn btn-outline-primary"><i class="ft-edit"></i> Add New</button>
                                                <button type="button" class="btn btn-outline-primary"><i class="ft-edit"></i> Export</button>
                                                <button type="button" class="btn btn-outline-primary dropdown-toggle" data-toggle="dropdown"
                                                        aria-haspopup="true" aria-expanded="false">
                                                    <span class="sr-only">Toggle Dropdown</span>
                                                </button>
                                                <div class="dropdown-menu">
                                                    <a class="dropdown-item" href="#">Excel</a>
                                                    <a class="dropdown-item" href="#">PDF</a>
