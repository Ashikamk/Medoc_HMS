                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </table>


                        </div>
                        <div class="card-content collapse show">
                            <div class="card-body card-dashboard">
                                <table id="tblreminder" class="table table-striped table-bordered base-style dataTable"></table>
                                <br />

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>


    <script>

    $("#UserName").autocomplete({
        source: function (request, response) {
            var data = {};
            data.UserName = $("#UserName").val();
            $.ajax({
                url: '../Master/UserSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    console.log(data);
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '1',
                            label: item.UserName,
                            label1: item.UserName,
                            label2: item.UserId,
                            UserId: item.UserId,
                        })
                    }));
                }

            })

        },
        autoFocus: true,
        select: function (event, ui) {
            $('#UserId').val(ui.item.UserId);
            $('#UserName').val(ui.item.UserName);

        },

    });





    $(function () {

            $('#Date').daterangepicker({
                minDate: minDate,
                maxDate: new Date(new Date().getFullYear(), new Date().getMonth() + 1, new Date().getDate()),
                singleDatePicker: true,
                showDropdowns: true,
                locale: {
                    format: 'DD/MM/YYYY'
                }

            });



        });
    </script>


    <div style="display:none"><input type="text" value="0" id="ReminderId" /></div>
