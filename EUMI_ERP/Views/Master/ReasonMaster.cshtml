
@{
    ViewBag.Title = "Reason";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script type="text/javascript" src="../Projectscript/Reason.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>


<div class="myData" data-x="M370" />
<div id="Entry" style="width:40%;margin-left:30%;height:100%;">

    <div class="row">
        <div class="col-md-12" style="margin-top:20%;margin-bottom:60px">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="text-align:center;font-weight:bold;">Reason</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:35px;"></div>
                                <form action="#">
                                    <div class="form-body">
                                        <div class="row">
                                            <div class="col-md-2"></div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label style="font-weight:bold;">Reason<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-5">
                                                <input type="text" id="txt" class="form-control" autocomplete="off">
                                            </div>
                                            <div class="col-md-2"></div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-2"></div>
                                            <div class="col-md-3">
                                                <div class="form-group">
                                                    <label style="font-weight:bold;">Description<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-5">
                                                <input type="text" id="txtdesc" class="form-control" autocomplete="off">
                                            </div>
                                            <div class="col-md-2"></div>
                                        </div>
                                    </div>



                                    <div class="form-actions center" style="margin-left:2%;">

                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">New <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>

                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





<div style="margin-top:2%;margin-left:5%;display:none;width:90%;" id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold;">Reason List</h4></td>
                                <td>
                                    <div class="heading-elements">
                                        <div class="text-right">
                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto;">
                            <table id="tblreason" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>


<div style="display:none"><input type="text" value="0" id="ReasonId" /></div>











