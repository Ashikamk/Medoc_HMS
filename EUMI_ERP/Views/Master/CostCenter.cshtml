
@{
    ViewBag.Title = "CostCenter";
    Layout = "~/Views/Shared/_Layout.cshtml";

}







<script type="text/javascript" src="../Projectscript/CostCenterMaster.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>

<div class="myData" data-x="M03" />
<div id="Entry" style="width:40%;margin-left:30%;height:100%;">

    <div class="row">
        <div class="col-md-12" style="margin-top:10%;">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="text-align:center;font-weight:bold">Disease</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>
                                <form action="#">
                                    <div class="form-body">



                                        <div class="row">
                                          
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Code<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-8" style="margin-left:-2%">
                                                <div class="form-group">
                                                    <input type="text" onkeyup="changetoupper(this.id),CodeName()" id="CostCenterCode" class="form-control" name="Code">
                                                </div>
                                            </div>
                                           
                                        </div>





                                        <div class="row">
                                           
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Name<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-8" style="margin-left:-2%">
                                                <div class="form-group">
                                                    <input type="text" id="CostCenterName" onkeyup="changetoupper(this.id)" class="form-control" name="Name">
                                                </div>
                                            </div>
                                           
                                        </div>





                                        <div class="row">
                                           
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label style="font-weight:bold">Description</label>
                                                </div>
                                            </div>
                                            <div class="col-md-8" style="margin-left:-2%">
                                                <div class="form-group">
                                                    <input type="text" id="CostCenterDescription" class="form-control" name="Description">
                                                </div>
                                            </div>
                                           
                                        </div>

                                    </div>
                                    <div class="form-actions center">

                                        <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                        <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>

                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





<div style="margin-left:0%;display:none;width:100%;" id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold">DISEASE LIST</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto;">
                            <table id="tblcostcenter" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>






<div style="display:none"><input type="text" value="0" id="CostCenterId" /></div>

