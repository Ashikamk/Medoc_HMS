<script>
    var createQRCode = function () {

        var data = $('#RegSeries').val() + '-' + $('#RegNo').val();
        $('#QRCode').empty();
        $('#QRCode').qrcode(data, 120, 90);
        //$('#QRCode').append('</br><strong>' + data + '</strong>');
    };

    function generatebarcode() {

        var Code = $('#RegSeries').val() + '-' + $('#RegNo').val();
        if ($('#RegNo').val() == '') { Code = 0; } JsBarcode("#barcode1", Code);
    }
    $('#RegSeries,#RegNo').keyup(function () { createQRCode(); generatebarcode(); });
    $('#RegSeries').change(function () { createQRCode(); generatebarcode(); })
    createQRCode();

    function CalcYear() {

        var Age = parseInt($("#Age").val()) || 0;      
        var month = parseInt($("#month").val()) || 0;

        if (month > 11) {
            warningshow('Month cannot be greater than 11');
            $("#month").val('');
            $("#month").focus();
            return;
        }

        var d = new Date();
        d.setFullYear(d.getFullYear() - Age);
        d.setMonth(d.getMonth() - month);

        var Day = d.getDate();
        if (Day < 10) { Day = '0' + Day; }

        var Month = d.getMonth() + 1;
        if (Month < 10) { Month = '0' + Month; }

        var Year = d.getFullYear();

        if (Month == 2 && Day == 29) { Day = 28 }

        $("#PDOB").val(Day + '/' + Month + '/' + Year);
    }


</script>





