        var imgcnt = 0;
       
        function imagesliderload(ProdId) {
            var dd = new Date();
       
            $('.pip').remove();
            $.ajax({
                url: "../ProjectImages/Products/" + $('#ItemId').val() + ".png",
                type: 'HEAD',
                error: function () {
                    $('#myImg').attr('src', "../app-assets/img/elements/04.png");
                },
                success: function () {
                    $('#myImg').attr('src', "../ProjectImages/Products/" + $('#ItemId').val() + ".png?" + dd.getTime());
                }
            });
            var formData = new FormData();
            var ImageId = $('#ItemId').val();
            formData.append("UniqueId", ImageId);

            $.ajax({
                type: "POST",
                url: '/Master/CheckFolderLengthProduct',
                data: formData,
                dataType: "html",
                contentType: false,
                processData: false,
                success: function (result1) {


                    var ProdId = ImageId;
                    TotalImage = result1;
                    
                    var SlideData = '';
                    if (TotalImage == 0) {

                        SlideData = '<img src="../app-assets/img/NoImage.png" style="height:600px;width:599px;align:center; margin-top:0;">';

                    } else {
                        for (i = 0; i < TotalImage; i++) {

                            var d = new Date();

                            var nextImage = 0; var prevImame = 0;

                            if (i == (0)) {
                                SlideData += '<div id=slimg-' + i + '><input type="radio"  visibility: hidden name="radio-btn" id=img-' + i + ' checked  /><li style="list-style:none;"><div  style="height:800px;width:500px ;text-align: left" class=""> <img src="../ProjectImages/Products/' + ProdId + '/' + ProdId + '-' + i + '.png?' + d.getTime() + '" style="height:600px;width:599px; align:center; margin-top:0;" id="im' + i + '"/><label for="img-' + prevImame + '" class="prev"  id="previous' + i + '" onclick=previmg(' + i + ')>&#10094; </label>&nbsp&nbsp <label for="img-' + nextImage + '" class="next1" id="next"  onclick=nextimg(' + i + ')>&#10095;</label></div></li></div>';

                                imgcnt = i;
                            }
                            else
                                SlideData += '<div style="display:none" id=slimg-' + i + '><input type="radio" visibility: hidden name="radio-btn" id=img-' + i + ' checked /><li style="list-style:none;"><div style="height:800px; width:500px ; text-align: left" class=""> <img src="../ProjectImages/Products/' + ProdId + '/' + ProdId + '-' + i + '.png?' + d.getTime() + '" style="height:600px;width:599px; align:center" id="im' + i + '"/><label for="img-' + prevImame + '" class="prev" style="border-bottom:0" id="previous' + i + '" onclick=previmg(' + i + ')>&#10094;</label>&nbsp&nbsp <label for="img-' + nextImage + '" class="next1" style="border-bottom:0" id="next' + i + '" onclick=nextimg(' + i + ')>&#10095;</label></div></li></div>';


                        }
                    }

            $('#DDh1').append(SlideData);

            $(".remove").click(function () {
                $(this).parent(".pip").remove();
            });

            }

                });

            $('#popupdiv1').show();
            $('#DDh1').show()
        }
        
        function previmg(i)
        {
           
            var j = i - 1;
            if ($('#slimg-' + j).length)
            {
                $('#slimg-' + i).hide();
                $('#slimg-' + j).show();
            }
           
        }
        function nextimg(i) {
          
            var j = i + 1;
            if ($('#slimg-' + j).length)
            {
                $('#slimg-' + i).hide();
                $('#slimg-' + j).show();
            }

        }
        
        
       </script>


