   <script>

       $(document).ready(function () {


           $("#dhinesh").click(function () {

               var ProdId = $('#ItemId').val();
               filesLength = 25           
               for (var i = 0; i <= filesLength; i++) {
                 

                   $("<span class=\"pip\">" +
                     "<img class=\"imageThumb\" src=../ProjectImages/Products/" + ProdId + "/" + ProdId + '-' + i + ".png>" +
                     "<br/><span class=\"remove\">Remove image</span>" +
                     "</span>").insertAfter("#DDh");
               
                   $(".remove").click(function () {
                       $(this).parent(".pip").remove();
                   });

               }

           });

           if (window.File && window.FileList && window.FileReader) {
               $("#files").on("change", function (e) {
                   var files = e.target.files,
                     filesLength = files.length;
                   for (var i = 0; i < filesLength; i++) {
                       var f = files[i]
                       var fileReader = new FileReader();
                       fileReader.onload = (function (e) {
                           var file = e.target;
                           $("<span class=\"pip\">" +
                             "<img class=\"imageThumb\" src=\"" + e.target.result + "\" title=\"" + file.name + "\"/>" +
                             "<br/><span class=\"remove\">Remove image</span>" +
                             "</span>").insertAfter("#DDh");
                           $(".remove").click(function () {
                               $(this).parent(".pip").remove();
                           });

                           // Old code here
                           /*$("<img></img>", {
                             class: "imageThumb",
                             src: e.target.result,
                             title: file.name + " | Click to remove"
                           }).insertAfter("#files").click(function(){$(this).remove();});*/

                       });
                       fileReader.readAsDataURL(f);
                   }
               });
           } else {
               alert("Your browser doesn't support to File API")
           }

           $("#searchcode").autocomplete({
               source: function (request, response) {
                   var data = {};
                   data.ItemCode = $("#searchcode").val();

                   $.ajax({
                       url: '../Purchase/ProductSearch',
                       type: "POST",
                       data: data,
                       dataType: "json",
                       success: function (data) {

                           response($.map(data, function (item) {
                               return ({
                                   ColCount: 'TWOEnq',
                                   label: item.ItemCode,
                                   label1: item.Description,
                                   ItemId: item.ItemId,
                                   Product: item.Description,
                                   productcode: item.ItemCode,
                                   GrpId: item.GrpId,
                                   CategoryId: item.CategoryId,
                                   headers: ["Product Code", "Product Name"]
                               })
                           }));
                       }

                   })

               },
               autoFocus: true,
               select: function (event, ui) {
                   $('#Loading').show();
                   $('#productid').val(ui.item.ItemId)
                   $('#productdesc').val(ui.item.Product);
                   $('#btnsubmit').focus();

                   GetItem(ui.item.ItemId, ui.item.GrpId, ui.item.CategoryId);
                   $('#code').show();
                   $('#searchcode').hide();
                   $('#btnsubmit').prop("disabled", false);
                   $('#btnsubmit').show();
                   $('#searchbutton').removeClass();
                   $('#searchbutton').addClass('btn btn-outline-primary');
               },
           });
       });

       function SavetMultiimages1() {

           var totalFiles = document.getElementById("files").files.length;

           if (totalFiles <= 25) {

               var data = {};
               data.ItemId = $('#ItemId').val();
               $.ajax({
                   type: "POST",
                   url: "../Master/RemoveExistingItemImageFolder",
                   data: data,
                   success: function (result) {


                       var ItemID = $('#ItemId').val();

                       for (var i = 0; i <= totalFiles; i++) {
                           var formData = new FormData();
                           var imageName = ItemID + '-' + i;
                           var browsedFile = document.getElementById("files").files[i];
                           var ImageId = ItemID;


                           if (browsedFile.type.match('image.*')) {
                               formData.append("FileUpload", browsedFile);
                               formData.append("ImageName", imageName);
                               formData.append("UniqueId", ImageId);

                               $.ajax({
                                   type: "POST",
                                   url: '/Master/UploadMultipleProductImage',
                                   data: formData,
                                   dataType: "html",
                                   contentType: false,
                                   processData: false,
                                   success: function (result) {
                                       formrefresh();
                                       swal('Images Uploaded Successfully', "", "success");
                                       $('.swal-button swal-button--confirm').focus();
                                       $("#files").val('');
                                       $(".pip").remove();
                                   }
                               });
                           }

                       }
                   }
               });
           }


           else {
               warningshow("Limit Exceeded(Maximum 25 Images)");
           }
       }
   </script>




   


    <script type="text/javascript">
    $(document).ready(function () {

        if ("@Request.QueryString["from"]" == "productlist") {
            var id = sessionStorage.getItem("inventory_productlist_id");
            sessionStorage.removeItem("inventory_productlist_id");
            var numId = parseInt(id, 10);
            if (!isNaN(numId)) {
                $('#Loading').show();
                jQuery(window).load(function () {
                    //alert('page is loaded');
                    setTimeout(GetRows(numId), 3000);

                });

            }
        }
    });

    function locationwiseqtyupdateclear() {
        $('#opqty').val(0);
    }


    function locationwiseqtyupdate()
    {
        var Qty = 0;
        $('#popupdiv').hide();
        var num = parseInt($('#NoOfLocations').val()-1);
        for (var i = 0; i <= num ; i++) {
            var LocationID = $('#locID' + i).val();
            var LocationQty = parseInt($('#lqty' + LocationID).val()||0);
            if (LocationQty != 0) {
                Qty +=LocationQty;
            }
        }
        $('#opqty').val(Qty);
    }


    function AddmoreImages()
    {
        var Imgcount=parseInt($('#Imagecount').val())
        var file = '<div id=' + "Imgdiv" + Imgcount + '><input type="file" id=' + 'SelmultiImage' + Imgcount + ' accept="image/*" onchange="readMultipleimageURL(this,' + Imgcount + ')"" class="btn btn-lg gradient-back-to-earth font-small-1 white p-2 mr-2"><img id=' + "Mimg" + Imgcount + ' src="../app-assets/img/elements/04.png" alt="Gini" width="50" style="margin-top:-18px" class="img-thumbnail multiimagebox" onerror="this.onerror=null; this.src=../app-assets/img/elements/04.png;">&#160;&#160;<button type="button" class="btn btn-danger" onclick="RemoveImages(' + Imgcount + ')"> <i class="ft-x"></i>Remove</button></div>'
        $('#divmultimage').append(file).show('slow');
        $('#Imagecount').val(Imgcount+1)
    }


    function RemoveImages(ImgId)
    {
        $('#Imgdiv' + ImgId).slideUp( function () { $('#Imgdiv' + ImgId).remove(); });
        //$('#Imgdiv' + ImgId).remove();

    }









    </script>





