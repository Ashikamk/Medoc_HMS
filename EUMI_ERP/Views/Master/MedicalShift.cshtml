<script>
    function MedShiftGets(result) {
        $('#tblsalesinvoice tr').remove();
        console.log(result)
        if ($('#tblsalesinvoice tr').length == 0) {
            Count = 1;
        }
        $('#Warningpopup').fadeOut();
        for (var n = 0; n < result.length; n++) {
            var id = parseInt(Count);
            var slno = parseInt(n)+1;
            var ProdRow1 = "<tr id=" + 'row' + id + " class=jsgrid-row>" +
               
                "<td id= 'col14_" + id + "'  class='jsgrid-cell jsgrid-control-field jsgrid-align-center' style='display:none;width:2%'><input class='jsgrid-button jsgrid-update-button' id='Update' type='button' onclick='updaterow(" + id + ")' title='Update'><input class='jsgrid-button jsgrid-cancel-edit-button' type='button' id='canceledit' onclick='editcancel(" + id + ")' title='Cancel edit'></td>" +
                 "<td  class='jsgrid-cell' style='width:2%;text-align:center;zoom:1.5' ><input type=checkbox id ='checkstatus" + id + "' checked ></td>" +
                "<td id=" + 'td' + id + " class='jsgrid-cell' style='width:3%;text-align:center'>" + slno + "</td>" +
                "<td class='jsgrid-cell jsgrid-align-right' style='width:10%;text-align:center' ><input type='text' id=" + 'AvailableId' + id + " style='display:none' value='" + result[n].AvailableId + "' /><select style='height:45px;background-color:009DA0' class='form-control text-left'  id=select_days" + id + " >" + DaysSelect + "</select></td>" +
                "<td class='jsgrid-cell jsgrid-align-right' style='width:4%;text-align:center' ><select style='height:45px;background-color:009DA0' class='form-control text-left' id=" + 'select_shift' + id + " >" + ShiftSelect + "</select></td>" +
                  "<td  onfocusout=Testing(" + id + ") class='jsgrid-cell jsgrid-align-right' style='width:4%;text-align:center' ><input type='Time' style='height:45px;background-color:white' class='form-control text-left' id=" + 'Time' + id + " value='" + result[n].StartTime + "'></td>" +
                 "<td  onfocusout=Testing(" + id + ") class='jsgrid-cell jsgrid-align-right' style='width:4%;text-align:center;margin-bottom:10px' ><input type='Time' style='height:45px;background-color:white' class='form-control text-left' id=" + 'EndTime' + id + " value='" + result[n].EndTime + "'></td>" +
                "</tr>";
           
            $('#tblsalesinvoice').append(ProdRow1);
            $('#checkstatus' + id).prop('checked');
            $('#select_shift' + id).val(result[n].Shift);
            $('#select_days' + id).val(result[n].Days);
            Count++;
        }
        $('#proddiv').animate({ scrollTop: 5000 }, 900);
    }

    function DeleteConfirm() {
  
        $("#tblsalesinvoice").remove();
 
    }
   
    function formrefreshconfirm() {
    
            var rowcount = CountRows();
            if (rowcount > 0 ) {
                $('#confirm').show();
                $('#confirmOk').focus();
                $('#Confirmflag').val('refresh'); $('#ConfirmRowId').val(0);
                $('#confirmmessage').text('Data will be lost.Do you want to Continue?');
            }
            else {
                formrefresh();
            }
    }
    function GetRows(DoctorsId) {

        $('#AvailableId').val(DoctorsId)
        var data = {};
        data.AvailableId = DoctorsId;
        $.ajax({
            type: "POST",
            url: "../Master/MedShiftGetandGets",
            data: data,
            success: function (result) {
                MedShiftGets(result.oList);
            }
        });

    }
    $("#select_doc").autocomplete({
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $("#doctorId").val('');
            var data = {};
            data.Name = $("#select_doc").val();
            data.DoctorsId = $("#DocId").val();
            data.Department = $("#Department").val();
            data.DeptId = ERPDeptId;

            $.ajax({
                url: '../Master/HMS_DoctorsSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.Name ,
                            label1: item.Department,
                            Department: item.Department,
                            DoctorsId:item.DoctorsId,
                            Name: item.Name,
                         
                           
                            headers: ["Name", "Department"]
                        })
                    }));
                }



            })
        },
        autoFocus: true,

        select: function (event, ui) {

            GetRows(ui.item.DoctorsId);
            $("#doctorId").val(ui.item.DoctorsId);
            $("#select_doc").focus();
        },

    });
    
</script>

