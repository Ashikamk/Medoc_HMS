
@{
    ViewBag.Title = "Tax";
    Layout = "~/Views/Shared/_Layout.cshtml";

}


<script type="text/javascript" src="../Projectscript/TaxMaster.js"></script>
<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script src="~/Scripts/Autocomplete/jquery-ui.js"></script>

<div class="myData" data-x="M10" />
<div id="Entry" style="">
    <div class="row">
        <div class="col-md-1"></div>
        <div class="col-md-10" style="">
            <div class="card">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="text-align:center;font-weight:bold">Tax</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">

                                <form action="#">
                                    <div class="form-body">
                                        <div class="col-md-12">

                                            <div class="row mt-2">

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label for="userinput1" style="font-weight:bold;">Name<span class="danger">*</span></label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <input type="text" id="TaxName" onkeyup="changetoupper(this.id)" class="form-control">
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label for="userinput2" style="font-weight:bold;">Rate<span class="danger">*</span></label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="form-group">
                                                        <input type="text" id="TaxRate" onkeypress="isNumberValue(event, this)" class="form-control">
                                                    </div>
                                                </div>
                                            </div>


                                            <div class="row">

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label style="font-weight:bold;">Sales Taxable</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="input-group m-0">
                                                        <input type="text" id="TaxableAccountSales" onkeyup="chkacntemptysales(event)" class="form-control">
                                                        <input type="hidden" id="hiddendebit" value="0" />
                                                        <div class="input-group-append">
                                                            <button class="btn btn-outline-primary" onclick="window.open('../master/AccountHead')" type="button">+</button>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label style="font-weight:bold;">Purchase Taxable</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="input-group m-0">
                                                        <input type="text" id="TaxableAccountpurchase" onkeyup="chkacntemptypurchase(event)" class="form-control">
                                                        <input type="hidden" id="hiddendebit2" value="0" />
                                                        <div class="input-group-append">
                                                            <button class="btn btn-outline-primary" onclick="window.open('../master/AccountHead')" type="button">+</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row">

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label style="font-weight:bold;">Sales Return</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="input-group m-0">
                                                        <input type="text" id="TaxableAcntSalesReturn" onkeyup="checktaxreturntemptysales(event)" class="form-control">
                                                        <input type="hidden" id="hiddendebit5" value="0" />
                                                        <div class="input-group-append">
                                                            <button class="btn btn-outline-primary" onclick="window.open('../master/AccountHead')" type="button">+</button>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
