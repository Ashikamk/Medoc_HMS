                                                            <button class="btn btn-outline-primary" id="btnaddaccount" onclick="window.open('../master/AccountHead')" type="button">+</button>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="col-md-2">
                                                    <div class="form-group">
                                                        <label style="font-weight:bold;">Purchase Tax</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
