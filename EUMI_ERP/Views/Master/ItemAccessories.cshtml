    function LabAdviceLoad(result) {
        for (var n = 0; n <= result.length; n++) {
            $('#PQty0').val(1);
            $('#TestId0').val(result[n].TestId);
            $('#TestName0').val(result[n].TestName);
            $('#TestCode0').val(result[n].TestName)
            $('#TestAmount0').val(result[n].PRate);
            $('#PRate0').val(result[n].PRate);
           AddTest()

        }
    }
</script>


