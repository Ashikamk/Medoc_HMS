<script>
    if ("@Request.QueryString["flag"]" == "reg") {


        var PatientId = sessionStorage.getItem("BSOP_PI");
        var IPNumber = sessionStorage.getItem("BSOP_IP");

        sessionStorage.removeItem("BSOP_PI");
        sessionStorage.removeItem("BSOP_IP");


        if (PatientId != null) {
            setTimeout(function () {

                $('#IpNo').val(IPNumber);
                GetLastRevisitDetails(PatientId);
               
                $('#TestName0').focus();
            }, 300);

        }

    }


    if ("@Request.QueryString["flag"]" == "scanreg") {


        var PatientId = sessionStorage.getItem("BSOP_PI");
        var IPNumber = sessionStorage.getItem("BSOP_IP");

        sessionStorage.removeItem("BSOP_PI");
        sessionStorage.removeItem("BSOP_IP");


        if (PatientId != null) {
            setTimeout(function () {

                $('#IpNo').val(IPNumber);
                GetLastRevisitDetails(PatientId);
                getBillProcedures(PatientId);
                $('#TestName0').focus();
            }, 300);

        }

    }



    //for scan customer
    function getBillProcedures(PatientId) {
        var data = {};
        data.OpNo = PatientId;
        data.RegNo = $('#RegNo').val();
        data.RegSeries = $('#RegSeries').val();

        $.ajax({
            type: "POST",
            url: "../Revisit/HMS_ProcAdvicegets",
            data: data,
            success: function (result) {
                LabAdviceLoad(result.oList);
            }
        });
