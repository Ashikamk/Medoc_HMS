                }
                else {
                    ProdRow += "<tr ondblclick=gotoSales(" + result[n].BillSlNo + "," + result[n].BillSeriesId + "," + result[n].DeptId + ") class='jsgrid-row' id=" + 'pdctrow' + (n + 1) + ">" +
