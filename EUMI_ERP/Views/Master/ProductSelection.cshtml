                          "<tr><th>Invoice No</th><th class='text-center'>Date </th><th>Supplier</th><th>Supp_No</th><th>Qty.</th><th style='text-align:right'>FC Cost</th><th style='text-align:right'>Cost</th><th>Location</th><th>Currency </th><th>Department</th><th>PO_Ref</th><th style='text-align:right'>OtherCost</th></tr></thead><tbody>";
        if (result.length != 0) {
            for (var p = 0; p < result.length; p++) {
                var a = (result[p].Rate + result[p].OtherCost).toFixed(Decimal);
                var lpotr = '';
                if (result[p].LPO != '0')
                    lpotr = result[p].LPO;

                if (result[p].PurchaseType == 'Local' || SuppDetailsRight == 'Yes') {
                    ProdRow = ProdRow + "<tr  id=" + 'pdctrow' + (p + 1) + ">" +
                        "<td style='width:10%' class='text-left'>" + result[p].InvoNo + "</td>" +
                        "<td class='text-center'>" + result[p].InvoDate + "</td>" +
                        "<td style='width:20%' class='text-left'>" + result[p].SupplierName + "</td>" +
                        "<td class='text-left'>" + result[p].AccName + "</td>" +
                        "<td style='text-align:center' class='QtyColour'>" + result[p].Quantity + "</td>" +
                        "<td style='text-align:right'>" + parseFloat(result[p].FCGrandTotal).toFixed(Decimal) + "</td>" +
                         "<td style='text-align:right'>" + a + "</td>" +
                        "<td class='text-left'>" + result[p].Locnname + "</td>" +
                        "<td class='text-left'>" + result[p].CurrencyName + "</td>" +
                        "<td class='text-left'>" + result[p].DeptName + "</td>" +
                        "<td class='text-left'>" + lpotr + "</td>" +
                         "<td style='text-align:right'>" + parseFloat(result[p].OtherCost).toFixed(Decimal) + "</td>" +
                        "</tr>";
                }
                else {
                    ProdRow = ProdRow + "<tr id=" + 'pdctrow' + (p + 1) + ">" +
                       "<td style='width:10%' class='text-left'>" + result[p].InvoNo + "</td>" +
                        "<td class='text-center'>" + result[p].InvoDate + "</td>" +
                        "<td></td>" +
                        "<td></td>" +
                        "<td style='text-align:center' class='QtyColour'>" + result[p].Quantity + "</td>" +
                        "<td style='text-align:right'>" + parseFloat(result[p].FCGrandTotal).toFixed(Decimal) + "</td>" +
                         "<td style='text-align:right'>" + a + "</td>" +
                        "<td class='text-left'>" + result[p].Locnname + "</td>" +
                        "<td class='text-left'>" + result[p].CurrencyName + "</td>" +
                        "<td class='text-left'>" + result[p].DeptName + "</td>" +
                        "<td class='text-left'>" + lpotr + "</td>" +
                         "<td style='text-align:right'>" + parseFloat(result[p].OtherCost).toFixed(Decimal) + "</td>" +
                        "</tr>";
                }
            }
            $('#tbltransaction').html(ProdRow + '</tbody>');
            datatableWithsearch('tbltransaction', 'MultiplePurchaseT');
            $('#tbltransaction').scrollTop(0);
        }
        else {
            $('#tbltransaction').html(ProdRow + '</tbody>');
            datatableWithsearch('tbltransaction', 'MultiplePurchaseT');
        }

    }

    function PurchaseCorrectionLoad(result) {
        disable_datatable('tbltransaction');
        var ProdRow = "<thead><tr class='font-small-2'><th >SI NO</th><th class='text-center'>Item</th><th>Batch</th><th>New Batch</th><th>Old Expiry</th><th >New Expiry</th><th >Old SPrice</th><th >New SPrice</th><th>Old Qty</th><th>New Qty</th><th>Loaction</th><th>Reason</th><th>Remarks</th></tr>" +
                          "<tr><th>SI No</th><th class='text-center'>Item </th><th>Batch</th><th>New Batch</th><th>Old Expiry</th><th >New Expiry</th><th >Old SPrice</th><th >New SPrice</th><th>Old Qty </th><th>New Qty</th><th>Loaction</th><th>Reason</th><th>Remarks</th></tr></thead><tbody>";
        if (result.length != 0) {
            for (var p = 0; p < result.length; p++) {
                var RID = parseInt(result[p].Status); var Indx = ReasonArray.findIndex(obj => obj.Id == RID);
                var ReasonTxt = ReasonArray[Indx].Reason;
                    ProdRow = ProdRow + "<tr  id=" + 'pdctrow' + (p + 1) + ">" +
                        "<td class='text-center'>" + result[p].SlNo + "</td>" +
                        "<td class='text-left'>" + result[p].ItemCode + "</td>" +
                        "<td class='text-left'>" + result[p].Batch + "</td>" +
                        "<td class='text-left'>" + result[p].ItemDescription + "</td>" +
                        "<td >" + result[p].Expiry + "</td>" +
                        "<td >" + result[p].InvoDate + "</td>" +
                        "<td style='text-align:right'>" + parseFloat(result[p].SellingRate).toFixed(Decimal) + "</td>" +
                        "<td style='text-align:right'>" + parseFloat(result[p].Amount).toFixed(Decimal) + "</td>" +
                        "<td class='text-center'>" + result[p].Loose + "</td>" +
                        "<td class='text-center'>" + result[p].Free + "</td>" +
                        "<td >" + result[p].DueDate + "</td>" +
                        "<td class='text-left'>" + ReasonTxt + "</td>" +
                        "<td >" + result[p].Remarks + "</td>" +
                        "</tr>";
            }
            $('#tbltransaction').html(ProdRow + '</tbody>');
            datatableWithsearch('tbltransaction', 'MultiplePurchaseTnn');
            $('#tbltransaction').scrollTop(0);
        }
        else {
            $('#tbltransaction').html(ProdRow + '</tbody>');
            datatableWithsearch('tbltransaction', 'MultiplePurchaseTnn');
        }

    }

    function datatableWithsearch(tablename, Type) {

        var a = '#' + tablename + ' tr:eq(1) th'

        $(a).each(function () {
            var title = $(this).text();
            if (title != ' ')
                if (title == 'Currency' || title == 'OrderNo' || title == 'SerialNo' || title == 'InvoiceNo') {
                    $(this).html('<input type="text" class="form-control"  style="width:120px"  placeholder="' + title + '"/>')
                }
                else {
                    $(this).html('<input type="text" class="form-control"   placeholder="' + title + '"/>')
                }
        });

        var table = null;

        if (Type == 'Single') {

            table = $('#' + tablename).DataTable({
                dom: 'tipr',
                orderCellsTop: true,
                //"order": false,
                paging: false,
            });

        }
        else if (Type == 'Multiple') {

            table = $('#' + tablename).DataTable({
                dom: 'tir',
                orderCellsTop: true,
                "order": [],
                paging: false,
              
            });


        }
        else if (Type == 'MultiplePurchaseT') {

            table = $('#' + tablename).DataTable({
                dom: 'tipr',
                "columnDefs": [
                    { "width": "10%", "targets": 0 },
                    { "width": "15%", "targets": 2 },
                ],
                orderCellsTop: true,
                "order": [],
                paging: false,
              
            });

        }
        else if (Type == 'MultiplePurchaseTnn') {

            table = $('#' + tablename).DataTable({
                dom: 'tipr',
                "columnDefs": [
