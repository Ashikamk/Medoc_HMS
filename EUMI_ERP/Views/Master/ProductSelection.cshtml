        disable_datatable('tbltransaction');        
        var ProdRow = "<thead><tr>" +
            "<th>SalesInvoice</th>" +
            "<th class='text-center'>Date</th>" +
            "<th>AccountName</th>" +
            "<th>Delivery Details</th>" +
            "<th>Qty.</th>" +
            "<th style='text-align:right'>Price</th>" +
            "<th>Location</th>" +
            "<th>Salesman</th>" +
            "<th>Department</th></tr>" +

            "<tr>" +
            "<th>SalesInvoice</th>" +
            "<th class='text-center'>Date</th>" +
            "<th>AccountName</th>" +
            "<th>Delivery Details</th>" +
            "<th>Qty.</th>" +
            "<th style='text-align:right'>Price</th>" +
            "<th>Location</th>" +
            "<th>Salesman</th>" +
            "<th>Department</th>" +
            "</tr></thead><tbody>";

