                    'OpeningQty': OpeningQty,
                    'OpeningCost': OpeningCost,

                    'LPCost': LPCost,
                    'VatPer': VatPer,
                    'Model1': Model1,
                    'Model2': Model2,
                    'Model3': Model3,
                    'MaxQty': MaxQty,
                    'MinQty': MinQty,
                    'Bin_A': Bin_A,
                    'Bin_B': Bin_B,
                    'Bin_C': Bin_C,

                    'Bin_D': Bin_D,
                    'Bin_E': Bin_E,
                    'Bin_F': Bin_F,
                    'Bin_G': Bin_G,
                    'Bin_H': Bin_H,
                    'Size': Size,
                    'Weight': Weight,
                    'Length': Length,
                    'Width': Width,
                    'Thickness': Thickness,

                    'Density': Density,
                    'Specification': Specification,
                    'AvgCost': AvgCost,
                    'Hsncode': Hsncode,
                    'MRP': MRP,
                    'SellingPrice1': SellingPrice1,
                    'SellingPrice2': SellingPrice2,
                    'Otherdescription': Otherdescription,
                    'UserId': UserId,
                    'DeptId': DeptId
                })
            }
        }
        if (bArray != "") {
            var data = { 'ItemMasterModel': bArray };
            $.ajax({
                type: "POST",
                url: "../Master/ItemImportInsertandUpdate",
                data: data,
                success: function (result) {
                    $('#btnitemimportsubmit').prop("disabled", false);
                    var status = result.oList[0].Status;
                    if(status==1){
                        Showalertsthis(status);
                    }
                    else {

                        if (status == 0)
                            var Desc = "Thses Items Already Exists!";
                        else if (status == 5)
                            var Desc = "Same ItemCode Found in Excel!";

                        $('#tblAlert tr').remove();
                        var Prod1 = "<tr class='jsgrid-row'><td colspan=4 style='border:none'><h2 style='color:#FF586B'>" + Desc + "</h2></td></tr>" +
                                            "<tr class='jsgrid-row' style='color:#607D8B'><th class='jsgrid-cell jsgrid-control-field jsgrid-align-center' >SL#</th><th class='jsgrid-cell jsgrid-control-field jsgrid-align-center' >ProductCode</th></tr>";

                        $('#tblAlert').append(Prod1);
                        for (var m = 0; m < result.oList.length; m++) {

                            var Prod1 =
                                "<tr class='jsgrid-row' style='color:#607D8B'>" +
                                "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center'  style='text-align:center'>" + (m+1) + "</td>"+
                                "<td class='jsgrid-cell jsgrid-control-field jsgrid-align-center'  style='text-align:left'>" + result.oList[m].ItemCode + "</td></tr>";

                            $('#tblAlert').append(Prod1);

                            $('#alertpopup').show();
                            $('#alertdiv').show();
                        }

                    }
                }
            });
        }
    }

    function Showalertsthis(Status) {

        if (Status == 1) {
            swal('Data Saved Successfully', "", "success");
            $('.swal-button swal-button--confirm').focus();
            $("#tblitemimport tbody tr").remove();
            $("#fileUpload").val('');
        }
        else if (Status == 5) {
            swal('Same ItemCode Found in Excel', "", "warning");
            $('.swal-button swal-button--confirm').focus();
        }
        else {
            swal('Data Already Exists', "", "warning");
            $('.swal-button swal-button--confirm').focus();
         
        }

    }

    //Show Warnig Popup right top
    function warningshow(message, Id) {
        $('#popupmessage').text(message);
        $('#Warningpopup').show();
        $('#' + Id).focus();
        window.setTimeout(function () {
            $('#Warningpopup').hide();
        }, 3000);
    }

    function SampleExcelFormat() {
        window.open('../PerfomaExcelFormat/ItemCreate' + ".xlsx", '_blank');
    }
</script>