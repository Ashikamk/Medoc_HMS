        var a = 0; b = 0; c = 0; d = 0;

        for (var k = 0; k < excelRows.length; k++) {

            if (excelRows[k]["ItemCode"] == '' || excelRows[k]["ItemCode"] == undefined || excelRows[k]["ItemCode"] == '') {
                a = 1;
                break;
            }
            if (excelRows[k]["Description"] == '' || excelRows[k]["Description"] == undefined || excelRows[k]["Description"] == '') {
                b = 1;
                break;
            }
            if (excelRows[k]["Unit"] == '' || excelRows[k]["Unit"] == undefined || excelRows[k]["Unit"] == '') {
                c = 1;
                break;
            }
            if (excelRows[k]["Group"] == '' || excelRows[k]["Group"] == undefined || excelRows[k]["Group"] == '') {
                d = 1;
