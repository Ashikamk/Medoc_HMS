@{
    ViewBag.Title = "DriverMaster";

}

<script type="text/javascript" src="../Projectscript/Common.js"></script>

<div class="myData" data-x="M206" />


<div id="Entry" style="width:40%;margin-left:30%;height:100%;">

    <div class="row">
        <div class="col-md-12" style="margin-top:30%;">
            <div class="card" >
                <div class="card-header" style="border-bottom:1px solid #e6e6e6">
                    <h4 class="card-title mb-0" style="text-align:center;font-weight:bold;">Driver</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>
                                <form action="#">
                                    <div class="form-body" style="margin-left:5%;">
                                        <div class="row">
                                            <div class="col-md-3"></div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label for="userinput2" style="font-weight:bold;">Name<span class="danger">*</span></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%;">
                                                <input type="text" id="txt_fname" maxlength="100" onkeyup="changetoupper(this.id)" class="form-control" name="txt_fname" autocomplete="off">
                                            </div>
                                            <div class="col-md-3"></div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-3"></div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label for="userinput2" style="font-weight:bold;">Address</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%;">
                                                <textarea id="txt_address" class="form-control"></textarea>
                                            </div>
                                            <div class="col-md-3"></div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-3"></div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label for="userinput1" style="font-weight:bold;">Contact#</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%;">
                                                <input type="text" id="txt_contactnumber" maxlength="15" class="form-control" name="txt_contactnumber" onkeypress="isNumberInt(event,this)" autocomplete="off">
                                            </div>
                                            <div class="col-md-3"></div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-3"></div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label for="userinput1" style="font-weight:bold;">Licence#</label>
                                                </div>
                                            </div>
                                            <div class="col-md-4" style="margin-left:-4%;">
                                                <input type="text" id="txt_lnumber" maxlength="50" class="form-control" name="txt_lnumber" onkeyup="changetoupper(this.id)" autocomplete="off">
                                            </div>
                                            <div class="col-md-3"></div>
                                        </div>




                                        <div class="form-actions center" style="margin-left:2%;">

                                            <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                            <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                            <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                            <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>

                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div style="display:none;">
    <input type="text" value="0" id="Id" />
</div>
<div style="margin-left:20%;display:none;width:60%;" id="listing">
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <table style="width:100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold"> Driver List</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="card-content collapse show">
                        <div class="card-body card-dashboard" style="overflow:auto;">
                            <table id="tbldrivers" class="table table-striped table-bordered base-style dataTable"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
    $(document).ready(function () {
        Defaultfocus();

        $("#btnsubmit").click(function (e) {
            SaveAndUpdate(1);
        });
    });
    function SaveAndUpdate(flag) {
        if ($('#txt_fname').val() == "") {
            warningshow('Enter the name', 'txt_fname')
       }
        
   else
        {
            var data = {};
            data.DriverId = $('#Id').val();
            data.DriverName = $('#txt_fname').val();
            data.Address = $('#txt_address').val();
            data.PhoneNumber = $('#txt_contactnumber').val();
            data.LicenceNumber = $('#txt_lnumber').val();
            data.ERPDeptId = ERPDeptId;
            data.DelFlag = flag;
            console.log('data');
            console.log(data)
            $.ajax({
                type: "POST",
                url: "../Master/DriverMasterInsertandUpdate",
                data: data,
                success: function (result) {

                    var status = result.oList[0].Status;
                    Showalerts(status);


                }
            });
        }

    }
    function formrefresh() {
        $('#Id').val('0');
        $('#txt_fname').val('');
        $('#txt_address').val('');
        $('#txt_contactnumber').val('');
        $('#txt_lnumber').val('');
        $('#btndelete').hide();
        Defaultfocus();
    }
    function Defaultfocus() {
        $('#txt_fname').focus();
    }
    function GetRows(Id) {
        var data = {};
        data.DriverId = Id;
        $.ajax({
            type: "POST",
            url: "../Master/DrivereGetsandGets",
            data: data,
            success: function (result) {
                if (Id == 0)
                    ShowDriverlist(result.oList);
                else
                    ShowDriverGet(result.oList);
            }
        });
    }
    function closetable(value) {
        $('#Entry').show();
        $('#listing').hide();
        if (value == 1)
            formrefresh();
    }
    function ShowDriverlist(result) {
        disable_datatable('tbldrivers');
        $('#Entry').hide();
        $('#listing').show();
        var responseText = "<thead><tr><th width=1%;align=center>Sl#</th><th width=30%>Driver Name</th><th width=25%>Address</th><th width=10%>Contact#</th><th width=10%>Licence#</th><th width=3%>Edit</th></tr></thead><tbody>";
        for (var i = 0; i < result.length; i++) {
            var slno = parseInt(i + 1);
            responseText += '<tr><td align=center>' + slno + '</td><td>' + result[i].DriverName + '</td><td>' + result[i].Address + '</td><td>' + result[i].PhoneNumber + '</td><td>' + result[i].LicenceNumber + '</td><td><a onclick="GetRows(' + result[i].DriverId + ')">' + Editbutton + '</a></td></tr>';
        }
        $('#tbldrivers').html(responseText + '</tbody><tfoot><tr><th>Sl#</th><th>Driver Name</th><th>Address</th><th>Contact#</th><th>Licence#</th><th>Edit</th></tr></tfoot>');
        datatableWithsearch1('tbldrivers');
    }
    function datatableWithsearch1(tablename, download, title, tableButtonContainerId) {

        var a = '#' + tablename + ' tfoot th'
        $(a).each(function () {
            var title = $(this).text();
            if (title != 'Edit' && title != 'Select' && title != 'Sl#' && title != 'Credit Limit' && title != 'Due Days' && title != 'O Balance' && title != ' ')
                $(this).html('<input type="text" placeholder="Search ' + title + '" style="width=100%" />');
            if (title == 'Key')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            //if (title == 'Sl#')
            //    $(this).html('<input type="text" placeholder="' + title + '" style="width:10%" />');
            if (title == 'Driver Name')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            else if (title == 'Contact#')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
            else if (title == 'Licence#')
                $(this).html('<input type="text" placeholder="' + title + '" style="width:100%" />');
        });
       

            // AddColumnSelectionButton(tableButtonContainerId, tablename)

            table = $('#' + tablename).DataTable({
                // dom: 'Bfrtip',
                dom: "<'row'<'col-sm-1'l><'col-sm-11'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-1'i><'col-sm-11'p>>",
                buttons: []

            });
            new $.fn.dataTable.Buttons(table, {
                buttons: [
                {
                    extend: 'collection',
                    text: 'Export',
                    buttons: [
                        {
                            extend: 'excelHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: [0, 1, 2, 3, 4] }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: [0, 1, 2, 3, 4] }
                        },
                        {
                            extend: 'print',
                            title: title,
                            messageTop: 'MEDOC HMS',
                            exportOptions: { columns: [0, 1, 2, 3, 4] }
                        }
                    ]
                },
                //'colvis'
                ]
            });
            table.buttons(0, null).container().appendTo($("#itemListButtonPlace"));
            $("#itemListButtonPlace").find(".buttons-collection").addClass("btn-outline-primary mx-1").css("border-radius", "4px");


            //$("#" + tableButtonContainerId).off("click.emButtonEvent").on("click.emButtonEvent", "[data-em-col]", function () {
            //    var column = table.column($(this).attr('data-em-col'));
            //    console.log($(this).attr('data-em-col'));
            //    console.log(column);
            //    column.visible($(this).prop("checked"));
            //});
        
        table.columns().every(function () {
            var that = this;
            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();

                }
            });
        });
    }
        function closelist() {
            $('#Entry').show();
            $('#listing').hide();
            formrefresh();
        }

    function ShowDriverGet(result) {

        for (var i = 0; i <result.length; i++) {
            $('#Id').val(result[i].DriverId);
            $('#txt_fname').val(result[i].DriverName);
            $('#txt_address').val(result[i].Address);
            $('#txt_contactnumber').val(result[i].PhoneNumber);
            $('#txt_lnumber').val(result[i].LicenceNumber);
            $('#txt_fname').focus();
        }
        $('#Entry').show();
        $('#listing').hide();
        $('#btndelete').show();
    }

    //Numeric Only Text Boxes without Decimal Point

    function isNumberInt(evt, selectedvalue) {
        var charCode = (evt.which) ? evt.which : event.keyCode
        $(selectedvalue).val($(selectedvalue).val().replace(/[^0-9\.]/g, ''));
        if (charCode != 8 && charCode != 13 && (charCode < 48 || charCode > 57)) {
            evt.preventDefault();
            warningshow('Digits Only')
            return false;
        }
        return true;

    }
    function disable_datatable(tablename, tableButtonContainerId) {
        $('#Warningpopup').fadeOut();
        if ($.fn.DataTable.isDataTable('#' + tablename)) {
            var table = $('#' + tablename).DataTable();
            table.destroy();
            if (tableButtonContainerId) { $("#" + tableButtonContainerId).empty(); }
            return;
        }
    }

</script>
