


@{
    ViewBag.Title = "SalesMan";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<script type="text/javascript" src="../Projectscript/Common.js"></script>
<script language="Javascript" src="../Projectscript/Salesman.js" type="text/javascript"></script>

<div class="myData" data-x="M09" />

<style>
    .label-control{
        font-weight:bold;
    }
   
</style>

<div id="Entry" style="width:50%;margin-left:25%;">
   
    <div class="row">
        <div class="col-md-12">
            <div class="card" style="margin-top:15%">
                <div class="card-header" style="border-bottom:1px solid #e6e6e6;text-align:center">
                    <h4 class="card-title mb-0" style="font-weight:bold;">Salesman</h4>
                </div>
                <div class="card-body">
                    <div class="px-3">
                        <div class="card-content collapse show">
                            <div class="card-body">
                                <div style="height:15px;"></div>
                                <form action="#">
                                    <div class="form-body">
                                        <br />
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput1">Code<span class="danger">*</span></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_code" maxlength="25" onkeyup="changetoupper(this.id),CodeName()" class="form-control" name="txt_code" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput2">Name<span class="danger">*</span></label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_fname" maxlength="100" onkeyup="changetoupper(this.id)" class="form-control" name="txt_fname" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                           
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput2">Address 1</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_address1" maxlength="100" class="form-control" name="txt_address1" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput1">Target Amt.</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_amount" maxlength="12" class="form-control" name="txt_amount" onkeypress="return isNumberKey(event)" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput1">Address 2</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_address2" maxlength="100" class="form-control" name="txt_address2" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput1">Contact#</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_contactnumber" maxlength="13" class="form-control" name="txt_contactnumber" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                          
                                        </div>


                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control" for="userinput2">Address 3</label>
                                                    <div class="col-md-8">
                                                        <input type="text" id="txt_address3" maxlength="100" class="form-control" name="txt_address3" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group row">
                                                    <label class="col-md-4 label-control">User</label>
                                                    <div class="col-md-8">
                                                        <select class="form-control" id="User">
                                                        <option value="0">---Select User---</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>



                                        <div class="form-actions">
                                            <div class="text-center">
                                                <button type="button" style="width:100px" id="btnsubmit" class="btn btn-primary btn-min-width mr-1 mb-1"><u>S</u>ave <i class="fa fa-check-square-o"></i></button>
                                                <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                                                <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                                                <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>





<div style="margin-left:20%;display:none;width:70%;" id="listing" >
    <section>
        <div class="row">
            <div class="col-12">
                <div class="card" style="margin-top:5%">
                    <div class="card-header">
                        <table width="100%">
                            <tr>
                                <td><h4 class="card-title" style="font-weight:bold;">Salesman List</h4></td>
                                <td align="right">
                                    <div class="heading-elements">
                                        <div>
                                            <button type="button" onclick="closelist()" class="btn btn-outline-primary" id="ed"><i class="ft-edit"></i> Add New</button>
                                            <span id="itemListButtonPlace">
                                            </span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>


                    </div>
                    <div class="card-content collapse show"  style="width:100%;">
                        <div class="card-body card-dashboard" style="overflow:auto">
                            <table id="tbl_salesman" class="table table-striped table-bordered base-style dataTable" style="width:100%"></table>
                            <br />

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>









    

<div style="display:none"><input type="text" value="0" id="Id" /></div>




