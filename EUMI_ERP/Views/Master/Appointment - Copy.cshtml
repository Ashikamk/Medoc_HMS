</style>

<style>
    /*Style for Local AutoComplete:*/
    .autocomplete1 {
        position: relative;
        display: inline-block;
    }

    .autocomplete1-items {
        position: absolute;
        border: 1px solid #d4d4d4;
        z-index: 99;
        top: 100%;
