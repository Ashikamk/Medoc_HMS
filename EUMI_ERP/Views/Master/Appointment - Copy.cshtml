<div style="display:none">
    <input type="text" id="AppointmentId" class="form-control" />
    <input type="text" id="RegId" class="form-control" />
 
</div>



<script>
    function RevisitPatient()
    {
        var PatId = $('#RegId').val();

        sessionStorage.setItem("PatId", PatId);
        window.location = "@Url.Action("Revis it", "Revisit", new { from = "PRegistration" })";
    }
    $("#btndeleted").click(function (e) {
        $('#confirmmessage').text('Do You Want To Delete This Record?')
        $('#confirm').show();
        $('#confirmOk').focus();
    });
    $("#AppFirst").autocomplete({
       
        delay: 0,
        minLength: 0,
        source: function (request, response) {
            $("#AppointmentId").val('');
          
            var data = {};
            data.FirstName = $("#AppFirst").val();
            data.Contact = $("#MobileNo").val();           
            $.ajax({
                url: '../Master/HMS_AppointmentSearch',
                type: "POST",
                data: data,
                dataType: "json",
                success: function (data) {
                    response($.map(data, function (item) {
                        return ({
                            ColCount: '2',
                            label: item.FirstName,
                            label1: item.Contact,
                            AppointmentId: item.AppointmentId,
                            FirstName: item.FirstName,
                            LastName: item.LastName,
                            DOB: item.DOB,
                            Gender: item.Gender,
                            Nationality: item.Nationality,
                            Contact: item.Contact,
                            Email: item.Email,
                            Branch: item.Branch,
                            Department: item.Department,
                            Doctor: item.Doctor,
                            FirstName: item.FirstName,
                            AppointmentTime: item.AppointmentTime,
                            AppointmentDate: item.AppointmentDate,
                            Contact: item.Contact,
                            Status1: item.Status1,
                            Status2: item.Status2,
                            headers: ["FirstName", "Contact"]
                        })
                    }));
                }
            })
        },
        autoFocus: true,

        select: function (event, ui) {
           
            GetRowsss(ui.item.AppointmentId);
            $("#AppointmentId").val(ui.item.AppointmentId);
            $("#MobileNo").val(ui.item.Contact);
            $("#AppLast").val(ui.item.LastName);
            $("#PDOB").val(ui.item.DOB);
            GetPatientAge();
            $("#PGender").val(ui.item.Gender);
            $("#Country").val(ui.item.Nationality);
            $("#EmailId").val(ui.item.Email);
            $("#Branch").val(ui.item.Branch);
            $("#txt_docdeptname").val(ui.item.Department);
            $("#Doctor").val(ui.item.Doctor);
            $("#PDATE").val(ui.item.AppointmentDate);
            $("#PTime").val(ui.item.AppointmentTime);
           
            $("#AppFirst").focus();
            $('#btndeleted').show();
        
            if (ui.item.Status1 == 0)
            {
                console.log('a')
                $('#self').prop('checked', true);
            }
            else if (ui.item.Status1 == 1)
            {
                console.log('b')
                $('#insurance').prop('checked', true);
            }

            if (ui.item.Status2 == 0)
            {
                console.log('c')
                $('#yes').prop('checked', true);
            }
           else if (ui.item.Status2 == 1)
            {
                console.log('d')
                $('#no').prop('checked', true);
            }
            
        },

    });
</script>

