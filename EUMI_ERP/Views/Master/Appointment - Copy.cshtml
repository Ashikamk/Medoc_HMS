<style>
    .label-control {
        font-weight: bold;
    }

    select.form-control:not([size]):not([multiple]) {
        height: calc(2.25rem + 4px) !important;
    }

    form .form-group {
        margin-bottom: .5rem;
    }

    .card .card-header {
        padding: 1.5rem;
        padding-bottom: .5rem;
    }

    form .form-actions {
        margin-top: 5px;
