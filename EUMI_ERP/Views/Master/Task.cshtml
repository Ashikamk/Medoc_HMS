<section class="taskboard-app-form bg-blue-grey bg-lighten-5">
    <div id="Entry">
       
        <div class="card">
            <div class="card-block pt-3">
                <h5 class="text-bold-500">Create new Task</h5>
                <div style="height:20px;"></div>
                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group row">
                            <label class="col-md-3 label-control">Task ID<span class="danger">*</span></label>
                            <div class="col-md-8">
                                <input type="text" id="TaskId" onkeyup="changetoupper(this.id)" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-group row">
                            <label class="col-md-3 label-control">To<span class="danger">*</span></label>
                            <div class="col-md-8">
                                <input type="hidden" id="UserId" class="form-control" />
                                <input type="text" id="UserName" class="form-control" />
                            </div>
                        </div>
                    </div>
                   

                    <button type="button" style="width:100px" class="btn btn-raised btn-primary" id="btnsubmit">
                        Create <i class="fa fa-check-square-o"></i>
                    </button>
                </div>
                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group row">
                            <label class="col-md-3 label-control">Date/Time<span class="danger">*</span></label>
                            <div class="col-md-4">
                                <input type="text" id="Date" class="form-control" />
                            </div>

                            <div class="col-md-5">
                                <div class="col-md-10">
                                    <input type="Time" id="Time" class="form-control" name="time">
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-group row">
                            <label class="col-md-3 label-control">Message<span class="danger">*</span></label>
                            <div class="col-md-8">
                                <textarea id="ReminderMessage" style="width:100%; height:150%" class="form-control" name="ReminderMessage"></textarea>
                            </div>
                        </div>
                    </div>
                    <div>

                        <button type="button" style="width:100px" id="btnlist" onclick="GetRows(0)" class="btn btn-primary btn-min-width mr-1 mb-1">List <i class="ft-align-justify"></i></button>
                    </div>

                </div>
                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group row" style="margin-top:-20px;">

                            <label class="col-md-3 label-control">Status<span class="danger">*</span></label>
                            <div class="col-md-8">
                                <select class="form-control" id="TaskStatus">
                                    <option value="0">Select</option>
                                    <option>Open</option>
                                    <option>Progress</option>
                                    <option>Complete</option>
                                    <option>Failure</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="text-right" style="margin-left:735px;margin-top:-25px">
                        <button type="button" style="width:100px" id="btnnew" onclick="formrefresh()" class="btn btn-primary btn-min-width mr-1 mb-1">Clear <i class="ft-refresh-cw position-right"></i></button>
                      @*  <button style="display:none" type="button" id="btndelete" class="btn btn-primary btn-min-width mr-1 mb-1">Delete <i class="fa fa-times"></i></button>*@
                    </div>
                </div>


            </div>
        </div>
        </div>
</section>

 </section>


    <div style="display:none;" id="listing">
        <section>
            <div class="row">
