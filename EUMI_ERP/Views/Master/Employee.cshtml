<script>
    $(document).ready(function () {
        if (getQueryString('EmpId') != null) {
            var data = {};
            data.EmpId = getQueryString('EmpId');
            $.ajax({
                type: "POST",
                url: "../Master/EmployeeGetandGets",
                data: data,
                success: function (result) {
                   
                    $('.form-control').prop('disabled', true);
                    $('.btnbottom').prop('disabled', true);

                    $('#btnsubmit').prop("disabled", true);
                    $('#btnlist').prop("disabled", true);
                    $('#btnadd').prop("disabled", true);
                    if (getQueryString('EmpName') == '') {
                        ShowEmployeeGet(result.oList);
                    }
                    else {
                        ShowEmployeeGet(result.oList);
                        $('#btnuploaddoc').prop("disabled", false);
                        $('#Uploadpopupdivshow').show();
                    }
                }
            });
        }
   


    if (window.File && window.FileList && window.FileReader) {
        $("#files").on("change", function (e) {
            var files = e.target.files,
              filesLength = files.length;
            for (var i = 0; i < filesLength; i++) {
                var f = files[i]
                var fileReader = new FileReader();
                fileReader.onload = (function (e) {
                    var file = e.target;
                    //$('.container img').prop('src', target.result);
                    $("<span class=\"pip\">" +
                      "<img class=\"imageThumb\" src=\"" + e.target.result + "\" title=\"" + file.name + "\"/>" +
                      "<br/><span class=\"remove\">Remove image</span>" +
                      "</span>").insertAfter("#DDh");
                    $(".remove").click(function () {
                        $(this).parent(".pip").remove();
                    });


                });
                fileReader.readAsDataURL(f);
                //fileReader.readAsDataURL(this.files[0]);
            }
        });
    } else {
        alert("Your browser doesn't support to File API")
    }
    });
</script>




