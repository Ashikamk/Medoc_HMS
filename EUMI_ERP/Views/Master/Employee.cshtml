                        function ShowViewUploadDoc(result) {
                            disable_datatable('tbldocumentlist');
                            var responseText = '';
                            for (var i = 0; i < result.length; i++) {

                                var extension = (result[i].DocumentName).split('.').pop().toLowerCase();


                                if (extension == 'jpeg' || extension == 'jpg' || extension == 'png' || extension == 'gif' || extension == 'tif') {
                                    var newrow = '<a style="" )>' + result[i].DocumentName + '</a></br>'
                                    responseText += '<tr id="' + result[i].EmployeeDocumentId + '"><td  align=center><img src="../ProjectImages/Employee/IconImages/imagepng.jpg" style="width:50px;height:40px" /></td><td>' + result[i].DocumentTypeName + '</td><td id="D' + result[i].EmployeeDocumentId + '">' + newrow + '</td><td align=center><a onclick=ViewDocuments(\'' + result[i].EmpId + '\',\'' + result[i].FolderName + '\',\'' + extension + '\')>' + DownloadButtton + '</a></td><td align=center><a onclick=DeleteUploadFile("' + result[i].EmployeeDocumentId + '")>' + DeleteButton + '</a></td></tr>';
                                }

                                else if (extension == 'pdf') {
                                    var newrow = '<a style="" )>' + result[i].DocumentName + '</a></br>'
                                    responseText += '<tr id="' + result[i].EmployeeDocumentId + '"><td  align=center><img src="../ProjectImages/Employee/IconImages/imagepdf.jpg" style="width:50px;height:40px" /></td><td>' + result[i].DocumentTypeName + '</td><td id="D' + result[i].EmployeeDocumentId + '">' + newrow + '</td><td align=center><a onclick=ViewDocuments(\'' + result[i].EmpId + '\',\'' + result[i].FolderName + '\',\'' + extension + '\')>' + DownloadButtton + '</a></td><td align=center><a onclick=DeleteUploadFile("' + result[i].EmployeeDocumentId + '")>' + DeleteButton + '</a></td></tr>';
                                }
                                else {

                                    var newrow = '<a style="" )>' + result[i].DocumentName + '</a></br>'
                                    responseText += '<tr id="' + result[i].EmployeeDocumentId + '"><td  align=center><img src="../ProjectImages/Employee/IconImages/imageexcel.png" style="width:50px;height:40px" /></td><td>' + result[i].DocumentTypeName + '</td><td id="D' + result[i].EmployeeDocumentId + '">' + newrow + '</td><td align=center><a onclick=ViewDocuments(\'' + result[i].EmpId + '\',\'' + result[i].FolderName + '\',\'' + extension + '\')>' + DownloadButtton + '</a></td><td align=center><a onclick=DeleteUploadFile("' + result[i].EmployeeDocumentId + '")>' + DeleteButton + '</a></td></tr>';
                                }


                                $('#tbldocumentlist').html(responseText + '');
                            }

                        }
