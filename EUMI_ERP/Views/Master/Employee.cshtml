                    function FileUploadDB(Flag, empId) {                      
                        // Database Save
                      
                        var Firstvalue = FileArray[0];
                        //alert(FileArray)
                        var data = {};
                        data.DepartmentId = ERPDeptId;
                        data.DocumentName = $("#files" + Firstvalue).get(0).files[Flag].name;
                        data.Extension = $("#files" + Firstvalue).get(0).files[Flag].name.split('.').pop();
                        data.DocumentType = $('#UploadDocument' + Firstvalue).val();
                        data.EmpId = empId;
                        data.Flag = Flag;
                        $.ajax({
                            type: "POST",
                            url: "../Master/EmployeeFileInsert",
                            data: data,
                            success: function (result) {
                                var DBFlag = result.dList[0].Flag;
                                var status = result.dList[0].Status;
                                var CrtEmpId = result.dList[0].EmpId;
                                var StatusFlag = result.dList[0].StatusFlag;
                                if (status == 1) {
                                    var formData = new FormData();
                                    var imageName = DBFlag
                                    var browsedFile = document.getElementById("files" + Firstvalue).files[Flag];
                                    var Extension = $("#files" + Firstvalue).get(0).files[Flag].name.split('.').pop();
                                    var SlNo = CrtEmpId

                                    formData.append("FileUpload", browsedFile);
                                    formData.append("FileName", imageName);
                                    formData.append("SlNo", SlNo);
                                    formData.append("Extension", Extension);
                                    console.log(formData)
                                    $.ajax({
                                        type: "POST",
                                        url: '/Master/EmployeeFileUpload',
                                        data: formData,
                                        dataType: "html",
                                        contentType: false,
                                        processData: false,
                                        success: function (result) {
                                            if (Flag < document.getElementById('files' + Firstvalue).files.length - 1) {
                                                Flag++;
                                                FileUploadDB(Flag, CrtEmpId);
                                            }
                                            else {
                                                $("#LoadingSmall").hide();
                                                FileArray.shift();
                                                if (FileArray.length > 0) {
                                                    FileUploadDB(0, CrtEmpId);
                                                }
                                                else {
                                                  
                                                    if (StatusFlag == 1) {
                                                        Showalerts(StatusFlag)
                                                        $('.adddelrow').remove();
                                                        $('#UploadDocument1').val(0);
                                                        $('#files1').val('');
                                                        rowcount = 2;
                                                    }
                                                    else {
                                                        Showalerts(StatusFlag)
                                                        $('.adddelrow').remove();
                                                        $('#UploadDocument1').val(0);
                                                        $('#files1').val('');
                                                        rowcount = 2;
                                                    }
                                                   
                                                }
                                               
                                                //ViewSavedFiles();
                                            }
                                        }
                                    });

                                }

                            }
                        });
                        }
                        
                    
