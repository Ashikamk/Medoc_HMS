@{
    ViewBag.Title = "Appointment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="~/Scripts/jquery-1.10.2.min.js"></script>
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="~/Scripts/Appoinmentscripts/sweet.js"></script>
<link rel="stylesheet" href="/Scripts/Autocomplete/autocomplete.css" />
<script src="/Scripts/Autocomplete/jquery-ui.js"></script>

<style>

    html, body {
        height: 100%;
        margin: 0;
        overflow: auto;
        font-family: 'Segoe UI', sans-serif;
        background: #f3f4f6;
    }

        body.modal-open {
            overflow: hidden !important;
        }

    .wrapper {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
    }

    nav#topdiv {
        flex-shrink: 0;
    }

    .main-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
    }

    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
    }

    .content-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
        margin-left: -55px;
    }

    main {
        flex: 1;
        width: 100%;
        display: flex;
        padding: 10px;
        overflow: hidden;
        min-height: 0;
    }

    footer.footer {
        flex-shrink: 0;
    }

    #calendar-view {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        width: 100%;
        padding: 15px;
        overflow-y: auto;
    }

    section {
        margin-bottom: 12px;
        position: relative;
    }

    h2 {
        font-family: "Segoe UI", Arial, sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 12px;
        letter-spacing: -0.2px;
    }

    .slot-heading {
        font-family: "Segoe UI", Arial, sans-serif;
        font-size: 18px;
        font-weight: 600;
        color: #1f2937;
        margin: 16px 0 12px;
        text-transform: capitalize;
    }

    .doctor-wrapper {
        position: relative;
    }

    .scroll-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #fff;
        border: none;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        cursor: pointer;
        z-index: 10;
        opacity: 0.9;
    }

        .scroll-btn:hover {
            transform: translateY(-50%) scale(1.05);
        }

    #doctorSelection {
        display: flex;
        gap: 15px;
        overflow-x: auto;
        padding: 10px 45px;
        scroll-behavior: smooth;
    }

        #doctorSelection::-webkit-scrollbar {
            height: 6px;
        }

        #doctorSelection::-webkit-scrollbar-thumb {
            background: #999;
            border-radius: 10px;
        }

    .doctor-card {
        min-width: 130px;
        padding: 15px;
        border-radius: 14px;
        background: #fff;
        text-align: center;
        box-shadow: 0 3px 12px rgba(0,0,0,0.05);
        cursor: pointer;
        transition: all 0.25s ease;
    }

        .doctor-card::before {
            content: "DR";
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, #7c3aed, #9333ea);
            color: white;
            border-radius: 50%;
            font-weight: bold;
            margin: 0 auto 8px;
        }

        .doctor-card p {
            margin: 2px 0;
            font-size: 13px;
        }

        .doctor-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .doctor-card.selected {
            border: 2px solid #14b8a6;
        }

    #scrollLeftBtnDoctor {
        left: 5px;
    }

    #scrollRightBtnDoctor {
        right: 5px;
    }


    .date-header {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        margin-bottom: 5px;
    }

        .date-header h3 {
            font-size: 22px;
            font-weight: 600;
        }

    .nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #fff;
        border: none;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        cursor: pointer;
        z-index: 10;
    }

        .nav-btn:hover {
            background: #fff;
            transform: translateY(-50%) scale(1.05);
        }

    #scrollLeftBtn,
    #scrollRightBtn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
    }

    #scrollLeftBtn {
        left: 5px;
    }

    #scrollRightBtn {
        right: 5px;
    }

    .day-wrapper {
        overflow: hidden;
        position: relative;
        padding: 0 40px;
    }

    #dayPicker {
        display: flex;
        gap: 10px;
        padding: 10px 0;
        overflow-x: auto;
        scroll-behavior: smooth;
    }

        #dayPicker::-webkit-scrollbar {
            display: none;
        }

    .day-slot {
        min-width: 65px;
        height: 75px;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        background: #fff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 5px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .day-slot:hover {
            border-color: #14b8a6;
        }

    .day-name {
        font-size: 12px;
        color: #6b7280;
    }

    .day-number {
        font-size: 18px;
        font-weight: 600;
    }

    .day-slot.selected-day {
        background: #14b8a6;
        color: white;
        border: 2px solid white;
        box-shadow: 0 6px 15px rgba(20,184,166,0.3);
    }

    .day-slot:focus,
    .day-slot:active {
        outline: none;
    }


    .time-dropdown {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        font-size: 14px;
        margin-bottom: 12px;
        color: #111827;
        pointer-events: none;
    }

    .small-dropdown {
        width: 120px !important;
        padding: 4px 8px;
        font-size: 13px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        background: #f3f4f6;
        color: #6b7280;
    }

    #timeSlotsContainer {
        margin-top: 10px;
    }

        #timeSlotsContainer button {
            width: 100%;
            min-width: unset;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            background: #fff;
            font-size: 14px;
            font-weight: 500;
            color: #111827;
            transition: all 0.2s ease;
        }

            #timeSlotsContainer button:hover:not(:disabled) {
                border-color: #14b8a6;
                transform: translateY(-1px);
            }

            #timeSlotsContainer button.active-slot {
                background: #14b8a6;
                color: #fff;
            }

            #timeSlotsContainer button:disabled {
                background: #f3f4f6;
                color: #9ca3af;
                cursor: not-allowed;
            }



    .modal-header-custom h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }

    #appointment-summary-text {
        font-size: 12px;
        text-transform: uppercase;
        opacity: 0.9;
    }


    .form-group {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 15px;
    }

        .form-group label {
            font-size: 12px;
            font-weight: 700;
            color: #2D2073;
            width: 120px;
            flex-shrink: 0;
        }

    .required {
        color: red;
    }


    .hidden {
        display: none !important;
    }

    .appointment-grid-form {
        background: #ffffff;
        padding: 0;
        border-radius: 0;
        margin: 0;
        box-shadow: none;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px 12px;
    }

        .appointment-grid-form .form-divider {
            grid-column: span 2;
        }

        .appointment-grid-form .form-control {
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            background: #f9fafb;
            height: 34px;
        }

    #existingOP-row,
    #firstname-row {
        grid-column: auto;
    }

    .readonly-input {
        background-color: #f3f4f6;
    }

    .triple-input {
        display: flex;
        gap: 5px;
        flex-grow: 1;
    }

        .triple-input input {
            width: 33.33%;
            padding: 8px;
            border: 1px solid #ced4da;
            border-radius: 4px;
            text-align: center;
        }


    .modal-footer-custom {
        grid-column: span 2;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
        border-top: 1px solid #eee;
        padding-top: 20px;
    }

    .btn-cancel, .btn-clear, .btn-save {
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        border: none;
    }

    .btn-cancel {
        background: #fff;
        border: 1px solid #ddd;
    }

    .btn-clear {
        background: #ffc107;
        color: #000;
    }

    .btn-save {
        background: #3c2a8c;
        color: #fff;
        padding: 10px 30px;
        text-transform: capitalize;
        transition: background 0.2s;
    }

        .btn-save:hover {
            background: #2d2073;
        }

    footer {
        height: 45px;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: #374151;
        border-top: 1px solid #e5e7eb;
        flex-shrink: 0;
    }

    #patient-modal {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.5);
        z-index: 99999;
        padding: 10px;
        box-sizing: border-box;
    }

    #patient-modal-content {
        width: 95%;
        max-width: 1100px;
        max-height: 85vh;
        height: auto;
        background: #f0f1f6;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: relative;
    }

        #patient-modal-content .form-group label {
            width: 100px;
            flex-shrink: 0;
        }

        #patient-modal-content .form-group .form-control {
            flex: 1;
            min-width: 0;
            width: 100%;
        }

        #patient-modal-content .appointment-grid-form {
            grid-template-columns: 1fr 1fr;
            gap: 8px 15px;
        }

        #patient-modal-content .modal-body {
            padding: 20px 15px;
        }

        #patient-modal-content .form-card {
            padding: 15px 10px;
        }

    .modal-body {
        flex: 1;
        overflow-y: auto !important;
        padding: 20px;
        overflow-x: hidden;
        background: #f5f6fa;
    }

        .modal-body::-webkit-scrollbar {
            width: 6px;
        }

        .modal-body::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }


    .modal-footer-fixed {
        flex-shrink: 0;
        padding: 8px 20px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        border-top: 1px solid #e5e7eb;
        background: #f0f1f6;
    }

    .modal-header-custom {
        background: #3c2a8c;
        color: white;
        padding: 14px 20px;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        flex-shrink: 0;
    }

    @@keyframes modalFadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes modalSlideDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    body.modal-open {
        overflow: hidden !important;
    }

    #morningSlots,
    #afternoonSlots,
    #eveningSlots {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 10px;
        padding: 0 20px;
        box-sizing: border-box;
    }

    .scroll-btn:focus,
    .scroll-btn:active,
    .nav-btn:focus,
    .nav-btn:active {
        outline: none;
        box-shadow: none;
    }

    button:focus,
    button:active {
        outline: none;
        box-shadow: none;
    }

    .form-card {
        background: white;
        padding: 10px;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
    }

    .form-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 15px 0;
        grid-column: span 2;
    }

    .ui-autocomplete {
        z-index: 11000 !important;
    }
    /*    //new 26/03*/
    .edit-btn {
        padding: 5px 14px;
        background: #3c2a8c;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
    }

        .edit-btn:hover {
            background: #2d2073;
        }

    #appointment-tbody tr:hover {
        background: #f9fafb;
    }

    #appointment-tbody td {
        padding: 10px 12px;
        border-bottom: 1px solid #e5e7eb;
        color: #374151;
        font-size: 14px;
    }

    .datepicker-wrapper {
        position: relative;
        flex: 1;
    }

        .datepicker-wrapper input {
            width: 100%;
            padding-right: 36px;
            box-sizing: border-box;
        }

        .datepicker-wrapper .cal-icon {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #3c2a8c;
            font-size: 16px;
            pointer-events: none;
        }

    input[type="date"]::-webkit-calendar-picker-indicator {
        opacity: 1;
        cursor: pointer;
        color: #3c2a8c;
    }

    #appointment-table_paginate {
        margin-top: 10px;
        text-align: right;
    }

        #appointment-table_paginate .paginate_button {
            padding: 3px 8px;
            margin: 0 1px;
            border: 1px solid #dee2e6 !important;
            border-radius: 3px;
            cursor: pointer;
            font-size: 13px;
            color: #333 !important;
            background: white !important;
            display: inline-block;
        }

            #appointment-table_paginate .paginate_button.current,
            #appointment-table_paginate .paginate_button.current:hover {
                background: #009da0 !important;
                color: white !important;
                border-color: #009da0 !important;
                font-weight: 600;
            }

            #appointment-table_paginate .paginate_button:hover:not(.current):not(.disabled) {
                background: #e9ecef !important;
                color: #333 !important;
            }

            #appointment-table_paginate .paginate_button.disabled,
            #appointment-table_paginate .paginate_button.disabled:hover {
                color: #aaa !important;
                cursor: default;
                background: white !important;
            }

        #appointment-table_paginate .ellipsis {
            padding: 3px 6px;
            font-size: 13px;
            color: #333;
        }
</style>
<main>


    <div id="calendar-view">

        <section class="doctor-wrapper">

            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <h2 style="margin:0;">Select a Specialist</h2>
                <div style="display:flex;gap:10px;">
                    <button onclick="showCalendarView()" style="padding:8px 20px;background:#3c2a8c;color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:14px;">Back to Calendar</button>
                    <button onclick="showListView()" style="padding:8px 20px;background:#14b8a6;color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;font-size:14px;">List</button>
                </div>
            </div>

            <button id="scrollLeftBtnDoctor" class="scroll-btn">&#8249;</button>
            <button id="scrollRightBtnDoctor" class="scroll-btn">&#8250;</button>

            <div id="doctorSelection"></div>

        </section>

        <section class="doctor-wrapper" style="margin-top:20px;">
            <h2>Choose Date</h2>

            <div class="date-header">
                <h3 id="currentMonthDisplay"></h3>
            </div>

            <div class="day-wrapper">
                <button id="scrollLeftBtn" class="nav-btn">&#8249;</button>

                <div id="dayPicker"></div>

                <button id="scrollRightBtn" class="nav-btn">&#8250;</button>
            </div>
        </section>

        <section style="margin-top:20px;">
            <h2>Available Times</h2>

            <select id="slotDurationSmall" class="time-dropdown small-dropdown" disabled>
                <option value="15">15 Minutes</option>
            </select>
            <div id="timeSlotsContainer">



                <p class="time-note">
                    Please select a date to view available time slots.
                </p>

            </div>
        </section>

    </div>


</main>
@*//new 26/03*@
<div id="list-view" style="display:none;padding:15px;height:100%;overflow-y:auto;position:fixed;inset:0;background:#f3f4f6;z-index:100;">
    <div style="background:#fff;border-radius:16px;box-shadow:0 6px 20px rgba(0,0,0,0.08);padding:20px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
            <h2 style="margin:0;">Booked Appointments</h2>
            <div style="display:flex;gap:10px;">
                <button onclick="showCalendarView()" style="padding:8px 20px;background:#3c2a8c;color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;">Back to Calendar</button>
                <button onclick="showCalendarView()" style="padding:8px 20px;background:#14b8a6;color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;">New Booking</button>
                <button onclick="openSearchModal()" style="padding:8px 20px;background:#7c3aed;color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;">Searching</button>
            </div>
        </div>
        <div style="overflow-x:auto;">
            <table id="appointment-table" style="width:100%;border-collapse:collapse;font-size:14px;">
                <thead>
                    <tr style="background:#f3f4f6;">
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Sl#</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">RegId</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Name</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">OP</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Doctor</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Date</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Time</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Mobile No</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Token No</th>
                        @*<th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Edit</th>*@
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Status</th>
                        <th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">Edit</th>
                    </tr>
                </thead>
                <tbody id="appointment-tbody">
                    <tr><td colspan="11" style="text-align:center;padding:20px;color:#6b7280;">Loading...</td></tr>
                </tbody>
                <tfoot>
                    <tr>
                        <th></th>
                        <th>RegId</th>
                        <th>Name</th>
                        <th>OP</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Mobile No</th>
                        <th>Token No</th>
                        <th></th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:16px;">
            <button id="showAllBtn" onclick="showAllAppointments()" style="display: none; padding: 9px 22px; background: #14b8a6; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 14px;">&#8635; Show All Appointments</button>
        </div>
    </div>
</div>
<div id="search-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:10001;align-items:center;justify-content:center;padding:20px;">
    <div style="background:#f0f1f6;border-radius:16px;width:90%;max-width:none;box-shadow:0 10px 40px rgba(0,0,0,0.2);overflow:hidden;display:flex;flex-direction:column;">
        <div style="background:#3c2a8c;color:white;padding:14px 20px;flex-shrink:0;">
            <h3 style="margin:0;font-size:18px;">Search Options</h3>
        </div>
        <div style="padding:20px;background:#f5f6fa;">
            <div style="background:white;padding:30px 20px;border-radius:16px;border:1px solid #e5e7eb;min-height:200px;">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px 15px;">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:12px;font-weight:700;color:#2D2073;width:100px;flex-shrink:0;">Doctor</label>
                        <select id="search-doctor" class="form-control" style="flex:1;">
                            <option value="0">Select</option>
                        </select>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:12px;font-weight:700;color:#2D2073;width:100px;flex-shrink:0;">From Date</label>
