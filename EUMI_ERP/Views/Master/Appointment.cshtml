<div id="patient-modal">
    <div id="patient-modal-content">
        <div class="modal-header-custom">
            <div class="header-left">
                <h3>Appointment Details</h3>
                <span id="appointment-summary-text"></span>
            </div>
            <div style="display:flex;gap:0;margin-top:10px;background:rgba(255,255,255,0.15);border-radius:8px;padding:4px;width:fit-content;">
                <button id="tab-new" onclick="switchTab('new')" style="padding:6px 20px;border:none;border-radius:6px;background:white;color:#3c2a8c;font-weight:700;cursor:pointer;font-size:13px;">New Appointment</button>
                <button id="tab-revisit" onclick="switchTab('revisit')" style="padding:6px 20px;border:none;border-radius:6px;background:transparent;color:rgba(255,255,255,0.8);font-weight:600;cursor:pointer;font-size:13px;">Revisit</button>
            </div>
        </div>
        <div class="modal-body">
            <div class="form-card">
                <form id="patient-form" class="appointment-grid-form">

                    <input id="AppointmentId" type="hidden" value="0" />

                    <div class="form-group" id="existingOP-row" style="display:none;">
                        <label>Existing OP</label>
                        <input type="text" id="ExistingOP" class="form-control" />
                    </div>

                    <div class="form-group" id="firstname-row">
                        <label>First Name <span class="required">*</span></label>
                        <input type="text" id="AppFirst" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Gender <span class="required">*</span></label>
                        <select id="PGender" class="form-control">
                            <option value="0">Select</option>
                            <option value="1">Male</option>
                            <option value="2">Female</option>
                            <option value="3">Others</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Contact No <span class="required">*</span></label>
                        <input type="text" id="MobileNo" class="form-control" />
                    </div>

                    <div class="form-group row-triple">
                        <label>Age</label>
                        <div class="triple-input">
                            <input type="text" id="Age" placeholder="YR" />
                            <input type="text" id="AgeMonths" placeholder="MO" />
                            <input type="text" id="AgeDays" placeholder="DA" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="PEmail" class="form-control" />
                    </div>

                    <div class="form-divider"></div>

                    <div class="form-group">
                        <label>DOB</label>
                        <div class="datepicker-wrapper">
                            <input type="date" id="PDOB" class="form-control"
                                   onchange="calculateAgeFromDOB()"
                                   style="border-radius:10px;border:1px solid #e5e7eb;background:#f9fafb;height:34px;flex:1;width:100%;" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Nationality <span class="required">*</span></label>
                        <select id="PNationality" class="form-control">
                            <option value="0">India</option>
                            <option value="1">USA</option>
                            <option value="3">UK</option>
                            <option value="4">Other</option>
                        </select>
                    </div>

                    <div class="form-divider"></div>

                    <div class="form-group">
                        <label>Department</label>
                        <select id="PDept" class="form-control readonly-input" disabled>
                            <option value="0">General</option>
                            <option value="1">Cardiology</option>
                            <option value="2">Neurology</option>
                            <option value="3">Paediatrics</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Token No <span class="required">*</span></label>
                        <input type="text" id="PToken" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Doctor <span class="required">*</span></label>
                        <select id="Doctor" class="form-control readonly-input" disabled>
                            <option value="0">Select Doctor</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Appt Date</label>
                        <input type="text" id="PDATE" class="form-control readonly-input" readonly />
                    </div>

                    <div class="form-group">
                        <label>Appt Time</label>
                        <input type="text" id="PTime" class="form-control readonly-input" readonly />
                    </div>

                    <select id="search-status" class="form-control" style="flex:1;">
                        <option value="">All</option>
                        <option value="Booked" selected>Booked</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Rescheduled">Rescheduled</option>
                        <option value="NotAnswered">Not Answered</option>
                        <option value="Others">Others</option>
                        <option value="Completed">Completed</option>
                    </select>

                </form>
            </div>
        </div>
        <div class="modal-footer-fixed">
            <button type="button" class="btn-cancel" onclick="closePatientModal()">Cancel</button>
            <button type="button" class="btn-clear" onclick="clearPatientForm()">Clear</button>
            <button type="button" id="saveBtn" class="btn-save" onclick="submitPatientDetails(0)">Save Booking</button>
        </div>
    </div>
</div>

